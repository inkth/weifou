:host { display: block; flex: 0 0 auto; position: relative; z-index: 90; }

.nav {
  flex: 0 0 auto;
  position: relative;
  z-index: 90;
  width: 100%;
  box-sizing: border-box;
  color: #24332c;
  background: rgba(247, 248, 245, 0.94);
  border-bottom: 1rpx solid rgba(36, 51, 44, 0.08);
}
.nav.is-transparent {
  background: rgba(246, 247, 251, 0.62);
  border-bottom-color: rgba(255, 255, 255, 0.24);
}
.nav.is-transparent .title,
.nav.is-transparent .subtitle { text-shadow: 0 1rpx 8rpx rgba(255, 255, 255, 0.96); }
.nav.is-transparent .back-hit { background: rgba(255, 255, 255, 0.32); }
.theme-dark { color: #ffffff; }
.status { width: 100%; }
.bar {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  box-sizing: border-box;
}
.copy { min-width: 0; text-align: center; }
.title {
  overflow: hidden;
  color: inherit;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.subtitle {
  overflow: hidden;
  margin-top: 2rpx;
  color: currentColor;
  font-size: 19rpx;
  line-height: 1.15;
  opacity: 0.68;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.back-hit {
  position: absolute;
  left: 6rpx;
  top: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  border-radius: 44rpx;
  transform: translateY(-50%);
}
.back-hit:active { background: rgba(36, 51, 44, 0.08); }
.nav.is-transparent .back-hit:active { background: rgba(255, 255, 255, 0.56); }
.theme-dark .back-hit:active { background: rgba(255, 255, 255, 0.14); }
.back-icon {
  width: 20rpx;
  height: 20rpx;
  border-left: 4rpx solid currentColor;
  border-bottom: 4rpx solid currentColor;
  transform: translateX(5rpx) rotate(45deg);
}
.home-icon { position: relative; width: 29rpx; height: 30rpx; }
.home-roof {
  position: absolute;
  left: 4rpx;
  top: 3rpx;
  width: 19rpx;
  height: 19rpx;
  border-left: 4rpx solid currentColor;
  border-top: 4rpx solid currentColor;
  transform: rotate(45deg);
}
.home-body {
  position: absolute;
  left: 7rpx;
  bottom: 1rpx;
  width: 17rpx;
  height: 16rpx;
  border: 4rpx solid currentColor;
  border-top: 0;
  box-sizing: border-box;
}
