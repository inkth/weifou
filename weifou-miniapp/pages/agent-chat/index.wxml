<view class="page {{gameSkin ? 'game' : ''}}" style="--accent: {{accent}};">
  <!-- 顶部：身份 + 额度/会员。游戏皮（学习课）隐藏整条——身份交给原生标题栏，付费只在真该收时出现（成交克制）。 -->
  <view wx:if="{{!gameSkin}}" class="topbar">
    <view class="tb-ic" style="background: {{accent}}1a; color: {{accent}};">{{icon}}</view>
    <view class="tb-mid">
      <view class="tb-name">{{name}}</view>
      <view class="tb-quota">{{quotaText}}</view>
    </view>
    <view class="tb-act" bindtap="openHistory">历史</view>
    <!-- 会员状态没回来前不亮商业按钮：防其他入口进课程时在加载窗口闪出「解锁全课」 -->
    <view wx:if="{{!member && !loading}}" class="tb-buy" bindtap="goMembership">解锁全课</view>
  </view>

  <!-- 数字人陪学舞台：人物负责讲述与倾听，进度只作为次级信息按需展开。 -->
  <view
    wx:if="{{gameSkin && !loading && !errored}}"
    class="lesson-stage {{mentorPhase === 'thinking' ? 'is-thinking' : ''}} {{mentorSpeaking ? 'is-speaking' : ''}} mentor-phase-{{mentorPhase}} feedback-{{answerFeedback}} mentor-motion-{{mentorMotion}}"
    style="--stage-accent: {{accent}};"
  >
    <view class="lesson-stage-ambience">
      <view class="mentor-glow"></view>
      <view class="mentor-line mentor-line-a"></view>
      <view class="mentor-line mentor-line-b"></view>
    </view>

    <view class="lesson-stage-copy">
      <view class="lesson-stage-kicker">
        <view class="lesson-live-dot"></view>
        <text>{{mentorIdleHint ? '还在陪你' : (answerFeedback === 'right' ? '回答正确' : (answerFeedback === 'wrong' ? '一起看看' : (mentorSpeaking ? '正在讲解' : (mentorPhase === 'listening' ? '我听到了' : (mentorPhase === 'thinking' ? '正在思考' : 'AI 陪学·已就绪')))))}}</text>
      </view>
      <view class="lesson-stage-title">{{mentorIdleHint ? '不用着急，想好再选' : (answerFeedback === 'right' ? '对，关键就在这里' : (answerFeedback === 'wrong' ? '这个选择很自然' : (mentorPhase === 'listening' ? '收到你的选择' : (mentorPhase === 'thinking' ? '我在整理背后的原因' : lessonTitle))))}}</view>
      <view class="lesson-stage-sub">{{mentorIdleHint ? '我会在这里等你。' : (answerFeedback === 'right' ? '你已经抓住了这一步。' : (answerFeedback === 'wrong' ? '这里还有一个容易忽略的条件。' : (mentorPhase === 'listening' ? '让我看一下它和关键条件的关系。' : (mentorPhase === 'thinking' ? '稍等一下，马上和你说。' : '选择之后，我会告诉你为什么。'))))}}</view>
      <view class="lesson-stage-actions">
        <view wx:if="{{lessonCard && lessonCard.content}}" class="mentor-voice {{mentorSpeaking ? 'playing' : ''}} {{mentorPaused ? 'paused' : ''}}" catchtap="onSpeakMentor" data-t="{{lessonCard.content}}" data-say="{{lessonCard.say}}" hover-class="mentor-action-press" hover-stay-time="0">
          <view class="mentor-voice-icon"><text></text><text></text><text></text></view>
          <text>{{mentorSpeaking ? '暂停' : (mentorPaused ? '继续' : '播放讲解')}}</text>
        </view>
        <view
          wx:if="{{lessonCard && lessonCard.content}}"
          class="mentor-mute {{voiceMuted ? 'is-muted' : ''}}"
          catchtap="onToggleMute"
          aria-role="button"
          aria-label="{{voiceMuted ? '取消静音' : '静音'}}"
          hover-class="mentor-action-press"
          hover-stay-time="0"
        >
          <text>{{voiceMuted ? '🔇' : '🔊'}}</text>
        </view>
        <view wx:if="{{concept}}" class="lesson-stage-progress" catchtap="toggleMap" hover-class="mentor-action-press" hover-stay-time="0">
          <text>{{lessonProgress || '学习进度'}}</text><text class="lesson-stage-chevron">›</text>
        </view>
      </view>
    </view>

    <view class="lesson-stage-person">
      <view class="mentor-speaking-ring"></view>
      <!-- idle 常驻做底层：变体帧盖在其上切换，过渡半透明期露出的是本人而非背景，否则每次切帧透底闪烁 -->
      <image class="lesson-mentor-img mentor-img-idle is-visible" src="{{mentorPortraits.idle}}" mode="aspectFit" />
      <image class="lesson-mentor-img mentor-img-blink {{!mentorSpeaking && mentorPose === 'blink' ? 'is-visible' : ''}}" src="{{mentorPortraits.blink}}" mode="aspectFit" />
      <image class="lesson-mentor-img mentor-img-glance {{!mentorSpeaking && mentorPose === 'glance' ? 'is-visible' : ''}}" src="{{mentorPortraits.glance}}" mode="aspectFit" />
      <image class="lesson-mentor-img mentor-img-mouth {{mentorSpeaking && mentorMouth === 'small' ? 'is-visible' : ''}}" src="{{mentorPortraits.speakSmall}}" mode="aspectFit" />
      <image class="lesson-mentor-img mentor-img-mouth {{mentorSpeaking && mentorMouth === 'wide' ? 'is-visible' : ''}}" src="{{mentorPortraits.speakWide}}" mode="aspectFit" />
      <image class="lesson-mentor-img mentor-img-mouth {{mentorSpeaking && mentorMouth === 'round' ? 'is-visible' : ''}}" src="{{mentorPortraits.speakRound}}" mode="aspectFit" />
    </view>
  </view>

  <scroll-view class="msgs" scroll-y scroll-into-view="{{scrollTo}}" scroll-with-animation>
    <!-- 加载骨架：头像/名牌来自跳转参数即时可见，正文用灰气泡占位——慢网/断网也不白屏发愣 -->
    <block wx:if="{{loading}}">
      <view class="astage">
        <view class="astage-frame" style="background: {{accent}}22;">
          <text class="astage-emoji">{{icon || '💬'}}</text>
        </view>
        <view class="astage-tag">{{name}}</view>
      </view>
      <view class="row row-assistant"><view class="skel skel-bubble"></view></view>
      <view class="row row-assistant"><view class="skel skel-bubble sk-short"></view></view>
      <view class="row row-user"><view class="skel skel-bubble sk-mine"></view></view>
      <view class="row row-assistant"><view class="skel skel-bubble sk-long"></view></view>
    </block>

    <!-- 加载失败：页内重试条（复用糖果卡样式），不再白屏 -->
    <view wx:elif="{{errored}}" class="chat-retry" bindtap="retryLoad" hover-class="card-press" hover-stay-time="0">
      <text class="chat-retry-ic">↻</text>
      <text>没能连上，点这里重试</text>
    </view>

    <block wx:else>
      <!-- 课程：单张任务卡原地推进，不把完整聊天记录铺在学习流中。 -->
      <block wx:if="{{gameSkin}}">
        <view class="lesson-card {{pending ? 'is-pending' : ''}} feedback-{{answerFeedback}}">
          <view class="lesson-card-eyebrow">{{lessonProgress || '当前任务'}}</view>
          <view wx:if="{{lessonChoice}}" class="lesson-choice feedback-{{answerFeedback}}">
            <text class="lesson-choice-label">{{answerFeedback === 'right' ? '✓ 你的选择' : '你的选择'}}</text>
            <text class="lesson-choice-text">{{lessonChoice}}</text>
          </view>
          <view wx:if="{{lessonCard}}" class="lesson-content">{{lessonCard.content}}</view>
          <view wx:else class="lesson-content lesson-empty">准备好后，从下面选一个答案开始。</view>
          <view wx:if="{{lessonCard.say}}" class="lesson-audio" catchtap="onSpeakSay" data-t="{{lessonCard.say}}" hover-class="say-audio-press" hover-stay-time="0">
            <text class="say-audio-ic">🔊</text><text>听发音</text>
          </view>
          <view wx:if="{{pending}}" class="lesson-thinking"><text></text><text></text><text></text></view>
        </view>
        <view wx:if="{{options.length && !pending && !freeMode}}" class="lesson-instruction">选择一个最接近的答案</view>
        <view wx:if="{{freeMode && !pending}}" class="lesson-instruction">这一拍要你自己的原话——说砸了也不罚</view>
        <!-- 兜底：复原出的旧卡没有点选项（纯点选无输入栏会成死局）时，给一键重开当前关 -->
        <view wx:if="{{lessonCard && !options.length && !pending}}" class="lesson-restart" bindtap="restartLevel" hover-class="card-press" hover-stay-time="0">
          <text class="lesson-restart-ic">↻</text><text>重新学习这一节</text>
        </view>
      </block>

      <!-- 普通 Agent 维持完整聊天流。 -->
      <block wx:else>
        <view class="astage">
          <view class="astage-frame {{pending ? 'busy' : ''}}" style="background: {{accent}}22;">
            <text class="astage-emoji">{{icon}}</text>
          </view>
          <view class="astage-tag">{{name}}</view>
        </view>

        <block wx:for="{{messages}}" wx:key="index">
          <view id="m{{index}}" class="row row-{{item.role}}">
            <view class="bubble bubble-{{item.role}}">{{item.content}}</view>
          </view>
          <view wx:if="{{item.say}}" class="row row-assistant say-row">
            <view class="say-audio" catchtap="onSpeakSay" data-t="{{item.say}}" hover-class="say-audio-press" hover-stay-time="0">
              <text class="say-audio-ic">🔊</text><text class="say-audio-tx">听发音</text>
            </view>
          </view>
        </block>
        <view wx:if="{{pending}}" class="row row-assistant">
          <view class="bubble bubble-assistant typing">思考中…</view>
        </view>
      </block>
    </block>
    <view class="msgs-pad"></view>
  </scroll-view>

  <!-- 提醒承诺：今日首学后递上「明天叫我」（执行意图；一天只邀一次，模板未配不出现） -->
  <view wx:if="{{remindState === 'offer' && (!gameSkin || (!options.length && !pending))}}" class="remind-bar" bindtap="onRemindTap">
    <text class="remind-text">⏰ 明天这个点叫你继续吗？</text>
    <text class="remind-yes">好啊</text>
  </view>
  <view wx:elif="{{remindState === 'done' && (!gameSkin || (!options.length && !pending))}}" class="remind-bar done">
    <text class="remind-text">✓ 说定了，明天见</text>
  </view>

  <!-- 产出节点：打字 / 按住说话（真开口·真动笔）。识别结果先进输入框，学员确认后再发 -->
  <view class="produce opts-tail" wx:if="{{freeMode && !pending}}" style="--accent: {{accent}};">
    <view class="produce-row">
      <textarea
        class="produce-input"
        value="{{freeText}}"
        maxlength="300"
        auto-height
        cursor-spacing="16"
        placeholder="{{recState === 'recording' ? '正在听你说…' : '把你的原话打出来，或按住 🎙️ 说'}}"
        bindinput="onFreeInput"
      />
      <view
        class="produce-mic {{recState === 'recording' ? 'recording' : ''}}"
        bindtouchstart="onMicStart"
        bindtouchend="onMicEnd"
        bindtouchcancel="onMicEnd"
      >🎙️</view>
      <view class="produce-send {{freeText ? '' : 'disabled'}}" bindtap="sendFree">说出去</view>
    </view>
    <view class="produce-skip" bindtap="skipFree">这句先欠着，直接过关 ›</view>
  </view>

  <!-- 本轮可点选项：点选即答（点选为主、产出关输入）。opts-tail 补齐 iPhone 底部安全区，让点选气泡即底栏 -->
  <view class="opts opts-tail {{gameSkin ? 'game-options' : ''}}" wx:if="{{options.length && !pending && !freeMode}}" style="--accent: {{accent}};">
    <view class="opt-chip {{item.en ? 'opt-chip-en' : ''}}" wx:for="{{options}}" wx:key="t" data-t="{{item.t}}" bindtap="pickOption">
      <text wx:if="{{gameSkin}}" class="opt-index">{{index + 1}}</text>
      <text class="opt-tx">{{item.t}}</text>
      <text wx:if="{{item.en}}" class="opt-speak" catchtap="onSpeakChip" data-t="{{item.t}}">🔊</text>
    </view>
  </view>

  <!-- 课程地图：从底部临时展开，当前学习内容保留在背景中。 -->
  <view class="drawer-mask course-map-mask" wx:if="{{gameSkin && mapVisible}}" bindtap="toggleMap">
    <view class="course-map-drawer {{nodes.length ? 'has-nodes' : ''}}" catchtap="noop" style="--accent: {{accent}};">
      <view class="drawer-grip"></view>
      <view class="course-map-head">
        <view>
          <view class="course-map-title">课程地图</view>
          <view class="course-map-sub">{{lessonProgress || '学习进度'}}</view>
        </view>
        <view class="course-map-close" catchtap="toggleMap" hover-class="mentor-action-press" hover-stay-time="0">收起</view>
      </view>

      <view class="course-voice-setting">
        <view class="course-voice-setting-copy">
          <view class="course-voice-setting-title">自动播放讲解</view>
          <view class="course-voice-setting-sub">进入课程和切换讲解时自动播放</view>
        </view>
        <switch checked="{{voiceAutoPlay}}" bindchange="onToggleVoiceAutoPlay" color="{{accent}}" />
      </view>

      <view wx:if="{{concept}}" class="cprog course-map-progress">
        <view class="cp-head">
          <view class="cp-stat">
            <block wx:if="{{concept.allDone}}"><text class="cp-tier">课程已完成</text></block>
            <block wx:else><text class="cp-tier">{{concept.cur.tier}}</text><text class="cp-num">{{concept.cur.lit}}</text><text class="cp-tot">/{{concept.cur.total}}</text></block>
            <text class="cp-all">· 已掌握 {{concept.lit}}/{{concept.total}}</text>
          </view>
          <view wx:if="{{reviewDue > 0}}" class="cp-review" catchtap="startReview">🔁 复习 {{reviewDue}}</view>
          <view wx:else class="cp-note">{{concept.note || '当前学习阶段'}}</view>
        </view>
        <view class="cp-track"><view class="cp-fill" style="width: {{concept.curPct}}%;"></view></view>
      </view>

      <scroll-view wx:if="{{nodes.length}}" scroll-y class="course-map-list">
        <view
          wx:for="{{nodes}}"
          wx:key="slug"
          class="course-map-node {{item.state}} {{item.memberLocked ? 'mlock' : ''}}"
          bindtap="openCard"
          data-slug="{{item.slug}}"
          hover-class="course-map-node-press"
          hover-stay-time="0"
        >
          <view class="course-map-node-num">{{item.num}}</view>
          <view class="course-map-node-copy">
            <view class="course-map-node-name">{{item.name}}</view>
            <view class="course-map-node-sub">{{item.state === 'mastered' ? '已掌握' : (item.state === 'lit' ? '已点亮' : (item.state === 'current' ? '正在学习' : (item.state === 'available' ? '下一节' : '未解锁')))}}</view>
          </view>
          <view class="course-map-node-mark">{{item.memberLocked ? '🔐' : item.emoji}}</view>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 庆祝浮层：升级 / 点亮 / 掌握共用（全屏彩带 + 大字弹簧） -->
  <view wx:if="{{celebrate}}" class="celebrate" style="--accent: {{accent}};">
    <view class="confetti">
      <view class="cf cf-1"></view><view class="cf cf-2"></view><view class="cf cf-3"></view>
      <view class="cf cf-4"></view><view class="cf cf-5"></view><view class="cf cf-6"></view>
      <view class="cf cf-7"></view><view class="cf cf-8"></view><view class="cf cf-9"></view>
      <view class="cf cf-10"></view><view class="cf cf-11"></view><view class="cf cf-12"></view>
    </view>
    <view class="celeb-card">
      <view class="celeb-spark">🎉</view>
      <view class="celeb-up">{{celebrate.up}}</view>
      <view class="celeb-name">{{celebrate.name}}</view>
      <view class="celeb-sub">{{celebrate.sub}}</view>
    </view>
  </view>

  <!-- 章末知识卡片：Boss 关通关专属，不自动消失——需主动「留在本子里」或「分享」 -->
  <view wx:if="{{chapterCard}}" class="cc-mask">
    <view class="cc-card" style="--accent: {{chapterCard.accent}};">
      <view class="cc-badge">👑 本章通关 · {{chapterCard.name}}</view>
      <view class="cc-takeaway">{{chapterCard.takeaway}}</view>
      <view class="cc-source">—— {{chapterCard.source}}</view>
      <view class="cc-actions">
        <view class="cc-btn" bindtap="onCloseChapterCard">留在本子里</view>
        <button class="cc-btn cc-btn-primary" open-type="share">分享这张卡</button>
      </view>
    </view>
  </view>

  <!-- 关卡卡片抽屉：点横版节点弹出（软锁也能预览），CTA 同页开课 -->
  <view class="drawer-mask" wx:if="{{card}}" bindtap="closeCard">
    <view class="lc-drawer" catchtap="noop" style="--accent: {{accent}};">
      <view class="lc-grip"></view>
      <view class="lc-state {{card.state}}">{{card.stateText}}</view>
      <view class="lc-flavor {{card.state}}">{{card.flavor}}</view>
      <view class="lc-name">{{card.name}}</view>
      <view class="lc-blurb">{{card.blurb}}</view>
      <view wx:if="{{card.note}}" class="lc-report">上次战报 · {{card.note}}</view>
      <view wx:if="{{card.hook}}" class="lc-hook">「{{card.hook}}」</view>
      <view class="lc-go btn-accent" bindtap="startNode">{{card.cta}}</view>
    </view>
  </view>

  <!-- 历史会话抽屉（多会话：每段对话各自成流） -->
  <view class="drawer-mask" wx:if="{{historyVisible}}" bindtap="closeHistory">
    <view class="drawer" catchtap="noop">
      <view class="drawer-grip"></view>
      <view class="drawer-title">{{gameSkin ? '学习记录' : '历史对话'}}</view>
      <view class="drawer-new" bindtap="newSession">{{gameSkin ? '重新开始本课' : '＋ 开启新对话'}}</view>
      <scroll-view scroll-y class="drawer-list">
        <view wx:if="{{!sessions.length}}" class="drawer-empty">还没有历史对话</view>
        <view
          wx:for="{{sessions}}"
          wx:key="sessionId"
          class="drawer-item {{item.sessionId === currentSessionId ? 'active' : ''}}"
          bindtap="switchSession"
          data-id="{{item.sessionId}}"
        >
          <view class="di-title">{{item.title}}</view>
          <view class="di-sub">{{item.lastMessage}}</view>
          <view class="di-time">{{item.timeText}}</view>
        </view>
      </scroll-view>
    </view>
  </view>
</view>
