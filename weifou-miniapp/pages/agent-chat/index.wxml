<view class="page">
  <!-- 顶部：身份 + 额度/会员 -->
  <view class="topbar">
    <view class="tb-ic" style="background: {{accent}}1a; color: {{accent}};">{{icon}}</view>
    <view class="tb-mid">
      <view class="tb-name">{{name}}</view>
      <view class="tb-quota">{{quotaText}}</view>
    </view>
    <view class="tb-act" bindtap="openHistory">历史</view>
    <view wx:if="{{!member}}" class="tb-buy" bindtap="goMembership">开通会员</view>
  </view>

  <!-- 学习型 Agent：三维段位面板（升级感）。段位只升不降，三维条次次微动。 -->
  <view wx:if="{{skill}}" class="skill" style="--accent: {{accent}};">
    <view class="sk-head">
      <view class="sk-tier">
        <text class="sk-lv">Lv.{{skill.level}}</text>
        <text class="sk-name">{{skill.levelName}}</text>
      </view>
      <view wx:if="{{skill.assessed === 0}}" class="sk-hint">用英文开口，我来给你定级 →</view>
      <view wx:elif="{{skill.note}}" class="sk-note">{{skill.note}}</view>
    </view>
    <view class="sk-bars">
      <view class="sk-bar">
        <text class="sk-bl">流利</text>
        <view class="sk-track"><view class="sk-fill" style="width: {{skill.fluency}}%;"></view></view>
        <text class="sk-bv">{{skill.fluency}}</text>
      </view>
      <view class="sk-bar">
        <text class="sk-bl">准确</text>
        <view class="sk-track"><view class="sk-fill" style="width: {{skill.accuracy}}%;"></view></view>
        <text class="sk-bv">{{skill.accuracy}}</text>
      </view>
      <view class="sk-bar">
        <text class="sk-bl">表达</text>
        <view class="sk-track"><view class="sk-fill" style="width: {{skill.expression}}%;"></view></view>
        <text class="sk-bv">{{skill.expression}}</text>
      </view>
    </view>
  </view>

  <!-- 概念型 Agent：分档点亮进度条 + 概念地图入口。头部显示当前正在攻的那一档。 -->
  <view wx:if="{{concept}}" class="cprog" style="--accent: {{accent}};" bindtap="openConceptMap">
    <view class="cp-head">
      <view class="cp-stat">
        <block wx:if="{{concept.allDone}}"><text class="cp-tier">全部通关</text></block>
        <block wx:else>
          <text class="cp-tier">{{concept.cur.tier}}</text>
          <text class="cp-num">{{concept.cur.lit}}</text><text class="cp-tot">/{{concept.cur.total}}</text>
        </block>
        <text class="cp-all">· 共点亮 {{concept.lit}}/{{concept.total}}</text>
      </view>
      <view class="cp-note">{{concept.note || '看概念地图 ›'}}</view>
    </view>
    <view class="cp-track"><view class="cp-fill" style="width: {{concept.curPct}}%;"></view></view>
  </view>

  <!-- 写小说：作品进度条（阶段 + 章数 + 字数），点开作品抽屉 -->
  <view wx:if="{{novel && work}}" class="cprog" style="--accent: {{accent}};" bindtap="openWork">
    <view class="cp-head">
      <view class="cp-stat">
        <text class="cp-tier">{{work.stage}}</text>
        <text class="cp-all">· {{work.chapterCount}} 章 · {{work.wanText}}</text>
      </view>
      <view class="cp-note">我的作品 ›</view>
    </view>
  </view>

  <scroll-view class="msgs" scroll-y scroll-into-view="{{scrollTo}}" scroll-with-animation>
    <view wx:for="{{messages}}" wx:key="index" id="m{{index}}" class="row row-{{item.role}}">
      <view class="bubble bubble-{{item.role}}">{{item.content}}</view>
      <view wx:if="{{novel && item.role === 'assistant'}}" class="bub-acts">
        <text class="bub-act" data-idx="{{index}}" bindtap="saveAsOutline">存为大纲</text>
        <text class="bub-act" data-idx="{{index}}" bindtap="saveAsChapter">存为一章</text>
      </view>
    </view>
    <view wx:if="{{pending}}" class="row row-assistant">
      <view class="bubble bubble-assistant typing">思考中…</view>
    </view>
    <view class="msgs-pad"></view>
  </scroll-view>

  <!-- 做音乐：生成/曲库工具条 -->
  <view wx:if="{{music}}" class="mbar" style="--accent: {{accent}};">
    <view class="mbar-btn" bindtap="openCompose" wx:if="{{genStatus !== 'generating'}}">🎵 生成歌曲</view>
    <view class="mbar-btn gen" wx:else>生成中…约 30-60 秒</view>
    <view class="mbar-btn ghost" bindtap="openLibrary">曲库</view>
  </view>

  <!-- 输入栏 -->
  <view class="composer">
    <input
      class="cp-input"
      value="{{draft}}"
      bindinput="onInput"
      placeholder="说点什么…"
      confirm-type="send"
      bindconfirm="send"
      disabled="{{pending}}"
    />
    <button class="cp-send" bindtap="send" disabled="{{pending || !draft}}">发送</button>
  </view>

  <!-- 庆祝浮层：升级 / 点亮 / 掌握共用 -->
  <view wx:if="{{celebrate}}" class="celebrate" style="--accent: {{accent}};">
    <view class="celeb-card">
      <view class="celeb-spark">🎉</view>
      <view class="celeb-up">{{celebrate.up}}</view>
      <view class="celeb-name">{{celebrate.name}}</view>
      <view class="celeb-sub">{{celebrate.sub}}</view>
    </view>
  </view>

  <!-- 概念地图抽屉：按主题列出全部概念，圆点亮度区分 未学/点亮/掌握 -->
  <view class="drawer-mask" wx:if="{{conceptMapVisible}}" bindtap="closeConceptMap">
    <view class="drawer" catchtap="noop" style="--accent: {{accent}};">
      <view class="drawer-grip"></view>
      <view class="drawer-title">概念地图 · 已点亮 {{concept.lit}}/{{concept.total}}</view>
      <scroll-view scroll-y class="drawer-list">
        <view wx:for="{{concept.tiers}}" wx:key="tier" class="cm-theme">
          <view class="cm-th-name">{{item.tier}} · {{item.lit}}/{{item.total}}</view>
          <view class="cm-grid">
            <view wx:for="{{item.concepts}}" wx:for-item="c" wx:key="name" class="cm-chip lv{{c.level}}">{{c.name}}</view>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 写小说：作品抽屉（阶段徽章 + 可编辑立意/大纲 + 章节列表） -->
  <view class="drawer-mask" wx:if="{{workVisible}}" bindtap="closeWork">
    <view class="drawer" catchtap="noop" style="--accent: {{accent}};">
      <view class="drawer-grip"></view>
      <view class="drawer-title">{{work.title || '未命名作品'}}</view>
      <view class="wk-stages">
        <view wx:for="{{work.stages}}" wx:key="label" class="wk-stage {{item.done ? 'done' : ''}}">{{item.label}}</view>
      </view>
      <scroll-view scroll-y class="drawer-list">
        <view class="wk-field" data-field="title" bindtap="editWorkField"><text class="wk-lb">标题</text><text class="wk-val">{{work.title || '点击填写'}}</text></view>
        <view class="wk-field" data-field="logline" bindtap="editWorkField"><text class="wk-lb">立意</text><text class="wk-val">{{work.logline || '一句话说清你的故事'}}</text></view>
        <view class="wk-field" data-field="genre" bindtap="editWorkField"><text class="wk-lb">题材</text><text class="wk-val">{{work.genre || '点击填写'}}</text></view>
        <view class="wk-field col" data-field="outline" bindtap="editWorkField"><text class="wk-lb">大纲</text><text class="wk-val ml">{{work.outline || '点击编辑大纲'}}</text></view>
        <view class="wk-sec">章节 · {{work.wanText}}</view>
        <view wx:for="{{work.chapters}}" wx:key="id" class="wk-chap" data-cid="{{item.id}}" data-content="{{item.content}}" bindtap="editChapter">
          <view class="wk-chap-t">第{{item.idx}}章 · {{item.title}}</view>
          <view class="wk-chap-c">{{item.content}}</view>
        </view>
        <view wx:if="{{!work.chapterCount}}" class="wk-empty">还没有章节——在对话里写好正文，点气泡下的「存为一章」。</view>
        <view class="wk-final {{work.finalized ? 'on' : ''}}" bindtap="toggleFinalized">{{work.finalized ? '已定稿 ✓（点击取消）' : '标记为定稿'}}</view>
      </scroll-view>
    </view>
  </view>

  <!-- 做音乐：写词/生成弹层 -->
  <view class="drawer-mask" wx:if="{{composeVisible}}" bindtap="closeCompose">
    <view class="drawer" catchtap="noop" style="--accent: {{accent}};">
      <view class="drawer-grip"></view>
      <view class="drawer-title">生成歌曲</view>
      <view class="cm-lb">歌词（用 [verse]/[chorus] 分段更好）</view>
      <textarea class="cm-lyrics" value="{{draftLyrics}}" bindinput="onLyrics" placeholder="把打磨好的歌词粘进来…" maxlength="2000" auto-height></textarea>
      <view class="cm-row">
        <input class="cm-in" value="{{draftStyle}}" bindinput="onStyle" placeholder="曲风，如：温暖民谣 木吉他 男声" />
      </view>
      <view class="cm-row">
        <input class="cm-in" value="{{draftTitle}}" bindinput="onTitle" placeholder="歌名（可留空）" />
      </view>
      <view class="cm-gen" bindtap="doGenerate">开始生成（约 30-60 秒）</view>
    </view>
  </view>

  <!-- 做音乐：曲库抽屉 -->
  <view class="drawer-mask" wx:if="{{libVisible}}" bindtap="closeLibrary">
    <view class="drawer" catchtap="noop" style="--accent: {{accent}};">
      <view class="drawer-grip"></view>
      <view class="drawer-title">我的曲库</view>
      <scroll-view scroll-y class="drawer-list">
        <view wx:if="{{!songs.length}}" class="wk-empty">还没有歌——去写词生成第一首吧。</view>
        <view wx:for="{{songs}}" wx:key="songId" class="song">
          <view class="song-meta">
            <view class="song-t">{{item.title}}</view>
            <view class="song-sub">{{item.status === 'done' ? item.timeText : (item.status === 'failed' ? '生成失败' : '生成中…')}}</view>
          </view>
          <view wx:if="{{item.audioUrl}}" class="song-play {{playingSongId === item.songId ? 'on' : ''}}" data-src="{{item.audioUrl}}" data-id="{{item.songId}}" catchtap="playSong">{{playingSongId === item.songId ? '⏸' : '▶'}}</view>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 历史会话抽屉（多会话：每段对话各自成流） -->
  <view class="drawer-mask" wx:if="{{historyVisible}}" bindtap="closeHistory">
    <view class="drawer" catchtap="noop">
      <view class="drawer-grip"></view>
      <view class="drawer-title">历史对话</view>
      <view class="drawer-new" bindtap="newSession">＋ 开启新对话</view>
      <scroll-view scroll-y class="drawer-list">
        <view wx:if="{{!sessions.length}}" class="drawer-empty">还没有历史对话</view>
        <view
          wx:for="{{sessions}}"
          wx:key="sessionId"
          class="drawer-item {{item.sessionId === currentSessionId ? 'active' : ''}}"
          bindtap="switchSession"
          data-id="{{item.sessionId}}"
        >
          <view class="di-title">{{item.title}}</view>
          <view class="di-sub">{{item.lastMessage}}</view>
          <view class="di-time">{{item.timeText}}</view>
        </view>
      </scroll-view>
    </view>
  </view>
</view>
