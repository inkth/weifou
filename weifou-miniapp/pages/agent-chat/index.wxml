<view class="page">
  <!-- 顶部：身份 + 额度/会员 -->
  <view class="topbar">
    <view class="tb-ic" style="background: {{accent}}1a; color: {{accent}};">{{icon}}</view>
    <view class="tb-mid">
      <view class="tb-name">{{name}}</view>
      <view class="tb-quota">{{quotaText}}</view>
    </view>
    <view class="tb-act" bindtap="openHistory">历史</view>
    <view wx:if="{{!member}}" class="tb-buy" bindtap="goMembership">开通会员</view>
  </view>

  <!-- 学习型 Agent：三维段位面板（升级感）。段位只升不降，三维条次次微动。 -->
  <view wx:if="{{skill}}" class="skill" style="--accent: {{accent}};">
    <view class="sk-head">
      <view class="sk-tier">
        <text class="sk-lv">Lv.{{skill.level}}</text>
        <text class="sk-name">{{skill.levelName}}</text>
      </view>
      <view wx:if="{{skill.assessed === 0}}" class="sk-hint">用英文开口，我来给你定级 →</view>
      <view wx:elif="{{skill.note}}" class="sk-note">{{skill.note}}</view>
    </view>
    <view class="sk-bars">
      <view class="sk-bar">
        <text class="sk-bl">流利</text>
        <view class="sk-track"><view class="sk-fill" style="width: {{skill.fluency}}%;"></view></view>
        <text class="sk-bv">{{skill.fluency}}</text>
      </view>
      <view class="sk-bar">
        <text class="sk-bl">准确</text>
        <view class="sk-track"><view class="sk-fill" style="width: {{skill.accuracy}}%;"></view></view>
        <text class="sk-bv">{{skill.accuracy}}</text>
      </view>
      <view class="sk-bar">
        <text class="sk-bl">表达</text>
        <view class="sk-track"><view class="sk-fill" style="width: {{skill.expression}}%;"></view></view>
        <text class="sk-bv">{{skill.expression}}</text>
      </view>
    </view>
  </view>

  <!-- 概念型 Agent：分档点亮进度条 + 概念地图入口。头部显示当前正在攻的那一档。 -->
  <view wx:if="{{concept}}" class="cprog" style="--accent: {{accent}};" bindtap="openConceptMap">
    <view class="cp-head">
      <view class="cp-stat">
        <block wx:if="{{concept.allDone}}"><text class="cp-tier">全部通关</text></block>
        <block wx:else>
          <text class="cp-tier">{{concept.cur.tier}}</text>
          <text class="cp-num">{{concept.cur.lit}}</text><text class="cp-tot">/{{concept.cur.total}}</text>
        </block>
        <text class="cp-all">· 共点亮 {{concept.lit}}/{{concept.total}}</text>
      </view>
      <view wx:if="{{reviewDue > 0}}" class="cp-review" catchtap="startReview">🔁 复习 {{reviewDue}}</view>
      <view wx:else class="cp-note">{{concept.note || '看概念地图 ›'}}</view>
    </view>
    <view class="cp-track"><view class="cp-fill" style="width: {{concept.curPct}}%;"></view></view>
  </view>

  <scroll-view class="msgs" scroll-y scroll-into-view="{{scrollTo}}" scroll-with-animation>
    <!-- 加载骨架：头像/名牌来自跳转参数即时可见，正文用灰气泡占位——慢网/断网也不白屏发愣 -->
    <block wx:if="{{loading}}">
      <view class="astage">
        <view class="astage-frame" style="background: {{accent}}22;">
          <text class="astage-emoji">{{icon || '💬'}}</text>
        </view>
        <view class="astage-tag">{{name}}</view>
      </view>
      <view class="row row-assistant"><view class="skel skel-bubble"></view></view>
      <view class="row row-assistant"><view class="skel skel-bubble sk-short"></view></view>
      <view class="row row-user"><view class="skel skel-bubble sk-mine"></view></view>
      <view class="row row-assistant"><view class="skel skel-bubble sk-long"></view></view>
    </block>

    <!-- 加载失败：页内重试条（复用糖果卡样式），不再白屏 -->
    <view wx:elif="{{errored}}" class="chat-retry" bindtap="retryLoad" hover-class="card-press" hover-stay-time="0">
      <text class="chat-retry-ic">↻</text>
      <text>没能连上，点这里重试</text>
    </view>

    <!-- 角色画框：新粗野拱窗 + 贴纸名牌，在消息流顶部，随对话自然滚走 -->
    <view wx:else class="astage">
      <view class="astage-frame {{pending ? 'busy' : ''}}" style="background: {{accent}}22;">
        <text class="astage-emoji">{{icon}}</text>
      </view>
      <view class="astage-tag">{{name}}</view>
    </view>

    <view wx:for="{{messages}}" wx:key="index" id="m{{index}}" class="row row-{{item.role}}">
      <view class="bubble bubble-{{item.role}}">{{item.content}}</view>
    </view>
    <view wx:if="{{pending}}" class="row row-assistant">
      <view class="bubble bubble-assistant typing">思考中…</view>
    </view>
    <view class="msgs-pad"></view>
  </scroll-view>

  <!-- 输入栏 -->
  <!-- 提醒承诺：今日首学后递上「明天叫我」（执行意图；一天只邀一次，模板未配不出现） -->
  <view wx:if="{{remindState === 'offer'}}" class="remind-bar" bindtap="onRemindTap">
    <text class="remind-text">⏰ 明天这个点叫你继续吗？</text>
    <text class="remind-yes">好啊</text>
  </view>
  <view wx:elif="{{remindState === 'done'}}" class="remind-bar done">
    <text class="remind-text">✓ 说定了，明天见</text>
  </view>

  <!-- 本轮可点选项：点选即答（点选为主）。产出型三门课连产出关也给可点成品；理解型课自由表达环节服务端不下发选项，改用麦克风/打字 -->
  <view class="opts" wx:if="{{options.length && !pending}}" style="--accent: {{accent}};">
    <view class="opt-chip" wx:for="{{options}}" wx:key="*this" data-t="{{item}}" bindtap="pickOption">{{item}}</view>
  </view>

  <view class="composer">
    <view wx:if="{{voice}}" class="cp-mic {{recording ? 'on' : ''}}" bindtouchstart="onMicStart" bindtouchend="onMicEnd" bindtouchcancel="onMicEnd">
      <view class="cp-mic-i"></view>
    </view>
    <input
      class="cp-input"
      value="{{draft}}"
      bindinput="onInput"
      placeholder="{{voice ? '按住麦克风说，或打字…' : '说点什么…'}}"
      confirm-type="send"
      bindconfirm="send"
      disabled="{{pending || loading || errored}}"
    />
    <button class="cp-send" bindtap="send" disabled="{{pending || !draft || loading || errored}}">发送</button>
  </view>

  <!-- 庆祝浮层：升级 / 点亮 / 掌握共用（全屏彩带 + 大字弹簧） -->
  <view wx:if="{{celebrate}}" class="celebrate" style="--accent: {{accent}};">
    <view class="confetti">
      <view class="cf cf-1"></view><view class="cf cf-2"></view><view class="cf cf-3"></view>
      <view class="cf cf-4"></view><view class="cf cf-5"></view><view class="cf cf-6"></view>
      <view class="cf cf-7"></view><view class="cf cf-8"></view><view class="cf cf-9"></view>
      <view class="cf cf-10"></view><view class="cf cf-11"></view><view class="cf cf-12"></view>
    </view>
    <view class="celeb-card">
      <view class="celeb-spark">🎉</view>
      <view class="celeb-up">{{celebrate.up}}</view>
      <view class="celeb-name">{{celebrate.name}}</view>
      <view class="celeb-sub">{{celebrate.sub}}</view>
    </view>
  </view>

  <!-- 概念地图抽屉：按主题列出全部概念，圆点亮度区分 未学/点亮/掌握 -->
  <view class="drawer-mask" wx:if="{{conceptMapVisible}}" bindtap="closeConceptMap">
    <view class="drawer" catchtap="noop" style="--accent: {{accent}};">
      <view class="drawer-grip"></view>
      <view class="drawer-title">概念地图 · 已点亮 {{concept.lit}}/{{concept.total}}</view>
      <scroll-view scroll-y class="drawer-list">
        <view wx:for="{{concept.tiers}}" wx:key="tier" class="cm-theme">
          <view class="cm-th-name">{{item.tier}} · {{item.lit}}/{{item.total}}</view>
          <view class="cm-grid">
            <view wx:for="{{item.concepts}}" wx:for-item="c" wx:key="name" class="cm-chip lv{{c.level}}">{{c.name}}</view>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 历史会话抽屉（多会话：每段对话各自成流） -->
  <view class="drawer-mask" wx:if="{{historyVisible}}" bindtap="closeHistory">
    <view class="drawer" catchtap="noop">
      <view class="drawer-grip"></view>
      <view class="drawer-title">历史对话</view>
      <view class="drawer-new" bindtap="newSession">＋ 开启新对话</view>
      <scroll-view scroll-y class="drawer-list">
        <view wx:if="{{!sessions.length}}" class="drawer-empty">还没有历史对话</view>
        <view
          wx:for="{{sessions}}"
          wx:key="sessionId"
          class="drawer-item {{item.sessionId === currentSessionId ? 'active' : ''}}"
          bindtap="switchSession"
          data-id="{{item.sessionId}}"
        >
          <view class="di-title">{{item.title}}</view>
          <view class="di-sub">{{item.lastMessage}}</view>
          <view class="di-time">{{item.timeText}}</view>
        </view>
      </scroll-view>
    </view>
  </view>
</view>
