page { background: var(--bg); height: 100%; }
.page { display: flex; flex-direction: column; height: 100vh; }

.topbar { display: flex; align-items: center; padding: 12rpx 28rpx; background: var(--surface); border-bottom: var(--bw-thin) solid var(--border); flex: 0 0 auto; }
.tb-spacer { flex: 1 1 auto; min-width: 16rpx; }
.tb-quota { flex: 0 1 auto; min-width: 0; font-size: 23rpx; color: var(--sub); }
.tb-buy { flex: 0 0 auto; padding: 12rpx 28rpx; background: var(--accent); color: var(--on-accent); font-size: 25rpx; font-weight: 800; border: none; border-radius: var(--r-md); box-shadow: var(--shadow-accent); transition: transform 0.1s var(--ease), box-shadow 0.1s var(--ease); }
.tb-buy:active { transform: scale(0.985); background: var(--accent-strong); }
.tb-act { flex: 0 0 auto; margin-left: 12rpx; padding: 10rpx 22rpx; background: var(--fill); color: var(--ink-2); font-size: 24rpx; border: var(--bw-thin) solid var(--border); border-radius: var(--r-full); transition: transform 0.1s var(--ease); }
.tb-act:active { transform: scale(0.985); opacity: 0.9; }

/* 历史会话抽屉 */
.drawer-mask { position: fixed; inset: 0; background: var(--scrim-soft); z-index: 50; display: flex; flex-direction: column; justify-content: flex-end; }
.drawer { background: var(--surface); border-radius: var(--r-3xl) var(--r-3xl) 0 0; max-height: 76vh; display: flex; flex-direction: column; padding: 0 28rpx calc(24rpx + env(safe-area-inset-bottom)); box-shadow: var(--shadow-pop); }
.drawer-grip { width: 64rpx; height: 8rpx; border-radius: 8rpx; background: var(--border); margin: 16rpx auto 8rpx; }
.drawer-title { font-size: 30rpx; font-weight: 700; color: var(--ink); text-align: center; padding: 8rpx 0 16rpx; }
.drawer-new { text-align: center; color: var(--accent-strong); font-size: 28rpx; font-weight: 700; padding: 20rpx; border: 2rpx dashed rgba(119, 114, 200, 0.40); border-radius: var(--r-md); margin-bottom: 16rpx; }
.drawer-new:active { opacity: 0.8; }
.drawer-list { flex: 1 1 auto; min-height: 0; }
.drawer-empty { text-align: center; color: var(--faint); font-size: 26rpx; padding: 60rpx 0; }
.drawer-item { padding: 20rpx 22rpx; border-radius: var(--r-md); margin-bottom: 12rpx; background: var(--fill); border: var(--bw-thin) solid transparent; }
.drawer-item.active { background: var(--accent-soft); border-color: var(--accent); }
.drawer-item:active { opacity: 0.85; }
.di-title { font-size: 28rpx; font-weight: 700; color: var(--ink); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.di-sub { font-size: 24rpx; color: var(--sub); margin-top: 6rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.di-time { font-size: 22rpx; color: var(--faint); margin-top: 6rpx; }

/* 课程地图：保持主学习界面在背景，以底部抽屉承载总览和跳转。 */
.course-map-drawer {
  width: 100%;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  padding: 0 28rpx calc(24rpx + env(safe-area-inset-bottom));
  background: var(--surface);
  border-radius: var(--r-3xl) var(--r-3xl) 0 0;
  box-shadow: var(--shadow-pop);
  animation: courseMapUp .26s var(--ease-out);
}
.course-map-drawer.has-nodes { height: 80vh; }
@keyframes courseMapUp { from { transform: translateY(14%); opacity: .4; } to { transform: translateY(0); opacity: 1; } }
.course-map-head { display: flex; align-items: center; justify-content: space-between; padding: 2rpx 4rpx 20rpx; }
.course-map-title { color: var(--ink); font-size: 32rpx; font-weight: 800; }
.course-map-sub { margin-top: 4rpx; color: var(--sub); font-size: 21rpx; }
.course-map-close { padding: 12rpx 16rpx; color: var(--accent-deep); font-size: 24rpx; font-weight: 700; }
.course-voice-setting {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 16rpx;
  padding: 18rpx 22rpx;
  background: var(--surface-sunken);
  border: var(--bw-thin) solid var(--border);
  border-radius: var(--r-lg);
}
.course-voice-setting-copy { flex: 1 1 auto; min-width: 0; }
.course-voice-setting-title { color: var(--ink); font-size: 26rpx; font-weight: 750; }
.course-voice-setting-sub { margin-top: 5rpx; color: var(--sub); font-size: 21rpx; line-height: 1.4; }
.course-map-progress {
  margin-bottom: 16rpx;
  padding: 20rpx 22rpx;
  background: var(--surface-sunken);
  border: var(--bw-thin) solid var(--border);
  border-radius: var(--r-lg);
}
.course-map-list { flex: 1 1 auto; min-height: 0; padding-bottom: 8rpx; }
.course-map-node {
  display: flex;
  align-items: center;
  min-height: 104rpx;
  margin-bottom: 12rpx;
  padding: 16rpx 18rpx;
  box-sizing: border-box;
  background: var(--fill);
  border: var(--bw-thin) solid transparent;
  border-radius: var(--r-lg);
  transition: transform .1s var(--ease), opacity .1s var(--ease);
}
.course-map-node.current { background: var(--accent-soft); border-color: var(--accent); box-shadow: var(--shadow-hair); }
.course-map-node.available { background: var(--surface); border-color: var(--accent); }
.course-map-node.mastered, .course-map-node.lit { background: var(--surface); border-color: var(--border); }
.course-map-node.locked, .course-map-node.mlock { opacity: .58; }
.course-map-node-press { transform: scale(.985); opacity: .82; }
.course-map-node-num {
  flex: 0 0 auto;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--accent-deep);
  font-size: 22rpx;
  font-weight: 800;
  background: var(--surface);
  border-radius: 50%;
}
.course-map-node.current .course-map-node-num { color: var(--on-accent); background: var(--accent); }
.course-map-node-copy { flex: 1 1 auto; min-width: 0; margin-left: 16rpx; }
.course-map-node-name { overflow: hidden; color: var(--ink); font-size: 27rpx; font-weight: 750; text-overflow: ellipsis; white-space: nowrap; }
.course-map-node-sub { margin-top: 5rpx; color: var(--sub); font-size: 21rpx; }
.course-map-node-mark { flex: 0 0 auto; margin-left: 16rpx; font-size: 31rpx; line-height: 1; }

.msgs { flex: 1 1 auto; min-height: 0; padding: 24rpx 28rpx 0; box-sizing: border-box; }

/* —— 角色画框（消息流顶部，随对话滚走）：人物拱窗 + 状态名牌 —— */
.astage { display: flex; flex-direction: column; align-items: center; padding: 24rpx 0 30rpx; }
.astage-frame {
  width: 168rpx; height: 188rpx;
  border-radius: 84rpx 84rpx 24rpx 24rpx;
  border: 6rpx solid var(--surface);
  background: linear-gradient(160deg, var(--sky-1), var(--sky-2));
  box-shadow: var(--shadow-card);
  display: flex; align-items: center; justify-content: center;
  animation: aBreath 4.5s ease-in-out infinite;
}
.astage-emoji { font-size: 84rpx; line-height: 1; }
@keyframes aBreath { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.03); } }
.astage-frame.busy { animation-duration: 1.6s; }
.astage-tag {
  margin-top: -16rpx;
  padding: 6rpx 24rpx;
  background: var(--pop-butter); color: var(--pop-butter-ink);
  border: none;
  border-radius: var(--r-full);
  font-size: 24rpx; font-weight: 800;
  box-shadow: var(--shadow-hair);
}

.row { display: flex; margin-bottom: 22rpx; }
.row-user { justify-content: flex-end; }
.row-assistant { justify-content: flex-start; }
.bubble { max-width: 76%; padding: 20rpx 24rpx; font-size: 29rpx; line-height: 1.55; border-radius: var(--r-lg); word-break: break-word; white-space: pre-wrap; }
.bubble-assistant { background: var(--surface); color: var(--ink); border-bottom-left-radius: 8rpx; border: var(--bw-thin) solid var(--border); box-shadow: var(--shadow-hair); }
.bubble-user { background: var(--accent); color: var(--on-accent); border-bottom-right-radius: 8rpx; box-shadow: var(--shadow-hair); }
.typing { color: var(--faint); }
/* 无输入栏：消息流可直抵页底，尾部补齐安全区，末条不压 iPhone Home 指示条 */
.msgs-pad { height: calc(24rpx + env(safe-area-inset-bottom)); }

/* —— 加载骨架气泡（复用 app.wxss .skel 的微光；无网也先占位，不白屏）—— */
.skel-bubble { height: 92rpx; width: 58%; border-radius: var(--r-lg); border-bottom-left-radius: 8rpx; }
.skel-bubble.sk-short { width: 38%; height: 76rpx; }
.skel-bubble.sk-long { width: 70%; height: 148rpx; }
.skel-bubble.sk-mine { width: 46%; height: 84rpx; border-bottom-left-radius: var(--r-lg); border-bottom-right-radius: 8rpx; }

/* —— 加载失败：页内重试条 —— */
.chat-retry {
  display: flex; align-items: center; justify-content: center; gap: 12rpx;
  margin: 80rpx 40rpx 0; padding: 28rpx;
  background: var(--surface); border: var(--bw-thin) solid var(--border);
  border-radius: var(--r-lg); box-shadow: var(--shadow-card);
  color: var(--ink-2); font-size: 28rpx; font-weight: 600;
  transition: transform 0.1s var(--ease), box-shadow 0.1s var(--ease);
}
.chat-retry-ic { font-size: 34rpx; color: var(--accent); font-weight: 800; }

/* 三维段位面板（升级感）：果冻进度条 */

/* 概念型 Agent：点亮进度条（果冻） */
.cprog { flex: 0 0 auto; background: var(--surface); padding: 16rpx 28rpx 20rpx; border-top: var(--bw-thin) solid var(--border); }
.cp-head { display: flex; align-items: baseline; gap: 10rpx; margin-bottom: 14rpx; }
.cp-stat { flex: 1 1 auto; min-width: 0; display: flex; align-items: baseline; gap: 6rpx; }
.cp-tier { font-size: 24rpx; font-weight: 800; color: var(--ink); }
.cp-num { font-size: 34rpx; font-weight: 800; color: var(--accent); margin-left: 4rpx; }
.cp-tot { font-size: 24rpx; font-weight: 600; color: var(--faint); }
.cp-all { font-size: 22rpx; color: var(--sub); margin-left: 4rpx; }
.cp-note { flex: 0 0 auto; font-size: 22rpx; color: var(--accent-strong); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 260rpx; }
/* 复习挑战徽章（检索练习入口，有到期概念时替换右侧提示） */
.cp-review {
  flex: 0 0 auto; font-size: 22rpx; font-weight: 800;
  padding: 4rpx 18rpx;
  background: var(--pop-butter); color: var(--pop-butter-ink);
  border: none; border-radius: var(--r-full);
  box-shadow: var(--shadow-hair);
  transition: transform 0.1s var(--ease), box-shadow 0.1s var(--ease);
}
.cp-review:active { transform: scale(0.985); }

/* 提醒承诺条（课后邀请「明天叫我」，点整条即弹授权） */
.remind-bar {
  flex: 0 0 auto;
  display: flex; align-items: center; gap: 12rpx;
  margin: 12rpx 24rpx 0;
  padding: 18rpx 24rpx;
  background: var(--pop-butter); color: var(--pop-butter-ink);
  border: none;
  border-radius: var(--r-md);
  font-size: 26rpx; font-weight: 700;
  box-shadow: var(--shadow-hair);
  animation: barIn 0.25s var(--ease) both;
  transition: transform 0.1s var(--ease), box-shadow 0.1s var(--ease);
}
.remind-bar:active { transform: scale(0.985); }
.remind-bar.done { background: var(--accent-soft); color: var(--accent-ink); box-shadow: var(--shadow-hair); }
.remind-text { flex: 1; }
.remind-yes {
  flex: 0 0 auto; font-size: 24rpx; font-weight: 800;
  padding: 4rpx 20rpx;
  background: var(--surface); color: var(--pop-butter-ink);
  border-radius: var(--r-full);
}
@keyframes barIn { from { opacity: 0; transform: translateY(8rpx); } to { opacity: 1; transform: translateY(0); } }
.cp-track { height: 20rpx; border-radius: var(--r-full); background: var(--fill); overflow: hidden; }
.cp-fill { position: relative; height: 100%; border-radius: var(--r-full); background: var(--accent); transition: width 0.6s cubic-bezier(0.22, 1, 0.36, 1); }
.cp-fill::after { content: ''; position: absolute; left: 8rpx; right: 8rpx; top: 4rpx; height: 6rpx; border-radius: var(--r-full); background: rgba(255, 255, 255, 0.35); }

/* 学习页内庆祝浮层：完全透明，不遮掉正在学习的舞台与卡片。 */
.celebrate { position: fixed; inset: 0; z-index: 60; display: flex; align-items: center; justify-content: center; background: transparent; animation: celebFade 0.25s ease; pointer-events: none; overflow: hidden; }
.celeb-card { position: relative; z-index: 2; max-width: 620rpx; padding: 48rpx 64rpx; text-align: center; background: transparent; border: 0; box-shadow: none; animation: celebPop 0.42s var(--ease-spring); }
.celeb-spark { font-size: 72rpx; line-height: 1; animation: sparkBounce 0.6s var(--ease-spring); }
.celeb-up { display: inline-block; font-size: 24rpx; font-weight: 800; color: #574825; letter-spacing: 4rpx; margin-top: 12rpx; padding: 4rpx 18rpx; background: var(--gold); border-radius: var(--r-full); box-shadow: var(--shadow-hair); }
.celeb-name { font-size: 56rpx; font-weight: 800; color: var(--ink); margin-top: 8rpx; text-shadow: 0 2rpx 12rpx rgba(255, 255, 255, 0.96); animation: namePop 0.5s var(--ease-spring) 0.08s both; }
.celeb-sub { font-size: 24rpx; color: var(--ink-2); margin-top: 12rpx; text-shadow: 0 2rpx 10rpx rgba(255, 255, 255, 0.96); }
@keyframes celebFade { from { opacity: 0; } to { opacity: 1; } }
@keyframes celebPop { 0% { opacity: 0; transform: scale(0.7); } 60% { opacity: 1; } 100% { opacity: 1; transform: scale(1); } }
@keyframes sparkBounce { 0% { transform: scale(0.4); } 60% { transform: scale(1.25); } 100% { transform: scale(1); } }
@keyframes namePop { 0% { opacity: 0; transform: scale(0.8); } 100% { opacity: 1; transform: scale(1); } }

/* 章末知识卡片：Boss 关通关专属，卡面样式沿用 celeb-card 但不自动消失、多两个操作按钮 */
.cc-mask { position: fixed; inset: 0; z-index: 61; display: flex; align-items: center; justify-content: center; background: var(--glass-light); animation: celebFade 0.25s ease; padding: 0 48rpx; }
.cc-card { position: relative; width: 100%; background: var(--surface); border-radius: var(--r-2xl); padding: 48rpx 44rpx; text-align: center; box-shadow: var(--shadow-pop); animation: celebPop 0.42s var(--ease-spring); }
.cc-badge { display: inline-block; font-size: 24rpx; font-weight: 800; color: var(--accent-ink); padding: 6rpx 20rpx; background: var(--accent-soft); border-radius: var(--r-full); }
.cc-takeaway { margin-top: 24rpx; font-size: 34rpx; font-weight: 700; color: var(--ink); line-height: 1.6; }
.cc-source { margin-top: 12rpx; font-size: 24rpx; color: var(--sub); }
.cc-actions { display: flex; gap: 16rpx; margin-top: 40rpx; }
.cc-btn {
  flex: 1; font-size: 28rpx; font-weight: 700; line-height: 1;
  padding: 22rpx 0; border-radius: var(--r-full);
  background: var(--fill); color: var(--ink-2);
  border: none; margin: 0;
}
.cc-btn::after { border: none; }
.cc-btn-primary { background: var(--accent); color: #fff; }
.cc-btn-primary:active { background: var(--accent-strong); }

/* 彩带：12 枚糖纸小方块，错峰下落一次（与 2.4s 自动收起节拍吻合） */
.confetti { position: absolute; inset: 0; z-index: 1; pointer-events: none; }
.cf { position: absolute; top: 0; width: 14rpx; height: 22rpx; border-radius: 4rpx; animation: cfFall 1.6s ease-in both; }
.cf-1  { left: 6%;  background: var(--pop-butter); animation-delay: 0s; }
.cf-2  { left: 14%; background: var(--cand-blue);  animation-delay: 0.22s; }
.cf-3  { left: 24%; background: var(--pop-coral);  animation-delay: 0.10s; }
.cf-4  { left: 32%; background: var(--accent);     animation-delay: 0.34s; }
.cf-5  { left: 41%; background: var(--pop-lilac);  animation-delay: 0.05s; }
.cf-6  { left: 49%; background: var(--gold);       animation-delay: 0.28s; }
.cf-7  { left: 57%; background: var(--cand-blue);  animation-delay: 0.16s; }
.cf-8  { left: 66%; background: var(--pop-coral);  animation-delay: 0.42s; }
.cf-9  { left: 74%; background: var(--accent);     animation-delay: 0.08s; }
.cf-10 { left: 82%; background: var(--pop-butter); animation-delay: 0.30s; }
.cf-11 { left: 90%; background: var(--pop-lilac);  animation-delay: 0.20s; }
.cf-12 { left: 96%; background: var(--gold);       animation-delay: 0.46s; }
@keyframes cfFall {
  0% { transform: translateY(-10vh) rotate(0deg); opacity: 1; }
  80% { opacity: 1; }
  100% { transform: translateY(110vh) rotate(540deg); opacity: 0; }
}

/* 本轮可点选项：白底细边气泡，点选即答（点选为主、输入兜底） */
.opts { flex: 0 0 auto; display: flex; flex-wrap: wrap; gap: 14rpx; padding: 14rpx 24rpx 6rpx; background: var(--surface); }
.opt-chip {
  display: inline-flex; align-items: center;
  padding: 14rpx 26rpx; font-size: 27rpx; color: var(--ink);
  background: var(--surface); border: var(--bw-thin) solid var(--border);
  border-radius: var(--r-full); box-shadow: var(--shadow-hair);
  transition: transform 0.1s var(--ease), box-shadow 0.1s var(--ease);
}
.opt-chip:active { transform: scale(0.985); border-color: var(--accent); color: var(--accent); }
/* 英语课·英文选项句：右侧🔊只朗读不作答（catchtap 拦截冒泡） */
.opt-chip-en .opt-tx { margin-right: 4rpx; }
.opt-speak {
  margin-left: 8rpx; font-size: 30rpx; line-height: 1;
  padding: 2rpx 6rpx; border-radius: var(--r-full);
}
.opt-speak:active { opacity: 0.45; }

/* 英语课·跟读示范句下方的「听发音」胶囊（示范句进场自动播一遍，这里供重播） */
.say-row { margin-top: -10rpx; }
.say-audio {
  display: inline-flex; align-items: center; gap: 8rpx;
  padding: 8rpx 22rpx; font-size: 24rpx; font-weight: 700;
  color: var(--accent-strong);
  background: var(--surface); border: var(--bw-thin) solid var(--accent);
  border-radius: var(--r-full); box-shadow: var(--shadow-hair);
}
.say-audio-press { transform: scale(0.985); background: var(--accent-soft); }
.say-audio-ic { font-size: 28rpx; }

/* ===================================================================== */
/* 课程专注布局（内部仍沿用 .game 类名以避免改动路由与会话判定）。 */
/* 分身/工具聊天无 skill/concept，gameSkin=false，不进此分支，样式完全不受影响。 */
/* ===================================================================== */
.page.game { background: var(--paper); }

/* 数字人陪学舞台：像一次面对面讲解，不再呈现游戏场景与角色对峙。 */
.lesson-stage {
  position: relative;
  flex: 0 0 auto;
  display: flex;
  align-items: stretch;
  min-height: 272rpx;
  margin: 14rpx 24rpx 4rpx;
  padding: 30rpx 24rpx 26rpx 30rpx;
  box-sizing: border-box;
  overflow: hidden;
  color: var(--ink);
  background: linear-gradient(118deg, #ffffff 0%, #f7f6fc 54%, #eff3fa 100%);
  border: var(--bw-thin) solid var(--border);
  border-radius: var(--r-2xl);
  box-shadow: var(--shadow-lift);
  transform: translateZ(0);
}
.lesson-stage-ambience { position: absolute; inset: 0; pointer-events: none; overflow: hidden; }
.mentor-glow {
  position: absolute;
  width: 330rpx; height: 330rpx;
  right: -70rpx; top: -48rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(201,195,235,.56) 0%, rgba(185,221,237,.24) 48%, transparent 72%);
}
.mentor-line { position: absolute; height: 1rpx; background: linear-gradient(90deg, transparent, rgba(79,74,139,.17), transparent); transform-origin: center; }
.mentor-line-a { width: 310rpx; right: -28rpx; top: 92rpx; transform: rotate(-18deg); }
.mentor-line-b { width: 260rpx; right: -42rpx; top: 150rpx; transform: rotate(16deg); }
.lesson-stage-copy {
  position: relative; z-index: 3;
  flex: 1 1 auto;
  min-width: 0;
  max-width: 410rpx;
  padding-top: 2rpx;
}
.lesson-stage-kicker { display: flex; align-items: center; gap: 11rpx; font-size: 20rpx; font-weight: 700; color: var(--accent-deep); letter-spacing: 1rpx; }
.lesson-live-dot {
  width: 10rpx; height: 10rpx;
  border-radius: 50%;
  background: var(--stage-accent);
  box-shadow: 0 0 0 7rpx rgba(119, 114, 200, 0.12);
}
.lesson-stage-title {
  display: -webkit-box;
  margin-top: 18rpx;
  overflow: hidden;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  font-size: 34rpx;
  line-height: 1.24;
  font-weight: 800;
  letter-spacing: -0.6rpx;
  color: var(--ink);
}
.lesson-stage-sub { margin-top: 12rpx; max-width: 350rpx; font-size: 22rpx; line-height: 1.5; color: var(--ink-2); }
.lesson-stage-actions { display: flex; align-items: center; flex-wrap: wrap; gap: 12rpx; max-width: 380rpx; margin-top: 22rpx; }
.mentor-voice, .lesson-stage-progress {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 9rpx;
  min-height: 52rpx;
  padding: 0 17rpx;
  box-sizing: border-box;
  border-radius: var(--r-md);
  font-size: 21rpx;
  font-weight: 700;
}
.mentor-voice { color: var(--on-accent); background: var(--accent-deep); }
.mentor-voice.playing { background: var(--accent-strong); }
.mentor-voice.paused { color: var(--accent-deep); background: var(--accent-soft); }
.mentor-mute {
  flex: 0 0 auto;
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  color: var(--ink-2);
  font-size: 24rpx;
  background: rgba(255,255,255,.82);
  border: var(--bw-thin) solid var(--border);
  border-radius: var(--r-md);
}
.mentor-mute.is-muted { color: var(--accent-deep); background: var(--accent-soft); border-color: rgba(119,114,200,.28); }
.lesson-stage-progress { color: var(--ink-2); background: rgba(255,255,255,.82); border: var(--bw-thin) solid var(--border); }
.lesson-stage-chevron { margin-left: 1rpx; color: var(--accent-deep); font-size: 28rpx; line-height: 1; }
.mentor-action-press { opacity: .82; transform: scale(.985); }
.mentor-voice-icon { display: flex; align-items: center; gap: 3rpx; width: 20rpx; height: 22rpx; }
.mentor-voice-icon text { width: 3rpx; height: 8rpx; border-radius: var(--r-full); background: currentColor; }
.mentor-voice-icon text:nth-child(2) { height: 16rpx; }
.mentor-voice-icon text:nth-child(3) { height: 11rpx; }
.mentor-voice.playing .mentor-voice-icon text { animation: mentorWave .72s ease-in-out infinite; }
.mentor-voice.playing .mentor-voice-icon text:nth-child(2) { animation-delay: .12s; }
.mentor-voice.playing .mentor-voice-icon text:nth-child(3) { animation-delay: .24s; }
.lesson-stage-person {
  position: absolute;
  z-index: 2;
  right: -12rpx;
  bottom: -88rpx;
  width: 292rpx;
  height: 390rpx;
  pointer-events: none;
  transform-origin: 50% 86%;
  animation: mentorBreathe 4.8s ease-in-out infinite;
}
.lesson-mentor-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
  transition: opacity .08s ease-out;
}
.lesson-mentor-img.is-visible { opacity: 1; }
.mentor-img-blink { transition-duration: .035s; }
.mentor-img-mouth { transition-duration: .025s; }
.mentor-speaking-ring { position: absolute; left: 50%; top: 60rpx; width: 180rpx; height: 180rpx; transform: translateX(-50%); border-radius: 50%; border: 1rpx solid rgba(119,114,200,.18); opacity: 0; }
.lesson-stage.mentor-phase-listening .lesson-live-dot { animation: mentorHear .52s var(--ease-out) both; }
.lesson-stage.mentor-phase-listening .lesson-stage-person { animation: mentorAcknowledge .62s var(--ease-out) both; }
.lesson-stage.is-thinking .lesson-live-dot { animation: mentorPulse 1.15s ease-in-out infinite; }
.lesson-stage.is-thinking .lesson-stage-person { animation: mentorListen 2.2s ease-in-out infinite; }
.lesson-stage.is-speaking .mentor-speaking-ring { animation: mentorRing 1.4s ease-out infinite; }
.lesson-stage.mentor-phase-speaking .lesson-stage-person { animation: mentorSpeakBody 3.4s ease-in-out infinite; }
.lesson-stage.mentor-phase-reassure .lesson-stage-person { animation: mentorReassure .9s var(--ease-out) both; }
.lesson-stage.mentor-motion-shift .lesson-stage-person { animation: mentorShift 2.4s ease-in-out both; }
.lesson-stage.feedback-right { animation: stageApprove 1.15s ease-out both; }
.lesson-stage.feedback-right .lesson-live-dot { background: #4f9d78; box-shadow: 0 0 0 7rpx rgba(79,157,120,.14); }
.lesson-stage.feedback-right .lesson-stage-kicker { color: #34775a; }
.lesson-stage.feedback-right .mentor-glow { animation: mentorGlowApprove 1.1s ease-out both; }
.lesson-stage.feedback-right .lesson-stage-person { animation: mentorNod .8s var(--ease-out) both; }
.lesson-stage.feedback-wrong { border-color: rgba(211,154,74,.28); }
.lesson-stage.feedback-wrong .lesson-live-dot { background: #d39a4a; box-shadow: 0 0 0 7rpx rgba(211,154,74,.12); }
.lesson-stage.feedback-wrong .lesson-stage-kicker { color: #93682f; }
@keyframes mentorBreathe { 0%, 100% { transform: translateY(0) scale(1); } 50% { transform: translateY(-3rpx) scale(1.004); } }
@keyframes mentorHear { 0% { transform: scale(.75); opacity: .45; } 60% { transform: scale(1.2); opacity: 1; } 100% { transform: scale(1); opacity: .9; } }
@keyframes mentorAcknowledge {
  0% { transform: translateY(0) rotate(0); }
  42% { transform: translateY(5rpx) rotate(-.55deg); }
  100% { transform: translateY(1rpx) rotate(0); }
}
@keyframes mentorListen { 0%, 100% { transform: translateY(0) rotate(0); } 50% { transform: translateY(2rpx) rotate(-.6deg); } }
@keyframes mentorSpeakBody {
  0%, 100% { transform: translateY(0) rotate(0); }
  36% { transform: translateY(-2rpx) rotate(.18deg); }
  70% { transform: translateY(1rpx) rotate(-.16deg); }
}
@keyframes mentorReassure {
  0% { transform: translateY(0) rotate(0); }
  45% { transform: translateY(2rpx) rotate(-.7deg); }
  100% { transform: translateY(0) rotate(-.2deg); }
}
@keyframes mentorShift {
  0%, 100% { transform: translate(0, 0) rotate(0); }
  35% { transform: translate(-3rpx, 2rpx) rotate(-.35deg); }
  72% { transform: translate(-1rpx, -1rpx) rotate(.18deg); }
}
@keyframes mentorPulse { 0%, 100% { opacity: .45; transform: scale(.86); } 50% { opacity: 1; transform: scale(1.08); } }
@keyframes mentorRing { 0% { opacity: .45; transform: translateX(-50%) scale(.86); } 100% { opacity: 0; transform: translateX(-50%) scale(1.32); } }
@keyframes mentorWave { 0%, 100% { transform: scaleY(.65); } 50% { transform: scaleY(1.15); } }
@keyframes stageApprove {
  0% { border-color: var(--border); box-shadow: var(--shadow-lift); }
  28% { border-color: rgba(79,157,120,.46); box-shadow: 0 18rpx 54rpx rgba(79,157,120,.15); }
  100% { border-color: rgba(79,157,120,.24); box-shadow: var(--shadow-lift); }
}
@keyframes mentorGlowApprove {
  0% { opacity: .72; transform: scale(.92); }
  38% { opacity: 1; transform: scale(1.1); background: radial-gradient(circle, rgba(167,221,191,.62) 0%, rgba(185,221,237,.26) 48%, transparent 72%); }
  100% { opacity: .84; transform: scale(1); }
}
@keyframes mentorNod {
  0%, 100% { transform: translateY(0) rotate(0); }
  32% { transform: translateY(7rpx) rotate(-1deg); }
  62% { transform: translateY(1rpx) rotate(.35deg); }
}

/* 单张学习卡：当前任务、选择和反馈在原位更新。 */
.lesson-card {
  position: relative;
  padding: 30rpx 30rpx 32rpx;
  background: var(--surface);
  border: var(--bw-thin) solid var(--border);
  border-radius: var(--r-xl);
  box-shadow: var(--shadow-card);
  animation: cardRise 0.28s var(--ease-out) both;
}
.lesson-card.is-pending { border-color: rgba(119, 114, 200, 0.28); }
.lesson-card.feedback-right { border-color: rgba(79,157,120,.26); }
.lesson-card.feedback-wrong { border-color: rgba(211,154,74,.22); }
.lesson-card-eyebrow { font-size: 21rpx; font-weight: 700; color: var(--accent-deep); letter-spacing: 1rpx; }
.lesson-choice {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-top: 20rpx;
  padding: 16rpx 18rpx;
  background: var(--accent-soft);
  border-radius: var(--r-md);
}
.lesson-choice-label { flex: 0 0 auto; font-size: 21rpx; color: var(--accent-deep); }
.lesson-choice-text { flex: 1 1 auto; font-size: 25rpx; font-weight: 650; color: var(--accent-ink); line-height: 1.45; }
.lesson-choice.feedback-right { background: rgba(79,157,120,.10); box-shadow: inset 0 0 0 1rpx rgba(79,157,120,.24); animation: choiceConfirm .75s var(--ease-out) both; }
.lesson-choice.feedback-right .lesson-choice-label { color: #34775a; font-weight: 800; }
.lesson-choice.feedback-right .lesson-choice-text { color: #285e47; }
.lesson-choice.feedback-wrong { background: rgba(211,154,74,.09); box-shadow: inset 0 0 0 1rpx rgba(211,154,74,.18); }
.lesson-choice.feedback-wrong .lesson-choice-label { color: #93682f; }
@keyframes choiceConfirm { 0% { transform: scale(.985); } 45% { transform: scale(1.008); } 100% { transform: scale(1); } }
.lesson-content { margin-top: 22rpx; font-size: 29rpx; color: var(--ink); line-height: 1.72; white-space: pre-wrap; word-break: break-word; }
.lesson-empty { color: var(--sub); }
.lesson-audio {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 22rpx;
  padding: 10rpx 18rpx;
  border-radius: var(--r-md);
  background: var(--accent-soft);
  color: var(--accent-deep);
  font-size: 23rpx;
  font-weight: 700;
}
.lesson-thinking { display: flex; gap: 8rpx; margin-top: 22rpx; }
.lesson-thinking text { width: 9rpx; height: 9rpx; border-radius: 50%; background: var(--accent); animation: thinkDot 1s ease-in-out infinite; }
.lesson-thinking text:nth-child(2) { animation-delay: 0.14s; }
.lesson-thinking text:nth-child(3) { animation-delay: 0.28s; }
@keyframes thinkDot { 0%, 100% { opacity: 0.28; transform: translateY(0); } 50% { opacity: 1; transform: translateY(-5rpx); } }
.lesson-instruction { padding: 22rpx 4rpx 0; text-align: center; font-size: 23rpx; color: var(--sub); }

/* 兜底重开当前关：复原出的旧卡无点选项时的唯一出口，做成温和的次级动作，不抢主操作台。 */
.lesson-restart {
  display: flex; align-items: center; justify-content: center; gap: 10rpx;
  margin: 28rpx 8rpx 0; padding: 22rpx;
  background: var(--surface); border: var(--bw-thin) solid var(--border);
  border-radius: var(--r-lg); box-shadow: var(--shadow-card);
  color: var(--accent-deep); font-size: 26rpx; font-weight: 700;
  transition: transform 0.1s var(--ease), box-shadow 0.1s var(--ease);
}
.lesson-restart-ic { font-size: 30rpx; color: var(--accent); font-weight: 800; }

/* 学习选项是本屏主操作台：纵向、等权、整行可点。 */
.game-options {
  flex-direction: column;
  flex-wrap: nowrap;
  gap: 12rpx;
  padding: 16rpx 28rpx calc(18rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid var(--line);
}
.game-options .opt-chip {
  width: 100%;
  min-height: 78rpx;
  padding: 16rpx 20rpx;
  border-radius: var(--r-md);
  box-shadow: none;
  line-height: 1.45;
}
.game-options .opt-tx { flex: 1 1 auto; }
.opt-index {
  flex: 0 0 auto;
  width: 42rpx;
  height: 42rpx;
  margin-right: 16rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: var(--fill);
  color: var(--ink-2);
  font-size: 21rpx;
  font-weight: 700;
}

/* 固定舞台：吉祥物常驻顶栏下方，卡片从其下滑过（挂机游戏的「场景位」） */
.game-stage { position: relative; flex: 0 0 auto; display: flex; flex-direction: column; align-items: center; padding: 16rpx 0 20rpx; background: var(--surface); }
/* 历史：缩成右上小胶囊（替代原 topbar 的「历史」按钮） */
.gs-hist { position: absolute; top: 14rpx; right: 24rpx; padding: 8rpx 20rpx; font-size: 22rpx; color: var(--ink-2); background: var(--fill); border: var(--bw-thin) solid var(--border); border-radius: var(--r-full); }
.gs-hist:active { transform: scale(0.97); }
.gs-guide { position: absolute; top: 14rpx; left: 24rpx; z-index: 8; padding: 8rpx 18rpx; font-size: 21rpx; font-weight: 700; color: var(--accent-ink); background: var(--pop-mint); border-radius: var(--r-full); }
/* 额度：一行小灰字，点了才去开通（克制版会员入口，非会员才出现） */
.gs-quota { margin-top: 8rpx; font-size: 21rpx; color: var(--faint); }
.gs-quota:active { color: var(--accent-strong); }
.gs-frame {
  width: 148rpx; height: 166rpx;
  border-radius: 74rpx 74rpx 22rpx 22rpx;
  border: 6rpx solid var(--surface);
  box-shadow: var(--shadow-card);
  display: flex; align-items: center; justify-content: center;
  animation: aBreath 4.5s ease-in-out infinite;
}
.gs-frame.busy { animation-duration: 1.6s; }
.gs-emoji { font-size: 76rpx; line-height: 1; }
.gs-tag {
  margin-top: -14rpx; padding: 5rpx 24rpx;
  background: var(--pop-butter); color: var(--pop-butter-ink);
  border-radius: var(--r-full); font-size: 23rpx; font-weight: 800;
  box-shadow: var(--shadow-hair);
}

/* 消息流里那份会滚走的画框，在游戏皮里由固定舞台替代——隐掉 */
.game .msgs .astage { display: none; }

/* 事件卡流：助手消息 = 整幅叙事卡（对齐截图「第N天」卡），左侧课程色描边，逐张上浮 */
.game .msgs { padding-top: 18rpx; }
.game .row-assistant { margin-bottom: 20rpx; }
.game .bubble-assistant {
  max-width: 100%; width: 100%; box-sizing: border-box;
  padding: 26rpx 28rpx;
  border-radius: var(--r-lg);
  border: var(--bw-thin) solid var(--border);
  border-left: 8rpx solid var(--accent);
  box-shadow: var(--shadow-card);
  animation: cardRise 0.34s var(--ease-spring) both;
}
.game .bubble-assistant.typing { animation: none; }
/* 我的选择：右侧小胶囊，读作「你说了这句」，不与事件卡抢戏 */
.game .bubble-user { max-width: 72%; font-size: 26rpx; padding: 14rpx 22rpx; opacity: 0.94; }
@keyframes cardRise { 0% { opacity: 0; transform: translateY(24rpx); } 100% { opacity: 1; transform: translateY(0); } }

/* 底部点选：游戏皮里作为主操作台，与卡片流之间一道分隔，留白更足 */
.game .opts { padding: 18rpx 24rpx 10rpx; border-top: var(--bw-thin) solid var(--border); }
/* 全站无输入栏：点选气泡即底栏，补齐 iPhone 底部安全区（在 .opts 之后，覆盖其 padding-bottom） */
.opts-tail { padding-bottom: calc(10rpx + env(safe-area-inset-bottom)); }

/* —— 产出条（真开口·真动笔）：Free 节点的底栏，打字 + 按住说话 + 欠着跳过 —— */
.produce {
  flex: 0 0 auto; padding: 18rpx 24rpx 10rpx;
  background: var(--surface); border-top: var(--bw-thin) solid var(--border);
}
.produce-row { display: flex; align-items: flex-end; gap: 14rpx; }
.produce-input {
  flex: 1 1 auto; min-height: 68rpx; max-height: 220rpx;
  padding: 16rpx 22rpx; box-sizing: border-box;
  background: var(--fill); border: var(--bw-thin) solid var(--border);
  border-radius: var(--r-lg); font-size: 28rpx; line-height: 1.5; color: var(--ink);
}
.produce-mic {
  flex: 0 0 auto; width: 84rpx; height: 84rpx; border-radius: var(--r-full);
  display: flex; align-items: center; justify-content: center; font-size: 38rpx;
  background: var(--surface); border: var(--bw-thin) solid var(--border);
  box-shadow: var(--shadow-card);
}
.produce-mic.recording {
  background: var(--accent); border-color: var(--accent);
  animation: micPulse 1s ease-in-out infinite;
}
@keyframes micPulse {
  0%, 100% { transform: scale(1); }
  50%      { transform: scale(1.08); }
}
.produce-send {
  flex: 0 0 auto; padding: 20rpx 30rpx; border-radius: var(--r-full);
  background: var(--accent); color: #fff; font-size: 26rpx; font-weight: 800;
}
.produce-send.disabled { opacity: 0.4; }
.produce-send:active { transform: scale(0.97); }
.produce-skip {
  margin-top: 14rpx; text-align: center;
  font-size: 22rpx; color: var(--faint); padding: 8rpx 0;
}


/* —— 关卡卡片抽屉（自 learn-map 搬入；复用本页 .drawer-mask 贴底遮罩）—— */
.lc-drawer {
  position: relative; width: 100%;
  background: var(--surface);
  border-radius: var(--r-3xl) var(--r-3xl) 0 0;
  padding: 20rpx 40rpx calc(env(safe-area-inset-bottom) + 40rpx);
  box-shadow: var(--shadow-pop);
  animation: lcUp 0.26s var(--ease-out);
}
@keyframes lcUp { from { transform: translateY(40%); opacity: 0.4; } to { transform: translateY(0); opacity: 1; } }
.lc-grip { width: 72rpx; height: 8rpx; border-radius: var(--r-full); background: var(--border); margin: 0 auto 28rpx; }
.lc-state {
  display: inline-block; padding: 6rpx 20rpx; border-radius: var(--r-full);
  font-size: 22rpx; font-weight: 800; background: var(--accent-soft); color: var(--accent-ink);
}
.lc-state.mastered { background: var(--gold); color: #574825; }
.lc-state.locked { background: var(--fill); color: var(--sub); }
.lc-flavor {
  position: absolute; top: 56rpx; right: 40rpx;
  padding: 6rpx 20rpx; border-radius: var(--r-full); font-size: 22rpx; font-weight: 800;
}
.lc-flavor.current { background: var(--pop-butter); color: var(--pop-butter-ink); }
.lc-flavor.available { background: var(--pop-sky); color: var(--pop-sky-ink); }
.lc-flavor.lit { background: var(--pop-mint); color: var(--pop-mint-ink); }
.lc-flavor.mastered { background: var(--gold); color: #574825; }
.lc-flavor.locked { background: var(--fill); color: var(--sub); }
.lc-name { margin-top: 16rpx; font-size: 44rpx; font-weight: 800; color: var(--ink); }
.lc-blurb { margin-top: 8rpx; font-size: 28rpx; color: var(--ink-2); }
.lc-report {
  margin-top: 16rpx; display: inline-block; padding: 8rpx 20rpx; border-radius: var(--r-full);
  background: var(--pop-mint); color: var(--pop-mint-ink); font-size: 24rpx; font-weight: 700;
}
.lc-hook {
  margin-top: 24rpx; padding: 24rpx 28rpx;
  background: var(--surface-sunken); border-radius: var(--r-md);
  font-size: 26rpx; color: var(--ink-2); line-height: 1.7;
}
.lc-go { margin-top: 32rpx; font-size: 32rpx; }
