page { background: var(--bg); height: 100%; }
.page { display: flex; flex-direction: column; height: 100vh; }

.topbar { display: flex; align-items: center; padding: 18rpx 28rpx; background: var(--surface); border-bottom: var(--bw-thin) solid var(--border); flex: 0 0 auto; }
.tb-ic { width: 64rpx; height: 64rpx; border-radius: var(--r-md); flex: 0 0 auto; display: flex; align-items: center; justify-content: center; font-size: 34rpx; }
.tb-mid { flex: 1 1 auto; min-width: 0; margin-left: 18rpx; }
.tb-name { font-size: 30rpx; font-weight: 700; color: var(--ink); }
.tb-quota { font-size: 23rpx; color: var(--sub); margin-top: 2rpx; }
.tb-buy { flex: 0 0 auto; padding: 12rpx 28rpx; background: var(--accent); color: var(--on-accent); font-size: 25rpx; font-weight: 700; border: none; border-radius: var(--r-full); box-shadow: 0 4rpx 0 var(--accent-strong); transition: transform 0.1s var(--ease), box-shadow 0.1s var(--ease); }
.tb-buy:active { transform: translateY(4rpx); box-shadow: none; }
.tb-act { flex: 0 0 auto; margin-left: 12rpx; padding: 10rpx 22rpx; background: var(--fill); color: var(--ink-2); font-size: 24rpx; border: var(--bw-thin) solid var(--border); border-radius: var(--r-full); transition: transform 0.1s var(--ease); }
.tb-act:active { transform: translateY(4rpx); box-shadow: none; }

/* 历史会话抽屉 */
.drawer-mask { position: fixed; inset: 0; background: var(--scrim-soft); z-index: 50; display: flex; flex-direction: column; justify-content: flex-end; }
.drawer { background: var(--surface); border-radius: var(--r-3xl) var(--r-3xl) 0 0; max-height: 76vh; display: flex; flex-direction: column; padding: 0 28rpx calc(24rpx + env(safe-area-inset-bottom)); box-shadow: var(--shadow-pop); }
.drawer-grip { width: 64rpx; height: 8rpx; border-radius: 8rpx; background: var(--border); margin: 16rpx auto 8rpx; }
.drawer-title { font-size: 30rpx; font-weight: 700; color: var(--ink); text-align: center; padding: 8rpx 0 16rpx; }
.drawer-new { text-align: center; color: var(--accent-strong); font-size: 28rpx; font-weight: 700; padding: 20rpx; border: 2rpx dashed rgba(24, 182, 144, 0.4); border-radius: var(--r-md); margin-bottom: 16rpx; }
.drawer-new:active { opacity: 0.8; }
.drawer-list { flex: 1 1 auto; min-height: 0; }
.drawer-empty { text-align: center; color: var(--faint); font-size: 26rpx; padding: 60rpx 0; }
.drawer-item { padding: 20rpx 22rpx; border-radius: var(--r-md); margin-bottom: 12rpx; background: var(--fill); border: var(--bw-thin) solid transparent; }
.drawer-item.active { background: var(--accent-soft); border-color: var(--accent); }
.drawer-item:active { opacity: 0.85; }
.di-title { font-size: 28rpx; font-weight: 700; color: var(--ink); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.di-sub { font-size: 24rpx; color: var(--sub); margin-top: 6rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.di-time { font-size: 22rpx; color: var(--faint); margin-top: 6rpx; }

.msgs { flex: 1 1 auto; min-height: 0; padding: 24rpx 28rpx 0; box-sizing: border-box; }

/* —— 角色画框（消息流顶部，随对话滚走）：糖果拱窗 + 胶囊名牌 —— */
.astage { display: flex; flex-direction: column; align-items: center; padding: 24rpx 0 30rpx; }
.astage-frame {
  width: 168rpx; height: 188rpx;
  border-radius: 84rpx 84rpx 24rpx 24rpx;
  border: 6rpx solid var(--surface);
  background: linear-gradient(160deg, var(--sky-1), var(--sky-2));
  box-shadow: var(--shadow-card);
  display: flex; align-items: center; justify-content: center;
  animation: aBreath 4.5s ease-in-out infinite;
}
.astage-emoji { font-size: 84rpx; line-height: 1; }
@keyframes aBreath { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.03); } }
.astage-frame.busy { animation-duration: 1.6s; }
.astage-tag {
  margin-top: -16rpx;
  padding: 6rpx 24rpx;
  background: var(--pop-butter); color: var(--pop-butter-ink);
  border: none;
  border-radius: var(--r-full);
  font-size: 24rpx; font-weight: 800;
  box-shadow: var(--shadow-hair);
}

.row { display: flex; margin-bottom: 22rpx; }
.row-user { justify-content: flex-end; }
.row-assistant { justify-content: flex-start; }
.bubble { max-width: 76%; padding: 20rpx 24rpx; font-size: 29rpx; line-height: 1.55; border-radius: var(--r-lg); word-break: break-word; white-space: pre-wrap; }
.bubble-assistant { background: var(--surface); color: var(--ink); border-bottom-left-radius: 8rpx; border: var(--bw-thin) solid var(--border); box-shadow: var(--shadow-hair); }
.bubble-user { background: var(--accent); color: var(--on-accent); border-bottom-right-radius: 8rpx; box-shadow: 0 3rpx 0 var(--accent-strong); }
.typing { color: var(--faint); }
.msgs-pad { height: 24rpx; }

/* —— 加载骨架气泡（复用 app.wxss .skel 的微光；无网也先占位，不白屏）—— */
.skel-bubble { height: 92rpx; width: 58%; border-radius: var(--r-lg); border-bottom-left-radius: 8rpx; }
.skel-bubble.sk-short { width: 38%; height: 76rpx; }
.skel-bubble.sk-long { width: 70%; height: 148rpx; }
.skel-bubble.sk-mine { width: 46%; height: 84rpx; border-bottom-left-radius: var(--r-lg); border-bottom-right-radius: 8rpx; }

/* —— 加载失败：页内重试条（糖果白卡 + 底唇，点按下沉）—— */
.chat-retry {
  display: flex; align-items: center; justify-content: center; gap: 12rpx;
  margin: 80rpx 40rpx 0; padding: 28rpx;
  background: var(--surface); border: var(--bw-thin) solid var(--border);
  border-radius: var(--r-lg); box-shadow: var(--shadow-card);
  color: var(--ink-2); font-size: 28rpx; font-weight: 600;
  transition: transform 0.1s var(--ease), box-shadow 0.1s var(--ease);
}
.chat-retry-ic { font-size: 34rpx; color: var(--accent); font-weight: 800; }

/* 三维段位面板（升级感）：果冻进度条 */
.skill { flex: 0 0 auto; background: var(--surface); padding: 16rpx 28rpx 20rpx; border-top: var(--bw-thin) solid var(--border); }
.sk-head { display: flex; align-items: center; gap: 16rpx; margin-bottom: 14rpx; }
.sk-tier { display: flex; align-items: baseline; gap: 8rpx; flex: 0 0 auto; }
.sk-lv { font-size: 22rpx; font-weight: 800; color: var(--accent-strong); letter-spacing: 0.5rpx; }
.sk-name { font-size: 28rpx; font-weight: 800; color: var(--ink); }
.sk-hint { font-size: 22rpx; color: var(--accent-strong); flex: 1 1 auto; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.sk-note { font-size: 22rpx; color: var(--sub); flex: 1 1 auto; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.sk-bars { display: flex; gap: 22rpx; }
.sk-bar { flex: 1 1 0; display: flex; align-items: center; gap: 8rpx; }
.sk-bl { font-size: 20rpx; color: var(--faint); flex: 0 0 auto; }
.sk-track { flex: 1 1 auto; height: 18rpx; border-radius: var(--r-full); background: var(--fill); overflow: hidden; }
.sk-fill { position: relative; height: 100%; border-radius: var(--r-full); background: var(--accent); transition: width 0.6s cubic-bezier(0.22, 1, 0.36, 1); }
.sk-fill::after { content: ''; position: absolute; left: 8rpx; right: 8rpx; top: 3rpx; height: 5rpx; border-radius: var(--r-full); background: rgba(255, 255, 255, 0.35); }
.sk-bv { font-size: 20rpx; color: var(--ink-2); flex: 0 0 auto; width: 36rpx; text-align: right; }

/* 概念型 Agent：点亮进度条（果冻） */
.cprog { flex: 0 0 auto; background: var(--surface); padding: 16rpx 28rpx 20rpx; border-top: var(--bw-thin) solid var(--border); }
.cp-head { display: flex; align-items: baseline; gap: 10rpx; margin-bottom: 14rpx; }
.cp-stat { flex: 1 1 auto; min-width: 0; display: flex; align-items: baseline; gap: 6rpx; }
.cp-tier { font-size: 24rpx; font-weight: 800; color: var(--ink); }
.cp-num { font-size: 34rpx; font-weight: 800; color: var(--accent); margin-left: 4rpx; }
.cp-tot { font-size: 24rpx; font-weight: 600; color: var(--faint); }
.cp-all { font-size: 22rpx; color: var(--sub); margin-left: 4rpx; }
.cp-note { flex: 0 0 auto; font-size: 22rpx; color: var(--accent-strong); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 260rpx; }
/* 复习挑战徽章：奶油黄糖果胶囊（检索练习入口，有到期概念时替换右侧提示） */
.cp-review {
  flex: 0 0 auto; font-size: 22rpx; font-weight: 800;
  padding: 4rpx 18rpx;
  background: var(--pop-butter); color: var(--pop-butter-ink);
  border: none; border-radius: var(--r-full);
  box-shadow: 0 4rpx 0 var(--gold-strong);
  transition: transform 0.1s var(--ease), box-shadow 0.1s var(--ease);
}
.cp-review:active { transform: translateY(4rpx); box-shadow: none; }

/* 提醒承诺条：奶油黄糖果条（课后邀请「明天叫我」，点整条即弹授权） */
.remind-bar {
  flex: 0 0 auto;
  display: flex; align-items: center; gap: 12rpx;
  margin: 12rpx 24rpx 0;
  padding: 18rpx 24rpx;
  background: var(--pop-butter); color: var(--pop-butter-ink);
  border: none;
  border-radius: var(--r-md);
  font-size: 26rpx; font-weight: 700;
  box-shadow: 0 5rpx 0 var(--gold-strong);
  animation: barIn 0.25s var(--ease) both;
  transition: transform 0.1s var(--ease), box-shadow 0.1s var(--ease);
}
.remind-bar:active { transform: translateY(4rpx); box-shadow: none; }
.remind-bar.done { background: var(--accent-soft); color: var(--accent-ink); box-shadow: 0 5rpx 0 #b9e6d6; }
.remind-text { flex: 1; }
.remind-yes {
  flex: 0 0 auto; font-size: 24rpx; font-weight: 800;
  padding: 4rpx 20rpx;
  background: var(--surface); color: var(--pop-butter-ink);
  border-radius: var(--r-full);
}
@keyframes barIn { from { opacity: 0; transform: translateY(8rpx); } to { opacity: 1; transform: translateY(0); } }
.cp-track { height: 20rpx; border-radius: var(--r-full); background: var(--fill); overflow: hidden; }
.cp-fill { position: relative; height: 100%; border-radius: var(--r-full); background: var(--accent); transition: width 0.6s cubic-bezier(0.22, 1, 0.36, 1); }
.cp-fill::after { content: ''; position: absolute; left: 8rpx; right: 8rpx; top: 4rpx; height: 6rpx; border-radius: var(--r-full); background: rgba(255, 255, 255, 0.35); }

/* 概念地图：按主题的概念芯片，亮度区分掌握档位（lv2 = 金冠） */
.cm-theme { margin-bottom: 24rpx; }
.cm-th-name { font-size: 24rpx; font-weight: 800; color: var(--ink); margin-bottom: 12rpx; }
.cm-grid { display: flex; flex-wrap: wrap; gap: 12rpx; }
.cm-chip { font-size: 22rpx; padding: 8rpx 18rpx; border-radius: var(--r-full); border: var(--bw-thin) solid var(--border); color: var(--faint); background: var(--fill-pressed); }
.cm-chip.lv1 { color: var(--accent-strong); border-color: var(--accent); background: var(--accent-soft); font-weight: 700; }
.cm-chip.lv2 { color: #7a5c00; border-color: transparent; background: var(--gold); font-weight: 800; box-shadow: 0 3rpx 0 var(--gold-strong); }

/* 庆祝浮层：多邻国式全屏彩带 + 大字弹簧 */
.celebrate { position: fixed; inset: 0; z-index: 60; display: flex; align-items: center; justify-content: center; background: var(--glass-light); animation: celebFade 0.25s ease; pointer-events: none; overflow: hidden; }
.celeb-card { position: relative; z-index: 2; background: var(--surface); border-radius: var(--r-2xl); padding: 48rpx 64rpx; text-align: center; box-shadow: var(--shadow-pop); animation: celebPop 0.42s var(--ease-spring); }
.celeb-spark { font-size: 72rpx; line-height: 1; animation: sparkBounce 0.6s var(--ease-spring); }
.celeb-up { display: inline-block; font-size: 24rpx; font-weight: 800; color: #7a5c00; letter-spacing: 4rpx; margin-top: 12rpx; padding: 4rpx 18rpx; background: var(--gold); border-radius: var(--r-full); box-shadow: 0 3rpx 0 var(--gold-strong); }
.celeb-name { font-size: 56rpx; font-weight: 800; color: var(--ink); margin-top: 8rpx; animation: namePop 0.5s var(--ease-spring) 0.08s both; }
.celeb-sub { font-size: 24rpx; color: var(--sub); margin-top: 12rpx; }
@keyframes celebFade { from { opacity: 0; } to { opacity: 1; } }
@keyframes celebPop { 0% { opacity: 0; transform: scale(0.7); } 60% { opacity: 1; } 100% { opacity: 1; transform: scale(1); } }
@keyframes sparkBounce { 0% { transform: scale(0.4); } 60% { transform: scale(1.25); } 100% { transform: scale(1); } }
@keyframes namePop { 0% { opacity: 0; transform: scale(0.8); } 100% { opacity: 1; transform: scale(1); } }

/* 彩带：12 枚糖纸小方块，错峰下落一次（与 2.4s 自动收起节拍吻合） */
.confetti { position: absolute; inset: 0; z-index: 1; pointer-events: none; }
.cf { position: absolute; top: 0; width: 14rpx; height: 22rpx; border-radius: 4rpx; animation: cfFall 1.6s ease-in both; }
.cf-1  { left: 6%;  background: var(--pop-butter); animation-delay: 0s; }
.cf-2  { left: 14%; background: var(--cand-blue);  animation-delay: 0.22s; }
.cf-3  { left: 24%; background: var(--pop-coral);  animation-delay: 0.10s; }
.cf-4  { left: 32%; background: var(--accent);     animation-delay: 0.34s; }
.cf-5  { left: 41%; background: var(--pop-lilac);  animation-delay: 0.05s; }
.cf-6  { left: 49%; background: var(--gold);       animation-delay: 0.28s; }
.cf-7  { left: 57%; background: var(--cand-blue);  animation-delay: 0.16s; }
.cf-8  { left: 66%; background: var(--pop-coral);  animation-delay: 0.42s; }
.cf-9  { left: 74%; background: var(--accent);     animation-delay: 0.08s; }
.cf-10 { left: 82%; background: var(--pop-butter); animation-delay: 0.30s; }
.cf-11 { left: 90%; background: var(--pop-lilac);  animation-delay: 0.20s; }
.cf-12 { left: 96%; background: var(--gold);       animation-delay: 0.46s; }
@keyframes cfFall {
  0% { transform: translateY(-10vh) rotate(0deg); opacity: 1; }
  80% { opacity: 1; }
  100% { transform: translateY(110vh) rotate(540deg); opacity: 0; }
}

/* 本轮可点选项：糖果风白底气泡 + 3D 底唇，点选即答（点选为主、输入兜底） */
.opts { flex: 0 0 auto; display: flex; flex-wrap: wrap; gap: 14rpx; padding: 14rpx 24rpx 6rpx; background: var(--surface); }
.opt-chip {
  padding: 14rpx 26rpx; font-size: 27rpx; color: var(--ink);
  background: var(--surface); border: var(--bw-thin) solid var(--border);
  border-radius: var(--r-full); box-shadow: 0 4rpx 0 var(--border);
  transition: transform 0.1s var(--ease), box-shadow 0.1s var(--ease);
}
.opt-chip:active { transform: translateY(4rpx); box-shadow: none; border-color: var(--accent); color: var(--accent); }

.composer { flex: 0 0 auto; display: flex; align-items: center; gap: 16rpx; padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom)); background: var(--surface); border-top: var(--bw-thin) solid var(--border); }
.cp-input { flex: 1 1 auto; min-width: 0; background: var(--surface-sunken); border: var(--bw-thin) solid var(--border); border-radius: var(--r-full); padding: 18rpx 28rpx; font-size: 29rpx; }
/* 语音麦克风（产出型三门课）：按住说，松开转写即发。样式承 onboarding 的 ob-mic。 */
.cp-mic { flex: 0 0 auto; width: 72rpx; height: 72rpx; border-radius: 50%; background: var(--surface-sunken); border: var(--bw-thin) solid var(--border); display: flex; align-items: center; justify-content: center; transition: transform 0.1s var(--ease); }
.cp-mic.on { background: var(--accent-soft); border-color: var(--accent); transform: scale(1.08); }
.cp-mic-i { position: relative; width: 20rpx; height: 30rpx; border-radius: 100rpx; background: var(--ink-2); }
.cp-mic.on .cp-mic-i { background: var(--accent); }
.cp-mic-i::after { content: ''; position: absolute; left: 50%; bottom: -14rpx; transform: translateX(-50%); width: 28rpx; height: 14rpx; border: 3rpx solid currentColor; border-top: none; border-radius: 0 0 28rpx 28rpx; color: var(--ink-2); }
.cp-mic.on .cp-mic-i::after { color: var(--accent); }
.cp-send { flex: 0 0 auto; background: var(--accent); color: var(--on-accent); font-size: 28rpx; font-weight: 800; border: none; border-radius: var(--r-full); padding: 0 36rpx; height: 72rpx; line-height: 72rpx; box-shadow: 0 5rpx 0 var(--accent-strong); transition: transform 0.1s var(--ease), box-shadow 0.1s var(--ease); }
.cp-send:active { transform: translateY(5rpx); box-shadow: none; }
.cp-send[disabled] { background: var(--accent); opacity: 0.35; color: var(--on-accent); box-shadow: none; }
.cp-send::after { border: none; }
