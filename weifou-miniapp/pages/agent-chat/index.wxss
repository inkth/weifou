page { background: var(--bg); height: 100%; }
.page { display: flex; flex-direction: column; height: 100vh; }

.topbar { display: flex; align-items: center; padding: 18rpx 28rpx; background: var(--surface); border-bottom: var(--bw-thin) solid var(--ink); flex: 0 0 auto; }
.tb-ic { width: 64rpx; height: 64rpx; border-radius: var(--r-md); flex: 0 0 auto; display: flex; align-items: center; justify-content: center; font-size: 34rpx; }
.tb-mid { flex: 1 1 auto; min-width: 0; margin-left: 18rpx; }
.tb-name { font-size: 30rpx; font-weight: 600; color: var(--ink); }
.tb-quota { font-size: 23rpx; color: var(--sub); margin-top: 2rpx; }
.tb-buy { flex: 0 0 auto; padding: 12rpx 28rpx; background: var(--accent); color: var(--on-accent); font-size: 25rpx; font-weight: 600; border: var(--bw-thin) solid var(--ink); border-radius: var(--r-full); box-shadow: var(--shadow-hair); transition: transform 0.12s var(--ease), box-shadow 0.12s var(--ease); }
.tb-buy:active { transform: translate(4rpx, 4rpx); box-shadow: 0 0 0 var(--ink); }
.tb-act { flex: 0 0 auto; margin-left: 12rpx; padding: 10rpx 22rpx; background: var(--fill); color: var(--ink-2); font-size: 24rpx; border: var(--bw-thin) solid var(--ink); border-radius: var(--r-full); transition: transform 0.12s var(--ease); }
.tb-act:active { transform: translate(4rpx, 4rpx); box-shadow: none; }

/* 历史会话抽屉 */
.drawer-mask { position: fixed; inset: 0; background: rgba(0, 0, 0, 0.4); z-index: 50; display: flex; flex-direction: column; justify-content: flex-end; }
.drawer { background: var(--surface); border: var(--bw) solid var(--ink); border-bottom: none; border-radius: 28rpx 28rpx 0 0; max-height: 76vh; display: flex; flex-direction: column; padding: 0 28rpx calc(24rpx + env(safe-area-inset-bottom)); box-shadow: var(--shadow-pop); }
.drawer-grip { width: 64rpx; height: 8rpx; border-radius: 8rpx; background: var(--border); margin: 16rpx auto 8rpx; }
.drawer-title { font-size: 30rpx; font-weight: 600; color: var(--ink); text-align: center; padding: 8rpx 0 16rpx; }
.drawer-new { text-align: center; color: var(--accent-strong); font-size: 28rpx; font-weight: 600; padding: 20rpx; border: 2rpx dashed rgba(24, 182, 144, 0.4); border-radius: 18rpx; margin-bottom: 16rpx; }
.drawer-new:active { opacity: 0.8; }
.drawer-list { flex: 1 1 auto; min-height: 0; }
.drawer-empty { text-align: center; color: var(--faint); font-size: 26rpx; padding: 60rpx 0; }
.drawer-item { padding: 20rpx 22rpx; border-radius: 18rpx; margin-bottom: 12rpx; background: var(--fill); border: var(--bw-thin) solid transparent; }
.drawer-item.active { background: var(--accent-soft); border-color: var(--ink); }
.drawer-item:active { opacity: 0.85; }
.di-title { font-size: 28rpx; font-weight: 600; color: var(--ink); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.di-sub { font-size: 24rpx; color: var(--sub); margin-top: 6rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.di-time { font-size: 22rpx; color: var(--faint); margin-top: 6rpx; }

.msgs { flex: 1 1 auto; min-height: 0; padding: 24rpx 28rpx 0; box-sizing: border-box; }

/* —— 角色画框（消息流顶部，随对话滚走）：新粗野拱窗 + 贴纸名牌 —— */
.astage { display: flex; flex-direction: column; align-items: center; padding: 24rpx 0 30rpx; }
.astage-frame {
  width: 168rpx; height: 188rpx;
  border-radius: 84rpx 84rpx 24rpx 24rpx;
  border: var(--bw) solid var(--ink);
  box-shadow: var(--shadow-card);
  display: flex; align-items: center; justify-content: center;
  animation: aBreath 4.5s ease-in-out infinite;
}
.astage-emoji { font-size: 84rpx; line-height: 1; }
@keyframes aBreath { 0%, 100% { transform: scale(1) rotate(0deg); } 50% { transform: scale(1.03) rotate(1deg); } }
.astage-frame.busy { animation-duration: 1.6s; }
.astage-tag {
  margin-top: -16rpx;
  padding: 6rpx 24rpx;
  background: var(--pop-butter); color: var(--pop-butter-ink);
  border: var(--bw-thin) solid var(--ink);
  border-radius: var(--r-full);
  font-size: 24rpx; font-weight: 700;
  transform: rotate(-3deg);
  box-shadow: var(--shadow-hair);
}

.row { display: flex; margin-bottom: 22rpx; }
.row-user { justify-content: flex-end; }
.row-assistant { justify-content: flex-start; }
.bubble { max-width: 76%; padding: 20rpx 24rpx; font-size: 29rpx; line-height: 1.55; border-radius: 22rpx; word-break: break-word; white-space: pre-wrap; }
.bubble-assistant { background: var(--surface); color: var(--ink); border-bottom-left-radius: 8rpx; border: var(--bw-thin) solid var(--ink); box-shadow: var(--shadow-hair); }
.bubble-user { background: var(--accent); color: var(--on-accent); border: var(--bw-thin) solid var(--ink); border-bottom-right-radius: 8rpx; }
.typing { color: var(--faint); }
.msgs-pad { height: 24rpx; }

/* 三维段位面板（升级感） */
.skill { flex: 0 0 auto; background: var(--surface); padding: 16rpx 28rpx 20rpx; border-top: var(--bw-thin) solid var(--ink); }
.sk-head { display: flex; align-items: center; gap: 16rpx; margin-bottom: 14rpx; }
.sk-tier { display: flex; align-items: baseline; gap: 8rpx; flex: 0 0 auto; }
.sk-lv { font-size: 22rpx; font-weight: 700; color: var(--accent-strong); letter-spacing: 0.5rpx; }
.sk-name { font-size: 28rpx; font-weight: 700; color: var(--ink); }
.sk-hint { font-size: 22rpx; color: var(--accent-strong); flex: 1 1 auto; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.sk-note { font-size: 22rpx; color: var(--sub); flex: 1 1 auto; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.sk-bars { display: flex; gap: 22rpx; }
.sk-bar { flex: 1 1 0; display: flex; align-items: center; gap: 8rpx; }
.sk-bl { font-size: 20rpx; color: var(--faint); flex: 0 0 auto; }
.sk-track { flex: 1 1 auto; height: 12rpx; border: var(--bw-thin) solid var(--ink); border-radius: var(--r-full); background: var(--fill); overflow: hidden; }
.sk-fill { height: 100%; border-radius: var(--r-full); background: var(--accent); transition: width 0.6s cubic-bezier(0.22, 1, 0.36, 1); }
.sk-bv { font-size: 20rpx; color: var(--ink-2); flex: 0 0 auto; width: 36rpx; text-align: right; }

/* 概念型 Agent：点亮进度条 */
.cprog { flex: 0 0 auto; background: var(--surface); padding: 16rpx 28rpx 20rpx; border-top: var(--bw-thin) solid var(--ink); }
.cp-head { display: flex; align-items: baseline; gap: 10rpx; margin-bottom: 14rpx; }
.cp-stat { flex: 1 1 auto; min-width: 0; display: flex; align-items: baseline; gap: 6rpx; }
.cp-tier { font-size: 24rpx; font-weight: 700; color: var(--ink); }
.cp-num { font-size: 34rpx; font-weight: 800; color: var(--accent-strong); margin-left: 4rpx; }
.cp-tot { font-size: 24rpx; font-weight: 600; color: var(--faint); }
.cp-all { font-size: 22rpx; color: var(--sub); margin-left: 4rpx; }
.cp-note { flex: 0 0 auto; font-size: 22rpx; color: var(--accent-strong); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 260rpx; }
/* 复习挑战徽章：奶油黄贴纸（检索练习入口，有到期概念时替换右侧提示） */
.cp-review {
  flex: 0 0 auto; font-size: 22rpx; font-weight: 700;
  padding: 4rpx 18rpx;
  background: var(--pop-butter); color: var(--pop-butter-ink);
  border: var(--bw-thin) solid var(--ink); border-radius: var(--r-full);
  box-shadow: var(--shadow-hair);
  transform: rotate(-2deg);
  transition: transform 0.12s var(--ease), box-shadow 0.12s var(--ease);
}
.cp-review:active { transform: translate(2rpx, 2rpx) rotate(0deg); box-shadow: none; }
.cp-track { height: 14rpx; border: var(--bw-thin) solid var(--ink); border-radius: var(--r-full); background: var(--fill); overflow: hidden; }
.cp-fill { height: 100%; border-radius: var(--r-full); background: var(--accent); transition: width 0.6s cubic-bezier(0.22, 1, 0.36, 1); }

/* 概念地图：按主题的概念芯片，亮度区分掌握档位 */
.cm-theme { margin-bottom: 24rpx; }
.cm-th-name { font-size: 24rpx; font-weight: 700; color: var(--ink); margin-bottom: 12rpx; }
.cm-grid { display: flex; flex-wrap: wrap; gap: 12rpx; }
.cm-chip { font-size: 22rpx; padding: 8rpx 18rpx; border-radius: var(--r-full); border: var(--bw-thin) solid var(--ink); color: var(--faint); background: var(--fill-pressed); }
.cm-chip.lv1 { color: var(--accent-strong); border-color: var(--ink); background: var(--surface); box-shadow: var(--shadow-hair); }
.cm-chip.lv2 { color: var(--on-accent); border-color: var(--ink); background: var(--accent); font-weight: 600; box-shadow: var(--shadow-hair); }

/* 升级庆祝浮层 */
.celebrate { position: fixed; inset: 0; z-index: 60; display: flex; align-items: center; justify-content: center; background: rgba(0, 0, 0, 0.32); animation: celebFade 0.25s ease; pointer-events: none; }
.celeb-card { background: var(--surface); border: var(--bw) solid var(--ink); border-radius: 28rpx; padding: 48rpx 64rpx; text-align: center; box-shadow: var(--shadow-pop); animation: celebPop 0.42s var(--ease-spring); }
.celeb-spark { font-size: 64rpx; line-height: 1; }
.celeb-up { display: inline-block; font-size: 24rpx; font-weight: 700; color: var(--pop-butter-ink); letter-spacing: 4rpx; margin-top: 12rpx; padding: 4rpx 18rpx; background: var(--pop-butter); border: var(--bw-thin) solid var(--ink); border-radius: var(--r-full); transform: rotate(-2deg); }
.celeb-name { font-size: 44rpx; font-weight: 800; color: var(--ink); margin-top: 8rpx; }
.celeb-sub { font-size: 24rpx; color: var(--sub); margin-top: 12rpx; }
@keyframes celebFade { from { opacity: 0; } to { opacity: 1; } }
@keyframes celebPop { 0% { opacity: 0; transform: scale(0.7); } 60% { opacity: 1; } 100% { opacity: 1; transform: scale(1); } }

/* 写小说：气泡下的存入作品动作 */
.bub-acts { display: flex; gap: 16rpx; margin: 6rpx 0 2rpx 8rpx; }
.bub-act { font-size: 22rpx; color: var(--accent-strong); padding: 4rpx 16rpx; border: var(--bw-thin) solid var(--ink); border-radius: var(--r-full); background: var(--surface); }

/* 做音乐：生成/曲库工具条 */
.mbar { flex: 0 0 auto; display: flex; align-items: center; gap: 16rpx; padding: 12rpx 24rpx; background: var(--surface); border-top: 1rpx solid var(--line); }
.mbar-btn { font-size: 26rpx; font-weight: 600; color: var(--on-accent); background: var(--accent); padding: 12rpx 28rpx; border: var(--bw-thin) solid var(--ink); border-radius: var(--r-full); box-shadow: var(--shadow-hair); }
.mbar-btn:active { transform: translate(4rpx, 4rpx); box-shadow: 0 0 0 var(--ink); }
.mbar-btn.ghost { color: var(--accent-strong); background: var(--surface); }
.mbar-btn.gen { background: var(--fill); color: var(--sub); box-shadow: none; }

/* 写小说：作品抽屉 */
.wk-stages { display: flex; gap: 12rpx; padding: 0 8rpx 16rpx; }
.wk-stage { font-size: 22rpx; color: var(--faint); padding: 6rpx 20rpx; border: var(--bw-thin) solid var(--ink); border-radius: var(--r-full); background: var(--fill); }
.wk-stage.done { color: var(--on-accent); background: var(--accent); font-weight: 600; }
.wk-field { display: flex; align-items: center; gap: 16rpx; padding: 18rpx 8rpx; border-bottom: 1rpx solid var(--line); }
.wk-field.col { flex-direction: column; align-items: flex-start; gap: 8rpx; }
.wk-lb { font-size: 24rpx; color: var(--faint); flex: 0 0 auto; }
.wk-val { font-size: 26rpx; color: var(--ink); flex: 1 1 auto; text-align: right; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.wk-val.ml { text-align: left; white-space: normal; line-height: 1.5; }
.wk-sec { font-size: 24rpx; font-weight: 700; color: var(--ink); margin: 22rpx 8rpx 12rpx; }
.wk-chap { padding: 16rpx; margin-bottom: 12rpx; background: var(--fill-pressed); border-radius: var(--r-md); }
.wk-chap-t { font-size: 25rpx; font-weight: 600; color: var(--ink); margin-bottom: 6rpx; }
.wk-chap-c { font-size: 24rpx; color: var(--ink-2); line-height: 1.5; max-height: 120rpx; overflow: hidden; }
.wk-empty { font-size: 24rpx; color: var(--faint); padding: 24rpx 8rpx; line-height: 1.6; }
.wk-final { margin: 20rpx 8rpx; text-align: center; font-size: 26rpx; font-weight: 600; color: var(--accent-strong); padding: 18rpx; border: var(--bw-thin) dashed var(--ink); border-radius: var(--r-md); }
.wk-final.on { color: var(--on-accent); background: var(--accent); border-style: solid; box-shadow: var(--shadow-hair); }

/* 做音乐：写词弹层 */
.cm-lb { font-size: 24rpx; color: var(--faint); margin: 4rpx 8rpx 10rpx; }
.cm-lyrics { width: 100%; box-sizing: border-box; min-height: 260rpx; max-height: 520rpx; padding: 20rpx; font-size: 26rpx; line-height: 1.6; color: var(--ink); background: var(--surface-sunken); border: var(--bw-thin) solid var(--ink); border-radius: var(--r-md); }
.cm-row { margin-top: 16rpx; }
.cm-in { width: 100%; box-sizing: border-box; padding: 18rpx 20rpx; font-size: 26rpx; color: var(--ink); background: var(--surface-sunken); border: var(--bw-thin) solid var(--ink); border-radius: var(--r-md); }
.cm-gen { margin-top: 24rpx; text-align: center; font-size: 28rpx; font-weight: 700; color: var(--on-accent); background: var(--accent); padding: 22rpx; border: var(--bw) solid var(--ink); border-radius: var(--r-full); box-shadow: var(--shadow-card); transition: transform 0.12s var(--ease), box-shadow 0.12s var(--ease); }
.cm-gen:active { transform: translate(4rpx, 4rpx); box-shadow: 0 0 0 var(--ink); }

/* 做音乐：曲库 */
.song { display: flex; align-items: center; gap: 16rpx; padding: 20rpx 8rpx; border-bottom: 1rpx solid var(--line); }
.song-meta { flex: 1 1 auto; min-width: 0; }
.song-t { font-size: 27rpx; font-weight: 600; color: var(--ink); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.song-sub { font-size: 22rpx; color: var(--faint); margin-top: 4rpx; }
.song-play { flex: 0 0 auto; width: 72rpx; height: 72rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 30rpx; color: var(--on-accent); background: var(--accent); border: var(--bw-thin) solid var(--ink); box-shadow: var(--shadow-hair); }
.song-play.on { background: var(--fill); color: var(--ink); }

.composer { flex: 0 0 auto; display: flex; align-items: center; gap: 16rpx; padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom)); background: var(--surface); border-top: var(--bw-thin) solid var(--ink); }
.cp-input { flex: 1 1 auto; min-width: 0; background: var(--surface-sunken); border: var(--bw-thin) solid var(--ink); border-radius: var(--r-full); padding: 18rpx 28rpx; font-size: 29rpx; }
.cp-send { flex: 0 0 auto; background: var(--accent); color: var(--on-accent); font-size: 28rpx; font-weight: 600; border: var(--bw-thin) solid var(--ink); border-radius: var(--r-full); padding: 0 36rpx; height: 72rpx; line-height: 72rpx; box-shadow: var(--shadow-hair); transition: transform 0.12s var(--ease), box-shadow 0.12s var(--ease); }
.cp-send:active { transform: translate(4rpx, 4rpx); box-shadow: 0 0 0 var(--ink); }
.cp-send[disabled] { background: var(--accent); opacity: 0.35; color: var(--on-accent); box-shadow: none; }
.cp-send::after { border: none; }
