.page { padding: 24rpx 28rpx calc(24rpx + env(safe-area-inset-bottom)); }

.hd { padding: 12rpx 4rpx 20rpx; }
.hd-title { font-size: 44rpx; font-weight: 800; color: var(--ink); }
.hd-sub { font-size: 24rpx; margin-top: 8rpx; }

.loading { text-align: center; padding: 120rpx 0; font-size: 26rpx; }
.empty { text-align: center; padding: 120rpx 40rpx; }
.empty-title { font-size: 32rpx; font-weight: 800; color: var(--ink); }
.empty .muted { margin-top: 12rpx; font-size: 26rpx; }

.course-section { margin-bottom: 36rpx; }
.course-hd { display: flex; align-items: center; gap: 12rpx; padding: 0 4rpx 16rpx; }
.course-icon { font-size: 34rpx; }
.course-name { flex: 1; font-size: 30rpx; font-weight: 800; color: var(--ink); }
.course-progress { font-size: 24rpx; color: var(--sub); font-weight: 700; }

.cardgrid { display: flex; flex-direction: column; gap: 16rpx; }
.kc { border-radius: var(--r-xl); padding: 24rpx 26rpx; }

.kc-unlocked {
  background: var(--surface); border: var(--bw-thin) solid var(--border);
  border-left: 6rpx solid var(--accent);
  box-shadow: var(--shadow-card);
}
.kc-tier { font-size: 22rpx; font-weight: 700; color: var(--accent); }
.kc-takeaway { margin-top: 10rpx; font-size: 28rpx; font-weight: 700; color: var(--ink); line-height: 1.6; }
.kc-foot { margin-top: 16rpx; display: flex; align-items: center; justify-content: space-between; gap: 12rpx; }
.kc-source { font-size: 22rpx; color: var(--sub); flex: 1; }
.kc-share {
  flex: 0 0 auto; font-size: 22rpx; font-weight: 700; line-height: 1;
  padding: 10rpx 24rpx; border-radius: var(--r-full);
  background: var(--fill); color: var(--ink-2); border: none; margin: 0;
}
.kc-share::after { border: none; }

.kc-locked {
  background: var(--fill); border: var(--bw-thin) dashed var(--border);
  display: flex; align-items: center; gap: 14rpx;
  color: var(--sub);
}
.kc-lock-emoji { font-size: 30rpx; }
.kc-locked-name { font-size: 26rpx; font-weight: 700; }
