.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: var(--sp-4);
  background: var(--bg);
}

.card {
  background: var(--surface);
  border: var(--bw) solid var(--ink);
  border-radius: var(--r-xl);
  box-shadow: var(--shadow-card);
  padding: var(--sp-5);
}

/* ---------- 开场 ---------- */
.intro {
  padding-top: 96rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}
.intro-badge {
  width: 132rpx;
  height: 132rpx;
  border-radius: var(--r-full);
  background: var(--accent-soft);
  border: var(--bw-thin) solid var(--ink);
  color: var(--accent);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  margin-bottom: var(--sp-5);
}
.intro-title { font-size: 46rpx; font-weight: 700; color: var(--ink); letter-spacing: -0.5rpx; }
.intro-sub {
  margin-top: var(--sp-3);
  font-size: 28rpx;
  line-height: 1.7;
  color: var(--ink-2);
  max-width: 560rpx;
}
.intro-note {
  margin-top: var(--sp-3);
  font-size: 24rpx;
  color: var(--sub);
  max-width: 520rpx;
  line-height: 1.6;
}
.intro-cta {
  margin-top: 64rpx;
  width: 440rpx;
  height: 92rpx;
  border-radius: var(--r-full);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
}
.intro-cta.is-busy { opacity: 0.6; }
.intro-history {
  margin-top: var(--sp-4);
  font-size: 26rpx;
  color: var(--accent);
}
.intro-legal {
  position: fixed;
  bottom: 48rpx;
  left: 0; right: 0;
  text-align: center;
  font-size: 22rpx;
  color: var(--faint);
}

/* ---------- 答题 ---------- */
.quiz { padding-top: 24rpx; }
.quiz-top {
  display: flex;
  align-items: center;
  height: 64rpx;
  margin-bottom: var(--sp-6);
}
.quiz-back {
  width: 56rpx; height: 56rpx;
  display: flex; align-items: center; justify-content: center;
  color: var(--ink-2);
  font-size: 36rpx;
}
.quiz-back.is-off { opacity: 0; pointer-events: none; }
.quiz-progress {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: var(--sub);
  margin-right: 56rpx;
  font-variant-numeric: tabular-nums;
}
.quiz-q {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.5;
  color: var(--ink);
  letter-spacing: -0.5rpx;
  margin-bottom: 48rpx;
  min-height: 120rpx;
}
.quiz-opt {
  display: flex;
  align-items: center;
  padding: 30rpx var(--sp-4);
  background: var(--surface);
  border: var(--bw) solid var(--ink);
  border-radius: var(--r-lg);
  box-shadow: var(--shadow-hair);
  margin-bottom: var(--sp-3);
  transition: all 0.18s var(--ease-out);
}
.quiz-opt:active { background: var(--fill-pressed); transform: translate(2rpx, 2rpx); box-shadow: 0 0 0 var(--ink); }
.quiz-opt.is-sel {
  background: var(--accent-soft);
}
.quiz-opt-key {
  width: 44rpx; height: 44rpx;
  flex: 0 0 auto;
  border-radius: var(--r-full);
  background: var(--fill);
  color: var(--sub);
  font-size: 24rpx;
  font-weight: 600;
  display: flex; align-items: center; justify-content: center;
  margin-right: var(--sp-3);
}
.quiz-opt.is-sel .quiz-opt-key { background: var(--accent); color: var(--on-accent); }
.quiz-opt-label { flex: 1; font-size: 30rpx; color: var(--ink); line-height: 1.5; }

/* ---------- 结果 ---------- */
.result { padding-bottom: 64rpx; }
.res-top {
  text-align: center;
  padding: 56rpx var(--sp-4) 48rpx;
  background: var(--accent-soft);
  border: var(--bw) solid var(--ink);
  border-radius: var(--r-2xl);
  box-shadow: var(--shadow-card);
  margin-bottom: var(--sp-4);
}
.res-eyebrow { font-size: 24rpx; color: var(--accent-strong); letter-spacing: 1rpx; }
.res-top-name { margin-top: var(--sp-2); font-size: 44rpx; font-weight: 700; color: var(--ink); }
.res-top-score {
  margin-top: var(--sp-2);
  font-size: 92rpx;
  font-weight: 800;
  color: var(--accent);
  line-height: 1.1;
}
.res-top-unit { font-size: 40rpx; font-weight: 700; }
/* 3 维拆解 */
.res-dims { margin-bottom: var(--sp-4); }
.dim { margin-bottom: var(--sp-4); }
.dim:last-of-type { margin-bottom: 0; }
.dim-row { display: flex; align-items: center; }
.dim-name { font-size: 28rpx; font-weight: 600; color: var(--ink); }
.dim-tag {
  margin-left: var(--sp-2);
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: var(--r-full);
  line-height: 1.7;
}
.dim-tag-same { color: var(--accent-strong); background: var(--accent-soft); border: var(--bw-thin) solid var(--ink); }
.dim-tag-comp { color: #b4690e; background: rgba(251, 146, 60, 0.14); border: var(--bw-thin) solid var(--ink); }
.dim-score {
  margin-left: auto;
  font-size: 26rpx; font-weight: 700; color: var(--accent);
  font-variant-numeric: tabular-nums;
}
.dim-bar {
  margin-top: var(--sp-2);
  height: 14rpx;
  border-radius: var(--r-full);
  background: var(--fill);
  overflow: hidden;
}
.dim-bar-fill {
  height: 100%;
  border-radius: var(--r-full);
  background: var(--accent);
  transition: width 0.5s var(--ease-out);
}
.dim-note { margin-top: var(--sp-1); font-size: 24rpx; color: var(--sub); line-height: 1.5; }
.dim-summary {
  margin-top: var(--sp-4);
  padding-top: var(--sp-3);
  border-top: 2rpx solid var(--line);
  font-size: 26rpx;
  line-height: 1.7;
  color: var(--ink-2);
}
.res-h {
  display: flex; align-items: center;
  font-size: 30rpx; font-weight: 700; color: var(--ink);
  margin-bottom: var(--sp-3);
}
.res-h-ic { font-size: 34rpx; color: var(--accent); margin-right: var(--sp-2); }
.res-profile { margin-bottom: var(--sp-4); }
.res-profile-text { font-size: 29rpx; line-height: 1.8; color: var(--ink-2); }

.res-matches { margin-bottom: var(--sp-4); }
.match { margin-bottom: var(--sp-4); }
.match:last-child { margin-bottom: 0; }
.match-row { display: flex; align-items: baseline; justify-content: space-between; }
.match-name { font-size: 28rpx; color: var(--ink); font-weight: 600; }
.match-score { font-size: 26rpx; color: var(--accent); font-weight: 700; font-variant-numeric: tabular-nums; }
.match-bar {
  margin-top: var(--sp-1);
  height: 12rpx;
  border-radius: var(--r-full);
  background: var(--fill);
  overflow: hidden;
}
.match-bar-fill {
  height: 100%;
  border-radius: var(--r-full);
  background: var(--accent);
  transition: width 0.5s var(--ease-out);
}
.match-reason { margin-top: var(--sp-1); font-size: 24rpx; color: var(--sub); line-height: 1.5; }

.res-fed {
  text-align: center;
  font-size: 24rpx;
  color: var(--sub);
  margin: var(--sp-2) 0 var(--sp-4);
}
.res-acts { display: flex; gap: var(--sp-3); }
.res-act {
  flex: 1;
  height: 92rpx;
  border-radius: var(--r-full);
  display: flex; align-items: center; justify-content: center;
  font-size: 30rpx; font-weight: 600;
}

/* ---------- 提交遮罩 ---------- */
.mask {
  position: fixed;
  inset: 0;
  background: rgba(255, 255, 255, 0.92);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 50;
}
.mask-spin {
  width: 64rpx; height: 64rpx;
  border: 6rpx solid var(--fill);
  border-top-color: var(--accent);
  border-radius: var(--r-full);
  animation: spin 0.8s linear infinite;
}
.mask-text { margin-top: var(--sp-4); font-size: 28rpx; color: var(--ink-2); }
@keyframes spin { to { transform: rotate(360deg); } }
