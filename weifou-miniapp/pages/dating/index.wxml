<view class="page">

  <!-- 开场 -->
  <view wx:if="{{stage === 'intro'}}" class="intro">
    <view class="intro-badge"><view class="ic ic-heart"></view></view>
    <view class="intro-title">择偶画像测试</view>
    <view class="intro-sub">AI 出 8 道小题，几分钟看清你在亲密关系里到底要什么，并算出你和 6 种伴侣原型的契合度。</view>
    <view class="intro-note">结果会生成一份「我的择偶画像」，自动存进你的 AI 分身。</view>
    <view class="intro-cta btn-accent {{loading ? 'is-busy' : ''}}" bindtap="onStart">
      <text>{{loading ? '正在出题…' : '开始测试'}}</text>
    </view>
    <view wx:if="{{hasHistory}}" class="intro-history" bindtap="onViewHistory">查看上次结果</view>
    <view class="intro-legal">测试结果仅供自我了解，由 AI 生成</view>
  </view>

  <!-- 答题 -->
  <view wx:elif="{{stage === 'quiz'}}" class="quiz">
    <view class="quiz-top">
      <view class="quiz-back {{index === 0 ? 'is-off' : ''}}" bindtap="onBack"><view class="ic ic-back"></view></view>
      <view class="quiz-progress">{{progressText}}</view>
    </view>
    <view class="quiz-q">{{cur.text}}</view>
    <view class="quiz-opts">
      <view
        class="quiz-opt {{answers[cur.id] === item.key ? 'is-sel' : ''}}"
        wx:for="{{cur.options}}"
        wx:key="key"
        data-key="{{item.key}}"
        bindtap="onPick">
        <view class="quiz-opt-key">{{item.key}}</view>
        <view class="quiz-opt-label">{{item.label}}</view>
      </view>
    </view>
  </view>

  <!-- 结果 -->
  <view wx:elif="{{stage === 'result'}}" class="result">
    <!-- 头条：最契合原型 + 大字总分 -->
    <view class="res-top">
      <view class="res-eyebrow">最契合的伴侣原型</view>
      <view class="res-top-name">{{headline.archetype}}</view>
      <view class="res-top-score">{{headline.total}}<text class="res-top-unit">%</text></view>
    </view>

    <!-- 3 维拆解 -->
    <view wx:if="{{headline.dimensions.length}}" class="card res-dims">
      <view class="res-h"><view class="ic ic-stats res-h-ic"></view><text>契合度拆解</text></view>
      <view class="dim" wx:for="{{headline.dimensions}}" wx:key="name">
        <view class="dim-row">
          <view class="dim-name">{{item.name}}</view>
          <view class="dim-tag dim-tag-{{item.type === '互补' ? 'comp' : 'same'}}">{{item.type}}</view>
          <view class="dim-score">{{item.score}}%</view>
        </view>
        <view class="dim-bar"><view class="dim-bar-fill" style="width:{{item.score}}%"></view></view>
        <view class="dim-note">{{item.note}}</view>
      </view>
      <view wx:if="{{headline.summary}}" class="dim-summary">{{headline.summary}}</view>
    </view>

    <view class="card res-profile">
      <view class="res-h"><view class="ic ic-heart res-h-ic"></view><text>我的择偶画像</text></view>
      <view class="res-profile-text">{{profile}}</view>
    </view>

    <view class="card res-matches">
      <view class="res-h"><view class="ic ic-user res-h-ic"></view><text>与 6 种原型的契合度</text></view>
      <view class="match" wx:for="{{matches}}" wx:key="archetype">
        <view class="match-row">
          <view class="match-name">{{item.archetype}}</view>
          <view class="match-score">{{item.score}}%</view>
        </view>
        <view class="match-bar"><view class="match-bar-fill" style="width:{{item.score}}%"></view></view>
        <view class="match-reason">{{item.reason}}</view>
      </view>
    </view>

    <view class="res-fed">画像已存入你的 AI 分身，对话时会用上</view>

    <view class="res-acts">
      <view class="btn-ghost res-act" bindtap="onRetake">重新测一次</view>
      <view class="btn-accent res-act" bindtap="goClone">去看我的分身</view>
    </view>
  </view>

  <!-- 提交分析中的遮罩 -->
  <view wx:if="{{loading && stage === 'quiz'}}" class="mask">
    <view class="mask-spin"></view>
    <view class="mask-text">正在生成你的择偶画像…</view>
  </view>

</view>
