<view class="mkt" style="padding-top:{{statusBarH}}px">
  <view class="mkt-top">
    <view class="mkt-h1">闯关式学习，点亮 AI 时代所需技能</view>
    <view wx:if="{{streak}}" class="mkt-streak">🔥 连续学习 {{streak.days}} 天{{streak.todayDone ? '' : ' · 今天还没学，别断'}}</view>
  </view>

  <block wx:if="{{loading}}">
    <view class="skel-card" wx:for="{{[1, 2, 3, 4]}}" wx:key="*this">
      <view class="skel skel-ic"></view>
      <view class="skel-lines">
        <view class="skel skel-l1"></view>
        <view class="skel skel-l2"></view>
      </view>
    </view>
  </block>

  <block wx:else>
    <view class="mbr {{isMember ? 'on' : ''}}" hover-class="card-press" hover-stay-time="0" bindtap="goMembership">
      <view class="ic ic-crown mbr-ic"></view>
      <text class="mbr-text">{{isMember ? '会员有效中 · 全部畅用' : '开通会员 · 一价畅用全部'}}</text>
      <text wx:if="{{!isMember}}" class="mbr-go">去开通 ›</text>
    </view>

    <view class="mcard" wx:for="{{agents}}" wx:key="id"
          data-id="{{item.id}}" data-name="{{item.name}}"
          hover-class="card-press" hover-stay-time="0" bindtap="open">
      <view class="mcard-ic">{{item.icon}}</view>
      <view class="mcard-meta">
        <view class="mcard-name">{{item.name}}</view>
        <view class="mcard-tag">{{item.tagline}}</view>
        <view class="mcard-status status-{{item.statusKind}}">{{item.status}}</view>
      </view>
      <view class="ic ic-chevron mcard-go"></view>
    </view>

    <view wx:if="{{agents.length === 0}}" class="empty-wrap">
      <view class="empty-ic"><view class="ic ic-sparkle"></view></view>
      <view class="empty-title">课程正在上新</view>
      <view class="empty-sub">AI 老师们正在备课，很快就能开讲</view>
    </view>
  </block>
</view>
