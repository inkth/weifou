<view class="wrap" style="padding-top:{{statusBarH}}px">
  <view class="head">
    <view class="h-title">用 AI 学习一切</view>
    <view class="h-sub">挑一个 AI 老师，先免费体验，会员畅用全部</view>
  </view>

  <view wx:if="{{loading}}" class="state">加载中…</view>

  <block wx:else>
    <view class="mbr-banner {{isMember ? 'on' : ''}}" bindtap="goMembership">
      <view class="ic ic-crown mb-crown"></view>
      <text class="mb-text">{{isMember ? '会员有效中 · 全部畅用' : '开通会员 · 一价畅用全部'}}</text>
      <text class="mb-arrow" wx:if="{{!isMember}}">去开通 ›</text>
    </view>

    <view class="list">
      <view
        wx:for="{{agents}}"
        wx:key="id"
        class="card"
        bindtap="open"
        data-id="{{item.id}}"
        data-name="{{item.name}}"
      >
        <view class="aic" style="background: {{item.accent}}1a; color: {{item.accent}};">{{item.icon}}</view>
        <view class="body">
          <view class="name">{{item.name}}</view>
          <view class="tagline">{{item.tagline}}</view>
          <view class="meta">
            <text class="status status-{{item.statusKind}}">{{item.status}}</text>
          </view>
        </view>
        <view
          class="pin {{item.pinned ? 'on' : ''}}"
          catchtap="togglePin"
          data-id="{{item.id}}"
          data-pinned="{{item.pinned}}"
        >{{item.pinned ? '已添加' : '+ 首页'}}</view>
      </view>

      <view wx:if="{{agents.length === 0}}" class="state">暂无可用工具</view>
    </view>
  </block>
</view>
