<view class="mkt" style="padding-top:{{statusBarH}}px">
  <view class="mkt-top">
    <view class="mkt-kicker">HUMAN SKILLS · AI 时代的必修课</view>
    <view class="mkt-h1">AI 时代，什么仍然值得学？</view>
    <view class="mkt-sub">从全球优质公开课程与经典研究中，精选真正有用的知识，重做成轻松、可互动、能练会的课程。</view>
    <view wx:if="{{streak}}" class="mkt-streak">连续 {{streak.days}} 天{{streak.todayDone ? '' : ' · 今天待练习'}}</view>
  </view>

  <block wx:if="{{loading}}">
    <view class="skel-course" wx:for="{{[1, 2]}}" wx:key="*this">
      <view class="skel skel-course-label"></view>
      <view class="skel skel-course-title"></view>
      <view class="skel skel-course-copy"></view>
      <view class="skel skel-course-desc"></view>
      <view class="skel skel-course-footer"></view>
    </view>
  </block>

  <block wx:else>
    <block wx:if="{{hasCourses}}">
      <view class="category-tabs">
        <view wx:for="{{categories}}" wx:key="key"
              class="category-tab {{selectedCategory === item.key ? 'active' : ''}}"
              data-category="{{item.key}}" bindtap="selectCategory">
          <text class="category-name">{{item.name}}</text>
        </view>
      </view>

      <block wx:for="{{courses}}" wx:key="id">
        <view class="course-card tone-{{item.cardTone}} {{item.isCurrent ? 'is-current' : ''}}"
              data-id="{{item.id}}" data-name="{{item.name}}"
              hover-class="card-press" hover-stay-time="0" bindtap="open">
          <view class="course-topline">
            <view class="course-label">{{item.cardLabel}}</view>
            <view class="course-number">COURSE {{item.courseNo}}</view>
          </view>

          <view class="course-heading">
            <view class="course-icon {{item.cover ? 'has-cover' : ''}}">
              <image wx:if="{{item.cover}}" class="course-cover" src="{{item.cover}}" mode="aspectFill" lazy-load></image>
              <text wx:else>{{item.icon}}</text>
            </view>
            <view class="course-title-wrap">
              <view class="course-subject">{{item.subject}}</view>
              <view class="course-title">{{item.name}}</view>
            </view>
          </view>

          <view class="course-outcome">{{item.outcome}}</view>
          <view wx:if="{{item.description}}" class="course-description">{{item.description}}</view>

          <view class="course-highlights" wx:if="{{item.highlights.length}}">
            <text class="course-highlight" wx:for="{{item.highlights}}" wx:for-item="point" wx:key="*this">{{point}}</text>
          </view>

          <view wx:if="{{item.showProgress}}" class="course-progress">
            <view class="course-progress-row">
              <text>{{item.progressText}}</text>
              <text>{{item.progressPercent}}%</text>
            </view>
            <view class="course-progress-track"><view class="course-progress-fill" style="width:{{item.progressPercent}}%"></view></view>
          </view>

          <view class="course-meta">
            <text wx:if="{{item.courseMeta}}">{{item.courseMeta}}</text>
            <view class="course-enter"><text>{{item.enterLabel}}</text><view class="ic ic-chevron"></view></view>
          </view>
        </view>
      </block>
    </block>

    <view wx:else class="empty-wrap">
      <view class="empty-ic"><view class="ic ic-sparkle"></view></view>
      <view class="empty-title">新能力正在准备</view>
      <view class="empty-sub">新的练习正在打磨，很快就能开始</view>
    </view>
  </block>
</view>
