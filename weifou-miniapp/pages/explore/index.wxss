/* 学习市场 = 清新浅色 + 薄荷青，与首页同一套令牌（白卡 / 芯片 / pill / hairline）。 */
.mkt {
  min-height: 100vh;
  background: var(--bg);
  padding: 0 36rpx calc(env(safe-area-inset-bottom) + 160rpx);
}
.mkt-top { padding: 36rpx 6rpx 24rpx; }
.mkt-h1 { font-size: 46rpx; font-weight: 600; color: var(--ink); letter-spacing: -1rpx; }
.mkt-sub { margin-top: 10rpx; font-size: 25rpx; color: var(--sub); }
.mkt-state { text-align: center; padding: 80rpx 0; color: var(--faint); font-size: 26rpx; }
.card-press { transform: scale(0.985); }

/* 骨架屏：结构与工具卡一致，加载不跳版 */
.skel-card {
  display: flex; align-items: center; gap: 24rpx;
  padding: 26rpx 28rpx; border-radius: 28rpx; margin-bottom: 20rpx;
  background: var(--surface); border: 1rpx solid var(--border);
}
.skel-ic { width: 92rpx; height: 92rpx; border-radius: 26rpx; flex: 0 0 auto; }
.skel-lines { flex: 1; }
.skel-l1 { height: 30rpx; width: 40%; }
.skel-l2 { height: 24rpx; width: 72%; margin-top: 14rpx; }

/* 会员横幅 */
.mbr {
  display: flex; align-items: center; gap: 14rpx;
  padding: 26rpx 28rpx; border-radius: var(--r-xl); margin-bottom: 28rpx;
  background: var(--accent-soft); border: 1rpx solid rgba(24, 182, 144, 0.22);
}
.mbr-ic { font-size: 34rpx; color: var(--accent-deep); }
.mbr-text { flex: 1; font-size: 27rpx; font-weight: 500; color: var(--accent-ink); }
.mbr-go { font-size: 24rpx; color: var(--accent-strong); font-weight: 500; }

/* 工具卡 */
.mcard {
  display: flex; align-items: center; gap: 24rpx;
  padding: 26rpx 28rpx; border-radius: 28rpx; margin-bottom: 20rpx;
  background: var(--surface); border: 1rpx solid var(--border); box-shadow: var(--shadow-card);
}
.mcard-ic { flex: 0 0 auto; width: 92rpx; height: 92rpx; border-radius: 26rpx; display: flex; align-items: center; justify-content: center; font-size: 42rpx; background: var(--accent-soft); }
.mcard-meta { flex: 1; min-width: 0; }
.mcard-name { font-size: 30rpx; font-weight: 600; color: var(--ink); }
.mcard-tag { margin-top: 6rpx; font-size: 25rpx; color: var(--sub); line-height: 1.5; }
.mcard-status { margin-top: 12rpx; font-size: 22rpx; }
.status-member { color: var(--accent-ink); }
.status-trial { color: var(--accent-strong); }
.status-used { color: #b3925a; }

/* 添加到首页 */
.pin { flex: 0 0 auto; align-self: center; font-size: 23rpx; padding: 12rpx 22rpx; border-radius: var(--r-full); color: var(--accent-strong); background: var(--accent-soft); transition: transform 0.16s var(--ease); }
.pin:active { transform: scale(0.94); }
.pin.on { color: var(--faint); background: var(--fill); }
