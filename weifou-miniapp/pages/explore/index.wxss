/* 技能：课程量克制时，每门课都用完整大卡讲清价值，不退化成工具列表。 */
.mkt {
  min-height: 100vh;
  background: var(--bg);
  padding: 0 36rpx calc(env(safe-area-inset-bottom) + 180rpx);
}

.mkt-top { position: relative; padding: 42rpx 6rpx 34rpx; }
.mkt-kicker { margin-bottom: 13rpx; color: var(--accent); font-size: 19rpx; line-height: 1; letter-spacing: 3.2rpx; font-weight: 800; }
.mkt-h1 { max-width: 650rpx; font-size: 48rpx; font-weight: 850; color: var(--ink); letter-spacing: -1rpx; line-height: 1.28; }
.mkt-sub { margin-top: 14rpx; max-width: 650rpx; font-size: 25rpx; color: var(--ink-2); line-height: 1.65; }
.mkt-streak {
  display: inline-block;
  margin-top: 14rpx;
  padding: 6rpx 20rpx;
  background: var(--pop-butter);
  color: var(--pop-butter-ink);
  border-radius: var(--r-full);
  font-size: 23rpx;
  font-weight: 650;
  box-shadow: var(--shadow-hair);
}

.category-tabs {
  display: flex;
  gap: 4rpx;
  padding: 6rpx;
  margin-bottom: 26rpx;
  background: var(--surface-sunken);
  border: var(--bw-thin) solid var(--border);
  border-radius: var(--r-lg);
}
.category-tab {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--ink-2);
  border-radius: 20rpx;
  transition: color 0.12s var(--ease), background 0.12s var(--ease), transform 0.12s var(--ease);
}
.category-tab:active { transform: scale(0.97); }
.category-tab.active { color: var(--on-accent); background: var(--accent); box-shadow: var(--shadow-accent); }
.category-name { font-size: 26rpx; font-weight: 800; white-space: nowrap; }

.card-press { transform: scale(0.985); opacity: 0.95; }

/* 全部课程统一使用完整大卡：结果承诺、介绍、训练点、路径信息和 CTA 一次讲全。 */
.course-card {
  position: relative;
  overflow: hidden;
  padding: 30rpx;
  margin-bottom: 26rpx;
  background: linear-gradient(145deg, #ffffff 0%, var(--accent-soft) 135%);
  border: var(--bw-thin) solid var(--mist-lilac);
  border-radius: var(--r-2xl);
  box-shadow: var(--shadow-card);
  transition: transform 0.12s var(--ease), box-shadow 0.12s var(--ease);
}
.course-card.tone-1 { background: linear-gradient(145deg, #ffffff 0%, var(--pop-mint) 145%); border-color: #d6e6e2; }
.course-card.tone-2 { background: linear-gradient(145deg, #ffffff 0%, var(--pop-butter) 150%); border-color: #e5ddce; }
.course-card.is-current { border-color: var(--accent); box-shadow: var(--shadow-lift); }
.course-card::after {
  content: '';
  position: absolute;
  right: -76rpx;
  top: -88rpx;
  width: 250rpx;
  height: 250rpx;
  border-radius: 50%;
  background: rgba(119, 114, 200, 0.06);
}
.course-topline { position: relative; z-index: 1; display: flex; align-items: center; justify-content: space-between; }
.course-label { padding: 6rpx 16rpx; border-radius: var(--r-full); background: rgba(255, 255, 255, 0.82); color: var(--accent-deep); border: var(--bw-thin) solid rgba(119, 114, 200, 0.13); font-size: 21rpx; font-weight: 750; }
.is-current .course-label { background: var(--accent); color: var(--on-accent); border-color: var(--accent); }
.course-number { color: var(--accent-deep); font-size: 17rpx; letter-spacing: 2rpx; font-weight: 800; opacity: 0.66; }
.course-heading { position: relative; z-index: 1; display: flex; align-items: center; gap: 20rpx; margin-top: 24rpx; }
.course-icon {
  width: 124rpx;
  height: 124rpx;
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.88);
  border: var(--bw-thin) solid rgba(119, 114, 200, 0.13);
  border-radius: var(--r-lg);
  font-size: 46rpx;
  box-shadow: var(--shadow-hair);
}
.course-icon.has-cover { background: var(--surface); }
.course-cover { display: block; width: 100%; height: 100%; }
.course-title-wrap { min-width: 0; }
.course-subject { color: var(--accent-deep); font-size: 20rpx; font-weight: 700; line-height: 1.4; }
.course-title { margin-top: 3rpx; color: var(--ink); font-size: 35rpx; line-height: 1.3; font-weight: 850; }
.course-outcome { position: relative; z-index: 1; margin-top: 24rpx; max-width: 600rpx; color: var(--ink); font-size: 30rpx; line-height: 1.5; font-weight: 750; }
.course-description {
  position: relative;
  z-index: 1;
  display: -webkit-box;
  margin-top: 14rpx;
  overflow: hidden;
  color: var(--ink-2);
  font-size: 23rpx;
  line-height: 1.65;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}
.course-highlights { position: relative; z-index: 1; display: flex; flex-wrap: wrap; gap: 10rpx; margin-top: 18rpx; }
.course-highlight { padding: 7rpx 15rpx; color: var(--accent-ink); background: rgba(255, 255, 255, 0.78); border: var(--bw-thin) solid rgba(119, 114, 200, 0.12); border-radius: var(--r-full); font-size: 21rpx; font-weight: 650; }
.course-progress { position: relative; z-index: 1; margin-top: 22rpx; }
.course-progress-row { display: flex; justify-content: space-between; color: var(--accent-deep); font-size: 21rpx; font-weight: 650; }
.course-progress-track { height: 9rpx; margin-top: 9rpx; overflow: hidden; background: rgba(119, 114, 200, 0.14); border-radius: var(--r-full); }
.course-progress-fill { height: 100%; background: var(--accent); border-radius: var(--r-full); }
.course-meta {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: var(--bw-thin) dashed rgba(79, 74, 139, 0.18);
  color: var(--ink-2);
  font-size: 22rpx;
}
.course-enter {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  gap: 2rpx;
  color: var(--accent-deep);
  font-size: 22rpx;
  font-weight: 800;
}
.course-enter .ic { color: var(--accent); font-size: 25rpx; }

/* 骨架屏与大卡结构一致，加载时不跳版。 */
.skel-course { padding: 30rpx; margin-bottom: 26rpx; min-height: 520rpx; border-radius: var(--r-2xl); background: var(--surface); border: var(--bw-thin) solid var(--border); }
.skel-course-label { width: 120rpx; height: 30rpx; }
.skel-course-title { width: 62%; height: 44rpx; margin-top: 38rpx; }
.skel-course-copy { width: 88%; height: 32rpx; margin-top: 30rpx; }
.skel-course-desc { width: 100%; height: 70rpx; margin-top: 18rpx; }
.skel-course-footer { width: 100%; height: 28rpx; margin-top: 110rpx; border-radius: var(--r-sm); }
