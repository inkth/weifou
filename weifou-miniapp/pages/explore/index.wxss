/* 学习市场 = 清新浅色 + 薄荷青，与首页同一套系统（白卡 / 芯片 / pill / hairline）。 */
.mkt {
  min-height: 100vh;
  background: #fbfcfb;
  padding: 0 36rpx calc(env(safe-area-inset-bottom) + 160rpx);
}
.mkt-top { padding: 36rpx 6rpx 24rpx; }
.mkt-h1 { font-size: 46rpx; font-weight: 600; color: #16241e; letter-spacing: -1rpx; }
.mkt-sub { margin-top: 10rpx; font-size: 25rpx; color: #8a9a93; }
.mkt-state { text-align: center; padding: 80rpx 0; color: #aab4af; font-size: 26rpx; }
.card-press { transform: scale(0.985); }

/* 会员横幅 */
.mbr {
  display: flex; align-items: center; gap: 14rpx;
  padding: 26rpx 28rpx; border-radius: 24rpx; margin-bottom: 28rpx;
  background: #e8f5ef; border: 1rpx solid rgba(24, 182, 144, 0.22);
}
.mbr-ic { font-size: 34rpx; color: #0f766e; }
.mbr-text { flex: 1; font-size: 27rpx; font-weight: 500; color: #0c5a48; }
.mbr-go { font-size: 24rpx; color: #18b690; }

/* 工具卡 */
.mcard {
  display: flex; align-items: center; gap: 24rpx;
  padding: 26rpx 28rpx; border-radius: 28rpx; margin-bottom: 20rpx;
  background: #fff; border: 1rpx solid #ecefec; box-shadow: 0 2rpx 6rpx rgba(20, 40, 30, 0.03);
}
.mcard-ic { flex: 0 0 auto; width: 92rpx; height: 92rpx; border-radius: 26rpx; display: flex; align-items: center; justify-content: center; font-size: 42rpx; background: #e8f5ef; }
.mcard-meta { flex: 1; min-width: 0; }
.mcard-name { font-size: 30rpx; font-weight: 600; color: #16241e; }
.mcard-tag { margin-top: 6rpx; font-size: 25rpx; color: #8a9a93; line-height: 1.5; }
.mcard-status { margin-top: 12rpx; font-size: 22rpx; }
.status-member { color: #0c5a48; }
.status-trial { color: #18b690; }
.status-used { color: #b3925a; }

/* 添加到首页 */
.pin { flex: 0 0 auto; align-self: center; font-size: 23rpx; padding: 12rpx 22rpx; border-radius: 999rpx; color: #18b690; background: #eaf6f1; }
.pin.on { color: #9aa0ab; background: #f1f2f4; }
