/* 技能：与全站共享编辑式结构，有限路径色只承担成长状态。 */
.mkt {
  min-height: 100vh;
  background: var(--bg);
  padding: 0 36rpx calc(env(safe-area-inset-bottom) + 180rpx);
}
.mkt-top { position: relative; padding: 42rpx 6rpx 38rpx; }
.mkt-kicker { margin-bottom: 13rpx; color: var(--accent); font-size: 19rpx; line-height: 1; letter-spacing: 3.2rpx; font-weight: 800; }
.mkt-h1 { max-width: 650rpx; font-size: 46rpx; font-weight: 800; color: var(--ink); letter-spacing: -1rpx; line-height: 1.3; }
.mkt-sub { margin-top: 14rpx; max-width: 650rpx; font-size: 25rpx; color: var(--ink-2); line-height: 1.65; }
/* 连续学习火焰条：贴纸小条，≥2 天才出现 */
.mkt-streak {
  display: inline-block;
  margin-top: 14rpx;
  padding: 6rpx 20rpx;
  background: var(--pop-butter); color: var(--pop-butter-ink);
  border: none;
  border-radius: var(--r-full);
  font-size: 23rpx; font-weight: 600;
  box-shadow: var(--shadow-hair);
}

.ability-head { display: flex; align-items: baseline; justify-content: space-between; margin: 6rpx 7rpx 22rpx; }
.ability-title { color: var(--ink); font-size: 30rpx; font-weight: 800; }
.ability-sub { color: var(--sub); font-size: 21rpx; }
.mkt-state { text-align: center; padding: 80rpx 0; color: var(--faint); font-size: 26rpx; }
.card-press { transform: scale(0.985); opacity: 0.94; }

/* 骨架屏：结构与工具卡一致，加载不跳版 */
.skel-card {
  display: flex; align-items: center; gap: 24rpx;
  padding: 26rpx 28rpx; border-radius: var(--r-xl); margin-bottom: 24rpx;
  background: var(--surface); border: var(--bw-thin) dashed var(--border-strong);
}
.skel-ic { width: 92rpx; height: 92rpx; border-radius: var(--r-lg); flex: 0 0 auto; }
.skel-lines { flex: 1; }
.skel-l1 { height: 30rpx; width: 40%; }
.skel-l2 { height: 24rpx; width: 72%; margin-top: 14rpx; }

/* 会员横幅：低饱和成就提示 */
.mbr {
  display: flex; align-items: center; gap: 14rpx;
  padding: 24rpx 28rpx; border-radius: var(--r-lg); margin-bottom: 32rpx;
  background: var(--pop-butter);
  border: none;
  box-shadow: var(--shadow-hair);
  transition: transform 0.12s var(--ease), box-shadow 0.12s var(--ease);
}
.mbr-ic { font-size: 34rpx; color: var(--pop-butter-ink); }
.mbr-text { flex: 1; font-size: 27rpx; font-weight: 600; color: var(--pop-butter-ink); }
.mbr-go { font-size: 24rpx; color: var(--pop-butter-ink); font-weight: 600; }
.mbr.on { background: var(--accent); box-shadow: var(--shadow-accent); }
.mbr.on .mbr-go { color: var(--on-accent); }
.mbr.on .mbr-ic, .mbr.on .mbr-text { color: var(--on-accent); }

/* 到期复习条：置顶于课程区（记忆窗口期 > 新课），糖果卡同款质感 */
.review-bar {
  display: flex; align-items: center; gap: 24rpx;
  padding: 26rpx 28rpx; border-radius: var(--r-xl); margin-bottom: 28rpx;
  background: var(--surface);
  border: var(--bw-thin) solid var(--border);
  box-shadow: var(--shadow-card);
}
.review-ic {
  flex: 0 0 auto; width: 84rpx; height: 84rpx; border-radius: var(--r-lg);
  display: flex; align-items: center; justify-content: center; font-size: 40rpx;
  background: var(--pop-butter);
}
.review-copy { flex: 1 1 auto; min-width: 0; }
.review-title { font-size: 30rpx; font-weight: 800; color: var(--ink); }
.review-sub { margin-top: 4rpx; font-size: 22rpx; color: var(--sub); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.review-go {
  flex: 0 0 auto; padding: 14rpx 28rpx; border-radius: var(--r-full);
  background: var(--accent); color: #fff; font-size: 24rpx; font-weight: 800;
}

/* 工具卡 */
.mcard {
  position: relative; overflow: hidden;
  display: flex; align-items: center; gap: 28rpx;
  min-height: 126rpx; padding: 34rpx 28rpx; border-radius: var(--r-xl); margin-bottom: 24rpx;
  background: var(--surface);
  border: var(--bw-thin) solid var(--border);
  box-shadow: var(--shadow-card);
  transition: transform 0.12s var(--ease), box-shadow 0.12s var(--ease);
}
.mcard-ic {
  position: relative; flex: 0 0 auto; width: 108rpx; height: 116rpx; border-radius: var(--r-lg);
  display: flex; align-items: center; justify-content: center; font-size: 46rpx;
  background: var(--pop-mint); border: none;
}
.mcard-order { position: absolute; left: 11rpx; top: 9rpx; color: rgba(23,24,28,.38); font-size: 16rpx; line-height: 1; letter-spacing: 1rpx; font-weight: 850; }
.mcard:nth-child(3n) .mcard-ic { background: var(--pop-coral); }
.mcard:nth-child(3n+1) .mcard-ic { background: var(--pop-lilac); }
.mcard-meta { flex: 1; min-width: 0; }
.mcard-brand { margin-bottom: 7rpx; font-size: 20rpx; font-weight: 650; color: var(--accent-deep); line-height: 1.35; }
.mcard-name { font-size: 31rpx; font-weight: 800; color: var(--ink); line-height: 1.35; }
.mcard-tag { margin-top: 8rpx; font-size: 24rpx; color: var(--ink-2); line-height: 1.5; }
.mcard-status { margin-top: 12rpx; font-size: 22rpx; font-weight: 600; }
.status-member { color: var(--accent-ink); }
.status-trial { color: var(--accent-strong); }
.status-used { color: var(--sub); }

/* 进入指示：右侧雪佛龙（点整卡进技能） */
.mcard-go { flex: 0 0 auto; align-self: center; display: flex; align-items: center; gap: 3rpx; color: var(--accent-deep); font-size: 20rpx; font-weight: 750; }
.mcard-go .ic { color: var(--accent); font-size: 26rpx; }
