/* 复用 Agent 市场（agents 页）样式，再补「添加到首页」按钮 */
@import "../agents/index.wxss";

.pin {
  flex-shrink: 0;
  align-self: center;
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  color: var(--accent, #FB923C);
  border: 1rpx solid var(--accent, #FB923C);
  background: transparent;
}
.pin.on {
  color: #9aa0ab;
  border-color: #d8dbe0;
}
