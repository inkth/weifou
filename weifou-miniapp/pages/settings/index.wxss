/* 设置页：令牌化表单（真源见 app.wxss）。 */
.page { padding: 32rpx 32rpx 120rpx; }
.card { margin-bottom: 24rpx; }
.section-title { font-size: 28rpx; font-weight: 600; margin-bottom: 24rpx; color: var(--ink); }

.field { margin-bottom: 24rpx; }
.label { font-size: 26rpx; color: var(--ink-2); margin-bottom: 12rpx; }
.input {
  height: 80rpx;
  background: var(--surface-sunken);
  border: var(--bw-thin) solid var(--border);
  border-radius: var(--r-md);
  padding: 0 24rpx;
  font-size: 30rpx;
}

.row { display: flex; align-items: center; margin-bottom: 24rpx; }
.flex-1 { flex: 1; }

.save { margin-top: 16rpx; }
.regen { margin-top: 16rpx; }
.danger { color: var(--danger); }
