<view class="page">
  <view class="card">
    <view class="section-title">我的形象</view>
    <view class="avatar-grid">
      <view
        class="avatar-cell {{selectedAvatar === item.id ? 'active' : ''}}"
        wx:for="{{avatarStyles}}"
        wx:key="id"
        bindtap="selectAvatar"
        data-id="{{item.id}}"
      >
        <avatar preset="{{item.id}}" name="{{realName}}" seed="{{item.id}}" size="96" static="{{selectedAvatar !== item.id}}"/>
        <view class="avatar-name">{{item.name}}</view>
      </view>
    </view>
    <button class="btn-primary save" bindtap="saveAvatar" disabled="{{savingAvatar}}">保存形象</button>
  </view>

  <view class="card">
    <view class="section-title">联系方式</view>
    <view class="field">
      <view class="label">微信号</view>
      <input class="input" placeholder="选填" value="{{form.contactWechat}}" maxlength="40" bindinput="onInput" data-key="contactWechat"/>
    </view>
    <view class="field">
      <view class="label">手机号</view>
      <input class="input" placeholder="选填" value="{{form.contactPhone}}" maxlength="40" bindinput="onInput" data-key="contactPhone" type="number"/>
    </view>
    <view class="row">
      <view class="label flex-1">允许访客查看</view>
      <switch checked="{{form.contactVisible}}" bindchange="onSwitch"/>
    </view>
    <button class="btn-primary save" bindtap="saveContact" disabled="{{saving}}">保存</button>
  </view>

  <view class="card">
    <view class="section-title">付费咨询</view>
    <view class="row">
      <view class="label flex-1">开放付费语音/视频咨询</view>
      <switch checked="{{consult.enabled}}" bindchange="onConsultSwitch"/>
    </view>
    <block wx:if="{{consult.enabled}}">
      <view class="field">
        <view class="label">30 分钟价格（元）</view>
        <input class="input" type="digit" value="{{consult.price30Yuan}}" bindinput="onConsultInput" data-key="price30Yuan"/>
      </view>
      <view class="field">
        <view class="label">60 分钟价格（元）</view>
        <input class="input" type="digit" value="{{consult.price60Yuan}}" bindinput="onConsultInput" data-key="price60Yuan"/>
      </view>
      <view class="field">
        <view class="label">咨询说明（选填）</view>
        <input class="input" placeholder="如：擅长 AI 产品 0-1 落地" value="{{consult.intro}}" maxlength="200" bindinput="onConsultInput" data-key="intro"/>
      </view>
    </block>
    <button class="btn-primary save" bindtap="saveConsult" disabled="{{savingConsult}}">保存咨询设置</button>
    <button class="btn-ghost regen" bindtap="goSlots" wx:if="{{consult.enabled}}">管理可约档期</button>
    <button class="btn-ghost regen" bindtap="goSessions">我的通话记录</button>
  </view>

  <view class="card">
    <view class="section-title">AI 主页</view>
    <button class="btn-ghost" bindtap="goEdit">修改我填写的内容</button>
    <button class="btn-ghost regen" bindtap="regenerate" disabled="{{regenerating}}">
      {{regenerating ? '重新生成中…' : '让 AI 重新生成主页'}}
    </button>
  </view>

  <view class="card">
    <button class="btn-ghost danger" bindtap="logout">退出登录</button>
  </view>
</view>
