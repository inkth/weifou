<view class="page" wx:if="{{profile}}">
  <!-- 晒点：刚生成完的庆祝时刻，分享意愿峰值 -->
  <view class="card fresh-card" wx:if="{{fresh && isMine && profile.persona}}">
    <view class="fresh-title">🎉 你的 AI 分身上线了</view>
    <view class="fresh-sub muted">它已经会替你回答：</view>
    <view class="fresh-starters">
      <view class="fresh-starter" wx:for="{{profile.persona.starters}}" wx:key="*this">「{{item}}」</view>
    </view>
    <view class="fresh-actions">
      <button class="btn-primary fresh-btn" open-type="share">发给朋友试试</button>
      <button class="btn-ghost fresh-btn" bindtap="goChat">我先试聊一下</button>
    </view>
    <!-- 首胜第三步：开启通知，让第一个访客动作就能找到主人 -->
    <view class="fresh-notify {{notifyAsked ? 'done' : ''}}" bindtap="enableNotify">
      {{notifyAsked ? '✓ 已开启 · 有人提问/留言会马上通知你' : '🔔 开启通知，有人来访第一时间找到你'}}
    </view>
  </view>

  <view class="hero card tier-{{stageTier}} stage-in" style="{{ambStyle}}">
    <view class="amb-layer">
      <view class="amb-wash"></view>
      <view class="amb-glow"></view>
      <view class="amb-blob amb-blob-1"></view>
    </view>
    <view class="hero-row">
      <image class="hero-ava" src="{{liheSrc}}" mode="aspectFill" wx:if="{{liheSrc}}"/>
      <view class="hero-ava hero-ava-toon" wx:elif="{{heroInitial}}">{{heroInitial}}</view>
      <view class="hero-ava hero-ava-ph" wx:else><view class="ic ic-user"></view></view>
      <view class="hero-meta">
        <view class="name">{{profile.realName}}</view>
        <view class="title-text muted">{{profile.title}}<text wx:if="{{profile.company}}"> · {{profile.company}}</text></view>
        <view class="city muted" wx:if="{{profile.city}}">{{profile.city}}</view>
      </view>
    </view>

    <view class="one-liner" wx:if="{{profile.persona}}">{{profile.persona.oneLiner}}</view>

    <view class="tags" wx:if="{{profile.persona}}">
      <view class="tag" wx:for="{{profile.persona.tags}}" wx:key="*this">{{item}}</view>
    </view>
  </view>

  <view class="card section" wx:if="{{profile.persona}}">
    <view class="section-title">关于 {{profile.realName}}</view>
    <view class="full-intro">{{profile.persona.fullIntro}}</view>
  </view>

  <view class="card section stats" wx:if="{{isMine && stats}}">
    <view class="stat">
      <view class="stat-num">{{stats.pv}}</view>
      <view class="stat-label muted">访问数</view>
    </view>
    <view class="stat">
      <view class="stat-num">{{stats.uv}}</view>
      <view class="stat-label muted">访客数</view>
    </view>
    <view class="stat">
      <view class="stat-num">{{stats.askCount}}</view>
      <view class="stat-label muted">问答数</view>
    </view>
  </view>

  <view class="actions">
    <button class="btn-accent" bindtap="goChat">问 {{profile.realName}} 的 AI 分身</button>
    <button class="btn-ghost" bindtap="exchangeCard" wx:if="{{!isMine}}">{{connected ? '✓ 已交换名片' : (hasOwnProfile ? '🤝 交换名片' : '🤝 建名片来交换')}}</button>
    <button class="btn-ghost" bindtap="onContact" wx:if="{{profile.contactVisible || isMine}}">联系本人</button>
    <button class="btn-ghost" open-type="share" wx:if="{{!isMine}}">分享给好友</button>
    <button class="btn-ghost" bindtap="goPoster" wx:if="{{isMine}}">生成分享海报</button>
    <button class="btn-ghost" bindtap="goSettings" wx:if="{{isMine}}">设置 / 重新生成</button>
  </view>

  <!-- 裂变：访客视图的平台线索（克制、不抢主人的转化场景） -->
  <view class="brand-foot muted" wx:if="{{!isMine}}" bindtap="goCreateOwn">微否 · 让你的 AI 分身替你先聊 ›</view>
</view>

<view wx:if="{{!profile && !loading}}" class="empty muted">主页不存在或加载失败</view>

