page { background: #15171c; }

.mr {
  min-height: 100vh; box-sizing: border-box; padding: 56rpx 40rpx 90rpx;
  background: radial-gradient(120% 80% at 50% 0%, #2a2118 0%, #15171c 55%);
}

/* 生成中 */
.mr-loading { padding-top: 220rpx; text-align: center; }
.mr-orb {
  width: 120rpx; height: 120rpx; margin: 0 auto 36rpx; border-radius: 50%;
  background: radial-gradient(circle at 35% 30%, #FFD9B0, #FB923C 60%, #B45309);
  box-shadow: 0 0 60rpx rgba(251, 146, 60, .5);
  animation: mr-pulse 1.6s ease-in-out infinite;
}
@keyframes mr-pulse {
  0%, 100% { transform: scale(1); opacity: .85; }
  50% { transform: scale(1.12); opacity: 1; }
}
.mr-loading-t { color: #cdd1d8; font-size: 28rpx; letter-spacing: 2rpx; }

/* 头部 + 锐评主视觉 */
.mr-head { text-align: center; margin: 24rpx 0 36rpx; }
.mr-eyebrow { color: #FB923C; font-size: 26rpx; letter-spacing: 6rpx; }
.mr-quip { color: #f4f1ea; font-size: 48rpx; font-weight: 800; line-height: 1.4; margin-top: 24rpx; }

/* 标签 */
.mr-tags { display: flex; flex-wrap: wrap; justify-content: center; gap: 16rpx; margin-bottom: 44rpx; }
.mr-tag {
  color: #FFD9B0; font-size: 26rpx; padding: 10rpx 28rpx; border-radius: 999rpx;
  background: rgba(251, 146, 60, .14); border: 1rpx solid rgba(251, 146, 60, .4);
}

/* 卡片 */
.mr-card {
  background: rgba(255, 255, 255, .05); border: 1rpx solid rgba(255, 255, 255, .08);
  border-radius: 28rpx; padding: 36rpx; margin-bottom: 24rpx;
}
.mr-card.soft { background: rgba(255, 255, 255, .03); }
.mr-card-label { color: #FB923C; font-size: 26rpx; font-weight: 600; margin-bottom: 16rpx; }
.mr-card.soft .mr-card-label { color: #9aa0ab; }
.mr-card-body { color: #e8e9ec; font-size: 31rpx; line-height: 1.7; }

.mr-foot { color: #6b7079; font-size: 22rpx; text-align: center; margin: 36rpx 0 20rpx; }

/* 按钮 */
.mr-btn {
  background: #FB923C; color: #fff; border-radius: 999rpx;
  font-size: 30rpx; padding: 22rpx 0; margin-top: 12rpx;
}
.mr-btn::after { border: none; }
.mr-btn.ghost { background: transparent; color: #cdd1d8; border: 1rpx solid rgba(255, 255, 255, .18); }

/* 空态 / 错误态 */
.mr-empty { padding-top: 200rpx; text-align: center; }
.mr-empty-t { color: #f4f1ea; font-size: 40rpx; font-weight: 700; margin-bottom: 20rpx; }
.mr-empty-s { color: #9aa0ab; font-size: 28rpx; line-height: 1.6; margin-bottom: 48rpx; padding: 0 40rpx; }
