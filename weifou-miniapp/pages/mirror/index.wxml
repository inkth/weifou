<view class="mr">

  <!-- 生成中 -->
  <view wx:if="{{loading}}" class="mr-loading">
    <view class="mr-orb"></view>
    <view class="mr-loading-t">分身正在端详你…</view>
  </view>

  <!-- 还没建分身 -->
  <view wx:elif="{{needProfile}}" class="mr-empty">
    <view class="mr-empty-t">我还不认识你</view>
    <view class="mr-empty-s">先花 30 秒建一个你的分身，我才看得懂你。</view>
    <button class="mr-btn" bindtap="goCreate">30 秒建我的分身</button>
  </view>

  <!-- 出错 -->
  <view wx:elif="{{error}}" class="mr-empty">
    <view class="mr-empty-s">{{error}}</view>
    <button class="mr-btn ghost" bindtap="reroll">再试一次</button>
  </view>

  <!-- 结果 -->
  <block wx:else>
    <view class="mr-head">
      <view class="mr-eyebrow">分身眼中的你</view>
      <view class="mr-quip">“{{quip}}”</view>
    </view>

    <view class="mr-tags">
      <text wx:for="{{tags}}" wx:key="*this" class="mr-tag">{{item}}</text>
    </view>

    <view class="mr-card">
      <view class="mr-card-label">我最欣赏你</view>
      <view class="mr-card-body">{{strength}}</view>
    </view>

    <view class="mr-card soft">
      <view class="mr-card-label">也想提醒你</view>
      <view class="mr-card-body">{{blindspot}}</view>
    </view>

    <view class="mr-foot">每次看，我都会从不同角度端详你</view>
    <button class="mr-btn ghost" bindtap="reroll">换个角度再看 →</button>
  </block>

</view>
