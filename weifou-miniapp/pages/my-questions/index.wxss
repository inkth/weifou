/* 我的提问：令牌化（真源见 app.wxss）。 */
.empty { text-align: center; padding: 80rpx 0; color: var(--faint); }
.mq-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8rpx; }
.mq-name { font-weight: 600; font-size: 30rpx; color: var(--ink); }
.mq-status { font-size: 24rpx; }
.mq-status.paid { color: var(--accent-strong); }
.mq-status.answered { color: var(--success); }
.mq-status.refunded { color: var(--faint); }
.mq-q { font-size: 28rpx; line-height: 1.5; color: var(--ink-2); margin-bottom: 8rpx; }
.mq-foot { font-size: 24rpx; }
