.empty { text-align: center; padding: 80rpx 0; }
.mq-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8rpx; }
.mq-name { font-weight: 600; font-size: 30rpx; }
.mq-status { font-size: 24rpx; }
.mq-status.paid { color: #18b690; }
.mq-status.answered { color: #16a34a; }
.mq-status.refunded { color: #999; }
.mq-q { font-size: 28rpx; line-height: 1.5; color: #333; margin-bottom: 8rpx; }
.mq-foot { font-size: 24rpx; }
