page { background: #f4f5f9; }
.center-page { min-height: 100vh; color: #17181c; padding-bottom: calc(60rpx + env(safe-area-inset-bottom)); }
.hero { position: relative; min-height: 470rpx; overflow: hidden; padding: 62rpx 34rpx 58rpx; color: #fff; background: linear-gradient(150deg, #171827 0%, #22233e 62%, #2b2c4c 100%); }
.hero-grid { position: absolute; inset: 0; opacity: .12; background-image: linear-gradient(rgba(255,255,255,.15) 1rpx, transparent 1rpx), linear-gradient(90deg, rgba(255,255,255,.15) 1rpx, transparent 1rpx); background-size: 60rpx 60rpx; transform: rotate(-8deg) scale(1.3); }
.hero-glow { position: absolute; width: 430rpx; height: 430rpx; right: -140rpx; top: -90rpx; border-radius: 50%; background: radial-gradient(circle, rgba(119,114,200,.64), transparent 68%); }
.hero-content { position: relative; z-index: 1; }
.hero-eyebrow { color: rgba(255,255,255,.55); font-size: 20rpx; letter-spacing: 4rpx; font-weight: 750; }
.live-dot { display: inline-block; width: 9rpx; height: 9rpx; margin-right: 10rpx; border-radius: 50%; background: #9ad9c1; box-shadow: 0 0 16rpx rgba(154,217,193,.7); }
.hero-title { margin-top: 20rpx; font-size: 54rpx; line-height: 1.2; font-weight: 850; letter-spacing: -2rpx; }
.hero-sub { margin-top: 12rpx; color: rgba(255,255,255,.63); font-size: 23rpx; }
.code-card { display: flex; align-items: center; justify-content: space-between; margin-top: 44rpx; padding: 24rpx 26rpx; border: 2rpx solid rgba(255,255,255,.14); border-radius: 25rpx; background: rgba(255,255,255,.08); }
.code-label { color: rgba(255,255,255,.52); font-size: 20rpx; }
.code-value { margin-top: 6rpx; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 35rpx; line-height: 1.2; letter-spacing: 4rpx; font-weight: 800; }
.copy-btn { padding: 14rpx 22rpx; border-radius: 16rpx; color: #302e55; background: #fff; font-size: 23rpx; font-weight: 800; }
.loading-wrap { padding: 32rpx; }.loading-card { height: 280rpx; margin-bottom: 22rpx; border-radius: 30rpx; }
.share-panel { position: relative; z-index: 2; display: flex; gap: 24rpx; margin: -25rpx 32rpx 0; padding: 30rpx; border: 2rpx solid #e7e8ee; border-radius: 32rpx; background: #fff; box-shadow: 0 18rpx 54rpx rgba(34,32,56,.10); }
.share-copy { min-width: 0; flex: 1; }.share-title { font-size: 31rpx; font-weight: 850; }.share-desc { margin-top: 10rpx; color: #6d6f79; font-size: 21rpx; line-height: 1.58; }
.share-btn { width: 100%; height: 72rpx; margin-top: 22rpx; border-radius: 18rpx; color: #fff; background: #7772c8; font-size: 24rpx; line-height: 72rpx; font-weight: 800; }
.qr-wrap { width: 164rpx; flex: none; text-align: center; }.qr-image, .qr-loading, .qr-retry { width: 164rpx; height: 164rpx; border-radius: 18rpx; }.qr-image { display: block; }.qr-loading, .qr-retry { display: flex; align-items: center; justify-content: center; color: #7772c8; background: #efedfa; font-size: 21rpx; }.qr-tip { margin-top: 8rpx; color: #a0a2ac; font-size: 18rpx; }
.section-head { display: flex; align-items: flex-end; justify-content: space-between; margin: 58rpx 36rpx 20rpx; }.section-eyebrow { color: #7772c8; font-size: 18rpx; letter-spacing: 3rpx; font-weight: 800; }.section-title { margin-top: 5rpx; font-size: 35rpx; font-weight: 850; }.update-note, .record-count { color: #a0a2ac; font-size: 19rpx; }
.stat-primary { display: flex; align-items: center; margin: 0 32rpx; padding: 32rpx 10rpx; border-radius: 30rpx; color: #fff; background: #171827; box-shadow: 0 14rpx 38rpx rgba(23,24,39,.13); }.stat-main { min-width: 0; flex: 1; text-align: center; }.stat-value { font-size: 42rpx; line-height: 1.2; font-weight: 850; }.stat-value text { margin-left: 2rpx; font-size: 22rpx; }.stat-label { margin-top: 8rpx; color: rgba(255,255,255,.52); font-size: 19rpx; }.stat-divider { width: 1rpx; height: 54rpx; background: rgba(255,255,255,.13); }
.stat-secondary { display: flex; gap: 16rpx; margin: 17rpx 32rpx 0; }.mini-stat { flex: 1; padding: 23rpx 8rpx; border: 2rpx solid #e7e8ee; border-radius: 24rpx; background: #fff; text-align: center; }.mini-value { color: #4f4a8b; font-size: 32rpx; font-weight: 850; }.mini-label { margin-top: 6rpx; color: #8d909b; font-size: 18rpx; }
.definition-card { margin: 20rpx 32rpx 0; padding: 24rpx 26rpx; border-radius: 24rpx; color: #666874; background: #ececf5; font-size: 21rpx; line-height: 1.6; }.definition-title { margin-bottom: 10rpx; color: #47427d; font-size: 22rpx; font-weight: 800; }.definition-row { display: flex; align-items: flex-start; margin-top: 7rpx; }.definition-dot { width: 10rpx; height: 10rpx; flex: none; margin: 11rpx 12rpx 0 0; border-radius: 50%; background: #7772c8; }.definition-dot.paid { background: #4f9d78; }
.recent-head { margin-top: 56rpx; }.record-list { margin: 0 32rpx; overflow: hidden; border: 2rpx solid #e7e8ee; border-radius: 28rpx; background: #fff; }.record { display: flex; align-items: center; min-height: 108rpx; padding: 20rpx 22rpx; border-bottom: 2rpx solid #f0f1f5; }.record:last-child { border-bottom: none; }.record-avatar { width: 58rpx; height: 58rpx; flex: none; display: flex; align-items: center; justify-content: center; border-radius: 19rpx; color: #4f4a8b; background: #efedfa; font-size: 20rpx; font-weight: 800; }.record-copy { min-width: 0; flex: 1; margin-left: 17rpx; }.record-name { font-size: 24rpx; font-weight: 750; }.record-time { margin-top: 4rpx; color: #a0a2ac; font-size: 18rpx; }.record-tags { display: flex; gap: 7rpx; }.record-tag { padding: 6rpx 10rpx; border-radius: 9rpx; color: #7772c8; background: #efedfa; font-size: 17rpx; }.record-tag.new { color: #506f80; background: #e2eef4; }.record-tag.paid { color: #3f805f; background: #e7f4ee; }
.empty-record { margin: 0 32rpx; padding: 52rpx 30rpx; border: 2rpx solid #e7e8ee; border-radius: 30rpx; background: #fff; text-align: center; }.empty-orbit { width: 76rpx; height: 76rpx; margin: 0 auto; border: 2rpx solid #c9c3eb; border-radius: 50%; display: flex; align-items: center; justify-content: center; }.empty-orbit view { width: 28rpx; height: 28rpx; border-radius: 50%; background: #7772c8; box-shadow: 0 0 24rpx rgba(119,114,200,.35); }.empty-title { margin-top: 22rpx; font-size: 29rpx; font-weight: 800; }.empty-desc { margin-top: 9rpx; color: #8d909b; font-size: 21rpx; }.empty-share { width: 260rpx; height: 76rpx; margin-top: 24rpx; border-radius: 18rpx; color: #fff; background: #17181c; font-size: 24rpx; line-height: 76rpx; font-weight: 800; }
.footer { margin-top: 52rpx; color: #b5b7c0; text-align: center; font-size: 19rpx; }
