.page { padding: 24rpx 32rpx 60rpx; }

.muted { color: #9a9da6; }

.tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #6b6e78;
  background: #fff;
  border-radius: 999rpx;
}
.tab.on {
  background: #1f2330;
  color: #fff;
  font-weight: 600;
}

.tip { font-size: 24rpx; margin-bottom: 20rpx; line-height: 1.5; }
.empty { text-align: center; padding-top: 120rpx; font-size: 28rpx; }

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}
.card.add {
  text-align: center;
  color: #1f2330;
  font-weight: 600;
  border: 2rpx dashed #d4d6dd;
  background: transparent;
}
.add-row { display: flex; gap: 16rpx; margin-bottom: 20rpx; }
.add-row .card.add { flex: 1; margin-bottom: 0; padding: 24rpx 12rpx; font-size: 26rpx; }

.q { font-size: 30rpx; font-weight: 600; color: #1f2330; line-height: 1.5; }
.note { font-size: 28rpx; color: #2b2e38; line-height: 1.6; margin-top: 8rpx; word-break: break-all; }
.meta { font-size: 22rpx; margin-top: 12rpx; }

.ops { display: flex; align-items: center; gap: 20rpx; margin-top: 24rpx; }
.op {
  padding: 12rpx 32rpx;
  font-size: 26rpx;
  border-radius: 999rpx;
  background: #f5f6fa;
  color: #2b2e38;
}
.op.primary { background: #1f2330; color: #fff; }
.op.contact { margin-top: 20rpx; display: inline-block; word-break: break-all; }
.ops .meta { margin-top: 0; flex: 1; }

.lead-head { display: flex; justify-content: space-between; align-items: baseline; }
.lead-name { font-size: 28rpx; font-weight: 600; color: #1f2330; }
