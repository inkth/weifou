/* 收件箱 = 主人后台：清新浅色令牌（真源见 app.wxss），横滑胶囊 Tab + 白卡列表。 */
.page { padding: 24rpx 32rpx 60rpx; }

.muted { color: var(--sub); }

/* 横滑胶囊 Tab：五个分区不挤压，活跃态墨青实底 */
.tabs {
  white-space: nowrap;
  margin: 0 -32rpx 24rpx;
  padding: 0 32rpx;
}
.tab {
  display: inline-block;
  padding: 14rpx 30rpx;
  margin-right: 14rpx;
  font-size: 26rpx;
  color: var(--ink-2);
  background: var(--surface);
  border: var(--bw-thin) solid var(--ink);
  border-radius: var(--r-full);
  transition: background 0.16s var(--ease), color 0.16s var(--ease);
}
.tab:last-child { margin-right: 32rpx; }
.tab.on {
  background: var(--ink);
  border-color: var(--ink);
  color: #fff;
  font-weight: 600;
  box-shadow: var(--shadow-hair);
}

.tip { font-size: 24rpx; margin-bottom: 20rpx; line-height: 1.5; }
.empty { text-align: center; padding-top: 120rpx; font-size: 28rpx; }

/* 空收件箱破局：把"还没人来"变成可行动的分享下一步（结构用 app.wxss 空态三层） */
.empty-wrap { padding-top: 100rpx; }
.es-btn {
  display: inline-block; margin-top: 32rpx;
  background: var(--ink); color: #fff;
  border: var(--bw) solid var(--ink);
  border-radius: var(--r-full); font-size: 26rpx;
  padding: 0 44rpx; line-height: 78rpx;
  box-shadow: var(--shadow-card);
  transition: transform 0.12s var(--ease), box-shadow 0.12s var(--ease);
}
.es-btn:active { transform: translate(4rpx, 4rpx); box-shadow: 0 0 0 var(--ink); }

.card {
  background: var(--surface);
  border: var(--bw) solid var(--ink);
  border-radius: var(--r-xl);
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-card);
}
.card.add {
  text-align: center;
  color: var(--ink);
  font-weight: 600;
  border: var(--bw-thin) dashed var(--ink);
  background: transparent;
  box-shadow: none;
}
.card.add:active { background: var(--fill-pressed); }
.add-row { display: flex; gap: 16rpx; margin-bottom: 20rpx; }
.add-row .card.add { flex: 1; margin-bottom: 0; padding: 24rpx 12rpx; font-size: 26rpx; }

.q { font-size: 30rpx; font-weight: 600; color: var(--ink); line-height: 1.5; }
.note { font-size: 28rpx; color: var(--ink-2); line-height: 1.6; margin-top: 8rpx; word-break: break-all; }
.meta { font-size: 22rpx; margin-top: 12rpx; }

.ops { display: flex; align-items: center; gap: 20rpx; margin-top: 24rpx; }
.op {
  padding: 12rpx 32rpx;
  font-size: 26rpx;
  border-radius: var(--r-full);
  background: var(--surface);
  color: var(--ink);
  border: var(--bw-thin) solid var(--ink);
  transition: transform 0.12s var(--ease), box-shadow 0.12s var(--ease);
}
.op:active { transform: translate(4rpx, 4rpx); box-shadow: 0 0 0 var(--ink); }
.op.primary { background: var(--ink); color: #fff; }
.op.contact { margin-top: 20rpx; display: inline-block; word-break: break-all; }
.ops .meta { margin-top: 0; flex: 1; }

.lead-head { display: flex; justify-content: space-between; align-items: baseline; }
.lead-name { font-size: 28rpx; font-weight: 600; color: var(--ink); }

/* 主人召回：开启「新提问」微信订阅提醒（仅订阅模板已配时显示）——奶油黄贴条 */
.notify-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: var(--pop-butter);
  color: var(--pop-butter-ink);
  border: var(--bw-thin) solid var(--ink);
  border-radius: var(--r-md);
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
  font-size: 26rpx;
  box-shadow: var(--shadow-hair);
}
.notify-ico { font-size: 30rpx; color: var(--pop-butter-ink); }
