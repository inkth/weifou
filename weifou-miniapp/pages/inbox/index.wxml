<view class="page">
  <view class="hd" style="padding-top:calc({{statusBarH}}px + 16rpx)">
    <view>
      <view class="hd-kicker">AI RECEPTION</view>
      <view class="hd-title">消息</view>
      <view class="hd-sub">分身接住的每一次来访，都在这里</view>
    </view>
    <view class="hd-meta {{pendingCount ? 'has-pending' : ''}}"><text class="hd-meta-dot"></text>{{pendingCount ? pendingCount + ' 条待回复' : '已全部处理'}}</view>
  </view>

  <!-- 真网络失败：可重试条（不把「挂了」伪装成「没消息」） -->
  <view wx:if="{{errored}}" class="retry-row" bindtap="load">
    <text>加载失败，点此重试 ›</text>
  </view>

  <!-- 主人召回：开启「新提问」微信订阅提醒（仅订阅模板已配时显示） -->
  <view wx:if="{{canNotify}}" class="notify-row" bindtap="enableNotify">
    <view class="ic ic-bell notify-ico"></view>
    <text>新提问微信提醒 ›</text>
  </view>

  <view wx:if="{{loading}}" class="empty muted">加载中…</view>

  <block wx:if="{{!loading}}">
    <!-- 空态破局：把「还没人来」变成可行动的分享下一步 -->
    <view wx:if="{{!questions.length}}" class="empty-wrap">
      <view class="empty-ic"><view class="ic ic-inbox"></view></view>
      <view class="empty-title">还没有人来问</view>
      <view class="empty-sub">有人匿名提问后，分身会先替你答，你可以再补一句</view>
      <button wx:if="{{profileId}}" class="es-btn" open-type="share">分享你的问答箱，让人来问 →</button>
    </view>

    <view wx:else>
      <view
        class="card {{item.escalatedAt ? 'urgent' : ''}}"
        wx:for="{{questions}}"
        wx:key="id"
        bindtap="reply"
        data-id="{{item.id}}"
        data-q="{{item.question}}"
        data-status="{{item.status}}"
      >
        <view class="lead-head">
          <view class="lead-person"><view class="lead-avatar">访</view><text class="lead-name">匿名访客</text></view>
          <text class="meta muted">{{item.timeText}}</text>
        </view>
        <view class="q">{{item.question}}</view>
        <view class="card-foot"><view class="meta status {{item.needsReply ? 'todo' : ''}}"><text class="status-dot"></text>{{item.statusText}}</view><text wx:if="{{item.needsReply}}" class="reply-link">去回复 ›</text></view>
      </view>
    </view>
  </block>
</view>
