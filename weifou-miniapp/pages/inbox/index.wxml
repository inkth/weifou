<view class="page">
  <view class="tip muted">你的 AI 分身替你接待的访客提问都在这。分身已先答过，亲自补一句会让对方更惊喜。</view>

  <!-- 真网络失败：可重试条（不把「挂了」伪装成「没消息」） -->
  <view wx:if="{{errored}}" class="retry-row" bindtap="load">
    <text>加载失败，点此重试 ›</text>
  </view>

  <!-- 主人召回：开启「新提问」微信订阅提醒（仅订阅模板已配时显示） -->
  <view wx:if="{{canNotify}}" class="notify-row" bindtap="enableNotify">
    <view class="ic ic-bell notify-ico"></view>
    <text>开启提醒：有人问你的分身时微信通知我 ›</text>
  </view>

  <view wx:if="{{loading}}" class="empty muted">加载中…</view>

  <block wx:if="{{!loading}}">
    <!-- 空态破局：把「还没人来」变成可行动的分享下一步 -->
    <view wx:if="{{!questions.length}}" class="empty-wrap">
      <view class="empty-ic"><view class="ic ic-inbox"></view></view>
      <view class="empty-title">还没有人来问</view>
      <view class="empty-sub">有人匿名提问后，分身会先替你答，你可以再补一句</view>
      <button wx:if="{{profileId}}" class="es-btn" open-type="share">分享你的问答箱，让人来问 →</button>
    </view>

    <view wx:else>
      <view wx:if="{{pendingCount}}" class="tip muted">有 {{pendingCount}} 条还等着你亲自回一句。</view>
      <view
        class="card {{item.escalatedAt ? 'urgent' : ''}}"
        wx:for="{{questions}}"
        wx:key="id"
        bindtap="reply"
        data-id="{{item.id}}"
        data-q="{{item.question}}"
        data-status="{{item.status}}"
      >
        <view class="lead-head">
          <text class="lead-name">匿名访客</text>
          <text class="meta muted">{{item.timeText}}</text>
        </view>
        <view class="q">{{item.question}}</view>
        <view wx:if="{{item.aiAnswer}}" class="note">分身答：{{item.aiAnswer}}</view>
        <view wx:if="{{item.status === 'answered' && item.answer}}" class="note mine">你答：{{item.answer}}</view>
        <view class="meta status {{item.needsReply ? 'todo' : ''}}">{{item.statusText}}{{item.needsReply ? ' ›' : ''}}</view>
      </view>
    </view>
  </block>
</view>
