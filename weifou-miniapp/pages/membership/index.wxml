<view class="wrap">
  <view class="hero">
    <view class="ic ic-crown crown"></view>
    <view class="h-title">微否会员</view>
    <view class="h-sub">一价畅用全部 AI 助手</view>
  </view>

  <view wx:if="{{loading}}" class="state">加载中…</view>

  <block wx:else>
    <view wx:if="{{isMember}}" class="member-card">
      <view class="mc-on">会员有效中 ✅</view>
      <view class="mc-exp" wx:if="{{expiresText}}">有效期至 {{expiresText}}</view>
    </view>

    <view class="benefits">
      <view class="bf"><view class="ic ic-apps bf-ic"></view>全部精选 Agent 畅用</view>
      <view class="bf"><text class="bf-ic">∞</text>不限次数，随时开练</view>
      <view class="bf"><view class="ic ic-sparkle bf-ic"></view>新上线 Agent 自动包含</view>
    </view>

    <!-- 安卓：套餐 + 微信支付 -->
    <block wx:if="{{canPay}}">
      <view class="plans">
        <view wx:for="{{plans}}" wx:key="id" class="plan" bindtap="openPlan" data-id="{{item.id}}">
          <view class="pl-name">{{item.name}}</view>
          <view class="pl-price"><text class="pl-num">¥{{item.priceYuan}}</text></view>
          <view class="pl-day" wx:if="{{item.perDay}}">约 ¥{{item.perDay}}/天</view>
        </view>
      </view>
      <view class="pay-tip">点套餐用微信支付开通{{isMember ? '（续费在原有效期上叠加）' : ''}}</view>
    </block>

    <!-- iOS：小程序内不做支付/外链引导（合规）→ 关注服务号承接 + 留意向 -->
    <block wx:else>
      <view class="ios-box">
        <view class="ios-title">iOS 会员开通</view>
        <view class="ios-desc">关注「微否」服务号，我们把开通入口发给你；也可以先留个意向，开放时第一时间通知你。</view>
        <official-account></official-account>
        <button wx:if="{{!intentDone}}" class="ios-btn" bindtap="onIntent">留个意向，通知我</button>
        <view wx:else class="ios-done">已记录 ✅ 我们会通知你</view>
      </view>
    </block>
  </block>
</view>
