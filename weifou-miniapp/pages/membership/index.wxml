<view class="wrap">
  <view class="hero">
    <view class="ic ic-crown crown"></view>
    <view class="h-title">人类基本功计划</view>
    <view class="h-sub">一次订阅，练习 AI 时代依然稀缺的七种能力</view>
  </view>

  <view wx:if="{{loading}}" class="state">加载中…</view>

  <block wx:else>
    <view wx:if="{{isMember}}" class="member-card">
      <view class="mc-on">会员有效中 ✅</view>
      <view class="mc-exp" wx:if="{{expiresText}}">有效期至 {{expiresText}}</view>
    </view>

    <!-- 被邀人首开加赠：只对「经好友邀请进入且还不是会员」的人展示 -->
    <view wx:if="{{isInvitee && !isMember}}" class="ref-banner">
      <text class="ref-banner-tag">好友邀请专享</text>
      <text class="ref-banner-text">首次开通额外加赠：月付 +7 天、年付 +31 天，支付后自动到账</text>
    </view>

    <view class="benefits">
      <view class="bf"><view class="ic ic-apps bf-ic"></view>解锁七条完整能力路径</view>
      <view class="bf"><text class="bf-ic">∞</text>全部进阶关卡与复习挑战</view>
      <view class="bf"><view class="ic ic-sparkle bf-ic"></view>后续新增实战课程自动包含</view>
    </view>

    <!-- 虚拟支付：iOS / 安卓统一（iOS 走苹果 IAP，安卓走微信虚拟支付） -->
    <block wx:if="{{canPay}}">
      <view class="plans">
        <view wx:for="{{plans}}" wx:key="id" class="plan" bindtap="openPlan" data-id="{{item.id}}">
          <view class="pl-name">{{item.name}}</view>
          <view class="pl-price">
            <text class="pl-num">¥{{item.priceYuan}}</text>
            <text wx:if="{{item.origYuan}}" class="pl-orig">¥{{item.origYuan}}</text>
          </view>
          <view class="pl-day" wx:if="{{item.perDay}}">约 ¥{{item.perDay}}/天</view>
          <view wx:if="{{item.saveText}}" class="pl-save">{{item.saveText}}</view>
        </view>
      </view>
      <view class="pay-tip">点套餐开通{{isMember ? '（续费在原有效期上叠加）' : ''}}</view>
    </block>

    <!-- 虚拟支付未配置时由 clientcfg 关闭入口 -->
    <block wx:else>
      <view class="ios-box">
        <view class="ios-title">会员开通</view>
        <view class="ios-desc">会员开通暂未开放，敬请期待。</view>
      </view>
    </block>

    <!-- 邀请好友：奖励挂「好友完成开通」，不挂分享动作（利诱分享红线） -->
    <view wx:if="{{refCode}}" class="ref-card">
      <view class="ref-title">邀请好友，同得会员时长</view>
      <view class="ref-rule">好友经你邀请首次开通：TA 买月付你得 1 个月、买年付你得 2 个月，TA 也额外加赠 7～31 天</view>
      <view wx:if="{{invitedCount > 0 || pendingDays > 0 || grantedDays > 0}}" class="ref-stats">
        已邀请 {{invitedCount}} 人<text wx:if="{{pendingDays > 0}}"> · 待到账 {{pendingDays}} 天</text><text wx:if="{{grantedDays > 0}}"> · 已到账 {{grantedDays}} 天</text>
      </view>
      <button class="ref-btn" open-type="share">邀请好友</button>
      <view class="ref-note">奖励在好友开通满 7 天后自动到账，只送时长不返现金</view>
    </view>
  </block>
</view>
