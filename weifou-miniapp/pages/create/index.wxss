.page { padding: 32rpx 32rpx 120rpx; }

.section {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(31, 35, 48, 0.04);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2330;
  margin-bottom: 24rpx;
}

.field { margin-bottom: 32rpx; }
.field:last-child { margin-bottom: 0; }

.label {
  font-size: 26rpx;
  color: #4a5070;
  margin-bottom: 16rpx;
}

.input {
  height: 80rpx;
  background: #f5f6fa;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
}

.textarea {
  width: 100%;
  min-height: 140rpx;
  background: #f5f6fa;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 30rpx;
  line-height: 1.6;
}

.actions {
  margin-top: 24rpx;
}
.hint { text-align: center; font-size: 24rpx; margin-top: 16rpx; }

/* —— 沟通风格选择 —— */
.optional { font-size: 24rpx; color: #9aa0ad; font-weight: 400; }
.style-chips { display: flex; flex-wrap: wrap; gap: 16rpx; margin-top: 16rpx; }
.style-chip {
  flex: 1 1 40%;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  background: #f5f6fa;
  border: 2rpx solid transparent;
}
.style-chip.sel {
  background: #eef1ff;
  border-color: #1f2330;
}
.style-label { font-size: 28rpx; font-weight: 600; color: #1f2330; }
.style-sub { font-size: 22rpx; color: #9aa0ad; margin-top: 4rpx; }
.hint.muted { font-size: 22rpx; margin-top: 12rpx; }

/* —— 快速创建（裂变通道） —— */
.quick-banner { padding: 24rpx 8rpx 8rpx; }
.quick-title { font-size: 38rpx; font-weight: 700; color: #1f2330; }
.quick-sub { font-size: 26rpx; margin-top: 8rpx; }
.switch-full { text-align: center; font-size: 26rpx; margin-top: 20rpx; padding: 12rpx; }
