.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 16rpx 28rpx calc(env(safe-area-inset-bottom) + 140rpx);
}
.hd { padding: 16rpx 4rpx 8rpx; }
.hd-title { font-size: 46rpx; font-weight: 700; color: #1f2330; }

.notice {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 16rpx 0 8rpx;
  padding: 26rpx 28rpx;
  background: linear-gradient(135deg, #fff3e9, #ffe9d6);
  border-radius: 22rpx;
}
.notice:active { opacity: 0.94; }
.notice-l { display: flex; align-items: center; gap: 18rpx; }
.notice-ic { font-size: 44rpx; }
.notice-title { font-size: 30rpx; font-weight: 700; color: #9a4d12; }
.notice-sub { margin-top: 4rpx; font-size: 24rpx; color: #b8763a; }
.notice-badge {
  min-width: 40rpx;
  height: 40rpx;
  padding: 0 12rpx;
  box-sizing: border-box;
  border-radius: 100rpx;
  background: var(--accent);
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 40rpx;
  text-align: center;
}
.notice-arrow { font-size: 40rpx; color: #c9923f; }

.sec-title { margin: 28rpx 4rpx 14rpx; font-size: 28rpx; font-weight: 600; color: #6b7180; }

.state { padding: 70rpx 0; text-align: center; color: #9aa0ad; font-size: 28rpx; line-height: 1.6; }
.state-sub { margin-top: 8rpx; font-size: 24rpx; color: #b3b8c2; }
.link { color: #fb923c; }

.row {
  display: flex;
  align-items: center;
  gap: 22rpx;
  margin-bottom: 16rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 22rpx;
  box-shadow: 0 4rpx 20rpx rgba(31, 35, 48, 0.04);
}
.row:active { transform: scale(0.995); }
.ava { width: 88rpx; height: 88rpx; border-radius: 50%; flex: 0 0 auto; }
.ava-fb {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f0f1f5;
  color: #6b7180;
  font-size: 34rpx;
  font-weight: 600;
}
.row-body { flex: 1 1 auto; min-width: 0; }
.row-top { display: flex; align-items: baseline; justify-content: space-between; }
.row-name { font-size: 30rpx; font-weight: 600; color: #1f2330; }
.row-time { font-size: 22rpx; color: #b3b8c2; }
.row-last {
  margin-top: 6rpx;
  font-size: 26rpx;
  color: #8a90a0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
