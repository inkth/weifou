<view class="wrap">
  <view class="head">
    <view class="h-title">人类基本功计划</view>
    <view class="h-sub">AI 越强，人的基本功越重要</view>
  </view>

  <view wx:if="{{loading}}" class="state">加载中…</view>

  <view wx:elif="{{blocked}}" class="state">当前环境暂不支持该功能，请在 Android 微信中体验。</view>

  <block wx:else>
    <view class="mbr-banner {{isMember ? 'on' : ''}}" bindtap="goMembership">
      <view class="ic ic-crown mb-crown"></view>
      <text class="mb-text">{{isMember ? '全课会员有效中 · 七条路径畅用' : '加入计划 · 解锁全部能力路径'}}</text>
      <text class="mb-arrow" wx:if="{{!isMember}}">去开通 ›</text>
    </view>

    <view class="list">
      <view
        wx:for="{{agents}}"
        wx:key="id"
        class="card"
        bindtap="open"
        data-id="{{item.id}}"
        data-name="{{item.name}}"
      >
        <view class="aic" style="background: {{item.accent}}1a; color: {{item.accent}};">{{item.icon}}</view>
        <view class="body">
          <view class="name">{{item.name}}</view>
          <view class="tagline">{{item.tagline}}</view>
          <view class="guide" wx:if="{{item.guide}}">{{item.subject}} · 闯关搭档 {{item.guide}}</view>
          <view class="meta" wx:if="{{item.status}}">
            <text class="status status-{{item.statusKind}}">{{item.status}}</text>
          </view>
        </view>
        <view class="ic ic-chevron arrow"></view>
      </view>

      <view wx:if="{{agents.length === 0}}" class="state">暂无可用工具</view>
    </view>
  </block>
</view>
