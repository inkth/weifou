<view class="squad">

  <view class="sq-top" style="padding-top:{{statusBarH}}px">
    <view class="sq-eyebrow">{{greeting}}</view>
    <view class="sq-h1">想办成<text class="hl">什么？</text></view>
  </view>

  <!-- 首屏加载骨架：避免 FALLBACK → 真数据的闪跳 -->
  <block wx:if="{{loading && !loaded}}">
    <view class="skel sk-hero"></view>
    <view class="skel sk-acard"></view>
    <view class="skel sk-acard"></view>
  </block>

  <block wx:else>

  <!-- 网络失败可重试条（区别于「新用户空态」的 demo 卡） -->
  <view wx:if="{{errored}}" class="retry" hover-class="retry-press" hover-stay-time="0" bindtap="retry">
    <text class="retry-ic">↻</text>
    <text class="retry-txt">没能连上，点这里重试</text>
  </view>

  <!-- AI 名片大卡：头像 + 数据 dashboard -->
  <view class="hero" hover-class="card-press" hover-stay-time="0" bindtap="enterChief">
    <view wx:if="{{chief.online}}" class="hero-sticker">● 在线</view>
    <view class="hero-top">
      <view class="hero-av">{{chief.initial}}<view wx:if="{{chief.online}}" class="hero-dot"></view></view>
      <view class="hero-id">
        <view class="hero-name">{{chief.name}}</view>
        <view class="hero-line">{{chief.line}}</view>
      </view>
      <view class="ic ic-chevron hero-go"></view>
    </view>

    <view wx:if="{{chief.stats}}" class="hero-stats">
      <view class="hstat" wx:for="{{chief.stats}}" wx:key="label">
        <view class="hstat-n">{{item.n}}</view>
        <view class="hstat-l">{{item.label}}</view>
      </view>
    </view>
  </view>

  <view wx:if="{{specialists.length}}" class="sec-label">我的 Agent</view>

  <!-- Agent 大卡 -->
  <view class="acard" wx:for="{{specialists}}" wx:key="id"
        data-id="{{item.id}}" data-name="{{item.name}}" data-kind="{{item.kind}}"
        hover-class="card-press" hover-stay-time="0"
        bindtap="enterSpecialist" bindlongpress="removeSpecialist">
    <view class="acard-top">
      <view class="acard-ic"><text>{{item.initial}}</text></view>
      <view class="acard-meta">
        <view class="acard-name">{{item.name}}</view>
        <view class="acard-tag {{item.nudge ? 'nudge' : ''}}">{{item.line}}</view>
      </view>
    </view>
    <view class="acard-foot">
      <view wx:if="{{item.pill}}" class="acard-pill">{{item.pill}}</view>
      <view class="acard-cta">去学习<view class="ic ic-arrow acard-cta-ic"></view></view>
    </view>
  </view>

  </block>

</view>
