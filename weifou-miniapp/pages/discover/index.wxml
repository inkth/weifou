<view class="squad">

  <view class="sq-top" style="padding-top:{{statusBarH}}px">
    <view class="sq-h1">想办成什么？</view>
    <view class="sq-sub">你的 AI 名片和 Agent，都在等你一句话</view>
  </view>

  <!-- 总管大卡（关系锚 / 唯一有人格的脸）-->
  <view class="chief art art-{{chief.tier}}" bindtap="enterChief">
    <view class="art-glow"></view>
    <view class="chief-av">{{chief.initial}}</view>
    <view class="chief-meta">
      <view class="chief-name">{{chief.name}}</view>
      <view class="chief-line">{{chief.line}}</view>
    </view>
    <view class="ic ic-arrow chief-go"></view>
  </view>

  <!-- 专才卡（平台工具 Agent / 种子兜底）-->
  <view class="spec" wx:for="{{specialists}}" wx:key="id"
        data-id="{{item.id}}" data-name="{{item.name}}" data-real="{{item.real}}" data-kind="{{item.kind}}"
        bindtap="enterSpecialist">
    <view class="spec-av art art-{{item.tier}}">
      <view class="art-glow"></view>
      <text>{{item.initial}}</text>
    </view>
    <view class="spec-meta">
      <view class="spec-name">{{item.name}}</view>
      <view class="spec-line">{{item.line}}</view>
    </view>
    <view class="ic ic-chevron spec-go"></view>
  </view>

  <!-- 召新 -->
  <view class="add" bindtap="addAgent">
    <view class="ic ic-plus"></view>
    <text>交给它一件你想办成的事</text>
  </view>

</view>
