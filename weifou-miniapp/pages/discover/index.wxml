<view class="home-shell">
  <view class="ambient ambient-a"></view>
  <view class="ambient ambient-b"></view>

  <view class="topbar" style="padding-top:{{statusBarH}}px">
    <view class="brand-row"><text class="brand-star">✦</text><text>WEIFOU</text><text class="brand-cn">微否</text></view>
    <view class="settings-btn {{editing ? 'editing' : ''}}" hover-class="settings-btn-press" bindtap="toggleEditor">
      <view class="settings-dot"></view>
      <text>{{editing ? '完成' : (chief.hasProfile ? '编辑' : '开始')}}</text>
    </view>
  </view>

  <block wx:if="{{loading && !loaded}}">
    <view class="skel stage-skeleton"></view>
  </block>

  <block wx:else>
    <view wx:if="{{errored}}" class="retry" hover-class="retry-press" bindtap="retry">
      <text class="retry-ic">↻</text>
      <text>资料暂未更新，点此重试</text>
    </view>

    <view class="identity-stage stage-dark stage-in tier-{{chief.stageTier}} {{chief.hasProfile ? '' : 'stage-demo'}} {{chief.portraitKind === 'illustration' ? 'has-illustration' : 'has-identity'}} {{editing ? 'is-editing' : ''}} {{savingEditor ? 'stage-active' : ''}}" style="{{chief.cardStyle}}" hover-class="stage-press" hover-stay-time="0" bindtap="enterCardEditor">
      <view class="stage-sky"></view>
      <view class="amb-layer">
        <view class="amb-wash"></view>
        <view class="amb-glow"></view>
        <view class="amb-blob amb-blob-1"></view>
        <view class="amb-blob amb-blob-2"></view>
      </view>

      <view class="character-stack motion-{{portraitMotion}}">
        <!-- 与课程舞台相同：idle 常驻，变体帧只做覆盖，切换过程不会透出背景。 -->
        <image wx:if="{{chief.portraitFrames.idle}}" class="character character-idle is-visible" src="{{chief.portraitFrames.idle}}" mode="aspectFit" data-pose="idle" binderror="portraitError"/>
        <view wx:else class="character character-fallback is-visible">
          <view class="identity-avatar-orbit"></view>
          <view class="identity-avatar-core">
            <image wx:if="{{chief.avatarUrl}}" class="identity-avatar-image" src="{{chief.avatarUrl}}" mode="aspectFill"/>
            <text wx:else class="identity-avatar-initial">{{chief.initial}}</text>
          </view>
          <view class="identity-avatar-caption">PERSONAL AI</view>
        </view>
        <image wx:if="{{chief.portraitFrames.blink}}" class="character character-blink {{portraitPose === 'blink' ? 'is-visible' : ''}}" src="{{chief.portraitFrames.blink}}" mode="aspectFit" data-pose="blink" binderror="portraitError"/>
        <image wx:if="{{chief.portraitFrames.glance}}" class="character character-glance {{portraitPose === 'glance' ? 'is-visible' : ''}}" src="{{chief.portraitFrames.glance}}" mode="aspectFit" data-pose="glance" binderror="portraitError"/>
      </view>
      <view wx:if="{{editing}}" class="edit-hit portrait-hit" catchtap="openPortrait"><text class="edit-pencil">✎</text> 换立绘</view>
      <view class="stage-vignette"></view>

      <view class="stage-head">
        <view class="live-pill {{chief.online ? '' : 'draft'}}">
          <text class="live-dot"></text>
          {{chief.online ? 'AI 分身在线' : 'AI 分身已就位'}}
        </view>
      </view>

      <view class="identity-copy">
        <view class="identity-main" bindtap="openIdentity">
          <view class="person-name">{{chief.name}}</view>
          <view class="person-role">{{chief.identity}}</view>
          <view wx:if="{{editing}}" class="inline-edit">✎ 点此修改身份</view>
        </view>

        <view class="quote" bindtap="openIntro"><text class="quote-mark">“</text>{{chief.oneLiner}}<text wx:if="{{editing}}" class="tiny-edit"> ✎</text></view>

        <view class="tags tags-edit-only" wx:if="{{editing}}" bindtap="openTags">
          <view class="tag-item tag-edit">＋ 修改标签</view>
        </view>

        <view class="stage-actions">
          <button wx:if="{{!chief.hasProfile}}" class="stage-cta stage-build" catchtap="startCardSetup">
            <text>完善我的名片</text><text class="stage-cta-arrow">→</text>
          </button>
          <block wx:else>
            <button class="stage-cta stage-share" open-type="share" catchtap="noop">
              <text>分享名片</text><text class="stage-cta-arrow">↗</text>
            </button>
            <view class="stage-preview-link" hover-class="stage-preview-link-press" catchtap="viewPublicCard">
              <text>查看访客视角</text><text class="stage-preview-arrow">→</text>
            </view>
          </block>
        </view>

      </view>
    </view>

    <view wx:if="{{editing}}" class="editor-guide">
      <view class="guide-pulse"></view>
      <view><text class="guide-title">直接点名片上的内容</text><text class="guide-sub">立绘、身份、介绍和标签都能单独修改</text></view>
    </view>
    <view wx:if="{{editing}}" class="quick-edit-row">
      <view class="quick-edit" bindtap="openPortrait">立绘</view>
      <view class="quick-edit" bindtap="openIdentity">身份</view>
      <view class="quick-edit" bindtap="openIntro">介绍</view>
      <view class="quick-edit" bindtap="openTags">标签</view>
    </view>

    <view class="insight" wx:if="{{chief.stats}}">
      <view class="insight-label">分身接待记录</view>
      <view class="hstat" wx:for="{{chief.stats}}" wx:key="label">
        <text class="hstat-n">{{item.n}}</text>
        <text class="hstat-l">{{item.label}}</text>
      </view>
    </view>
    <view wx:elif="{{chief.hasProfile}}" class="home-live-note">
      <view class="home-live-icon">✦</view>
      <view><view class="home-live-title">分身已就位</view><view class="home-live-sub">分享后，访客无需下载就能直接和它聊</view></view>
    </view>
  </block>

  <view wx:if="{{editorOpen}}" class="sheet-mask" catchtap="closeSheet"></view>
  <view class="edit-sheet {{editorOpen ? 'show' : ''}}">
    <view class="sheet-handle"></view>
    <view class="sheet-head">
      <view>
        <view class="sheet-title">{{editorTitle}}</view>
        <view class="sheet-sub">保存后，眼前的名片会立即更新</view>
      </view>
      <view class="sheet-close" bindtap="closeSheet">×</view>
    </view>

    <block wx:if="{{editorKind === 'identity'}}">
      <view class="field-label">怎么称呼你</view>
      <input class="sheet-input" value="{{draft.realName}}" maxlength="20" data-key="realName" bindinput="onDraftInput"/>
      <view class="field-label">你的身份</view>
      <input class="sheet-input" value="{{draft.title}}" maxlength="32" data-key="title" bindinput="onDraftInput"/>
      <view class="two-fields">
        <view class="half-field"><view class="field-label">公司或团队</view><input class="sheet-input" value="{{draft.company}}" maxlength="40" data-key="company" bindinput="onDraftInput"/></view>
        <view class="half-field"><view class="field-label">所在城市</view><input class="sheet-input" value="{{draft.city}}" maxlength="20" data-key="city" bindinput="onDraftInput"/></view>
      </view>
    </block>

    <block wx:elif="{{editorKind === 'intro'}}">
      <view class="field-label">一句让人记住你的介绍</view>
      <textarea class="sheet-textarea" value="{{draft.oneLiner}}" maxlength="80" auto-height data-key="oneLiner" bindinput="onDraftInput"/>
    </block>

    <block wx:elif="{{editorKind === 'tags'}}">
      <view class="field-label">用逗号隔开，最多 5 个</view>
      <input class="sheet-input" value="{{draft.tagsText}}" maxlength="60" data-key="tagsText" bindinput="onDraftInput" placeholder="例如：品牌策略、内容创作、创业者"/>
    </block>

    <block wx:elif="{{editorKind === 'portrait'}}">
      <scroll-view class="portrait-list" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="portrait-options">
          <view class="portrait-option {{chief.avatarStyle === item.id ? 'selected' : ''}}" wx:for="{{portraitOptions}}" wx:key="id" data-id="{{item.id}}" bindtap="choosePortrait">
            <view class="portrait-preview" style="{{item.style}}">
              <image wx:if="{{item.previewUrl}}" src="{{item.previewUrl}}" mode="aspectFill"/>
              <text wx:else>✦</text>
            </view>
            <view class="portrait-name">{{item.name}}</view>
          </view>
        </view>
      </scroll-view>
    </block>

    <button wx:if="{{editorKind !== 'portrait'}}" class="sheet-save" loading="{{savingEditor}}" disabled="{{savingEditor}}" bindtap="saveEditor">保存到名片</button>
  </view>
</view>
