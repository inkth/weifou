<view class="squad">

  <view class="sq-top" style="padding-top:{{statusBarH}}px">
    <view class="sq-eyebrow">{{greeting}}</view>
    <view class="sq-h1">想办成什么？</view>
  </view>

  <view class="chief" hover-class="card-press" hover-stay-time="0" bindtap="enterChief">
    <view class="chief-av">{{chief.initial}}<view wx:if="{{chief.online}}" class="chief-dot"></view></view>
    <view class="chief-meta">
      <view class="chief-name">{{chief.name}}</view>
      <view class="chief-line">{{chief.line}}</view>
    </view>
    <view class="ic ic-chevron chief-go"></view>
  </view>

  <view wx:if="{{chief.hasProfile}}" class="seen" bindtap="goVisitors">
    <view class="ic ic-user seen-ic"></view><text>谁看过你的名片</text>
  </view>

  <view wx:if="{{specialists.length}}" class="sec-label">我的 Agent</view>

  <view class="spec" wx:for="{{specialists}}" wx:key="id"
        data-id="{{item.id}}" data-name="{{item.name}}" data-kind="{{item.kind}}"
        hover-class="card-press" hover-stay-time="0"
        bindtap="enterSpecialist" bindlongpress="removeSpecialist">
    <view class="spec-av"><text>{{item.initial}}</text></view>
    <view class="spec-meta">
      <view class="spec-name">{{item.name}}</view>
      <view class="spec-line">{{item.line}}</view>
    </view>
    <view wx:if="{{item.pill}}" class="spec-pill">{{item.pill}}</view>
  </view>

</view>
