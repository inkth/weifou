/* 首页 = 糖果风（令牌真源见 app.wxss）：纯白底、浅灰细边白卡、垂直 3D 底唇、糖果色点缀。 */
.squad {
  min-height: 100vh;
  background: var(--bg);
  padding: 0 32rpx calc(env(safe-area-inset-bottom) + 200rpx);
}

.sq-top { padding: 36rpx 8rpx 28rpx; }
.sq-eyebrow { font-size: 26rpx; color: var(--ink-2); font-weight: 500; }
.sq-h1 { margin-top: 10rpx; font-size: 52rpx; font-weight: 700; color: var(--ink); letter-spacing: -1rpx; line-height: 1.3; }

/* 按压=下沉+底唇收没：复用 app.wxss 全局 .card-press，本页不再另立 */

/* 首屏骨架（.skel 微光见 app.wxss） */
.sk-hero { height: 220rpx; border-radius: var(--r-2xl); margin-bottom: 28rpx; }
.sk-acard { height: 180rpx; border-radius: var(--r-xl); margin-bottom: 26rpx; }

/* 网络失败重试条：克制描边（非糖果色，成交外的功能提示） */
.retry {
  display: flex; align-items: center; justify-content: center; gap: 12rpx;
  padding: 20rpx 28rpx; border-radius: var(--r-lg); margin-bottom: 24rpx;
  background: var(--surface);
  border: var(--bw-thin) solid var(--border);
  box-shadow: 0 5rpx 0 var(--border);
  font-size: 26rpx; font-weight: 600; color: var(--ink-2);
  transition: transform 0.12s var(--ease), box-shadow 0.12s var(--ease);
}
.retry-press { transform: translateY(5rpx); box-shadow: none; }
.retry-ic { font-size: 32rpx; color: var(--accent-strong); }

/* ===== AI 名片大卡 ===== */
.hero {
  position: relative;
  padding: 40rpx 36rpx 12rpx;
  border-radius: var(--r-2xl); margin-bottom: 28rpx;
  background: var(--surface);
  border: var(--bw) solid var(--border);
  box-shadow: var(--shadow-lift);
  transition: transform 0.12s var(--ease), box-shadow 0.12s var(--ease);
}
.hero-sticker {
  position: absolute; top: -18rpx; right: 28rpx;
  padding: 4rpx 20rpx;
  background: var(--pop-butter); color: var(--pop-butter-ink);
  border: none; border-radius: var(--r-full);
  font-size: 22rpx; font-weight: 600;
  box-shadow: var(--shadow-hair);
}
.hero-top { display: flex; align-items: center; gap: 28rpx; }
.hero-av {
  position: relative; flex: 0 0 auto; width: 120rpx; height: 120rpx; border-radius: 28rpx;
  display: flex; align-items: center; justify-content: center;
  background: var(--accent); border: none;
  font-size: 50rpx; font-weight: 600; color: var(--on-accent);
}
.hero-dot { position: absolute; right: -8rpx; bottom: -8rpx; width: 26rpx; height: 26rpx; border-radius: 50%; background: var(--pop-butter); border: var(--bw-thin) solid #ffffff; }
.hero-id { flex: 1; min-width: 0; }
.hero-name { font-size: 38rpx; font-weight: 700; color: var(--ink); letter-spacing: -0.5rpx; }
.hero-line { margin-top: 10rpx; font-size: 27rpx; color: var(--ink-2); line-height: 1.5; }
.hero-go {
  flex: 0 0 auto; width: 52rpx; height: 52rpx; border-radius: 50%;
  border: var(--bw-thin) solid var(--border);
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; color: var(--ink);
}

/* 数据 dashboard：描边小片 */
.hero-stats { display: flex; gap: 14rpx; margin-top: 30rpx; padding: 0 0 28rpx; }
.hstat {
  flex: 1; text-align: center; padding: 14rpx 0 10rpx;
  background: var(--accent-soft);
  border: none;
  border-radius: var(--r-md);
}
.hstat-n { font-size: 40rpx; font-weight: 700; color: var(--ink); letter-spacing: -0.5rpx; }
.hstat-l { margin-top: 2rpx; font-size: 22rpx; color: var(--accent-ink); }

/* 区段标：剪裁线 */
.sec-label {
  display: flex; align-items: center; gap: 16rpx;
  padding: 0 8rpx 20rpx; font-size: 24rpx; letter-spacing: 3rpx; font-weight: 600; color: var(--sub);
}
.sec-label::after { content: ''; flex: 1; border-top: var(--bw-thin) dashed var(--border-strong); }

/* ===== Agent 大卡 ===== */
.acard {
  padding: 30rpx 30rpx 22rpx; border-radius: var(--r-xl); margin-bottom: 26rpx;
  background: var(--surface);
  border: var(--bw) solid var(--border);
  box-shadow: var(--shadow-card);
  transition: transform 0.12s var(--ease), box-shadow 0.12s var(--ease);
}
.acard-top { display: flex; align-items: center; gap: 26rpx; }
.acard-ic {
  flex: 0 0 auto; width: 96rpx; height: 96rpx; border-radius: var(--r-lg);
  display: flex; align-items: center; justify-content: center;
  background: var(--pop-mint);
  border: none;
}
.acard:nth-child(3n) .acard-ic { background: var(--pop-coral); }
.acard:nth-child(3n+1) .acard-ic { background: var(--pop-lilac); }
.acard-ic text { font-size: 42rpx; font-weight: 600; color: var(--ink); }
.acard-meta { flex: 1; min-width: 0; }
.acard-name { font-size: 32rpx; font-weight: 700; color: var(--ink); }
.acard-tag { margin-top: 8rpx; font-size: 26rpx; color: var(--ink-2); line-height: 1.5; }
/* 催课条：服务端算好的动态学习状态（下一个概念/待复习/段位弱项）——比 tagline 更该被看见 */
.acard-tag.nudge { color: var(--accent-strong); font-weight: 600; }
.acard-foot {
  display: flex; align-items: center; justify-content: space-between;
  margin-top: 24rpx; padding-top: 20rpx; border-top: var(--bw-thin) dashed var(--border);
}
.acard-pill {
  font-size: 23rpx; font-weight: 600; padding: 6rpx 20rpx; border-radius: var(--r-full);
  background: var(--accent-soft); color: var(--accent-ink);
  border: none;
}
.acard-cta { display: flex; align-items: center; gap: 8rpx; font-size: 26rpx; font-weight: 600; color: var(--ink); }
.acard-cta-ic { font-size: 26rpx; }
