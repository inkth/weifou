/* 首页 = 我的 Agent 小队，清新浅色（薄荷青点睛）。
   AI 名片 = 薄荷青浅底大卡；Agent = 白卡 + 薄荷青芯片。不引暗场 stage。 */
.squad {
  min-height: 100vh;
  background: #f3f8f5;
  padding: 0 32rpx calc(env(safe-area-inset-bottom) + 200rpx);
}
.art-glow { display: none; }

.sq-top { padding: 28rpx 8rpx 24rpx; }
.sq-h1 { font-size: 42rpx; font-weight: 700; color: #16241e; letter-spacing: -0.5rpx; }
.sq-sub { margin-top: 8rpx; font-size: 25rpx; color: #8a9a93; }

/* AI 名片大卡：薄荷青浅底 + 实色头像 */
.chief {
  position: relative; display: flex; align-items: center; gap: 24rpx;
  padding: 32rpx 28rpx; border-radius: 32rpx; margin-bottom: 22rpx;
  background: #e2f5ef; border: 1rpx solid rgba(24, 182, 144, 0.28);
}
.chief:active { transform: scale(0.985); }
.chief-av {
  position: relative; z-index: 1; flex: 0 0 auto;
  width: 112rpx; height: 112rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  background: #18b690; font-size: 44rpx; font-weight: 700; color: #fff;
}
.chief-meta { position: relative; z-index: 1; flex: 1; min-width: 0; }
.chief-name { font-size: 34rpx; font-weight: 700; color: #0c3a2e; }
.chief-line { margin-top: 8rpx; font-size: 26rpx; color: #2f8c72; line-height: 1.5; }
.chief-go { position: relative; z-index: 1; font-size: 40rpx; color: #18b690; }

/* 谁看过我（wxml 内联色为 --accent-ink，浅底上可读） */

/* Agent 卡：白卡 + 薄荷青芯片 */
.spec {
  display: flex; align-items: center; gap: 22rpx;
  padding: 24rpx 26rpx; border-radius: 28rpx; margin-bottom: 18rpx;
  background: #ffffff; border: 1rpx solid #e8ece9;
}
.spec:active { transform: scale(0.985); }
.spec-av {
  position: relative; flex: 0 0 auto;
  width: 92rpx; height: 92rpx; border-radius: 24rpx;
  display: flex; align-items: center; justify-content: center;
  background: #e2f5ef;
}
.spec-av text { position: relative; z-index: 1; font-size: 36rpx; font-weight: 700; color: #0c5a48; }
.spec-meta { flex: 1; min-width: 0; }
.spec-name { font-size: 30rpx; font-weight: 600; color: #16241e; }
.spec-line {
  margin-top: 8rpx; font-size: 26rpx; color: #8a9a93;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.spec-go { flex: 0 0 auto; font-size: 34rpx; color: #c2cbc6; }
