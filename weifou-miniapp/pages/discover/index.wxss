.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 16rpx 28rpx calc(env(safe-area-inset-bottom) + 140rpx);
}
.hd { padding: 20rpx 4rpx 4rpx; }
.hd-title { font-size: 48rpx; font-weight: 700; color: var(--ink); letter-spacing: -0.5rpx; }
.hd-sub { margin-top: 8rpx; font-size: 26rpx; color: var(--ink-2); }

.search {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin: 24rpx 0 8rpx;
  padding: 22rpx 28rpx;
  background: var(--surface);
  border-radius: var(--r-full);
  box-shadow: var(--shadow-card);
}
.search-ic { font-size: 34rpx; color: var(--sub); }
.search-ph { font-size: 28rpx; color: var(--sub); }

.cats { white-space: nowrap; margin: 22rpx 0 8rpx; }
.cat {
  display: inline-block;
  padding: 14rpx 30rpx;
  margin-right: 14rpx;
  background: var(--surface);
  border: 1rpx solid var(--border);
  border-radius: var(--r-full);
  font-size: 26rpx;
  color: var(--ink-2);
  transition: background 0.18s var(--ease), color 0.18s var(--ease), border-color 0.18s var(--ease);
}
.cat.on {
  background: var(--accent);
  border-color: var(--accent);
  color: #fff;
  font-weight: 600;
  box-shadow: 0 4rpx 14rpx rgba(24, 182, 144, 0.26);
}

.state { padding: 80rpx 0; text-align: center; color: var(--sub); font-size: 28rpx; }
.state.sm { padding: 40rpx 0; }

.sec { margin-top: 36rpx; }
.sec-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding: 0 4rpx;
}
.sec-title { font-size: 32rpx; font-weight: 700; color: var(--ink); letter-spacing: -0.3rpx; }
.sec-more { display: flex; align-items: center; gap: 2rpx; font-size: 25rpx; color: var(--sub); }
.sec-more-ic { font-size: 26rpx; }

.grid { display: grid; grid-template-columns: 1fr 1fr; gap: 18rpx; }
.acard {
  background: var(--surface);
  border-radius: var(--r-xl);
  padding: 28rpx 26rpx;
  box-shadow: var(--shadow-card);
  transition: transform 0.16s var(--ease);
}
.acard:active { transform: scale(0.98); }
.acard-ic {
  width: 84rpx;
  height: 84rpx;
  border-radius: var(--r-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
}
.acard-name { margin-top: 20rpx; font-size: 30rpx; font-weight: 600; color: var(--ink); }
.acard-tag {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: var(--sub);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ph-card {
  background: var(--surface);
  border-radius: var(--r-xl);
  padding: 64rpx 40rpx;
  text-align: center;
  box-shadow: var(--shadow-card);
}
.ph-ic-wrap {
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto;
  border-radius: var(--r-full);
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--accent-soft);
}
.ph-ic { font-size: 60rpx; color: var(--accent); }
.ph-title { margin-top: 24rpx; font-size: 30rpx; font-weight: 600; color: var(--ink); }
.ph-sub { margin-top: 10rpx; font-size: 25rpx; color: var(--sub); line-height: 1.6; }
