@import "../../styles/stage.wxss";

/* 首页 = 我的 Agent 小队，暗场沉浸（借猫箱/星野壳）。
   总管 = 温度档渐变大卡 + 强调描边；专才 = 中性深卡；都用第一人称说事，不做仪表盘。 */
.squad {
  min-height: 100vh;
  background: #10221d;
  padding: 0 32rpx calc(env(safe-area-inset-bottom) + 200rpx);
}

.sq-top { padding: 28rpx 8rpx 24rpx; }
.sq-h1 { font-size: 42rpx; font-weight: 700; color: #fff; letter-spacing: -0.5rpx; }
.sq-sub { margin-top: 8rpx; font-size: 25rpx; color: rgba(255, 255, 255, 0.55); }

/* 总管大卡 */
.chief {
  position: relative; display: flex; align-items: center; gap: 24rpx;
  padding: 32rpx 28rpx; border-radius: 32rpx; margin-bottom: 24rpx;
  border: 1rpx solid rgba(24, 182, 144, 0.5);
  transition: transform 0.16s var(--ease);
}
.chief:active { transform: scale(0.985); }
.chief-av {
  position: relative; z-index: 1; flex: 0 0 auto;
  width: 116rpx; height: 116rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  background: rgba(255, 255, 255, 0.10); border: 2rpx solid rgba(24, 182, 144, 0.85);
  font-size: 44rpx; font-weight: 700; color: #fff;
}
.chief-meta { position: relative; z-index: 1; flex: 1; min-width: 0; }
.chief-name { font-size: 34rpx; font-weight: 700; color: #fff; }
.chief-line { margin-top: 8rpx; font-size: 26rpx; color: #5fd5b0; }
.chief-go { position: relative; z-index: 1; font-size: 40rpx; color: #18b690; }

/* 专才卡 */
.spec {
  display: flex; align-items: center; gap: 22rpx;
  padding: 24rpx 26rpx; border-radius: 28rpx; margin-bottom: 22rpx;
  background: #16312a; border: 1rpx solid rgba(255, 255, 255, 0.08);
  transition: transform 0.16s var(--ease);
}
.spec:active { transform: scale(0.985); }
.spec-av {
  position: relative; flex: 0 0 auto;
  width: 96rpx; height: 96rpx; border-radius: 26rpx;
  display: flex; align-items: center; justify-content: center;
}
.spec-av text { position: relative; z-index: 1; font-size: 36rpx; font-weight: 700; color: #fff; }
.spec-meta { flex: 1; min-width: 0; }
.spec-name { font-size: 30rpx; font-weight: 600; color: #fff; }
.spec-line {
  margin-top: 8rpx; font-size: 26rpx; color: rgba(255, 255, 255, 0.6);
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.spec-go { flex: 0 0 auto; font-size: 34rpx; color: rgba(255, 255, 255, 0.35); }

/* 召新 */
.add {
  display: flex; align-items: center; justify-content: center; gap: 12rpx;
  margin-top: 4rpx; padding: 30rpx; border-radius: 28rpx;
  border: 1rpx dashed rgba(255, 255, 255, 0.22); color: rgba(255, 255, 255, 0.55);
  font-size: 26rpx;
}
.add .ic { font-size: 34rpx; }
