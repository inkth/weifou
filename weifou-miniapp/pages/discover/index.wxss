/* 首页 = 清新浅色 + 薄荷青，顶级质量基线：克制留白、精致字阶、0.5px hairline + 极轻阴影。 */
.squad {
  min-height: 100vh;
  background: #fbfcfb;
  padding: 0 36rpx calc(env(safe-area-inset-bottom) + 200rpx);
}

.sq-top { padding: 36rpx 6rpx 28rpx; }
.sq-eyebrow { font-size: 26rpx; color: #8a9a93; }
.sq-h1 { margin-top: 8rpx; font-size: 52rpx; font-weight: 600; color: #16241e; letter-spacing: -1rpx; }

.card-press { transform: scale(0.985); }

/* AI 名片大卡 */
.chief {
  display: flex; align-items: center; gap: 28rpx;
  padding: 36rpx 32rpx; border-radius: 36rpx; margin-bottom: 24rpx;
  background: #fff; border: 1rpx solid #ecefec; box-shadow: 0 2rpx 6rpx rgba(20, 40, 30, 0.04);
}
.chief-av {
  position: relative; flex: 0 0 auto; width: 112rpx; height: 112rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  background: #18b690; font-size: 46rpx; font-weight: 500; color: #fff;
}
.chief-dot { position: absolute; right: 2rpx; bottom: 2rpx; width: 26rpx; height: 26rpx; border-radius: 50%; background: #34d399; border: 5rpx solid #fff; }
.chief-meta { flex: 1; min-width: 0; }
.chief-name { font-size: 34rpx; font-weight: 600; color: #16241e; }
.chief-line { margin-top: 8rpx; font-size: 26rpx; color: #8a9a93; line-height: 1.5; }
.chief-go { flex: 0 0 auto; font-size: 34rpx; color: #cfd6d2; }

/* 谁看过我 */
.seen { display: flex; align-items: center; gap: 10rpx; margin: 0 8rpx 32rpx; font-size: 26rpx; color: #18b690; }
.seen-ic { font-size: 30rpx; }

/* 区段标 */
.sec-label { padding: 0 8rpx 16rpx; font-size: 24rpx; letter-spacing: 3rpx; color: #aab4af; }

/* Agent 行 */
.spec {
  display: flex; align-items: center; gap: 24rpx;
  padding: 28rpx; border-radius: 28rpx; margin-bottom: 20rpx;
  background: #fff; border: 1rpx solid #ecefec; box-shadow: 0 2rpx 6rpx rgba(20, 40, 30, 0.03);
}
.spec-av { flex: 0 0 auto; width: 92rpx; height: 92rpx; border-radius: 26rpx; display: flex; align-items: center; justify-content: center; background: #e8f5ef; }
.spec-av text { font-size: 38rpx; font-weight: 500; color: #0f766e; }
.spec-meta { flex: 1; min-width: 0; }
.spec-name { font-size: 30rpx; font-weight: 600; color: #16241e; }
.spec-line { margin-top: 6rpx; font-size: 25rpx; color: #8a9a93; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.spec-pill { flex: 0 0 auto; font-size: 22rpx; padding: 6rpx 18rpx; border-radius: 999rpx; background: #eaf6f1; color: #0c5a48; }
