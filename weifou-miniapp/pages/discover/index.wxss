@import "../../styles/stage.wxss";

/* 首页是一张沉浸式动态身份名片：内容来自资料，动效只负责让人物“活”起来。 */
.home-shell {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  padding: 0 28rpx calc(env(safe-area-inset-bottom) + 190rpx);
  background: #f3f3f9;
}

.ambient { position: absolute; border-radius: 50%; filter: blur(2rpx); pointer-events: none; }
.ambient-a { width: 560rpx; height: 560rpx; right: -260rpx; top: -180rpx; background: rgba(201, 195, 235, .48); filter: blur(14rpx); }
.ambient-b { width: 460rpx; height: 460rpx; left: -300rpx; top: 680rpx; background: rgba(185, 221, 237, .34); filter: blur(18rpx); }

.topbar {
  position: relative; z-index: 2;
  display: flex; align-items: flex-end; justify-content: space-between;
  padding-left: 6rpx; padding-right: 4rpx; padding-bottom: 28rpx;
}
.brand-row { display: flex; align-items: center; color: var(--ink); font-size: 21rpx; line-height: 1; letter-spacing: 4rpx; font-weight: 850; }
.brand-star { display: inline-block; margin-right: 7rpx; color: var(--accent); animation: starTurn 7s linear infinite; }
.brand-cn { margin-left: 14rpx; padding-left: 14rpx; border-left: 1rpx solid rgba(23,24,28,.16); color: var(--sub); font-size: 18rpx; letter-spacing: 2rpx; font-weight: 650; }
.greeting { margin-top: 14rpx; color: var(--sub); font-size: 23rpx; font-weight: 550; }
.greeting-strong { color: var(--ink-2); font-weight: 700; }
.settings-btn {
  display: flex; align-items: center; gap: 10rpx;
  height: 60rpx; padding: 0 22rpx;
  color: #35403c; background: rgba(255,255,255,.62);
  border: 1rpx solid rgba(42,56,50,.10); border-radius: 999rpx;
  font-size: 23rpx; font-weight: 750; box-shadow: 0 8rpx 24rpx rgba(46,57,52,.06);
  transition: transform .12s ease;
}
.settings-dot { width: 9rpx; height: 9rpx; border-radius: 50%; background: #778f83; box-shadow: 0 0 0 6rpx rgba(119,143,131,.12); }
.settings-btn-press { transform: scale(.96); }
.settings-btn.editing { color: #f6f1e5; background: #26362f; }
.settings-btn.editing .settings-dot { background: #d9c18d; box-shadow: 0 0 0 6rpx rgba(217,193,141,.14); }

.stage-skeleton { height: 1010rpx; border-radius: 52rpx; background: #d9deda; }
.retry {
  position: relative; z-index: 3; display: flex; align-items: center; justify-content: center; gap: 10rpx;
  margin-bottom: 18rpx; padding: 15rpx 24rpx; border-radius: 18rpx;
  color: #42504a; background: rgba(255,255,255,.78); font-size: 23rpx; font-weight: 650;
}
.retry-ic { font-size: 29rpx; color: #73877e; }
.retry-press { transform: scale(.985); }

.identity-stage {
  --stage-dark: #17231f;
  position: relative; height: 1010rpx; overflow: hidden;
  border-radius: 52rpx; color: #fff; background: var(--stage-dark);
  box-shadow: 0 36rpx 90rpx rgba(35,47,42,.27), 0 3rpx 0 rgba(255,255,255,.36) inset;
  isolation: isolate; transform: translateZ(0);
  transition: transform .16s ease, box-shadow .16s ease;
}
.stage-press { transform: scale(.988); box-shadow: 0 20rpx 50rpx rgba(35,47,42,.22); }
.identity-stage.is-editing { box-shadow: 0 0 0 4rpx #d9c18d, 0 36rpx 90rpx rgba(35,47,42,.27); }
.stage-sky {
  position: absolute; inset: 0;
  background:
    radial-gradient(circle at 74% 20%, rgba(245,224,175,.28), transparent 29%),
    linear-gradient(155deg, var(--card-b, #9caeaa) -5%, var(--card-a, #536962) 42%, #18241f 94%);
}
.identity-stage .amb-layer { z-index: 1; }
.identity-stage .amb-glow {
  background: radial-gradient(410rpx 520rpx at 50% 34%, var(--amb-b, #b9dded) 0%, transparent 72%);
}
.character-stack {
  position: absolute; z-index: 1; top: 6rpx; left: 5%; width: 90%; height: 770rpx;
  transform-origin: 50% 70%; animation: characterBreathe 6s ease-in-out infinite;
  filter: saturate(.88) contrast(1.02);
}
.character { position: absolute; inset: 0; width: 100%; height: 100%; opacity: 0; transition: opacity .08s ease-out; }
.character.is-visible { opacity: 1; }
.character-blink { transition-duration: .035s; }
.character-fallback { display: flex; flex-direction: column; align-items: center; padding-top: 118rpx; }
.identity-avatar-orbit {
  position: absolute; top: 78rpx; left: 50%; width: 350rpx; height: 350rpx;
  margin-left: -175rpx; border: 1rpx solid rgba(255,255,255,.18); border-radius: 50%;
  box-shadow: 0 0 0 45rpx rgba(255,255,255,.035), 0 0 100rpx rgba(185,221,237,.14) inset;
}
.identity-avatar-core {
  position: relative; z-index: 1; width: 260rpx; height: 260rpx; overflow: hidden;
  display: flex; align-items: center; justify-content: center;
  border: 2rpx solid rgba(255,255,255,.48); border-radius: 88rpx;
  color: rgba(255,255,255,.94); background: linear-gradient(145deg, rgba(255,255,255,.22), rgba(255,255,255,.07));
  box-shadow: 0 30rpx 80rpx rgba(15,14,36,.28), 0 2rpx 0 rgba(255,255,255,.32) inset;
  backdrop-filter: blur(12rpx);
}
.identity-avatar-image { width: 100%; height: 100%; }
.identity-avatar-initial { font-family: "Songti SC", "STSong", serif; font-size: 116rpx; line-height: 1; font-weight: 800; text-shadow: 0 10rpx 30rpx rgba(18,16,44,.28); }
.identity-avatar-caption { position: relative; z-index: 1; margin-top: 27rpx; color: rgba(255,255,255,.62); font-size: 16rpx; font-weight: 750; letter-spacing: 5rpx; }
.character-stack.motion-shift { animation: characterShift 2.2s var(--ease-out) both; }
.edit-hit { position: absolute; z-index: 7; display: flex; align-items: center; gap: 7rpx; padding: 9rpx 15rpx; border-radius: 999rpx; color: #26342e; background: rgba(246,239,221,.94); border: 1rpx solid rgba(255,255,255,.62); box-shadow: 0 9rpx 24rpx rgba(13,23,19,.18); font-size: 19rpx; font-weight: 800; animation: editPop .25s ease-out; }
.portrait-hit { top: 105rpx; right: 27rpx; }
.edit-pencil { font-size: 23rpx; }
.stage-vignette {
  position: absolute; z-index: 2; inset: 0;
  background: linear-gradient(180deg, rgba(11,18,15,.10) 0%, transparent 38%, rgba(17,29,24,.18) 55%, rgba(15,25,21,.96) 78%, #111d18 100%);
}

.stage-head { position: absolute; z-index: 5; top: 30rpx; left: 30rpx; right: 30rpx; display: flex; align-items: center; justify-content: space-between; }
.live-pill {
  display: flex; align-items: center; gap: 10rpx; padding: 9rpx 16rpx; border-radius: 999rpx;
  background: rgba(20,31,27,.43); border: 1rpx solid rgba(255,255,255,.18); backdrop-filter: blur(12rpx);
  font-size: 20rpx; font-weight: 750; letter-spacing: .5rpx;
}
.live-dot { width: 10rpx; height: 10rpx; border-radius: 50%; background: #b9e6c7; box-shadow: 0 0 0 6rpx rgba(185,230,199,.12); animation: onlinePulse 2.4s ease-in-out infinite; }
.live-pill.draft { color: rgba(255,255,255,.70); }
.draft .live-dot { background: #dfcfad; box-shadow: none; animation: none; }
.card-no { color: rgba(255,255,255,.58); font-size: 18rpx; letter-spacing: 2.5rpx; font-weight: 700; }
.stage-identity-meta { display: flex; flex-direction: column; align-items: flex-end; gap: 5rpx; }
.portrait-kind { color: rgba(255,255,255,.58); font-size: 16rpx; font-weight: 650; letter-spacing: .5rpx; }

.identity-copy { position: absolute; z-index: 5; left: 34rpx; right: 34rpx; bottom: 32rpx; }
.mini-avatar-wrap { position: absolute; top: 7rpx; right: 0; width: 80rpx; height: 80rpx; }
.mini-avatar { width: 80rpx; height: 80rpx; border-radius: 25rpx; border: 2rpx solid rgba(255,255,255,.62); background: rgba(255,255,255,.12); box-shadow: 0 12rpx 30rpx rgba(0,0,0,.20); }
.mini-avatar-fallback { display: flex; align-items: center; justify-content: center; color: #26342e; background: #e7e3d7; font-size: 32rpx; font-weight: 850; }
.mini-badge { position: absolute; right: -6rpx; bottom: -6rpx; display: flex; align-items: center; justify-content: center; width: 34rpx; height: 34rpx; border-radius: 12rpx; color: #26342e; background: #d9c18d; border: 2rpx solid #17241f; font-size: 14rpx; font-weight: 900; }
.identity-main { padding-right: 98rpx; }
.identity-kicker { color: #d9c18d; font-size: 17rpx; letter-spacing: 3rpx; font-weight: 800; }
.person-name { margin-top: 3rpx; max-width: 470rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-family: "Songti SC", "STSong", serif; font-size: 65rpx; line-height: 1.12; font-weight: 800; letter-spacing: 2rpx; }
.person-role { margin-top: 8rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: rgba(255,255,255,.69); font-size: 22rpx; letter-spacing: .5rpx; }
.inline-edit { display: inline-block; margin-top: 10rpx; padding: 5rpx 11rpx; border-radius: 9rpx; color: #dac89f; background: rgba(218,200,159,.11); border: 1rpx solid rgba(218,200,159,.23); font-size: 17rpx; font-weight: 700; }
.quote { margin-top: 23rpx; max-width: 610rpx; color: rgba(255,255,255,.91); font-size: 26rpx; line-height: 1.55; font-weight: 600; }
.quote-mark { margin-right: 5rpx; color: #d9c18d; font-family: Georgia, serif; font-size: 35rpx; line-height: 0; }
.tiny-edit { color: #d9c18d; font-size: 22rpx; }
.tags { display: flex; flex-wrap: wrap; gap: 10rpx; margin-top: 18rpx; }
.tag-item { padding: 6rpx 15rpx; border-radius: 999rpx; color: rgba(255,255,255,.75); background: rgba(255,255,255,.075); border: 1rpx solid rgba(255,255,255,.12); font-size: 19rpx; }
.tag-edit { color: #e1cfa8; border-color: rgba(225,207,168,.34); }
.editor-guide { display: flex; align-items: center; gap: 16rpx; margin: 22rpx 7rpx 0; padding: 19rpx 22rpx; border-radius: 23rpx; color: #f8f3e7; background: #26362f; box-shadow: 0 15rpx 35rpx rgba(38,54,47,.16); animation: guideIn .25s ease-out; }
.guide-pulse { width: 14rpx; height: 14rpx; flex: 0 0 auto; border-radius: 50%; background: #d9c18d; box-shadow: 0 0 0 8rpx rgba(217,193,141,.13); animation: onlinePulse 2s infinite; }
.guide-title { display: block; font-size: 22rpx; font-weight: 800; }
.guide-sub { display: block; margin-top: 3rpx; color: rgba(255,255,255,.60); font-size: 18rpx; }
.quick-edit-row { display: flex; gap: 11rpx; margin: 12rpx 7rpx 0; }
.quick-edit { flex: 1; padding: 13rpx 0; border-radius: 16rpx; text-align: center; color: #51605a; background: rgba(255,255,255,.65); border: 1rpx solid rgba(45,58,52,.09); font-size: 20rpx; font-weight: 750; }
.quick-edit:active { color: #f7f1e3; background: #35483f; transform: scale(.97); }

.foot-note { position: relative; display: flex; align-items: center; gap: 18rpx; margin: 28rpx 8rpx 0; }
.foot-spark { width: 62rpx; height: 62rpx; flex: 0 0 auto; display: flex; align-items: center; justify-content: center; border-radius: 20rpx; color: #88744c; background: rgba(255,255,255,.62); border: 1rpx solid rgba(45,58,52,.08); box-shadow: 0 8rpx 24rpx rgba(46,57,52,.05); font-size: 25rpx; }
.foot-copy { min-width: 0; }
.foot-title { color: #26322d; font-size: 25rpx; font-weight: 800; }
.foot-sub { margin-top: 3rpx; color: #77817c; font-size: 20rpx; line-height: 1.45; }

.insight { display: flex; align-items: center; margin-top: 24rpx; padding: 22rpx 28rpx; border-radius: 25rpx; background: rgba(255,255,255,.58); border: 1rpx solid rgba(45,58,52,.08); }
.insight-label { flex: 1; color: #4d5a54; font-size: 22rpx; font-weight: 750; }
.hstat { margin-left: 28rpx; }
.hstat-n { color: #26322d; font-size: 26rpx; font-weight: 850; }
.hstat-l { margin-left: 7rpx; color: #8b938f; font-size: 19rpx; }

.sheet-mask { position: fixed; z-index: 1800; inset: 0; background: rgba(18,27,23,.46); animation: maskIn .2s ease; }
.edit-sheet { position: fixed; z-index: 1801; left: 0; right: 0; bottom: 0; padding: 13rpx 30rpx calc(env(safe-area-inset-bottom) + 30rpx); border-radius: 42rpx 42rpx 0 0; background: #f7f6f1; box-shadow: 0 -28rpx 80rpx rgba(24,36,31,.20); transform: translateY(110%); transition: transform .28s cubic-bezier(.16,1,.3,1); }
.edit-sheet.show { transform: translateY(0); }
.sheet-handle { width: 68rpx; height: 7rpx; margin: 0 auto 24rpx; border-radius: 99rpx; background: #d3d5d0; }
.sheet-head { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 27rpx; }
.sheet-title { color: #24312b; font-size: 34rpx; line-height: 1.3; font-weight: 850; }
.sheet-sub { margin-top: 5rpx; color: #8a928e; font-size: 20rpx; }
.sheet-close { width: 54rpx; height: 54rpx; display: flex; align-items: center; justify-content: center; border-radius: 50%; color: #59635e; background: #e9eae5; font-size: 34rpx; }
.field-label { margin: 20rpx 3rpx 9rpx; color: #69736e; font-size: 21rpx; font-weight: 700; }
.sheet-input, .sheet-textarea { width: 100%; color: #26332d; background: #fff; border: 1rpx solid #dde0da; border-radius: 20rpx; font-size: 27rpx; }
.sheet-input { height: 78rpx; padding: 0 22rpx; }
.sheet-textarea { min-height: 150rpx; padding: 20rpx 22rpx; line-height: 1.55; }
.two-fields { display: flex; gap: 15rpx; }
.half-field { flex: 1; min-width: 0; }
.sheet-save { height: 82rpx; margin-top: 29rpx; display: flex; align-items: center; justify-content: center; border-radius: 23rpx; color: #f9f4e8; background: #26362f; font-size: 27rpx; font-weight: 800; }
.portrait-list { width: 100%; white-space: nowrap; }
.portrait-options { display: inline-flex; gap: 17rpx; padding: 4rpx 4rpx 15rpx; }
.portrait-option { width: 150rpx; padding: 8rpx 8rpx 13rpx; border-radius: 24rpx; border: 2rpx solid transparent; background: #fff; }
.portrait-option.selected { border-color: #8e7a51; box-shadow: 0 0 0 4rpx rgba(142,122,81,.10); }
.portrait-preview { width: 130rpx; height: 152rpx; display: flex; align-items: center; justify-content: center; overflow: hidden; border-radius: 18rpx; color: rgba(255,255,255,.84); font-size: 36rpx; }
.portrait-preview image { width: 100%; height: 100%; }
.portrait-name { margin-top: 9rpx; overflow: hidden; text-overflow: ellipsis; text-align: center; color: #4b5751; font-size: 20rpx; font-weight: 700; }

@keyframes characterBreathe {
  0%, 100% { transform: translateY(0) scale(1.015); }
  50% { transform: translateY(-12rpx) scale(1.035); }
}
@keyframes characterShift {
  0%, 100% { transform: translate(0, 0) scale(1.015); }
  38% { transform: translate(-5rpx, 2rpx) rotate(-.25deg) scale(1.026); }
  72% { transform: translate(-2rpx, -2rpx) rotate(.12deg) scale(1.02); }
}
@keyframes onlinePulse { 0%,100% { opacity: .65; transform: scale(.85); } 50% { opacity: 1; transform: scale(1.1); } }
@keyframes starTurn { to { transform: rotate(360deg); } }
@keyframes editPop { from { opacity: 0; transform: scale(.8); } }
@keyframes guideIn { from { opacity: 0; transform: translateY(-10rpx); } }
@keyframes maskIn { from { opacity: 0; } }

@media (prefers-reduced-motion: reduce) {
  .character-stack, .live-dot, .brand-star { animation: none; }
}

/* 3.0 品牌收敛：人物仍是主体，所有平台装饰统一回雾蓝紫 AI 气场。 */
.settings-btn { color: var(--ink-2); background: rgba(255,255,255,.74); border-color: rgba(78,73,135,.10); box-shadow: 0 8rpx 24rpx rgba(54,49,96,.07); }
.settings-dot { background: var(--accent); box-shadow: 0 0 0 6rpx rgba(119,114,200,.12); }
.settings-btn.editing { color: #fff; background: var(--accent-deep); }
.settings-btn.editing .settings-dot { background: var(--mist-blue); box-shadow: 0 0 0 6rpx rgba(185,221,237,.14); }
.stage-skeleton { background: #e4e3ef; }
.identity-stage { --stage-dark: #232238; box-shadow: 0 36rpx 90rpx rgba(49,45,92,.25), 0 3rpx 0 rgba(255,255,255,.30) inset; }
.stage-press { box-shadow: 0 20rpx 50rpx rgba(49,45,92,.21); }
.identity-stage.is-editing { box-shadow: 0 0 0 4rpx var(--mist-blue), 0 36rpx 90rpx rgba(49,45,92,.25); }
.stage-sky { background: radial-gradient(circle at 74% 20%, rgba(225,223,255,.32), transparent 29%), linear-gradient(155deg, var(--card-b, #b9dded) -5%, var(--card-a, #7772c8) 42%, #232238 94%); }
.stage-action { position: absolute; z-index: 6; top: 102rpx; right: 27rpx; display: flex; align-items: center; gap: 8rpx; padding: 11rpx 15rpx; border-radius: 999rpx; color: rgba(255,255,255,.82); background: rgba(32,31,57,.28); border: 1rpx solid rgba(255,255,255,.15); font-size: 18rpx; font-weight: 650; backdrop-filter: blur(12rpx); }
.stage-action-arrow { color: var(--mist-blue); font-size: 22rpx; }
.identity-kicker, .quote-mark, .tiny-edit { color: #cfd7ff; }
.mini-badge { color: #343064; background: var(--mist-blue); border-color: #292744; }
.inline-edit { color: #d8dcff; background: rgba(207,215,255,.11); border-color: rgba(207,215,255,.23); }
.tag-edit { color: #d8dcff; border-color: rgba(207,215,255,.34); }
.foot-spark { color: var(--accent-deep); border-color: rgba(78,73,135,.08); box-shadow: 0 8rpx 24rpx rgba(54,49,96,.06); }
.foot-title, .hstat-n { color: var(--ink); }
.foot-sub, .hstat-l { color: var(--sub); }
.insight { background: rgba(255,255,255,.68); border-color: rgba(78,73,135,.08); }
.insight-label { color: var(--ink-2); }
.editor-guide { color: #fff; background: var(--accent-deep); box-shadow: 0 15rpx 35rpx rgba(79,74,139,.18); }
.guide-pulse { background: var(--mist-blue); box-shadow: 0 0 0 8rpx rgba(185,221,237,.13); }
.quick-edit:active { color: #fff; background: var(--accent-deep); }
.edit-sheet { background: #f7f7fb; box-shadow: 0 -28rpx 80rpx rgba(38,34,71,.20); }
.sheet-title { color: var(--ink); }
.sheet-save { color: #fff; background: var(--accent); }
.portrait-option.selected { border-color: var(--accent); box-shadow: 0 0 0 4rpx rgba(119,114,200,.10); }

/* 首页名片的价值闭环：展示身份 → 说明分身能做什么 → 立即分享给来访者。 */
.stage-vignette {
  background: linear-gradient(180deg, rgba(18,17,38,.10) 0%, transparent 34%, rgba(25,23,52,.20) 52%, rgba(24,22,46,.93) 70%, #1f1e35 100%);
}
.service-strip {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 20rpx;
  padding: 16rpx 18rpx;
  border: 1rpx solid rgba(255,255,255,.15);
  border-radius: 18rpx;
  background: rgba(255,255,255,.095);
  backdrop-filter: blur(12rpx);
}
.service-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  flex: 0 0 auto;
  border-radius: 13rpx;
  color: var(--accent-deep);
  background: var(--mist-blue);
  font-size: 16rpx;
  font-weight: 900;
}
.service-copy { min-width: 0; }
.service-title { color: rgba(255,255,255,.95); font-size: 21rpx; line-height: 1.35; font-weight: 800; }
.service-sub { margin-top: 3rpx; color: rgba(255,255,255,.64); font-size: 18rpx; line-height: 1.4; }
.stage-cta {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  width: 100%;
  height: 84rpx;
  margin-top: 16rpx;
  padding: 0;
  border: none;
  border-radius: 22rpx;
  font-size: 27rpx;
  line-height: 84rpx;
  font-weight: 850;
  letter-spacing: .4rpx;
  transition: transform .12s var(--ease), opacity .12s var(--ease);
}
.stage-cta:active { transform: scale(.985); opacity: .9; }
.stage-share { color: #2a2944; background: #fff; box-shadow: 0 12rpx 28rpx rgba(8,8,20,.20); }
.stage-cta-arrow { font-size: 28rpx; line-height: 1; }

/* 4.0 角色主视觉首页：人物负责第一眼吸引，身份与行动仍保持清晰。 */
.home-shell {
  padding-left: 26rpx;
  padding-right: 26rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 170rpx);
  background: #f6f2ed;
}
.ambient-a { background: rgba(237,200,165,.42); }
.ambient-b { background: rgba(201,195,235,.30); }
.topbar { padding-bottom: 24rpx; }
.stage-skeleton { height: 900rpx; border-radius: 48rpx; }

.identity-stage {
  height: 900rpx;
  border-radius: 48rpx;
  background: #25233b;
  box-shadow: 0 32rpx 76rpx rgba(53,45,72,.23), 0 3rpx 0 rgba(255,255,255,.32) inset;
}
.identity-stage .stage-sky {
  background:
    radial-gradient(circle at 82% 12%, rgba(255,244,222,.58), transparent 25%),
    radial-gradient(circle at 66% 30%, var(--card-b, #edc8a5), transparent 42%),
    linear-gradient(152deg, #f3e9de -8%, var(--card-b, #edc8a5) 23%, var(--card-a, #b87468) 55%, #28253f 100%);
}
.identity-stage .amb-glow {
  background: radial-gradient(360rpx 470rpx at 74% 25%, rgba(255,245,222,.78) 0%, transparent 72%);
  opacity: .25;
}
.identity-stage.has-illustration .character-stack {
  top: 62rpx;
  left: auto;
  right: -30rpx;
  width: 73%;
  height: 630rpx;
  transform-origin: 66% 68%;
  filter: saturate(.94) contrast(1.01);
}
.identity-stage.has-identity .character-stack {
  top: 28rpx;
  left: 0;
  right: auto;
  width: 100%;
  height: 620rpx;
}
.identity-stage.has-identity .character-fallback { padding-top: 116rpx; }
.stage-vignette {
  background:
    linear-gradient(90deg, rgba(34,31,53,.70) 0%, rgba(34,31,53,.16) 48%, transparent 74%),
    linear-gradient(180deg, rgba(30,27,45,.03) 0%, transparent 43%, rgba(34,31,53,.58) 62%, rgba(29,27,47,.96) 76%, #211f37 100%);
}
.stage-head { top: 27rpx; left: 28rpx; right: 28rpx; }
.live-pill { background: rgba(36,32,52,.35); }
.portrait-kind { color: rgba(255,255,255,.65); }
.companion-bubble {
  position: absolute;
  z-index: 4;
  top: 130rpx;
  left: 28rpx;
  width: 260rpx;
  padding: 17rpx 19rpx;
  border: 1rpx solid rgba(255,255,255,.62);
  border-radius: 12rpx 23rpx 23rpx 23rpx;
  color: #51493e;
  background: rgba(255,248,235,.91);
  box-shadow: 0 15rpx 35rpx rgba(50,42,65,.12);
  font-size: 21rpx;
  line-height: 1.48;
  font-weight: 650;
  backdrop-filter: blur(12rpx);
  animation: bubbleIn .5s var(--ease-out) both;
}
.identity-copy { left: 30rpx; right: 30rpx; bottom: 28rpx; }
.identity-main { max-width: 72%; padding-right: 0; }
.identity-kicker { color: #efe1bd; }
.person-name { max-width: 480rpx; font-size: 59rpx; }
.person-role { margin-top: 7rpx; font-size: 21rpx; }
.quote { max-width: 100%; margin-top: 18rpx; font-size: 24rpx; line-height: 1.48; }
.quote-mark { color: #efe1bd; }
.tags { gap: 8rpx; margin-top: 13rpx; }
.tag-item { padding: 5rpx 13rpx; font-size: 18rpx; }

.stage-actions { display: flex; gap: 12rpx; width: 100%; }
.stage-actions .stage-cta {
  width: auto;
  height: 74rpx;
  margin-top: 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  line-height: 74rpx;
}
.stage-actions .stage-cta::after { border: none; }
.stage-build, .stage-share {
  flex: 1;
  color: #302d45;
  background: #fffaf0;
  box-shadow: 0 12rpx 28rpx rgba(8,8,20,.18);
}
.stage-preview {
  flex: 0 0 190rpx;
  color: rgba(255,255,255,.88);
  background: rgba(255,255,255,.10);
  border: 1rpx solid rgba(255,255,255,.18);
}

.setup-panel, .home-live-note {
  position: relative;
  display: flex;
  align-items: center;
  gap: 17rpx;
  margin: 24rpx 4rpx 0;
  padding: 22rpx 22rpx;
  border: 1rpx solid rgba(80,69,100,.08);
  border-radius: 26rpx;
  background: rgba(255,255,255,.72);
  box-shadow: 0 12rpx 30rpx rgba(68,55,83,.06);
  transition: transform .12s ease;
}
.setup-panel-press { transform: scale(.985); }
.setup-step, .home-live-icon {
  width: 58rpx;
  height: 58rpx;
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 19rpx;
  color: #fff;
  background: var(--accent);
  font-size: 18rpx;
  font-weight: 850;
  letter-spacing: 1rpx;
}
.setup-copy { min-width: 0; flex: 1; }
.setup-title, .home-live-title { color: #302e40; font-size: 24rpx; font-weight: 850; }
.setup-sub, .home-live-sub { margin-top: 4rpx; color: #7d7888; font-size: 19rpx; line-height: 1.4; }
.setup-progress { height: 7rpx; margin-top: 13rpx; overflow: hidden; border-radius: 99rpx; background: #e9e4e3; }
.setup-progress-bar { width: 34%; height: 100%; border-radius: inherit; background: linear-gradient(90deg, var(--accent), #b8a9d7); }
.setup-arrow { color: #968fa2; font-size: 44rpx; line-height: 1; }
.home-live-note { padding-top: 20rpx; padding-bottom: 20rpx; }
.home-live-icon { color: var(--accent-deep); background: #eeeaf7; }

.insight {
  margin: 24rpx 4rpx 0;
  padding: 22rpx 24rpx;
  border-radius: 26rpx;
  background: rgba(255,255,255,.72);
  box-shadow: 0 12rpx 30rpx rgba(68,55,83,.05);
}

@keyframes bubbleIn {
  from { opacity: 0; transform: translateY(8rpx) scale(.98); }
}

@media (prefers-reduced-motion: reduce) {
  .companion-bubble { animation: none; }
}
