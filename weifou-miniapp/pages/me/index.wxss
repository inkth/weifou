.page {
  min-height: 100vh;
  box-sizing: border-box;
  background: #fbfcfb;
  padding: 16rpx 28rpx calc(env(safe-area-inset-bottom) + 140rpx);
}
.hd { padding: 28rpx 4rpx 12rpx; }
.hd-title { font-size: 48rpx; font-weight: 600; color: var(--ink); letter-spacing: -0.5rpx; }

.card { background: var(--surface); border-radius: var(--r-xl); box-shadow: var(--shadow-card); }

.clone { padding: 32rpx 28rpx; margin-bottom: 24rpx; }
.clone:active { transform: scale(0.99); }
.clone-top { display: flex; align-items: center; gap: 22rpx; }
.clone-ava {
  width: 100rpx;
  height: 100rpx;
  border-radius: var(--r-lg);
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--accent-soft);
}
.clone-ava .ic { font-size: 56rpx; color: var(--accent); }
.clone-id { flex: 1 1 auto; min-width: 0; }
.clone-name { font-size: 32rpx; font-weight: 600; color: var(--ink); letter-spacing: -0.3rpx; }
.clone-sub { margin-top: 6rpx; font-size: 25rpx; color: var(--sub); }
.clone-arrow { font-size: 30rpx; color: var(--faint); }
.clone-acts {
  display: flex;
  margin-top: 28rpx;
  padding-top: 8rpx;
  border-top: 1rpx solid var(--line);
}
.clone-act {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding: 22rpx 0 6rpx;
  font-size: 24rpx;
  color: var(--ink-2);
}
.clone-act:active { opacity: 0.55; }
.ca-ic { font-size: 42rpx; color: var(--ink-2); }

.create { padding: 44rpx 32rpx; margin-bottom: 24rpx; text-align: center; }
.create:active { transform: scale(0.99); }
.create-title { font-size: 34rpx; font-weight: 700; color: var(--ink); letter-spacing: -0.3rpx; }
.create-sub { margin-top: 10rpx; font-size: 26rpx; color: var(--sub); }
.create-btn {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 26rpx;
  padding: 20rpx 44rpx;
  background: var(--accent);
  color: #fff;
  border-radius: var(--r-full);
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: var(--shadow-accent);
}
.create-btn-ic { font-size: 30rpx; }

.group {
  margin-top: 4rpx;
  background: var(--surface);
  border-radius: var(--r-xl);
  overflow: hidden;
  box-shadow: var(--shadow-card);
}
.cell {
  display: flex;
  align-items: center;
  padding: 30rpx 28rpx;
  border-bottom: 1rpx solid var(--line);
}
.cell:last-child { border-bottom: none; }
.cell:active { background: var(--fill-pressed); }
.cell-ic { font-size: 42rpx; margin-right: 22rpx; color: var(--ink-2); }
.cell-ic-accent { color: var(--accent); }
.cell-label { flex: 1; font-size: 30rpx; color: var(--ink); }
.cell-arrow { font-size: 28rpx; color: var(--faint); }

/* 我的问答箱入口 */
.qabox { margin-top: 20rpx; display: flex; align-items: center; gap: 20rpx; }
.qabox-info { flex: 1; }
.qabox-title { font-size: 30rpx; font-weight: 600; color: var(--ink); }
.qabox-sub { font-size: 24rpx; margin-top: 6rpx; line-height: 1.5; }
.qabox-acts { display: flex; flex-direction: column; align-items: flex-end; gap: 12rpx; }
.qabox-share {
  background: var(--accent); color: #fff; font-size: 26rpx; font-weight: 600;
  border-radius: var(--r-full); padding: 12rpx 36rpx; line-height: 1.4; margin: 0;
}
.qabox-share::after { border: none; }
.qabox-preview { font-size: 24rpx; color: var(--faint); }

.legal { margin-top: 40rpx; text-align: center; color: var(--faint); font-size: 22rpx; line-height: 1.8; }
.brand-sign { color: var(--ink); opacity: 0.5; font-size: 26rpx; letter-spacing: 1rpx; margin-bottom: 14rpx; }
.legal-links { margin-top: 4rpx; }
.legal-links .dot { margin: 0 12rpx; }
