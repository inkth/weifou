<view class="page">
  <view class="hd"><view class="hd-title">我的</view></view>

  <!-- 分身、名片和分享合并为一张核心资产卡。 -->
  <view wx:if="{{profileId}}" class="clone card">
    <view class="clone-top" bindtap="goMyProfile">
      <view class="clone-ava"><view class="ic ic-bot"></view></view>
      <view class="clone-id">
        <view class="clone-name">{{realName ? realName + ' 的 AI 分身' : '我的 AI 分身'}}</view>
        <view class="clone-sub">会说话的个人名片 · 随时在线</view>
      </view>
      <view class="ic ic-chevron clone-arrow"></view>
    </view>
    <view class="clone-acts">
      <view class="clone-act" bindtap="goMyProfile"><view class="ic ic-user ca-ic"></view><text>主页</text></view>
      <button class="clone-act" open-type="share"><view class="ic ic-compose ca-ic"></view><text>分享</text></button>
      <view class="clone-act" bindtap="goOnboarding"><view class="ic ic-edit ca-ic"></view><text>编辑</text></view>
    </view>
  </view>

  <!-- 功能入口 -->
  <view class="group">
    <view class="cell" bindtap="goConnections">
      <view class="ic ic-user cell-ic cell-ic-accent"></view><text class="cell-label">名片夹</text><view class="ic ic-chevron cell-arrow"></view>
    </view>
    <view class="cell" wx:if="{{memberEntry}}" bindtap="goMembership">
      <view class="ic ic-crown cell-ic cell-ic-accent"></view><text class="cell-label">会员</text><view class="ic ic-chevron cell-arrow"></view>
    </view>
    <view class="cell" bindtap="goMemory">
      <view class="ic ic-edit cell-ic cell-ic-accent"></view><text class="cell-label">分身记忆</text><view class="ic ic-chevron cell-arrow"></view>
    </view>
  </view>

  <view class="group">
    <view class="cell" bindtap="goSettings">
      <view class="ic ic-settings cell-ic"></view><text class="cell-label">设置</text><view class="ic ic-chevron cell-arrow"></view>
    </view>
  </view>

  <!-- 合规位（AIGC 必备：备案 / 协议） -->
  <view class="legal">
    <view class="brand-sign">微否 · 每个人的 AI 分身</view>
    <view>大模型服务已依法备案 · 内容由 AI 生成</view>
    <view class="legal-links"><text>用户协议</text><text class="dot">·</text><text>隐私政策</text></view>
    <view class="logout-link" bindtap="logout">退出登录</view>
  </view>
</view>
