<view class="page">
  <view class="hd"><view class="hd-title">我的</view></view>

  <!-- 我的分身：顶部最显眼的资产卡（主人的核心资产 / 收益入口） -->
  <view wx:if="{{profileId}}" class="clone card" bindtap="goMyProfile">
    <view class="clone-top">
      <view class="clone-ava"><view class="ic ic-bot"></view></view>
      <view class="clone-id">
        <view class="clone-name">{{realName ? realName + ' 的 AI 分身' : '我的 AI 分身'}}</view>
        <view class="clone-sub">查看主页 · 人设 / 定价 / 收益</view>
      </view>
      <view class="ic ic-chevron clone-arrow"></view>
    </view>
    <view class="clone-acts">
      <view class="clone-act" catchtap="goInbox"><view class="ic ic-inbox ca-ic"></view><text>收件箱</text></view>
      <view class="clone-act" catchtap="goCreate"><view class="ic ic-edit ca-ic"></view><text>编辑</text></view>
      <view class="clone-act" catchtap="goMyProfile"><view class="ic ic-stats ca-ic"></view><text>数据</text></view>
    </view>
  </view>

  <!-- 未创建：引导创建 -->
  <view wx:elif="{{!loading}}" class="create card" bindtap="goOnboarding">
    <view class="create-title">创建我的 AI 分身</view>
    <view class="create-sub">让你的 AI 替你接待、回答、变现</view>
    <view class="create-btn"><text>开始创建</text><view class="ic ic-arrow create-btn-ic"></view></view>
  </view>

  <!-- 功能入口 -->
  <view class="group">
    <view class="cell" wx:if="{{memberEntry}}" bindtap="goMembership">
      <view class="ic ic-crown cell-ic cell-ic-accent"></view><text class="cell-label">会员</text><view class="ic ic-chevron cell-arrow"></view>
    </view>
    <view class="cell" bindtap="goQuestions">
      <view class="ic ic-compose cell-ic"></view><text class="cell-label">我的提问</text><view class="ic ic-chevron cell-arrow"></view>
    </view>
    <view class="cell" bindtap="goCalls">
      <view class="ic ic-phone cell-ic"></view><text class="cell-label">我的通话</text><view class="ic ic-chevron cell-arrow"></view>
    </view>
    <view class="cell" bindtap="goSettings">
      <view class="ic ic-settings cell-ic"></view><text class="cell-label">设置</text><view class="ic ic-chevron cell-arrow"></view>
    </view>
  </view>

  <!-- 合规位（AIGC 必备：备案 / 协议） -->
  <view class="legal">
    <view class="brand-sign">微否 · 每个人的 AI 助理</view>
    <view>大模型服务已依法备案 · 内容由 AI 生成</view>
    <view class="legal-links"><text>用户协议</text><text class="dot">·</text><text>隐私政策</text></view>
  </view>
</view>
