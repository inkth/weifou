.page {
  min-height: 100vh;
  padding: 32rpx 32rpx 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.canvas-wrap {
  background: #fff;
  border: var(--bw) solid var(--ink);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: var(--shadow-card);
}

.poster-canvas { display: block; }

.actions { width: 100%; margin-top: 48rpx; }
.hint { text-align: center; font-size: 24rpx; margin-top: 24rpx; }
.loading { margin-top: 96rpx; }
