<view class="page">
  <view class="canvas-wrap">
    <canvas type="2d" id="poster" class="poster-canvas" style="width: 600rpx; height: 900rpx;"></canvas>
  </view>

  <view class="actions" wx:if="{{ready}}">
    <button class="btn-primary" bindtap="saveToAlbum">保存到相册</button>
    <view class="hint muted">长按可识别下方小程序码进入主页</view>
  </view>
  <view wx:if="{{!ready}}" class="loading muted">海报合成中…</view>
</view>
