.page { padding: 32rpx; }
.card { margin-bottom: 24rpx; }
.section-title { font-size: 28rpx; font-weight: 600; margin-bottom: 24rpx; }

.row { display: flex; align-items: center; margin-bottom: 28rpx; }
.label { width: 120rpx; font-size: 28rpx; color: #4a5070; }
.picker-val {
  flex: 1;
  background: #f5f6fa;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  font-size: 30rpx;
}
.dur-opts { flex: 1; display: flex; gap: 20rpx; }
.dur {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  background: #f5f6fa;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: 2rpx solid transparent;
}
.dur.active { border-color: #1f2330; background: #fff; }
.save { margin-top: 8rpx; }

.empty { text-align: center; padding: 32rpx 0; }
.slot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f0f1f5;
}
.slot:last-child { border-bottom: none; }
.slot-time { font-size: 30rpx; }
.slot-meta { font-size: 24rpx; margin-top: 6rpx; }
.slot-del { color: #b34040; font-size: 26rpx; padding: 8rpx 16rpx; }
