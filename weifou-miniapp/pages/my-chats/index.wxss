.page { padding: 32rpx; }

/* 付费资产入口：并排两卡 */
.quick { display: flex; gap: 24rpx; margin-bottom: 40rpx; }
.quick-item {
  flex: 1;
  background: var(--surface);
  border: var(--bw) solid var(--border);
  border-radius: var(--r-xl);
  padding: 30rpx 0;
  box-shadow: var(--shadow-card);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}
.quick-emoji { font-size: 42rpx; line-height: 1; color: var(--accent); }
.quick-label { font-size: 26rpx; color: var(--ink); }

.sec-title { font-size: 26rpx; color: var(--sub); margin: 0 8rpx 20rpx; }
/* 付费往来：降权为列表下方的次级记录，与"最近聊过"拉开间距 */
.pay-title { margin-top: 48rpx; }

/* 文字对话项 */
.chat-item { display: flex; align-items: center; gap: 24rpx; margin-bottom: 20rpx; }
.avatar { width: 88rpx; height: 88rpx; border-radius: 50%; flex-shrink: 0; }
.avatar-img { overflow: hidden; }
.avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--accent-soft);
  color: var(--accent-ink);
  border: var(--bw-thin) solid var(--border);
  font-size: 36rpx;
  font-weight: 600;
}
.chat-body { flex: 1; min-width: 0; }
.chat-top { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 8rpx; }
.chat-name { font-size: 30rpx; font-weight: 600; color: var(--ink); }
.chat-time { font-size: 24rpx; flex-shrink: 0; margin-left: 16rpx; }
.chat-last { font-size: 26rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

.empty { text-align: center; padding-top: 160rpx; line-height: 1.9; }
.empty-sub { font-size: 26rpx; margin-top: 8rpx; }
