/* 学习区主页:双视图(第N课卡片流 + 闯关地图)。每个节点/课卡都是一颗 3D 糖果控件。
   页面级皮肤:暖纸底 --paper(学习区限定,"翻开冒险手账"),控件层令牌不动。 */
.map {
  position: relative;
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--paper);
}

/* —— 顶部角色面板:四格属性条(白卡上四等分格,发丝线分隔) —— */
.map-top {
  display: flex;
  align-items: stretch;
  padding: 14rpx 16rpx;
  background: var(--surface);
  border-bottom: var(--bw-thin) solid var(--border);
}
.st-cell {
  flex: 1;
  min-width: 0;
  text-align: center;
  padding: 6rpx 4rpx;
}
.st-cell + .st-cell { border-left: 2rpx solid var(--line); }
.st-val {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--ink);
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.st-lab {
  margin-top: 4rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: var(--sub);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.st-ic {
  display: inline-block;
  width: 26rpx;
  height: 26rpx;
  vertical-align: -4rpx;
  margin-right: 4rpx;
}

/* —— 骨架 —— */
.map-loading { padding: 40rpx 48rpx; }
.skel-banner { height: 96rpx; border-radius: var(--r-lg); margin-bottom: 48rpx; }
.skel-node { width: 120rpx; height: 120rpx; border-radius: 50%; margin: 0 auto 56rpx; }
.skel-node-r { transform: translateX(120rpx); }

/* —— 地图滚动区 —— */
.map-scroll { flex: 1; min-height: 0; }
.map-pad { height: 200rpx; }

/* checkpoint 横幅:糖果色横带 */
.cp-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 40rpx 32rpx 44rpx;
  padding: 24rpx 32rpx;
  border-radius: var(--r-lg);
  font-weight: 800;
}
.cp-banner .cpb-name { font-size: 30rpx; }
.cp-banner .cpb-prog { font-size: 26rpx; opacity: 0.85; }
.tone-butter { background: var(--pop-butter); color: var(--pop-butter-ink); box-shadow: 0 6rpx 0 #d9a900; }
.tone-sky    { background: var(--pop-sky); color: var(--pop-sky-ink); box-shadow: 0 6rpx 0 #b7e3f8; }
.tone-mint   { background: var(--pop-mint); color: var(--pop-mint-ink); box-shadow: 0 6rpx 0 #83d9b9; }
.tone-lilac  { background: var(--pop-lilac); color: var(--pop-lilac-ink); box-shadow: 0 6rpx 0 #cbaaf0; }

/* —— 蜿蜒节点行:JS 注入 translateX 相位 —— */
.node-row {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 20rpx;
}

/* 节点 = 3D 糖果按钮(120rpx 圆) */
.node {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.1s var(--ease), box-shadow 0.1s var(--ease);
}
.node-face { font-size: 52rpx; line-height: 1; }
.node-img { width: 64rpx; height: 64rpx; }
.node.locked .node-img { width: 56rpx; height: 56rpx; opacity: 0.55; }

.node.locked {
  background: var(--fill);
  box-shadow: 0 10rpx 0 var(--border);
}
.node.locked .node-face { opacity: 0.55; font-size: 44rpx; }
.node.available {
  background: var(--surface);
  border: 4rpx solid var(--accent);
  box-shadow: 0 10rpx 0 var(--border);
}
.node.current {
  background: var(--accent);
  box-shadow: 0 10rpx 0 var(--accent-strong);
  transform: scale(1.15);
}
.node.current:active { transform: scale(1.15) translateY(10rpx); }
.node.lit {
  background: var(--accent);
  box-shadow: 0 10rpx 0 var(--accent-strong);
}
.node.mastered {
  background: var(--gold);
  box-shadow: 0 10rpx 0 var(--gold-strong);
}
.node:active { transform: translateY(10rpx); box-shadow: none; }

/* 当前关外圈脉冲 */
.node-pulse {
  position: absolute;
  inset: -18rpx;
  border-radius: 50%;
  border: 6rpx solid var(--accent);
  opacity: 0.5;
  animation: nodePulse 1.6s ease-out infinite;
  pointer-events: none;
}
@keyframes nodePulse {
  0% { transform: scale(0.9); opacity: 0.55; }
  70% { transform: scale(1.12); opacity: 0; }
  100% { transform: scale(1.12); opacity: 0; }
}

.node-name {
  margin-top: 12rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: var(--ink);
  max-width: 220rpx;
  text-align: center;
}
.node-name.dim { color: var(--faint); font-weight: 600; }

/* 节点间路径感:3 个渐隐小圆点 */
.dotlead {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
  margin-top: 8rpx;
  line-height: 0.9;
}
.dotlead text { color: var(--border-strong); font-size: 34rpx; font-weight: 800; }
.dotlead text:nth-child(2) { opacity: 0.66; }
.dotlead text:nth-child(3) { opacity: 0.33; }
.node-row:last-child .dotlead { visibility: hidden; }

/* —— 底部固定 CTA(纸色渐变垫:节点滚到按钮下方时不穿帮) —— */
.map-cta-wrap {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 48rpx 32rpx calc(env(safe-area-inset-bottom) + 24rpx);
  background: linear-gradient(180deg, rgba(255, 251, 240, 0) 0%, var(--paper) 56%);
  z-index: 20;
}
.map-cta {
  font-size: 32rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  padding-left: 24rpx;
  padding-right: 24rpx;
}

/* —— 关卡卡片抽屉 —— */
.drawer-mask {
  position: fixed;
  inset: 0;
  z-index: 50;
  background: rgba(75, 75, 75, 0.35);
  display: flex;
  align-items: flex-end;
}
.lc-drawer {
  position: relative;
  width: 100%;
  background: var(--surface);
  border-radius: var(--r-3xl) var(--r-3xl) 0 0;
  padding: 20rpx 40rpx calc(env(safe-area-inset-bottom) + 40rpx);
  box-shadow: var(--shadow-pop);
  animation: lcUp 0.26s var(--ease-out);
}
@keyframes lcUp { from { transform: translateY(40%); opacity: 0.4; } to { transform: translateY(0); opacity: 1; } }
.lc-grip {
  width: 72rpx;
  height: 8rpx;
  border-radius: var(--r-full);
  background: var(--border);
  margin: 0 auto 28rpx;
}
.lc-state {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: var(--r-full);
  font-size: 22rpx;
  font-weight: 800;
  background: var(--accent-soft);
  color: var(--accent-ink);
}
.lc-state.mastered { background: var(--gold); color: #7a5c00; }
.lc-state.locked { background: var(--fill); color: var(--sub); }

/* 角落风味角标(借挂机游戏事件卡"小吉"位置感,文案只正向/中性) */
.lc-flavor {
  position: absolute;
  top: 56rpx;
  right: 40rpx;
  padding: 6rpx 20rpx;
  border-radius: var(--r-full);
  font-size: 22rpx;
  font-weight: 800;
}
.lc-flavor.current { background: var(--pop-butter); color: var(--pop-butter-ink); }
.lc-flavor.available { background: var(--pop-sky); color: var(--pop-sky-ink); }
.lc-flavor.lit { background: var(--pop-mint); color: var(--pop-mint-ink); }
.lc-flavor.mastered { background: var(--gold); color: #7a5c00; }
.lc-flavor.locked { background: var(--fill); color: var(--sub); }
.lc-name { margin-top: 16rpx; font-size: 44rpx; font-weight: 800; color: var(--ink); }
.lc-blurb { margin-top: 8rpx; font-size: 28rpx; color: var(--ink-2); }
.lc-report {
  margin-top: 16rpx;
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: var(--r-full);
  background: var(--pop-mint);
  color: var(--pop-mint-ink);
  font-size: 24rpx;
  font-weight: 700;
}
.lc-hook {
  margin-top: 24rpx;
  padding: 24rpx 28rpx;
  background: var(--surface-sunken);
  border-radius: var(--r-md);
  font-size: 26rpx;
  color: var(--ink-2);
  line-height: 1.7;
}
.lc-go { margin-top: 32rpx; }

/* ============ 视图一:第N课卡片流 ============ */
.stream-scroll { flex: 1; min-height: 0; }

/* 视图切换 chip(糖果小丸,浮在滚动区右上) */
.view-toggle {
  position: absolute;
  top: 128rpx;
  right: 24rpx;
  z-index: 30;
  padding: 12rpx 24rpx;
  border-radius: var(--r-full);
  background: var(--surface);
  box-shadow: var(--shadow-card);
  font-size: 24rpx;
  font-weight: 800;
  color: var(--ink);
  transition: transform 0.1s var(--ease), box-shadow 0.1s var(--ease);
}
.view-toggle:active { transform: translateY(6rpx); box-shadow: none; }

/* 吉祥物舞台:emoji 占位 + 台面(真立绘后续替换 stage-face) */
.stage {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 36rpx 32rpx 4rpx;
}
.stage-face {
  font-size: 104rpx;
  line-height: 1.15;
  filter: drop-shadow(0 8rpx 0 rgba(0, 0, 0, 0.08));
}
.stage-deck {
  width: 300rpx;
  height: 24rpx;
  margin-top: -2rpx;
  border-radius: var(--r-full);
  background: var(--surface);
  box-shadow: var(--shadow-card);
}

/* 课卡基形:白卡 + 3D 底唇 + 按压下沉 */
.lsn {
  margin: 0 32rpx 24rpx;
  padding: 26rpx 30rpx;
  background: var(--surface);
  border-radius: var(--r-lg);
  box-shadow: var(--shadow-card);
  transition: transform 0.1s var(--ease), box-shadow 0.1s var(--ease);
}
.lsn:active { transform: translateY(5rpx); box-shadow: none; }
.lsn-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.lsn-num { font-size: 22rpx; font-weight: 800; color: var(--sub); }
.lsn-flavor {
  padding: 4rpx 18rpx;
  border-radius: var(--r-full);
  font-size: 20rpx;
  font-weight: 800;
}
.lsn-flavor.current { background: var(--pop-butter); color: var(--pop-butter-ink); }
.lsn-flavor.lit { background: var(--pop-mint); color: var(--pop-mint-ink); }
.lsn-flavor.mastered { background: var(--gold); color: #7a5c00; }
.lsn-name { margin-top: 8rpx; font-size: 32rpx; font-weight: 800; color: var(--ink); }
.lsn-report {
  margin-top: 10rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--ink-2);
}
.lsn-ic {
  display: inline-block;
  width: 26rpx;
  height: 26rpx;
  vertical-align: -4rpx;
  margin-right: 6rpx;
}
.lsn-note { color: var(--sub); font-weight: 600; }

/* 当前课:悬念卡(描边高亮 + Hook 全文 + 内嵌大按钮) */
.lsn.current {
  border: 4rpx solid var(--accent);
  box-shadow: 0 10rpx 0 var(--accent-strong);
}
.lsn-hook {
  margin-top: 16rpx;
  padding: 22rpx 26rpx;
  background: var(--surface-sunken);
  border-radius: var(--r-md);
  font-size: 26rpx;
  color: var(--ink-2);
  line-height: 1.7;
}
.lsn-go {
  margin-top: 22rpx;
  font-size: 30rpx;
}

/* 未来课:蒙雾卡(只有课号+名,软锁可点) */
.lsn.available,
.lsn.locked {
  padding: 20rpx 30rpx;
  background: var(--fill);
  box-shadow: 0 6rpx 0 var(--border);
}
.lsn.available .lsn-name,
.lsn.locked .lsn-name { color: var(--faint); font-weight: 700; font-size: 28rpx; }
.lsn.available .lsn-num,
.lsn.locked .lsn-num { color: var(--faint); }

/* Boss 关(章末综合关):金卡(蒙雾中的 Boss 也保留金边预告分量;普通掌握卡不加金边,守住 Boss 稀缺感) */
.lsn.boss {
  border: 4rpx solid var(--gold);
  box-shadow: 0 10rpx 0 var(--gold-strong);
}
.lsn.boss.current { border-color: var(--gold); }
