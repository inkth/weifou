<view class="map" style="--accent: {{accent}};">
  <!-- 顶部角色面板:四格属性条(借挂机游戏 EXP/生命/攻击/防御 的紧凑编排,皮肤用自己的) -->
  <view class="map-top" wx:if="{{!loading}}">
    <block wx:if="{{skill}}">
      <view class="st-cell"><view class="st-val">Lv.{{skill.level}}</view><view class="st-lab"><image class="st-ic" src="/assets/icons/learn/medal.webp" />{{skill.levelName}}</view></view>
      <view class="st-cell"><view class="st-val">{{skill.fluency}}</view><view class="st-lab"><image class="st-ic" src="/assets/icons/learn/speak.webp" />流利</view></view>
      <view class="st-cell"><view class="st-val">{{skill.accuracy}}</view><view class="st-lab"><image class="st-ic" src="/assets/icons/learn/target.webp" />准确</view></view>
      <view class="st-cell"><view class="st-val">{{skill.expression}}</view><view class="st-lab"><image class="st-ic" src="/assets/icons/learn/bubble.webp" />表达</view></view>
    </block>
    <block wx:else>
      <view class="st-cell"><view class="st-val">{{streakDays}}</view><view class="st-lab"><image class="st-ic" src="/assets/icons/learn/flame.webp" />连学</view></view>
      <view class="st-cell"><view class="st-val">{{lit}}/{{total}}</view><view class="st-lab"><image class="st-ic" src="/assets/icons/learn/star.webp" />点亮</view></view>
      <view class="st-cell"><view class="st-val">{{mastered}}</view><view class="st-lab"><image class="st-ic" src="/assets/icons/learn/crown.webp" />掌握</view></view>
      <view class="st-cell"><view class="st-val">{{due}}</view><view class="st-lab"><image class="st-ic" src="/assets/icons/learn/review.webp" />复习</view></view>
    </block>
  </view>

  <!-- 视图切换:卡片流 ⇄ 地图 -->
  <view wx:if="{{!loading}}" class="view-toggle" bindtap="toggleView">{{viewMode === 'stream' ? '🗺️ 地图' : '📜 课程'}}</view>

  <view wx:if="{{loading}}" class="map-loading">
    <view class="skel skel-banner"></view>
    <view class="skel skel-node"></view>
    <view class="skel skel-node skel-node-r"></view>
    <view class="skel skel-node"></view>
  </view>

  <!-- 视图一:第N课卡片流(默认)。成果卡=战报,当前卡=Hook悬念+大按钮,未来卡=蒙雾(软锁可点) -->
  <scroll-view wx:elif="{{viewMode === 'stream'}}" scroll-y class="stream-scroll" scroll-into-view="{{streamAnchor}}" scroll-with-animation>
    <!-- 吉祥物舞台:课程 emoji 占位,真立绘后续补 -->
    <view class="stage">
      <view class="stage-face">{{icon}}</view>
      <view class="stage-deck"></view>
    </view>
    <block wx:for="{{sections}}" wx:key="key" wx:for-item="sec">
      <view class="cp-banner tone-{{sec.tone}}">
        <view class="cpb-name">{{sec.tier}} · {{sec.theme}}</view>
        <view class="cpb-prog">{{sec.lit}}/{{sec.total}}</view>
      </view>
      <view
        wx:for="{{sec.nodes}}"
        wx:key="slug"
        wx:for-item="n"
        id="card-{{n.slug}}"
        class="lsn {{n.state}} {{n.boss ? 'boss' : ''}}"
        bindtap="openCard"
        data-slug="{{n.slug}}"
      >
        <view class="lsn-top">
          <text class="lsn-num">{{n.boss ? '👑 ' : ''}}第{{n.num}}课</text>
          <text wx:if="{{n.state === 'mastered' || n.state === 'lit' || n.state === 'current'}}" class="lsn-flavor {{n.state}}">{{n.flavor}}</text>
        </view>
        <view class="lsn-name">{{n.name}}</view>
        <view wx:if="{{n.state === 'mastered' || n.state === 'lit'}}" class="lsn-report">
          <image class="lsn-ic" src="{{n.icon}}" mode="aspectFit" />
          <text>{{n.state === 'mastered' ? '已掌握' : '已点亮'}}</text>
          <text wx:if="{{n.note}}" class="lsn-note"> · {{n.note}}</text>
        </view>
        <block wx:if="{{n.state === 'current'}}">
          <view class="lsn-hook">{{n.hook || n.blurb}}</view>
          <view class="lsn-go btn-accent" catchtap="startFromCard" data-slug="{{n.slug}}">上这一课</view>
        </block>
      </view>
    </block>
    <view class="map-pad"></view>
  </scroll-view>

  <!-- 视图二:闯关地图(蜿蜒路径,自由跳关) -->
  <scroll-view wx:else scroll-y class="map-scroll" scroll-into-view="{{currentAnchor}}" scroll-with-animation>
    <block wx:for="{{sections}}" wx:key="key" wx:for-item="sec">
      <!-- 主题 checkpoint 横幅(糖果色轮换) -->
      <view class="cp-banner tone-{{sec.tone}}">
        <view class="cpb-name">{{sec.tier}} · {{sec.theme}}</view>
        <view class="cpb-prog">{{sec.lit}}/{{sec.total}}</view>
      </view>
      <view
        wx:for="{{sec.nodes}}"
        wx:key="slug"
        wx:for-item="n"
        id="node-{{n.slug}}"
        class="node-row"
        style="transform: translateX({{n.x}}rpx);"
      >
        <view class="node {{n.state}}" bindtap="openCard" data-slug="{{n.slug}}">
          <view wx:if="{{n.state === 'current'}}" class="node-pulse"></view>
          <image wx:if="{{n.icon}}" class="node-img" src="{{n.icon}}" mode="aspectFit" />
          <text wx:else class="node-face">{{n.emoji}}</text>
        </view>
        <view class="node-name {{n.state === 'locked' ? 'dim' : ''}}">{{n.name}}</view>
        <view class="dotlead"><text>·</text><text>·</text><text>·</text></view>
      </view>
    </block>
    <view class="map-pad"></view>
  </scroll-view>

  <!-- 底部固定 CTA -->
  <view wx:if="{{!loading}}" class="map-cta-wrap">
    <view class="map-cta btn-accent" bindtap="startCurrent">
      {{current ? '继续学习 · ' + current.name : '全图点亮 · 去冲掌握'}}
    </view>
  </view>

  <!-- 关卡卡片(底部抽屉) -->
  <view class="drawer-mask" wx:if="{{card}}" bindtap="closeCard">
    <view class="lc-drawer" catchtap="noop">
      <view class="lc-grip"></view>
      <view class="lc-state {{card.state}}">{{card.stateText}}</view>
      <view class="lc-flavor {{card.state}}">{{card.flavor}}</view>
      <view class="lc-name">{{card.name}}</view>
      <view class="lc-blurb">{{card.blurb}}</view>
      <view wx:if="{{card.note}}" class="lc-report">上次战报 · {{card.note}}</view>
      <view wx:if="{{card.hook}}" class="lc-hook">「{{card.hook}}」</view>
      <view class="lc-go btn-accent" bindtap="startNode">{{card.cta}}</view>
    </view>
  </view>
</view>
