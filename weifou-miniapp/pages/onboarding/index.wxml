<view class="ob">
  <!-- 创建阶段不预设人物形象，只保留安静的 AI 环境光。 -->
  <view class="bg-scrim"></view>

  <view class="ob-hero">
    <view class="ob-helper">
      <view class="ob-hero-title">{{editMode ? '想更新什么？说一句就改' : '先聊几句，我来替你建分身'}}</view>
    </view>
    <view class="ob-hero-sub muted">{{editMode ? '没提到的都给你留着' : '说一句，或点下方选项都行'}}</view>
  </view>

  <scroll-view class="ob-msgs" scroll-y scroll-into-view="{{toLast}}" scroll-with-animation>
    <view wx:for="{{msgs}}" wx:key="id" id="{{item.id}}" class="ob-row {{item.role}}">
      <view class="ob-bubble {{item.role}}">{{item.text}}</view>
    </view>
    <view wx:if="{{thinking}}" class="ob-row ai">
      <view class="ob-bubble ai ob-typing"><text class="dot"></text><text class="dot"></text><text class="dot"></text></view>
    </view>
    <view class="ob-pad" id="ob-pad-bottom"></view>
  </scroll-view>

  <view class="ob-foot">
    <!-- 快捷选项：承自原 5 步点选，点了即答（也可在下方自由说/语音） -->
    <view class="ob-opts" wx:if="{{chipKind}}">
      <block wx:if="{{chipKind === 'domain'}}">
        <view class="ob-opt" wx:for="{{DOMAINS}}" wx:key="*this"
              data-field="title" data-value="{{item}}" data-label="{{item}}" bindtap="pickChip">{{item}}</view>
      </block>
      <block wx:elif="{{chipKind === 'audience'}}">
        <view class="ob-opt" wx:for="{{AUDIENCES}}" wx:key="label"
              data-field="howToKnow" data-value="{{item.hk}}" data-label="{{item.label}}" bindtap="pickChip">{{item.label}}</view>
      </block>
      <block wx:elif="{{chipKind === 'style'}}">
        <view class="ob-opt col" wx:for="{{STYLES}}" wx:key="value"
              data-field="style" data-value="{{item.value}}" data-label="{{item.label}}" bindtap="pickChip">
          <text class="ob-opt-l">{{item.label}}</text>
          <text class="ob-opt-d">{{item.desc}}</text>
        </view>
      </block>
      <block wx:elif="{{chipKind === 'strengths'}}">
        <view class="ob-opt full" wx:for="{{strengthOpts}}" wx:key="*this"
              data-field="strengths" data-value="{{item}}" data-label="{{item}}" bindtap="pickChip">{{item}}</view>
        <view class="ob-opt ghost" wx:if="{{optsLoading}}">正在替你想几个…</view>
        <view class="ob-opt ghost" wx:elif="{{strengthOpts.length}}" bindtap="moreStrengthOpts">🔄 换一批</view>
      </block>
    </view>

    <view class="ob-quick" wx:if="{{canFinish}}">
      <view class="ob-chip strong" bindtap="onFinishNow">{{editMode ? '更新分身 ›' : '信息够了，先上岗 ›'}}</view>
    </view>
    <view class="ob-composer">
      <view class="ob-mic {{recording ? 'on' : ''}}" bindtouchstart="onMicStart" bindtouchend="onMicEnd" bindtouchcancel="onMicEnd">
        <view class="ob-mic-i"></view>
      </view>
      <input class="ob-input" placeholder="{{recording ? '松开结束 · 正在听…' : '打字，或按住左侧说话'}}" placeholder-style="color: #8d909b" value="{{input}}"
             confirm-type="send" bindinput="onInput" bindconfirm="onSend"
             disabled="{{submitting || recording}}"/>
      <view class="ob-send {{input ? '' : 'off'}}" bindtap="onSend">
        <view class="ob-send-i"></view>
      </view>
    </view>
  </view>
</view>
