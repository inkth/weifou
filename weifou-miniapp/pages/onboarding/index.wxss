@import "../../styles/stage.wxss";

/* 创建页 = 全屏糖果亮场沉浸：助理在场 + 对话/输入全白玻璃半透明，与首页同款 */
.ob {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
  background: var(--grad-sky);
}
/* 与首页/build 统一：立绘铺底 + 轻白雾，内容浮其上 */
.bg-lihe { position: fixed; inset: 0; width: 100%; height: 100%; z-index: 0; }
.bg-scrim {
  position: fixed; inset: 0; z-index: 1;
  background: linear-gradient(180deg, rgba(255,255,255,0.2) 0%, rgba(255,255,255,0.55) 100%);
}
.ob-hero, .ob-msgs, .ob-foot { position: relative; z-index: 2; }

.ob-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: calc(env(safe-area-inset-top) + 24rpx) 0 18rpx;
  background: transparent;
}
.ob-helper { display: flex; align-items: center; gap: 14rpx; }
.ob-hero-title { font-size: 30rpx; font-weight: 600; color: var(--ink); }
.ob-hero-sub { font-size: 24rpx; margin-top: 8rpx; color: var(--ink-2); }

.ob-msgs {
  flex: 1;
  min-height: 0;
  padding: 24rpx 28rpx 0;
  box-sizing: border-box;
  position: relative;
  z-index: 1;
}
.ob-pad { height: 12rpx; }

.ob-row { display: flex; margin-bottom: 18rpx; }
.ob-row.ai { justify-content: flex-start; }
.ob-row.me { justify-content: flex-end; }

.ob-bubble {
  max-width: 78%;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  line-height: 1.5;
  border-radius: 24rpx;
}
.ob-bubble.ai {
  background: var(--glass-dark);
  border: 1rpx solid var(--border);
  color: var(--ink);
  border-bottom-left-radius: 8rpx;
}
.ob-bubble.me {
  background: rgba(24, 182, 144, 0.9); /* = --accent @ .9，玻璃上有意留半透，故落 rgba */
  color: var(--on-accent);
  border-bottom-right-radius: 8rpx;
}

.ob-foot {
  background: transparent;
  padding: 12rpx 24rpx calc(env(safe-area-inset-bottom) + 16rpx);
  position: relative;
  z-index: 1;
}

.ob-quick { display: flex; gap: 16rpx; margin-bottom: 14rpx; }
.ob-chip {
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  color: var(--ink);
  background: var(--glass-dark);  border: 1rpx solid var(--border);
  border-radius: 100rpx;
}
.ob-chip.strong {
  color: var(--accent-ink);
  background: var(--accent-soft);
  border-color: var(--accent);
  font-weight: 500;
}

/* 快捷选项（承自原 5 步点选）：白玻璃气泡，点按高亮碧绿 */
.ob-opts { display: flex; flex-wrap: wrap; gap: 14rpx; margin-bottom: 14rpx; }
.ob-opt {
  padding: 16rpx 26rpx;
  font-size: 26rpx;
  color: var(--ink);
  background: var(--glass-dark);  border: 1rpx solid var(--border);
  border-radius: 100rpx;
}
.ob-opt:active { background: var(--accent-soft); border-color: var(--accent); }
.ob-opt.col {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 4rpx;
  padding: 18rpx 26rpx;
  border-radius: 20rpx;
}
.ob-opt-l { font-size: 28rpx; font-weight: 600; }
.ob-opt-d { font-size: 22rpx; color: var(--sub); }
/* 卖点动态候选：整句成行 + 「换一批/生成中」灰态 */
.ob-opt.full { width: 100%; box-sizing: border-box; border-radius: 20rpx; line-height: 1.5; }
.ob-opt.ghost { color: var(--sub); background: rgba(255,255,255,0.45); }

.ob-typing { display: inline-flex; align-items: center; gap: 10rpx; padding: 24rpx 26rpx; }
.ob-typing .dot { width: 12rpx; height: 12rpx; border-radius: 50%; background: var(--sub); animation: obBlink 1.2s infinite ease-in-out; }
.ob-typing .dot:nth-child(2) { animation-delay: 0.2s; }
.ob-typing .dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes obBlink { 0%, 80%, 100% { opacity: 0.3; } 40% { opacity: 1; } }

.ob-composer { display: flex; align-items: center; gap: 14rpx; }

.ob-mic {
  width: 80rpx; height: 80rpx; flex-shrink: 0; border-radius: 50%;
  background: var(--glass-dark);  border: 1rpx solid var(--border);
  display: flex; align-items: center; justify-content: center;
}
.ob-mic.on { background: var(--accent-soft); border-color: var(--accent); }
.ob-mic-i { position: relative; width: 22rpx; height: 34rpx; border-radius: 100rpx; background: var(--ink-2); }
.ob-mic.on .ob-mic-i { background: var(--accent); }
.ob-mic-i::after {
  content: ''; position: absolute; left: 50%; bottom: -16rpx; transform: translateX(-50%);
  width: 30rpx; height: 16rpx; border: 3rpx solid currentColor; border-top: none;
  border-radius: 0 0 30rpx 30rpx; color: var(--ink-2);
}
.ob-mic.on .ob-mic-i::after { color: var(--accent); }
.ob-input {
  flex: 1; height: 80rpx; padding: 0 28rpx;
  background: var(--glass-dark);  border: 1rpx solid var(--border);
  border-radius: 100rpx; font-size: 28rpx; color: var(--ink);
}
.ob-send {
  width: 80rpx; height: 80rpx; border-radius: 50%;
  background: var(--accent);
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 6rpx 0 var(--accent-strong);
}
.ob-send.off { background: var(--border); box-shadow: none; }
.ob-send-i { width: 0; height: 0; border-left: 14rpx solid transparent; border-right: 14rpx solid transparent; border-bottom: 20rpx solid var(--on-accent); margin-top: -2rpx; }

.ob-form-link { text-align: center; font-size: 24rpx; margin-top: 18rpx; color: var(--sub); }
