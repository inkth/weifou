.ob {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
}

.ob-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 36rpx 0 20rpx;
  background: #fff;
}
.ob-hero-title {
  margin-top: 18rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--ink);
}
.ob-hero-sub { font-size: 24rpx; margin-top: 6rpx; }

.ob-msgs {
  flex: 1;
  min-height: 0;
  padding: 24rpx 28rpx 0;
  box-sizing: border-box;
}
.ob-pad { height: 12rpx; }

.ob-row { display: flex; margin-bottom: 18rpx; }
.ob-row.ai { justify-content: flex-start; }
.ob-row.me { justify-content: flex-end; }

.ob-bubble {
  max-width: 78%;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  line-height: 1.5;
  border-radius: 24rpx;
}
.ob-bubble.ai {
  background: #fff;
  color: var(--ink);
  border: 2rpx solid #f0e6dc;
  border-bottom-left-radius: 8rpx;
}
.ob-bubble.me {
  background: var(--ink);
  color: #fff;
  border-bottom-right-radius: 8rpx;
}

.ob-foot {
  background: var(--bg);
  padding: 12rpx 24rpx calc(env(safe-area-inset-bottom) + 16rpx);
}

.ob-quick {
  display: flex;
  gap: 16rpx;
  margin-bottom: 14rpx;
}
.ob-chip {
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  color: var(--sub);
  background: #fff;
  border: 2rpx solid var(--border);
  border-radius: 100rpx;
}
.ob-chip.strong {
  color: var(--accent-ink);
  background: var(--accent-soft);
  border-color: transparent;
  font-weight: 500;
}

.ob-typing {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 24rpx 26rpx;
}
.ob-typing .dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #c3b4a6;
  animation: obBlink 1.2s infinite ease-in-out;
}
.ob-typing .dot:nth-child(2) { animation-delay: 0.2s; }
.ob-typing .dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes obBlink {
  0%, 80%, 100% { opacity: 0.3; }
  40% { opacity: 1; }
}

.ob-composer {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.ob-mic {
  width: 80rpx;
  height: 80rpx;
  flex-shrink: 0;
  border-radius: 50%;
  background: #fff;
  border: 2rpx solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
}
.ob-mic.on {
  background: var(--accent-soft);
  border-color: var(--accent);
}
/* 麦克风图形：圆角竖条 + 底座 */
.ob-mic-i {
  position: relative;
  width: 22rpx;
  height: 34rpx;
  border-radius: 100rpx;
  background: var(--sub);
}
.ob-mic.on .ob-mic-i { background: var(--accent); }
.ob-mic-i::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: -16rpx;
  transform: translateX(-50%);
  width: 30rpx;
  height: 16rpx;
  border: 3rpx solid currentColor;
  border-top: none;
  border-radius: 0 0 30rpx 30rpx;
  color: var(--sub);
}
.ob-mic.on .ob-mic-i::after { color: var(--accent); }
.ob-input {
  flex: 1;
  height: 80rpx;
  padding: 0 28rpx;
  background: #fff;
  border: 2rpx solid var(--border);
  border-radius: 100rpx;
  font-size: 28rpx;
}
.ob-send {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--accent);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 16rpx rgba(251, 146, 60, 0.4);
}
.ob-send.off { background: #cfd3da; box-shadow: none; }
.ob-send-i {
  width: 0;
  height: 0;
  border-left: 14rpx solid transparent;
  border-right: 14rpx solid transparent;
  border-bottom: 20rpx solid #fff;
  margin-top: -2rpx;
}

.ob-form-link {
  text-align: center;
  font-size: 24rpx;
  margin-top: 18rpx;
}
