.call-page {
  position: relative;
  width: 100vw;
  height: 100vh;
  background: #000;
  overflow: hidden;
}

.remote-area {
  position: absolute;
  inset: 0;
  display: flex;
  flex-wrap: wrap;
}
.remote-player { width: 100%; height: 100%; }

.waiting {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 30rpx;
}

.local-pusher {
  position: absolute;
  top: 120rpx;
  right: 24rpx;
  width: 200rpx;
  height: 300rpx;
  border-radius: 16rpx;
  overflow: hidden;
  z-index: 10;
}

.timer {
  position: absolute;
  top: 40rpx;
  left: 0;
  right: 0;
  text-align: center;
  color: #fff;
  font-size: 30rpx;
  z-index: 10;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.6);
}

.controls {
  position: absolute;
  bottom: calc(60rpx + env(safe-area-inset-bottom));
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  gap: 32rpx;
  z-index: 10;
}
.ctrl {
  padding: 20rpx 28rpx;
  background: rgba(255,255,255,0.18);
  color: #fff;
  border-radius: 100rpx;
  font-size: 26rpx;
}
.ctrl.off { background: rgba(255,255,255,0.08); color: #aaa; }
.ctrl.hangup { background: #e0404b; }

.fallback {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}
.fb-title { color: #fff; font-size: 30rpx; text-align: center; line-height: 1.6; }
