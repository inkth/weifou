<view class="page">
  <view class="intro">
    <view class="intro-title">分身的记忆</view>
    <view class="intro-sub muted">这些是你的 AI 分身记住的、关于你的资料 —— 它对外回答时会用上。越喂越懂你。</view>
  </view>

  <view class="acts">
    <view class="act act-primary" hover-class="act-press" hover-stay-time="0" bindtap="ingestMemory">✨ 粘贴资料，自动整理</view>
    <view class="act" hover-class="act-press" hover-stay-time="0" bindtap="addMemory">＋ 手动加一条</view>
  </view>

  <view wx:if="{{loading}}" class="empty muted">加载中…</view>
  <view wx:elif="{{loadError}}" class="empty-wrap">
    <view class="empty-title">加载失败</view>
    <view class="empty-sub">网络不太稳,点下面重试</view>
    <view class="empty-cta" bindtap="retry">重试</view>
  </view>
  <view wx:elif="{{!items.length}}" class="empty muted">还没有记忆。粘贴一段你的资料，分身就开始懂你了。</view>

  <view class="m-item" wx:for="{{items}}" wx:key="id">
    <view wx:if="{{item.topic}}" class="m-topic">{{item.topic}}</view>
    <view class="m-content">{{item.content}}</view>
    <view class="m-foot">
      <text class="m-src muted">{{item.source === 'gap' ? '来自访客提问' : item.source === 'ingest' ? '自动整理' : '手动添加'}}</text>
      <text class="m-del" catchtap="deleteMemory" data-id="{{item.id}}">删除</text>
    </view>
  </view>
</view>
