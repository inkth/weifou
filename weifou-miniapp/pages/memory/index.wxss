page { background: #f5f6fa; }
.page { padding: 24rpx; }
.muted { color: #9aa0ab; }

.intro { padding: 8rpx 8rpx 24rpx; }
.intro-title { font-size: 36rpx; font-weight: 700; color: var(--ink, #1a1a1a); }
.intro-sub { font-size: 26rpx; line-height: 1.6; margin-top: 12rpx; }

.acts { display: flex; gap: 16rpx; margin-bottom: 24rpx; }
.act {
  flex: 1; text-align: center; background: #fff; border-radius: 16rpx;
  padding: 28rpx 0; font-size: 26rpx; color: var(--accent-ink, #b45309);
  border: 1rpx dashed var(--accent, #FB923C);
}

.empty { text-align: center; padding: 60rpx 0; font-size: 26rpx; line-height: 1.6; }

.m-item { background: #fff; border-radius: 20rpx; padding: 28rpx; margin-bottom: 16rpx; }
.m-topic { font-size: 28rpx; font-weight: 600; color: var(--ink, #1a1a1a); margin-bottom: 10rpx; }
.m-content { font-size: 29rpx; color: #333; line-height: 1.6; }
.m-foot { display: flex; align-items: center; justify-content: space-between; margin-top: 18rpx; }
.m-src { font-size: 22rpx; }
.m-del { font-size: 24rpx; color: #d0524b; padding: 6rpx 12rpx; }
