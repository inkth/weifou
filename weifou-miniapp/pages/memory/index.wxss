/* 记忆管理：白卡记忆条 + 清晰双动作。 */
page { background: var(--bg); }
.page { padding: 24rpx 28rpx calc(env(safe-area-inset-bottom) + 60rpx); }
.muted { color: var(--sub); }

.intro { padding: 16rpx 8rpx 28rpx; }
.intro-title { font-size: 40rpx; font-weight: 800; color: var(--ink); letter-spacing: -0.5rpx; }
.intro-sub { font-size: 26rpx; line-height: 1.6; margin-top: 14rpx; color: var(--sub); }

.acts { display: flex; gap: 16rpx; margin-bottom: 28rpx; }
.act { flex: 1; text-align: center; padding: 26rpx 0; font-size: 26rpx; font-weight: 800; border-radius: var(--r-md); background: var(--surface); color: var(--ink); border: var(--bw-thin) solid var(--border); box-shadow: var(--shadow-hair); transition: transform 0.12s var(--ease), box-shadow 0.12s var(--ease); }
.act-primary { background: var(--accent); color: var(--on-accent); border: var(--bw-thin) solid transparent; box-shadow: var(--shadow-accent); }
.act-press { transform: scale(0.985); opacity: 0.92; }

.empty { text-align: center; padding: 80rpx 0; font-size: 26rpx; line-height: 1.6; color: var(--faint); }

.m-item { background: var(--surface); border: var(--bw-thin) solid var(--border); box-shadow: var(--shadow-card); border-radius: var(--r-xl); padding: 28rpx; margin-bottom: 18rpx; }
.m-topic { font-size: 28rpx; font-weight: 800; color: var(--ink); margin-bottom: 10rpx; }
.m-content { font-size: 28rpx; color: var(--ink-2); line-height: 1.65; }
.m-foot { display: flex; align-items: center; justify-content: space-between; margin-top: 20rpx; padding-top: 18rpx; border-top: var(--bw-thin) dashed var(--border); }
.m-src { font-size: 22rpx; color: var(--faint); }
.m-del { font-size: 24rpx; color: var(--danger); padding: 6rpx 14rpx; }
