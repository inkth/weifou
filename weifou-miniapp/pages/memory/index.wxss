page { background: #fbfcfb; }
.page { padding: 24rpx 28rpx calc(env(safe-area-inset-bottom) + 60rpx); }
.muted { color: #8a9a93; }

.intro { padding: 16rpx 8rpx 28rpx; }
.intro-title { font-size: 40rpx; font-weight: 600; color: #16241e; letter-spacing: -0.5rpx; }
.intro-sub { font-size: 26rpx; line-height: 1.6; margin-top: 14rpx; color: #8a9a93; }

.acts { display: flex; gap: 16rpx; margin-bottom: 28rpx; }
.act { flex: 1; text-align: center; padding: 26rpx 0; font-size: 26rpx; font-weight: 500; border-radius: 18rpx; background: #eaf6f1; color: #0c5a48; }
.act-primary { background: #18b690; color: #fff; }
.act-press { opacity: 0.85; }

.empty { text-align: center; padding: 80rpx 0; font-size: 26rpx; line-height: 1.6; color: #9aa8a1; }

.m-item { background: #fff; border: 1rpx solid #ecefec; box-shadow: 0 2rpx 6rpx rgba(20, 40, 30, 0.03); border-radius: 24rpx; padding: 28rpx; margin-bottom: 18rpx; }
.m-topic { font-size: 28rpx; font-weight: 600; color: #16241e; margin-bottom: 10rpx; }
.m-content { font-size: 28rpx; color: #4a5a53; line-height: 1.65; }
.m-foot { display: flex; align-items: center; justify-content: space-between; margin-top: 20rpx; padding-top: 18rpx; border-top: 1rpx solid #f0f2f0; }
.m-src { font-size: 22rpx; color: #9aa8a1; }
.m-del { font-size: 24rpx; color: #c0524b; padding: 6rpx 14rpx; }
