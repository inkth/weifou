<view class="page">
  <view wx:if="{{loading}}" class="muted empty">加载中…</view>

  <block wx:else>
    <view class="card">
      <view class="ask-title">向 {{realName}} 提问</view>
      <view class="ask-sub muted">AI 助理会即时回答；这条会直接送到 {{realName}} 本人，TA 有空时可能亲自回你一句。问题越具体，回答越有用。</view>
      <textarea
        class="ask-input"
        placeholder="把你的问题说清楚：背景是什么、你想解决什么…"
        maxlength="500"
        value="{{question}}"
        bindinput="onInput"
        auto-height
      />
      <view class="ask-count muted">{{question.length}}/500</view>
    </view>

    <view class="card promise" wx:if="{{trustLine}}">
      <view class="promise-row">
        <text class="promise-k muted">口碑</text>
        <text class="promise-v trust">★ {{trustLine}}</text>
      </view>
      <view class="promise-note muted">{{realName}} 会尽量抽空回答，免费。</view>
    </view>

    <button class="btn-primary ask-pay" bindtap="submit" disabled="{{submitting || question.length < 5}}">
      {{submitting ? '提交中…' : '免费提问'}}
    </button>
    <view class="ask-foot muted">提问免费，回答与否取决于 {{realName}} 本人。</view>
  </block>
</view>
