<view class="page">
  <view wx:if="{{loading}}" class="muted empty">加载中…</view>

  <block wx:elif="{{asyncEnabled}}">
    <view class="card">
      <view class="ask-title">付费向 {{realName}} 提问</view>
      <view class="ask-sub muted">由 {{realName}} 本人作答（非 AI）。问题越具体，回答越有用。</view>
      <textarea
        class="ask-input"
        placeholder="把你的问题说清楚：背景是什么、你想解决什么…"
        maxlength="500"
        value="{{question}}"
        bindinput="onInput"
        auto-height
      />
      <view class="ask-count muted">{{question.length}}/500</view>
    </view>

    <view class="card promise">
      <view class="promise-row">
        <text class="promise-k muted">价格</text>
        <text class="promise-v">¥{{priceYuan}}</text>
      </view>
      <view class="promise-note muted">{{realName}} 会尽快回答；若超时未答，系统将<text class="hl">全额退款</text>给你。</view>
    </view>

    <button class="btn-primary ask-pay" bindtap="pay" disabled="{{paying || question.length < 5}}">
      {{paying ? '处理中…' : '支付 ¥' + priceYuan + ' 提问'}}
    </button>
    <view class="ask-foot muted">付费购买的是 {{realName}} 本人的回答时间，非虚拟商品。</view>
  </block>

  <view wx:else class="empty muted">对方暂未开放付费提问</view>
</view>
