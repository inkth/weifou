<view class="page">
  <view class="hd">
    <view class="hd-title">名片夹</view>
    <view class="hd-sub muted">你交换过名片的人 · 点开随时问 TA 的分身</view>
  </view>

  <view wx:if="{{!loading && connections.length}}" class="list">
    <view class="conn card" wx:for="{{connections}}" wx:key="profileId"
          bindtap="goChat" data-id="{{item.profileId}}" data-name="{{item.realName}}">
      <view class="conn-ava">{{item.ini}}</view>
      <view class="conn-id">
        <view class="conn-name">{{item.realName}}</view>
        <view class="conn-sub muted" wx:if="{{item.title || item.company}}">{{item.title}}{{item.title && item.company ? ' · ' : ''}}{{item.company}}</view>
        <view class="conn-sub muted" wx:elif="{{item.city}}">{{item.city}}</view>
      </view>
      <view class="ic ic-chevron conn-arrow"></view>
    </view>
  </view>

  <view wx:elif="{{!loading}}" class="empty">
    <view class="empty-title">名片夹还是空的</view>
    <view class="muted">去逛逛别人的分身，聊得来就交换名片</view>
    <button class="empty-btn" bindtap="goDiscover">去发现</button>
  </view>

  <view wx:if="{{loading}}" class="loading muted">加载中…</view>
</view>
