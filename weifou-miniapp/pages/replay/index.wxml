<view class="page">
  <!-- 全屏立绘铺底 + 暗场（与首页/对话统一）-->
  <image class="bg-lihe" src="{{liheSrc}}" mode="aspectFill" wx:if="{{liheSrc}}"/>
  <view class="bg-scrim" wx:if="{{liheSrc}}"></view>

  <view class="replay-head tier-warm stage-in">
    <view class="amb-layer">
      <view class="amb-wash"></view>
      <view class="amb-glow"></view>
    </view>
    <view class="replay-head-row">
      <view class="presence-dot"></view>
      <view class="replay-head-name">你的 AI 分身</view>
    </view>
    <view class="replay-head-sub muted">与「{{visitorName}}」的对话回放</view>
  </view>

  <view wx:if="{{loading}}" class="empty muted">加载中…</view>
  <view wx:if="{{!loading && !messages.length}}" class="empty muted">这个会话还没有消息</view>

  <block wx:for="{{messages}}" wx:key="index">
    <view class="msg {{item.role === 'assistant' ? 'right' : 'left'}}">
      <view class="who muted">{{item.role === 'assistant' ? '你的 AI 分身' : visitorName}} · {{item.timeText}}</view>
      <view class="bubble {{item.role}}">{{item.content}}</view>
    </view>
  </block>
</view>
