@import "../../styles/stage.wxss";

/* 全屏立绘沉浸（与首页/对话统一）：立绘铺底 + 暗场 */
.page { padding: 24rpx; position: relative; min-height: 100vh; box-sizing: border-box; }
.bg-lihe { position: fixed; inset: 0; width: 100%; height: 100%; z-index: 0; }
.bg-scrim {
  position: fixed; inset: 0; z-index: 0;
  background: linear-gradient(to bottom, rgba(16,18,26,0.55) 0%, rgba(16,18,26,0.4) 34%, rgba(16,18,26,0.7) 100%);
}
.replay-head, .empty, .msg { position: relative; z-index: 1; }

.replay-head {
  position: relative;
  overflow: hidden;
  margin: -24rpx -24rpx 20rpx;
  padding: 28rpx 24rpx;
  background: rgba(20, 22, 30, 0.55);
  backdrop-filter: blur(20rpx); -webkit-backdrop-filter: blur(20rpx);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.12);
}
.replay-head .amb-layer { display: none; }
.replay-head-row { position: relative; z-index: 1; display: flex; align-items: center; gap: 12rpx; }
.presence-dot { width: 14rpx; height: 14rpx; border-radius: 50%; background: var(--success); animation: presencePulse 2s ease-in-out infinite; }
@keyframes presencePulse { 0%, 100% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.45); } 50% { box-shadow: 0 0 0 10rpx rgba(16, 185, 129, 0); } }
.replay-head-name { font-size: 30rpx; font-weight: 600; color: #fff; }
.replay-head-sub { position: relative; z-index: 1; font-size: 22rpx; margin-top: 6rpx; color: rgba(255, 255, 255, 0.7); }
.empty { text-align: center; padding: 120rpx 0; font-size: 26rpx; }
.muted { color: rgba(255, 255, 255, 0.6); }

.msg { margin-bottom: 24rpx; display: flex; flex-direction: column; }
.msg.left { align-items: flex-start; }
.msg.right { align-items: flex-end; }
.who { font-size: 22rpx; margin-bottom: 8rpx; }
.bubble {
  max-width: 80%;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-all;
}
/* 访客气泡白底、AI 气泡暗场玻璃（与对话立绘模式一致） */
.bubble.user { background: rgba(255, 255, 255, 0.92); color: var(--ink); }
.bubble.assistant {
  background: rgba(18, 20, 28, 0.55);
  color: #fff;
  backdrop-filter: blur(8rpx); -webkit-backdrop-filter: blur(8rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}
