.page { padding: 24rpx; }
.tip { font-size: 24rpx; margin-bottom: 24rpx; }
.empty { text-align: center; padding: 120rpx 0; font-size: 26rpx; }
.muted { color: #9aa0ad; }

.msg { margin-bottom: 24rpx; display: flex; flex-direction: column; }
.msg.left { align-items: flex-start; }
.msg.right { align-items: flex-end; }
.who { font-size: 22rpx; margin-bottom: 8rpx; }
.bubble {
  max-width: 80%;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-all;
}
.bubble.user { background: #fff; color: #1f2330; }
.bubble.assistant { background: #1f2330; color: #fff; }
