<view class="invite-page">
  <view class="sky">
    <view class="grid"></view><view class="glow glow-a"></view><view class="glow glow-b"></view>
    <view class="brand"><view class="brand-mark">微</view><text>微否 · 每个人的 AI 分身</text></view>
    <view class="signal"><text class="signal-dot"></text> PARTNER INVITATION</view>
    <view class="headline">有人为你打开了<text>一扇新的门</text></view>
    <view class="hero-desc">认识更清晰的自己，练习 AI 时代真正重要的能力。</view>
  </view>

  <view class="result-card">
    <view class="state-icon state-{{state}}">
      <view wx:if="{{loading}}" class="spinner"></view>
      <text wx:elif="{{state === 'success'}}">✓</text>
      <text wx:else>✦</text>
    </view>
    <view class="result-eyebrow">INVITE · {{code || 'WEIFOU'}}</view>
    <view class="result-title">{{title}}</view>
    <view class="result-desc">{{desc}}</view>
    <button wx:if="{{!loading}}" class="enter-btn" bindtap="goHome">进入微否</button>
    <view class="privacy-note">邀请归因仅用于代理商数据统计，不会向邀请人展示你的个人资料</view>
  </view>

  <view class="feature-row">
    <view class="feature"><view class="feature-no">01</view><view class="feature-title">AI 分身</view><view class="feature-desc">一张会说话的个人名片</view></view>
    <view class="feature"><view class="feature-no">02</view><view class="feature-title">能力成长</view><view class="feature-desc">把知识练成真正会用</view></view>
  </view>
  <view class="footer">微否合作伙伴计划</view>
</view>
