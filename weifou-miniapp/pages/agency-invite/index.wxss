page { background: #f4f5f9; }
.invite-page { min-height: 100vh; color: #17181c; overflow: hidden; padding-bottom: calc(52rpx + env(safe-area-inset-bottom)); }
.sky { position: relative; min-height: 650rpx; overflow: hidden; padding: 56rpx 38rpx 120rpx; color: #fff; background: linear-gradient(155deg, #171827, #232440 65%, #2c2d4d); }
.grid { position: absolute; inset: 0; opacity: .11; background-image: linear-gradient(rgba(255,255,255,.15) 1rpx, transparent 1rpx), linear-gradient(90deg, rgba(255,255,255,.15) 1rpx, transparent 1rpx); background-size: 62rpx 62rpx; transform: perspective(600rpx) rotateX(55deg) scale(1.7) translateY(220rpx); }
.glow { position: absolute; border-radius: 50%; }.glow-a { width: 430rpx; height: 430rpx; right: -160rpx; top: 40rpx; background: radial-gradient(circle, rgba(119,114,200,.65), transparent 68%); }.glow-b { width: 360rpx; height: 360rpx; left: -170rpx; bottom: -100rpx; background: radial-gradient(circle, rgba(115,168,207,.38), transparent 68%); }
.brand { position: relative; z-index: 1; display: flex; align-items: center; color: rgba(255,255,255,.72); font-size: 23rpx; }.brand-mark { width: 52rpx; height: 52rpx; margin-right: 14rpx; border: 2rpx solid rgba(255,255,255,.25); border-radius: 17rpx; display: flex; align-items: center; justify-content: center; color: #fff; background: rgba(255,255,255,.08); font-weight: 850; }
.signal { position: relative; z-index: 1; margin-top: 94rpx; color: rgba(255,255,255,.48); font-size: 19rpx; letter-spacing: 4rpx; font-weight: 750; }.signal-dot { display: inline-block; width: 9rpx; height: 9rpx; margin-right: 10rpx; border-radius: 50%; background: #9ad9c1; box-shadow: 0 0 16rpx rgba(154,217,193,.7); }
.headline { position: relative; z-index: 1; margin-top: 22rpx; max-width: 620rpx; font-size: 57rpx; line-height: 1.18; font-weight: 850; letter-spacing: -2rpx; }.headline text { display: block; color: #c9c3eb; }.hero-desc { position: relative; z-index: 1; max-width: 570rpx; margin-top: 24rpx; color: rgba(255,255,255,.65); font-size: 25rpx; line-height: 1.65; }
.result-card { position: relative; z-index: 2; margin: -64rpx 32rpx 0; padding: 44rpx 36rpx 36rpx; border: 2rpx solid #e7e8ee; border-radius: 34rpx; background: #fff; box-shadow: 0 18rpx 54rpx rgba(34,32,56,.11); text-align: center; }.state-icon { width: 84rpx; height: 84rpx; margin: 0 auto 24rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #5b569f; background: #efedfa; font-size: 38rpx; font-weight: 850; }.state-success { color: #3f805f; background: #e7f4ee; }.spinner { width: 34rpx; height: 34rpx; border: 4rpx solid rgba(119,114,200,.18); border-top-color: #7772c8; border-radius: 50%; animation: spin .8s linear infinite; }.result-eyebrow { color: #a0a2ac; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 18rpx; letter-spacing: 2rpx; }.result-title { margin-top: 14rpx; font-size: 39rpx; font-weight: 850; }.result-desc { margin-top: 15rpx; color: #666874; font-size: 24rpx; line-height: 1.65; }.enter-btn { height: 92rpx; margin-top: 28rpx; border-radius: 21rpx; color: #fff; background: #17181c; font-size: 28rpx; line-height: 92rpx; font-weight: 850; }.privacy-note { margin-top: 20rpx; color: #b0b2bb; font-size: 18rpx; line-height: 1.5; }
.feature-row { display: flex; gap: 18rpx; margin: 30rpx 32rpx 0; }.feature { flex: 1; min-height: 210rpx; padding: 25rpx; border: 2rpx solid #e7e8ee; border-radius: 27rpx; background: #fff; }.feature-no { color: #7772c8; font-size: 18rpx; letter-spacing: 2rpx; font-weight: 800; }.feature-title { margin-top: 22rpx; font-size: 27rpx; font-weight: 800; }.feature-desc { margin-top: 8rpx; color: #8d909b; font-size: 20rpx; line-height: 1.5; }.footer { margin-top: 42rpx; color: #b5b7c0; text-align: center; font-size: 19rpx; }
@keyframes spin { to { transform: rotate(360deg); } }
