@import "../../styles/stage.wxss";

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg);
}

/* —— 角色舞台（容器尺寸；氛围/开幕/状态/指示器/欣喜原子见 styles/stage.wxss）—— */
.stage {
  flex: 0 0 auto;
  position: relative;
  overflow: hidden;
  height: 380rpx;
  max-height: 44vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  padding: 28rpx 28rpx 20rpx;
  background: var(--surface);
  border-bottom: var(--bw-thin) solid var(--border);
}
@media (max-height: 640px) {
  .stage { height: 320rpx; gap: 10rpx; padding: 16rpx 28rpx 12rpx; }
}
/* ==========================================================================
   名片开场（无立绘）：三幕——递卡→开口→便签。
   frame-toon 的渐变属角色层词汇（同 stage.wxss 立绘卡纪律），不算底盘渐变。
   ========================================================================== */
.frame-toon {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  font-weight: 700; color: var(--on-accent);
  background: linear-gradient(135deg, var(--amb-a, #7772c8), var(--amb-b, #b9dded));
  animation: toonBreath 4.5s ease-in-out infinite;
}
@keyframes toonBreath { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.05); } }
/* 状态耦合：思考/说话时呼吸加快 */
.stage-active .frame-toon { animation-duration: 1.8s; }

/* —— 第一幕：名片盖章落下 —— */
.ncard-wrap { flex: 0 0 auto; padding: 24rpx 28rpx 6rpx; opacity: 0; }
.ncard-wrap.stage-in { animation: cardStamp 0.5s var(--ease-spring) both; }
@keyframes cardStamp {
  0% { opacity: 0; transform: scale(1.07); }
  100% { opacity: 1; transform: scale(1); }
}

/* —— 翻面结构：正面定高度，背面绝对铺满 + 内滚 —— */
.ncard { perspective: 1600rpx; }
.ncard-inner {
  position: relative;
  transform-style: preserve-3d;
  transition: transform 0.55s var(--ease);
}
.ncard.flipped .ncard-inner { transform: rotateY(180deg); }
.ncard-face {
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
  background: var(--surface);
  border: var(--bw-thin) solid var(--border);
  border-radius: var(--r-xl);
  box-shadow: var(--shadow-lift);
}
.ncard-front { position: relative; padding: 34rpx 28rpx 18rpx; }
.ncard-back {
  position: absolute; inset: 0;
  transform: rotateY(180deg);
  padding: 24rpx 28rpx;
  display: flex; flex-direction: column;
}

/* 正面：贴纸 + 画框 + 身份 + 一句话 + 标签 */
.ncard-sticker {
  position: absolute; top: -18rpx; right: 24rpx;
  padding: 4rpx 18rpx;
  background: var(--pop-butter); color: var(--pop-butter-ink);
  border: var(--bw-thin) solid var(--border); border-radius: var(--r-full);
  font-size: 21rpx; font-weight: 600;
  box-shadow: var(--shadow-hair);
}
.ncard-row { display: flex; align-items: center; gap: 22rpx; }
.ncard-frame {
  flex: 0 0 auto; width: 116rpx; height: 130rpx;
  border: var(--bw-thin) solid var(--border);
  border-radius: 58rpx 58rpx 16rpx 16rpx;
  overflow: hidden;
}
.ncard-frame .frame-toon { font-size: 50rpx; }
.ncard-id { flex: 1; min-width: 0; }
.ncard-name { font-size: 36rpx; font-weight: 800; color: var(--ink); letter-spacing: -0.5rpx; }
.ncard-title { margin-top: 4rpx; font-size: 24rpx; color: var(--ink-2); }
.ncard-proof { margin-top: 4rpx; font-size: 22rpx; color: var(--sub); }
.ncard-oneliner { margin-top: 20rpx; font-size: 28rpx; font-weight: 600; color: var(--ink); line-height: 1.55; }
.ncard-tags { margin-top: 18rpx; display: flex; flex-wrap: wrap; gap: 10rpx; align-items: center; }
.ncard-tag {
  font-size: 21rpx; padding: 4rpx 16rpx;
  border: var(--bw-thin) solid var(--border); border-radius: var(--r-full);
  color: var(--ink);
}
.ncard-flip {
  font-size: 21rpx; padding: 4rpx 16rpx;
  background: var(--accent-soft); color: var(--accent-ink);
  border: var(--bw-thin) solid var(--border); border-radius: var(--r-full);
  font-weight: 600;
}
.ncard-dots { justify-content: center; margin-top: 4rpx; }
.stage-indicator.ncard-dots.on { margin-top: 14rpx; }

/* 背面：完整介绍（内滚） */
.ncard-back-head { display: flex; align-items: center; justify-content: space-between; flex: 0 0 auto; }
.ncard-back-title { font-size: 30rpx; font-weight: 800; color: var(--ink); }
.ncard-back-scroll { flex: 1 1 auto; min-height: 0; margin-top: 14rpx; }
.ncard-back-sub { font-size: 24rpx; color: var(--ink-2); }
.ncard-back-tags { margin-top: 14rpx; display: flex; flex-wrap: wrap; gap: 10rpx; }
.ncard-back-intro { margin-top: 16rpx; font-size: 26rpx; line-height: 1.7; color: var(--ink-2); white-space: pre-wrap; }
.ncard-back-proof { margin: 16rpx 0 8rpx; font-size: 22rpx; color: var(--accent-deep); }

/* —— 收起态：顶部胶囊条 —— */
.ncard-bar {
  flex: 0 0 auto;
  display: flex; align-items: center; gap: 14rpx;
  margin: 16rpx 28rpx 6rpx;
  padding: 8rpx 22rpx 8rpx 8rpx;
  background: var(--surface);
  border: var(--bw-thin) solid var(--border);
  border-radius: var(--r-full);
  box-shadow: var(--shadow-hair);
  animation: barIn 0.25s var(--ease) both;
}
@keyframes barIn { from { opacity: 0; transform: translateY(-8rpx); } to { opacity: 1; transform: translateY(0); } }
.ncard-bar-ava {
  flex: 0 0 auto; width: 64rpx; height: 64rpx;
  border: var(--bw-thin) solid var(--border); border-radius: 50%;
  overflow: hidden;
}
.ncard-bar-ava .frame-toon { font-size: 30rpx; }
.ncard-bar-name { flex: 1; min-width: 0; font-size: 27rpx; font-weight: 600; color: var(--ink); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.ncard-bar-chip {
  flex: 0 0 auto; font-size: 22rpx; font-weight: 600;
  padding: 4rpx 18rpx;
  background: var(--accent-soft); color: var(--accent-ink);
  border: var(--bw-thin) solid var(--border); border-radius: var(--r-full);
}
.identity-bar {
  margin: 0;
  padding: 18rpx 28rpx;
  border: none;
  border-bottom: 1rpx solid var(--line);
  border-radius: 0;
  box-shadow: none;
  background: linear-gradient(90deg, var(--surface), var(--accent-soft));
}
.identity-bar .ncard-bar-chip {
  padding: 4rpx 0;
  background: transparent;
  border: none;
}

/* —— 全屏立绘模式（星野式：立绘铺底 + 气泡浮层）—— */
.lihe-bg { position: fixed; inset: 0; z-index: 0; }
.lihe-img { width: 100%; height: 100%; transform-origin: 50% 45%; animation: liheBreath 7s ease-in-out infinite; }
/* 立绘微动：极轻的"呼吸"，让静止立绘有生命感。纯 transform/GPU，scale≥1 不露底 */
@keyframes liheBreath { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.025); } }
.lihe-scrim {
  position: absolute; inset: 0;
  background: linear-gradient(to bottom, rgba(255, 255, 255, 0) 30%, rgba(255, 255, 255, 0.55) 62%, rgba(255, 255, 255, 0.92) 100%);
}
.lihe.page { background: transparent; }
/* 立绘即角色：隐藏氛围层/思考点，舞台只留名牌浮在立绘上 */
.lihe .stage { background: transparent; border-bottom: none; height: auto; max-height: none; padding: 20rpx 28rpx 8rpx; z-index: 1; }
.lihe .amb-layer, .lihe .stage-indicator { display: none; }
.lihe .stage-name { color: var(--ink); }
.lihe .stage-more { color: var(--sub); }
.lihe .stage-status { color: var(--ink-2); }
.lihe .msg-list { position: relative; z-index: 1; }
/* 气泡浮层：AI 白玻璃、用户深蓝紫，浮在立绘上保持清晰。 */
.lihe .msg-assistant .bubble { background: rgba(255, 255, 255, 0.92); color: var(--ink); border: none; box-shadow: none; }
.lihe .msg-user .bubble { background: rgba(91, 86, 159, 0.96); color: var(--on-accent); }
.lihe .choices { position: relative; z-index: 1; background: var(--glass-dark); border-top: none; }

.msg-list {
  flex: 1 1 auto;
  min-height: 0; /* 关键：小屏下让 scroll-view 正确收缩，不撑破布局 */
  padding: 28rpx 24rpx 32rpx;
  box-sizing: border-box;
}

.welcome {
  padding: 32rpx 24rpx;
  font-size: 26rpx;
  white-space: pre-line;
  line-height: 1.7;
}

.msg { display: flex; margin-bottom: 24rpx; }
.msg-user { justify-content: flex-end; }
.msg-assistant { justify-content: flex-start; }

.bubble {
  max-width: 75%;
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-word;
  white-space: pre-wrap;
}
.msg-user .bubble {
  background: var(--accent);
  color: var(--on-accent);
  border-bottom-right-radius: 8rpx;
}
.msg-assistant .bubble {
  background: var(--surface);
  color: var(--ink);
  border-bottom-left-radius: 8rpx;
  border: var(--bw-thin) solid var(--border);
  box-shadow: var(--shadow-hair);
  animation: bubbleIn 0.28s ease both;
}
/* 新气泡入场：路径 setData 不重建节点，故每条只播一次（不随打字机重放） */
@keyframes bubbleIn {
  from { opacity: 0; transform: translateY(6rpx); }
  to { opacity: 1; transform: none; }
}
.bubble.dim { color: var(--sub); }

/* 对话内成交卡片 */
.offer-card {
  background: var(--surface);
  border: var(--bw-thin) solid var(--border);
  border-radius: var(--r-lg);
  padding: 24rpx;
  margin: 0 0 24rpx;
  box-shadow: var(--shadow-card);
}
.offer-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--ink);
  margin-bottom: 18rpx;
}
.offer-slots {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}
.slot {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 22rpx;
  border-radius: var(--r-md);
  background: var(--fill);
  border: var(--bw-thin) solid transparent;
  transition: border-color 0.16s var(--ease), background 0.16s var(--ease);
}
.slot.sel {
  background: var(--accent-soft);
  border-color: var(--accent);
}
.slot-time { font-size: 28rpx; color: var(--ink); }
.slot-meta { font-size: 24rpx; color: var(--sub); }
.offer-btn {
  margin-top: 20rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: var(--accent);
  color: var(--on-accent);
  border: none;
  border-radius: var(--r-md);
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: var(--shadow-accent);
  transition: transform 0.12s var(--ease), box-shadow 0.12s var(--ease);
}
.offer-btn:active { transform: scale(0.985); background: var(--accent-strong); }
.offer-btn[disabled] { opacity: 0.4; box-shadow: none; }

.sys-link {
  align-self: flex-start;
  margin: -8rpx 0 24rpx;
  font-size: 26rpx;
  color: var(--ink);
  text-decoration: underline;
}

.choices {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: var(--surface);
  border-top: var(--bw-thin) solid var(--border);
}
.chip {
  padding: 16rpx 26rpx;
  border: var(--bw-thin) solid var(--border);
  border-radius: var(--r-full);
  font-size: 26rpx;
  line-height: 1.2;
  transition: transform 0.12s var(--ease), box-shadow 0.12s var(--ease);
}
.chip:active { transform: scale(0.985); opacity: 0.9; }
/* 第三幕：引导问题使用低饱和气场底，保持邀请感。 */
.chip.q {
  flex: 1 1 100%;
  text-align: left;
  padding: 20rpx 26rpx;
  border-radius: var(--r-md);
  box-shadow: var(--shadow-hair);
  font-size: 27rpx;
  line-height: 1.4;
}
.chip.q.note-0 { background: var(--pop-sky); color: var(--pop-sky-ink); animation: noteIn0 0.32s var(--ease-spring) 0.05s backwards; }
.chip.q.note-1 { background: var(--accent-soft); color: var(--accent-ink); animation: noteIn1 0.32s var(--ease-spring) 0.14s backwards; }
.chip.q.note-2 { background: var(--pop-lilac); color: var(--pop-lilac-ink); animation: noteIn2 0.32s var(--ease-spring) 0.23s backwards; }
@keyframes noteIn0 { from { opacity: 0; transform: translateY(14rpx); } }
@keyframes noteIn1 { from { opacity: 0; transform: translateY(14rpx); } }
@keyframes noteIn2 { from { opacity: 0; transform: translateY(14rpx); } }
.chip.q:active { transform: scale(0.985); }
/* 行动入口（转化）：深蓝紫强调 */
.chip.act {
  background: var(--accent);
  color: var(--on-accent);
}
.chip.act.done { background: var(--accent-soft); color: var(--accent-ink); }
.next-action { flex: 1 1 100%; text-align: center; border-radius: var(--r-md); padding: 20rpx 26rpx; }
/* 换一批：描边 */
.chip.ghost {
  background: transparent;
  color: var(--ink-2);
  border-color: transparent;
}
.reshuffle { margin-left: auto; padding-left: 12rpx; padding-right: 12rpx; font-size: 24rpx; }

/* 成交阶梯进度条：聊→问→约，走过的段落用蓝紫点亮。 */
.stage-rail {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 14rpx 24rpx;
  background: var(--surface);
  border-top: var(--bw-thin) solid var(--border);
}
.rail-node {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: var(--ink-2);
  background: var(--surface);
  border: var(--bw-thin) solid var(--border);
  transition: transform 0.3s var(--ease), background 0.3s var(--ease), color 0.3s var(--ease);
}
.rail-node.done { color: var(--accent-ink); background: var(--accent-soft); border-color: var(--accent-soft); }
.rail-node.on {
  color: var(--on-accent);
  background: var(--accent);
  border-color: var(--accent);
  font-weight: 700;
  transform: scale(1.08);
}
.rail-line { width: 44rpx; height: 4rpx; border-radius: 2rpx; background: var(--border); transition: background 0.3s var(--ease); }
.rail-line.done { background: var(--accent); }

/* 点选附言 / 举手意向：弹层内 chip 组，代替输入框 */
.sheet-chips { display: flex; flex-wrap: wrap; gap: 14rpx; margin: 24rpx 0 4rpx; }
.leave-chips { margin-top: 28rpx; }
.sheet-chip {
  padding: 18rpx 26rpx;
  background: var(--fill);
  border: 1rpx solid var(--border);
  border-radius: 100rpx;
  font-size: 27rpx;
  color: var(--ink);
  transition: transform 0.1s var(--ease);
}
.sheet-chip.on { background: var(--accent-soft); border-color: var(--accent); color: var(--accent-ink); font-weight: 600; }
.sheet-chip:active { transform: scale(0.985); }

/* —— chat-first 开场体验 —— */
.choices { opacity: 0; transform: translateY(12rpx); }
.choices.revealed {
  opacity: 1;
  transform: translateY(0);
  transition: opacity 0.4s ease, transform 0.4s ease;
}
.choices-hint { width: 100%; font-size: 24rpx; margin-bottom: 4rpx; }
.trust-cap { width: 100%; font-size: 22rpx; color: var(--sub); margin-top: 2rpx; line-height: 1.5; }
.empty { padding: 200rpx 48rpx; text-align: center; }
.empty-title { font-size: 34rpx; font-weight: 800; color: var(--ink); margin-bottom: 16rpx; }

/* —— 裂变钩子 —— */
.own-hook { color: var(--faint); font-size: 24rpx; }
.own-cta {
  margin: 16rpx 48rpx;
  padding: 28rpx;
  background: var(--surface);
  border: var(--bw-thin) solid var(--border);
  border-radius: var(--r-lg);
  box-shadow: var(--shadow-card);
  text-align: center;
}
.own-cta-title { font-size: 30rpx; font-weight: 800; color: var(--ink); }
.own-cta-sub { font-size: 24rpx; color: var(--sub); margin: 8rpx 0 20rpx; }
.own-cta-btn {
  background: var(--accent);
  color: var(--on-accent);
  border: none;
  border-radius: var(--r-md);
  font-size: 28rpx;
  font-weight: 700;
  padding: 0 48rpx;
  display: inline-block;
  line-height: 72rpx;
  box-shadow: var(--shadow-accent);
  transition: transform 0.12s var(--ease), box-shadow 0.12s var(--ease);
}
.own-cta-btn:active { transform: scale(0.985); background: var(--accent-strong); }

/* —— 页内浮层：白玻璃底部抽屉（关于 / 让 TA 找我）—— */
.mask { position: fixed; inset: 0; z-index: 100; background: var(--scrim); display: flex; align-items: flex-end; }
.sheet {
  width: 100%; box-sizing: border-box;
  background: var(--glass-dark);
  backdrop-filter: var(--blur-glass); -webkit-backdrop-filter: var(--blur-glass);
  border-top-left-radius: 32rpx; border-top-right-radius: 32rpx;
  border-top: 1rpx solid var(--glass-hair);
  padding: 16rpx 40rpx calc(env(safe-area-inset-bottom) + 40rpx);
  color: var(--ink);
}
.sheet-grab { width: 64rpx; height: 8rpx; border-radius: 4rpx; background: var(--border); margin: 6rpx auto 22rpx; }
.sheet-title { font-size: 34rpx; font-weight: 800; color: var(--ink); }
.sheet-sub { font-size: 24rpx; color: var(--sub); margin-top: 8rpx; }
.sheet-oneliner { font-size: 30rpx; font-weight: 600; color: var(--ink); margin-top: 22rpx; line-height: 1.5; }
.sheet-tags { margin-top: 18rpx; display: flex; flex-wrap: wrap; gap: 12rpx; }
.sheet-tag { font-size: 24rpx; color: var(--ink-2); background: var(--fill); border: 1rpx solid var(--border); border-radius: 100rpx; padding: 6rpx 20rpx; }
.sheet-intro { font-size: 27rpx; line-height: 1.7; color: var(--ink-2); margin-top: 22rpx; white-space: pre-wrap; }
.sheet-input { background: var(--fill); border: 1rpx solid var(--border); border-radius: 16rpx; padding: 24rpx; font-size: 28rpx; color: var(--ink); margin: 28rpx 0; }
.sheet-pay { margin-top: 8rpx; background: var(--accent); color: var(--on-accent); border-radius: var(--r-md); padding: 24rpx 0; text-align: center; font-size: 30rpx; font-weight: 800; box-shadow: var(--shadow-accent); transition: transform 0.12s var(--ease), box-shadow 0.12s var(--ease); }
.sheet-pay:active { transform: scale(0.985); background: var(--accent-strong); }
.sheet-pay[disabled] { opacity: 0.45; box-shadow: none; }
.slot-list { margin: 24rpx 0; max-height: 600rpx; overflow-y: auto; }
.sheet-empty { text-align: center; padding: 48rpx 0; color: var(--sub); font-size: 26rpx; }
.slot-pick { padding: 24rpx; background: var(--fill); border: 1rpx solid var(--border); border-radius: 16rpx; margin-bottom: 16rpx; }
.slot-pick.on { background: var(--accent-soft); border-color: var(--accent); }
.sp-time { font-size: 30rpx; font-weight: 600; color: var(--ink); }
.sp-meta { font-size: 24rpx; color: var(--sub); margin-top: 6rpx; }

/* —— 成交庆祝浮层（复用课程事件卡）：约/留话达成时全屏彩带 + 大字弹簧 —— */
.celebrate { position: fixed; inset: 0; z-index: 120; display: flex; align-items: center; justify-content: center; background: var(--glass-light); animation: celebFade 0.25s ease; pointer-events: none; overflow: hidden; }
.celeb-card { position: relative; z-index: 2; background: var(--surface); border-radius: var(--r-2xl); padding: 48rpx 64rpx; text-align: center; box-shadow: var(--shadow-pop); animation: celebPop 0.42s var(--ease-spring); }
.celeb-spark { font-size: 72rpx; line-height: 1; animation: sparkBounce 0.6s var(--ease-spring); }
.celeb-up { display: inline-block; font-size: 24rpx; font-weight: 800; color: #574825; letter-spacing: 4rpx; margin-top: 12rpx; padding: 4rpx 18rpx; background: var(--gold); border-radius: var(--r-full); box-shadow: var(--shadow-hair); }
.celeb-name { font-size: 56rpx; font-weight: 800; color: var(--ink); margin-top: 8rpx; animation: namePop 0.5s var(--ease-spring) 0.08s both; }
.celeb-sub { font-size: 24rpx; color: var(--sub); margin-top: 12rpx; }
@keyframes celebFade { from { opacity: 0; } to { opacity: 1; } }
@keyframes celebPop { 0% { opacity: 0; transform: scale(0.7); } 60% { opacity: 1; } 100% { opacity: 1; transform: scale(1); } }
@keyframes sparkBounce { 0% { transform: scale(0.4); } 60% { transform: scale(1.25); } 100% { transform: scale(1); } }
@keyframes namePop { 0% { opacity: 0; transform: scale(0.8); } 100% { opacity: 1; transform: scale(1); } }
.confetti { position: absolute; inset: 0; z-index: 1; pointer-events: none; }
.cf { position: absolute; top: 0; width: 14rpx; height: 22rpx; border-radius: 4rpx; animation: cfFall 1.6s ease-in both; }
.cf-1  { left: 6%;  background: var(--pop-butter); animation-delay: 0s; }
.cf-2  { left: 14%; background: var(--cand-blue);  animation-delay: 0.22s; }
.cf-3  { left: 24%; background: var(--pop-coral);  animation-delay: 0.10s; }
.cf-4  { left: 32%; background: var(--accent);     animation-delay: 0.34s; }
.cf-5  { left: 41%; background: var(--pop-lilac);  animation-delay: 0.05s; }
.cf-6  { left: 49%; background: var(--gold);       animation-delay: 0.28s; }
.cf-7  { left: 57%; background: var(--cand-blue);  animation-delay: 0.16s; }
.cf-8  { left: 66%; background: var(--pop-coral);  animation-delay: 0.42s; }
.cf-9  { left: 74%; background: var(--accent);     animation-delay: 0.08s; }
.cf-10 { left: 82%; background: var(--pop-butter); animation-delay: 0.30s; }
.cf-11 { left: 90%; background: var(--pop-lilac);  animation-delay: 0.20s; }
.cf-12 { left: 96%; background: var(--gold);       animation-delay: 0.46s; }
@keyframes cfFall {
  0% { transform: translateY(-10vh) rotate(0deg); opacity: 1; }
  80% { opacity: 1; }
  100% { transform: translateY(110vh) rotate(540deg); opacity: 0; }
}
