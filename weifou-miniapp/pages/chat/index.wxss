.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f6fa;
}

.chat-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 28rpx;
  background: #fff;
  border-bottom: 2rpx solid #e5e7ec;
}
.header-meta { display: flex; flex-direction: column; }
.header-name { font-size: 30rpx; font-weight: 600; color: #1f2330; }
.header-status { font-size: 22rpx; margin-top: 4rpx; }

.msg-list {
  flex: 1;
  padding: 24rpx 24rpx 32rpx;
  box-sizing: border-box;
}

.welcome {
  padding: 32rpx 24rpx;
  font-size: 26rpx;
  white-space: pre-line;
  line-height: 1.7;
}

.msg { display: flex; margin-bottom: 24rpx; }
.msg-user { justify-content: flex-end; }
.msg-assistant { justify-content: flex-start; }

.bubble {
  max-width: 75%;
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-word;
  white-space: pre-wrap;
}
.msg-user .bubble {
  background: #1f2330;
  color: #fff;
  border-bottom-right-radius: 8rpx;
}
.msg-assistant .bubble {
  background: #fff;
  color: #1f2330;
  border-bottom-left-radius: 8rpx;
}
.bubble.dim { color: #8a8f9c; }

/* 对话内成交卡片 */
.offer-card {
  background: #fff;
  border: 2rpx solid #e5e7ec;
  border-radius: 24rpx;
  padding: 24rpx;
  margin: 0 0 24rpx;
}
.offer-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1f2330;
  margin-bottom: 18rpx;
}
.offer-slots {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}
.slot {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 22rpx;
  border-radius: 16rpx;
  background: #f0f1f5;
  border: 2rpx solid transparent;
}
.slot.sel {
  background: #fff;
  border-color: #1f2330;
}
.slot-time { font-size: 28rpx; color: #1f2330; }
.slot-meta { font-size: 24rpx; color: #8a8f9c; }
.offer-btn {
  margin-top: 20rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: #1f2330;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
}
.offer-btn[disabled] { opacity: 0.4; }

.sys-link {
  align-self: flex-start;
  margin: -8rpx 0 24rpx;
  font-size: 26rpx;
  color: #1f2330;
  text-decoration: underline;
}

.choices {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 2rpx solid #e5e7ec;
}
.chip {
  padding: 16rpx 26rpx;
  border-radius: 100rpx;
  font-size: 26rpx;
  line-height: 1.2;
}
/* 引导问题 */
.chip.q {
  background: #f0f1f5;
  color: #1f2330;
}
/* 行动入口（转化）：深色强调 */
.chip.act {
  background: #1f2330;
  color: #fff;
}
/* 自己问：描边 */
.chip.ghost {
  background: #fff;
  color: #4a5070;
  border: 2rpx solid #d6d9e0;
}

.composer {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 2rpx solid #e5e7ec;
}
.composer .input {
  flex: 1;
  height: 72rpx;
  background: #f5f6fa;
  border-radius: 36rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
}
.composer .send {
  width: 140rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: #1f2330;
  color: #fff;
  border-radius: 36rpx;
  font-size: 28rpx;
}
.composer .send[disabled] { opacity: 0.4; }

/* —— chat-first 开场体验 —— */
.header-more { color: #9aa0ad; font-weight: 400; }
.choices { opacity: 0; transform: translateY(12rpx); }
.choices.revealed {
  opacity: 1;
  transform: translateY(0);
  transition: opacity 0.4s ease, transform 0.4s ease;
}
.choices-hint { width: 100%; font-size: 24rpx; margin-bottom: 4rpx; }
.empty { padding: 200rpx 48rpx; text-align: center; }
.empty-title { font-size: 34rpx; font-weight: 600; color: #1f2330; margin-bottom: 16rpx; }

/* —— 裂变钩子 —— */
.own-hook { color: #9aa0ad; font-size: 24rpx; }
.own-cta {
  margin: 16rpx 48rpx;
  padding: 28rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(31, 35, 48, 0.06);
  text-align: center;
}
.own-cta-title { font-size: 30rpx; font-weight: 600; color: #1f2330; }
.own-cta-sub { font-size: 24rpx; color: #9aa0ad; margin: 8rpx 0 20rpx; }
.own-cta-btn {
  background: #1f2330;
  color: #fff;
  border-radius: 36rpx;
  font-size: 28rpx;
  padding: 0 48rpx;
  display: inline-block;
  line-height: 72rpx;
}
