<view class="page">
  <!-- 主页不存在 / 参数缺失空态 -->
  <view wx:if="{{notFound}}" class="empty">
    <view class="empty-title">主页不存在或已下线</view>
    <view class="muted">链接可能已失效，去看看其他人的 AI 主页吧</view>
  </view>

  <block wx:else>
  <!-- 头部即名片入口：点击进完整主页（预约/打赏/联系都在那） -->
  <view class="chat-header" bindtap="goProfile">
    <avatar preset="{{avatarStyle}}" name="{{realName}}" seed="{{profileId}}" size="96" state="{{introState || (pending ? 'speaking' : 'idle')}}"/>
    <view class="header-meta">
      <view class="header-name">{{realName ? realName + ' 的 AI 助理' : '正在连线…'}} <text class="header-more">›</text></view>
      <!-- 副标题优先 oneLiner：访客 3 秒内完成"这是谁、值不值得聊"的判断 -->
      <view class="header-status muted">{{oneLiner || (pending ? '思考中…' : '助理在线 · 点这里看 TA 的主页')}}</view>
    </view>
  </view>

  <scroll-view class="msg-list" scroll-y scroll-into-view="msg-{{messages.length-1}}" enhanced show-scrollbar="{{false}}">
    <block wx:for="{{messages}}" wx:key="index">
      <view wx:if="{{item.content}}" id="msg-{{index}}" class="msg msg-{{item.role}}">
        <view class="bubble">{{item.content}}</view>
      </view>

      <!-- 对话内成交卡片：选档期直接预约 -->
      <view wx:if="{{item.card && item.card.type === 'consult_offer'}}" class="offer-card">
        <view class="offer-title">选个时间，和 TA 面对面聊聊</view>
        <view class="offer-slots">
          <view wx:for="{{item.card.slots}}" wx:for-item="s" wx:key="id"
                class="slot {{item.card.selectedSlotId === s.id ? 'sel' : ''}}"
                bindtap="selectCardSlot" data-mi="{{index}}" data-id="{{s.id}}">
            <view class="slot-time">{{s.timeText}}</view>
            <view class="slot-meta">{{s.durationMin}}分钟 · ¥{{s.priceYuan}}</view>
          </view>
        </view>
        <button class="offer-btn" bindtap="bookFromCard" data-mi="{{index}}"
                disabled="{{!item.card.selectedSlotId || acting}}">立即预约</button>
      </view>

      <!-- 预约成功后的查看入口 -->
      <view wx:if="{{item.action === 'go-sessions'}}" class="sys-link" bindtap="goSessions">查看我的通话 ›</view>

      <!-- 裂变：对话内轻线索（被回答种草后） -->
      <view wx:if="{{item.action === 'create-own'}}" id="msg-{{index}}" class="sys-link own-hook" bindtap="goCreateOwn">
        ✨ 这位 AI 助理是 {{realName}} 用 1 分钟请来的 · 我也要一个 ›
      </view>

      <!-- 裂变：目的达成后的身份反转 CTA -->
      <view wx:if="{{item.action === 'create-own-strong'}}" id="msg-{{index}}" class="own-cta">
        <view class="own-cta-title">也有很多人想了解你</view>
        <view class="own-cta-sub">刚才它替 {{realName}} 接待了你。1 分钟，让你的 AI 助理替你先聊。</view>
        <button class="own-cta-btn" bindtap="goCreateOwn">请一位我的 AI 助理</button>
      </view>
    </block>

    <view wx:if="{{pending}}" class="msg msg-assistant">
      <view class="bubble dim">思考中…</view>
    </view>
  </scroll-view>

  <!-- 选项区：开场动画结束后引导问题淡入；行动入口在首轮回答后才出现，开场聚焦"开始聊" -->
  <view class="choices {{startersRevealed ? 'revealed' : ''}}" wx:if="{{!pending && startersRevealed}}">
    <view wx:if="{{starters.length && !answeredOnce}}" class="choices-hint muted">你可以这样开始 ↓</view>
    <view class="chip q" wx:for="{{starters}}" wx:key="*this" bindtap="pickStarter" data-q="{{item}}">{{item}}</view>

    <block wx:if="{{answeredOnce && !isMine}}">
      <view class="chip act" wx:if="{{contactAvailable}}" bindtap="onContact">联系本人</view>
      <view class="chip act" wx:if="{{asyncAvailable}}" bindtap="goAsk">✍️ 付费问本人{{asyncPriceYuan ? ' ¥' + asyncPriceYuan : ''}}</view>
      <view class="chip act" wx:if="{{consultAvailable}}" bindtap="goProfileAction">约 TA 聊聊</view>
      <view class="chip act" bindtap="onLeaveMessage">💬 留个话给 TA</view>
    </block>
    <view class="chip ghost" bindtap="toggleInput">{{showInput ? '收起输入' : '✏️ 自己问'}}</view>
  </view>

  <view class="composer" wx:if="{{showInput}}">
    <input class="input" placeholder="请输入你的问题" value="{{draft}}" maxlength="200" bindinput="onInput" confirm-type="send" bindconfirm="send" focus="{{showInput}}"/>
    <button class="send" bindtap="send" disabled="{{pending || !draft}}">发送</button>
  </view>
  </block>
</view>
