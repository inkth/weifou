<view class="page {{liheSrc ? 'lihe' : ''}}">
  <!-- 全屏立绘背景（星野式）：avatar 为 image 类型时铺满，气泡浮于其上；fixed 不随消息滚动 -->
  <view wx:if="{{liheSrc}}" class="lihe-bg">
    <image class="lihe-img" src="{{liheSrc}}" mode="aspectFill"/>
    <view class="lihe-scrim"></view>
  </view>

  <!-- 主页不存在 / 参数缺失空态 -->
  <view wx:if="{{notFound}}" class="empty">
    <view class="empty-title">主页不存在或已下线</view>
    <view class="muted">链接可能已失效，去看看其他人的 AI 主页吧</view>
  </view>

  <block wx:else>
  <!-- 立绘模式：角色舞台（点击进关于抽屉），沉浸皮肤保持原样 -->
  <view wx:if="{{liheSrc}}"
        class="stage tier-{{stageTier}} {{stageEntered ? 'stage-in' : ''}} {{(pending || introState) ? 'stage-active' : ''}}"
        style="{{ambStyle}}" bindtap="openAbout">
    <view class="amb-layer">
      <view class="amb-wash"></view>
      <view class="amb-glow"></view>
      <view class="amb-blob amb-blob-1"></view>
      <view class="amb-blob amb-blob-2"></view>
    </view>
    <view class="stage-meta">
      <view class="stage-name">{{realName ? realName + ' 的 AI 分身' : '正在连线…'}} <text class="stage-more">›</text></view>
      <view class="stage-status muted">{{oneLiner || (pending ? '思考中…' : '分身随时答 · 点这里看 TA 的主页')}}</view>
    </view>
    <view class="stage-indicator {{(pending || introState === 'thinking') ? 'on' : ''}}">
      <view class="dot"></view><view class="dot"></view><view class="dot"></view>
    </view>
  </view>

  <!-- 名片开场（无立绘）：三幕——递卡→开口→便签。开聊后收成顶部胶囊条。 -->
  <block wx:if="{{!liheSrc}}">
    <view wx:if="{{!cardCompact}}"
          class="ncard-wrap {{stageEntered ? 'stage-in' : ''}} {{(pending || introState) ? 'stage-active' : ''}}"
          style="{{ambStyle}}">
      <view class="ncard {{cardFlipped ? 'flipped' : ''}}">
        <view class="ncard-inner">
          <!-- 正面：信任信息一次给足（点卡翻面） -->
          <view class="ncard-face ncard-front" bindtap="flipCard">
            <view class="ncard-sticker">AI 分身 · 随时在线</view>
            <view class="ncard-row">
              <view class="ncard-frame"><view class="frame-toon">{{stageInitial}}</view></view>
              <view class="ncard-id">
                <view class="ncard-name">{{realName || '正在连线…'}}</view>
                <view class="ncard-title" wx:if="{{title || company}}">{{title}}{{title && company ? ' · ' : ''}}{{company}}</view>
                <view class="ncard-proof" wx:if="{{trustLine}}">{{trustLine}}</view>
                <view class="ncard-proof" wx:elif="{{city}}">{{city}}</view>
              </view>
            </view>
            <view class="ncard-oneliner" wx:if="{{oneLiner}}">{{oneLiner}}</view>
            <view class="ncard-tags">
              <text class="ncard-tag" wx:for="{{cardTags}}" wx:key="*this">{{item}}</text>
              <text class="ncard-flip">翻面看详情 ↻</text>
            </view>
            <view class="stage-indicator ncard-dots {{(pending || introState === 'thinking') ? 'on' : ''}}">
              <view class="dot"></view><view class="dot"></view><view class="dot"></view>
            </view>
          </view>
          <!-- 背面：完整介绍（只有"翻回"按钮可翻，内容可滚动） -->
          <view class="ncard-face ncard-back">
            <view class="ncard-back-head">
              <view class="ncard-back-title">关于 {{realName}}</view>
              <view class="ncard-flip" bindtap="flipCard">↻ 翻回</view>
            </view>
            <scroll-view class="ncard-back-scroll" scroll-y>
              <view class="ncard-back-sub" wx:if="{{title || company || city}}">{{title}}{{title && (company || city) ? ' · ' : ''}}{{company}}{{company && city ? ' · ' : ''}}{{city}}</view>
              <view class="ncard-back-tags" wx:if="{{tags.length}}">
                <text class="ncard-tag" wx:for="{{tags}}" wx:key="*this">{{item}}</text>
              </view>
              <view class="ncard-back-intro" wx:if="{{fullIntro}}">{{fullIntro}}</view>
              <view class="ncard-back-proof" wx:if="{{trustLine}}">{{trustLine}}</view>
            </scroll-view>
          </view>
        </view>
      </view>
    </view>

    <!-- 收起态：顶部胶囊条（点击重新展开名片） -->
    <view wx:else class="ncard-bar" bindtap="expandCard">
      <view class="ncard-bar-ava" style="{{ambStyle}}"><view class="frame-toon">{{stageInitial}}</view></view>
      <view class="ncard-bar-name">{{realName}} 的 AI 分身</view>
      <view class="ncard-bar-chip">名片</view>
    </view>
  </block>

  <scroll-view class="msg-list" scroll-y scroll-into-view="msg-{{messages.length-1}}" enhanced show-scrollbar="{{false}}">
    <block wx:for="{{messages}}" wx:key="index">
      <view wx:if="{{item.content}}" id="msg-{{index}}" class="msg msg-{{item.role}}">
        <view class="bubble">{{item.content}}</view>
      </view>

      <!-- 裂变：对话内轻线索（被回答种草后） -->
      <view wx:if="{{item.action === 'create-own'}}" id="msg-{{index}}" class="sys-link own-hook" bindtap="goCreateOwn">
        ✨ 这个 AI 分身是 {{realName}} 用 1 分钟建的 · 我也要一个 ›
      </view>

      <!-- 裂变：目的达成后的身份反转 CTA -->
      <view wx:if="{{item.action === 'create-own-strong'}}" id="msg-{{index}}" class="own-cta">
        <view class="own-cta-title">也有很多人想了解你</view>
        <view class="own-cta-sub">刚才它替 {{realName}} 接待了你。1 分钟，建一个你的 AI 分身替你先聊。</view>
        <button class="own-cta-btn" bindtap="goCreateOwn">建一个我的 AI 分身</button>
      </view>
    </block>
  </scroll-view>

  <!-- 选项区：开场动画结束后引导问题淡入；行动入口在首轮回答后才出现，开场聚焦"开始聊" -->
  <view class="choices {{startersRevealed ? 'revealed' : ''}}" wx:if="{{!pending && startersRevealed}}">
    <view wx:if="{{starters.length && !answeredOnce}}" class="choices-hint muted">你可以这样开始 ↓</view>
    <!-- 开场引导问题：有了本轮追问选项后让位（追问更贴上下文），下一轮无追问时回归 -->
    <block wx:if="{{!followups.length}}">
      <view class="chip q note-{{index % 3}}" wx:for="{{starters}}" wx:key="*this" bindtap="pickStarter" data-q="{{item}}">{{item}}</view>
    </block>

    <!-- 追问选项：每轮回答后分身给的下一问，点选即发（点选为主、输入兜底） -->
    <view class="chip q note-{{index % 3}}" wx:for="{{followups}}" wx:key="*this" bindtap="pickFollowup" data-q="{{item}}">{{item}}</view>

    <block wx:if="{{answeredOnce && !isMine}}">
      <view class="chip act" bindtap="openAboutEntry">关于 TA</view>
      <view class="chip act" wx:if="{{contactAvailable}}" bindtap="onContact">联系本人</view>
      <view class="chip act" bindtap="openTip">打赏 TA</view>
      <view class="chip act" bindtap="onLeaveMessage">💬 留个话给 TA</view>
    </block>
    <view class="chip ghost" bindtap="toggleInput">{{showInput ? '收起输入' : '✏️ 自己问'}}</view>

    <!-- 信任 caption：社会证明；trustLine 为空则不显示 -->
    <view class="trust-cap" wx:if="{{answeredOnce && !isMine && trustLine}}">
      <text>{{trustLine}}</text>
    </view>
  </view>

  <view class="composer" wx:if="{{showInput}}">
    <input class="input" placeholder="请输入你的问题" value="{{draft}}" maxlength="200" bindinput="onInput" confirm-type="send" bindconfirm="send" focus="{{showInput}}"/>
    <button class="send" bindtap="send" disabled="{{pending || !draft}}">发送</button>
  </view>

  <!-- 页内浮层：关于 TA / 打赏 / 约档期（毛玻璃底部抽屉，访客不离立绘）-->
  <view class="mask" wx:if="{{aboutVisible}}" bindtap="closeAbout">
    <view class="sheet" catchtap="noop">
      <view class="sheet-grab"></view>
      <view class="sheet-title">{{realName}}{{title ? ' · ' + title : ''}}</view>
      <view class="sheet-sub" wx:if="{{company || city}}">{{company}}{{company && city ? ' · ' : ''}}{{city}}</view>
      <view class="sheet-oneliner" wx:if="{{oneLiner}}">{{oneLiner}}</view>
      <view class="sheet-tags" wx:if="{{tags.length}}">
        <text class="sheet-tag" wx:for="{{tags}}" wx:key="*this">{{item}}</text>
      </view>
      <view class="sheet-intro" wx:if="{{fullIntro}}">{{fullIntro}}</view>
    </view>
  </view>

  <view class="mask" wx:if="{{tipVisible}}" bindtap="closeTip">
    <view class="sheet" catchtap="noop">
      <view class="sheet-grab"></view>
      <view class="sheet-title">打赏 {{realName}}</view>
      <view class="sheet-sub">自愿赠予，表达你的认可</view>
      <view class="tip-amounts">
        <view class="tip-amount {{tipAmount === item ? 'on' : ''}}" wx:for="{{tipPresets}}" wx:key="*this" data-amount="{{item}}" bindtap="selectTip">¥{{item}}</view>
      </view>
      <input class="sheet-input" placeholder="留句话（选填）" placeholder-style="color: rgba(255,255,255,0.45)" maxlength="60" value="{{tipMessage}}" bindinput="onTipMsg"/>
      <button class="sheet-pay" bindtap="payTip" disabled="{{tipPaying}}">{{tipPaying ? '处理中…' : '确认打赏 ¥' + tipAmount}}</button>
    </view>
  </view>

  </block>
</view>
