<view class="page {{liheSrc ? 'lihe' : ''}}">
  <immersive-nav title="{{realName ? '和 ' + realName + ' 的 AI 聊聊' : 'AI 分身'}}" transparent="{{liheSrc ? true : false}}" />

  <!-- 全屏立绘背景（星野式）：avatar 为 image 类型时铺满，气泡浮于其上；fixed 不随消息滚动 -->
  <view wx:if="{{liheSrc}}" class="lihe-bg">
    <image class="lihe-img" src="{{liheSrc}}" mode="aspectFill"/>
    <view class="lihe-scrim"></view>
  </view>

  <!-- 主页不存在 / 参数缺失空态 -->
  <view wx:if="{{notFound}}" class="empty">
    <view class="empty-title">这个 AI 分身不在了</view>
    <view class="muted">链接可能已失效，去看看其他人的 AI 分身吧</view>
  </view>

  <block wx:else>
  <!-- 立绘模式：角色舞台（点击进关于抽屉），沉浸皮肤保持原样 -->
  <view wx:if="{{liheSrc}}"
        class="stage tier-{{stageTier}} {{stageEntered ? 'stage-in' : ''}} {{(pending || introState) ? 'stage-active' : ''}}"
        style="{{ambStyle}}" bindtap="openAbout">
    <view class="amb-layer">
      <view class="amb-wash"></view>
      <view class="amb-glow"></view>
      <view class="amb-blob amb-blob-1"></view>
      <view class="amb-blob amb-blob-2"></view>
    </view>
    <view class="stage-meta">
      <view class="stage-name">{{realName ? realName + ' 的 AI 分身' : '正在连线…'}} <text class="stage-more">›</text></view>
      <view class="stage-status muted">{{oneLiner || (pending ? '思考中…' : '分身随时答 · 点这里看 TA 的主页')}}</view>
    </view>
    <view class="stage-indicator {{(pending || introState === 'thinking') ? 'on' : ''}}">
      <view class="dot"></view><view class="dot"></view><view class="dot"></view>
    </view>
  </view>

  <!-- 无立绘时保持一行身份头；详细资料统一进入「关于 TA」抽屉。 -->
  <view wx:if="{{!liheSrc}}" class="ncard-bar identity-bar" bindtap="openAbout">
    <view class="ncard-bar-ava" style="{{ambStyle}}"><view class="frame-toon">{{stageInitial}}</view></view>
    <view class="ncard-bar-name">{{realName ? realName + ' 的 AI 分身' : '正在连线…'}}</view>
    <view class="ncard-bar-chip">关于 TA ›</view>
  </view>

  <scroll-view class="msg-list" scroll-y scroll-into-view="msg-{{messages.length-1}}" enhanced show-scrollbar="{{false}}">
    <block wx:for="{{messages}}" wx:key="index">
      <view wx:if="{{item.content}}" id="msg-{{index}}" class="msg msg-{{item.role}}">
        <view class="bubble">{{item.content}}</view>
      </view>

    </block>
  </scroll-view>

  <!-- 选项区：开场动画结束后引导问题淡入；行动入口在首轮回答后才出现，开场聚焦"开始聊" -->
  <view class="choices {{startersRevealed ? 'revealed' : ''}}" wx:if="{{!pending && startersRevealed}}">
    <view wx:if="{{starters.length && !answeredOnce}}" class="choices-hint muted">你可以这样开始 ↓</view>
    <!-- 开场引导问题：本轮有上下文选项时让位，下一轮无选项时回归 -->
    <block wx:if="{{!options.length}}">
      <view class="chip q note-{{index % 3}}" wx:for="{{starters}}" wx:key="*this" bindtap="pickStarter" data-q="{{item}}">{{item}}</view>
    </block>

    <!-- 每轮回答后分身现编的下一步，点选即发（换不到就「换一批」） -->
    <view class="chip q note-{{index % 3}}" wx:for="{{options}}" wx:key="*this" bindtap="pickOption" data-q="{{item}}">{{item}}</view>

    <!-- 每次只给一个最相关的关系行动；其他资料从顶部身份头进入。 -->
    <block wx:if="{{answeredOnce && !isMine}}">
      <view wx:if="{{hasOwnProfile}}" class="chip act next-action {{connected ? 'done' : ''}}" bindtap="openExchange">{{connected ? '已交换名片' : '交换名片'}}</view>
      <view wx:elif="{{contactAvailable}}" class="chip act next-action" bindtap="onContact">联系本人</view>
      <view wx:else class="chip act next-action" bindtap="openLeave">让 TA 找我</view>
    </block>
    <view class="chip ghost reshuffle" wx:if="{{options.length}}" bindtap="reshuffle">换一批</view>

    <!-- 信任 caption：社会证明；trustLine 为空则不显示 -->
    <view class="trust-cap" wx:if="{{answeredOnce && !isMine && trustLine}}">
      <text>{{trustLine}}</text>
    </view>
  </view>

  <!-- 页内浮层：关于 TA（毛玻璃底部抽屉，访客不离立绘）-->
  <view class="mask" wx:if="{{aboutVisible}}" bindtap="closeAbout">
    <view class="sheet" catchtap="noop">
      <view class="sheet-grab"></view>
      <view class="sheet-title">{{realName}}{{title ? ' · ' + title : ''}}</view>
      <view class="sheet-sub" wx:if="{{company || city}}">{{company}}{{company && city ? ' · ' : ''}}{{city}}</view>
      <view class="sheet-oneliner" wx:if="{{oneLiner}}">{{oneLiner}}</view>
      <view class="sheet-tags" wx:if="{{tags.length}}">
        <text class="sheet-tag" wx:for="{{tags}}" wx:key="*this">{{item}}</text>
      </view>
      <view class="sheet-intro" wx:if="{{fullIntro}}">{{fullIntro}}</view>
    </view>
  </view>

  <!-- 交换名片：站内连接（关系）+ 可选「捎句话」（意向点选，跳过则纯连接） -->
  <view class="mask" wx:if="{{exchangeVisible}}" bindtap="closeExchange">
    <view class="sheet" catchtap="noop">
      <view class="sheet-grab"></view>
      <view class="sheet-title">交换名片</view>
      <view class="sheet-sub">和 {{realName}} 互相进名片夹，随时能问 TA 的分身。想捎句话就点一个（可跳过）</view>
      <view class="sheet-chips">
        <view class="sheet-chip {{exchangeNote === item ? 'on' : ''}}" wx:for="{{exchangePresets}}" wx:key="*this" data-msg="{{item}}" bindtap="pickExchangeNote">{{item}}</view>
      </view>
      <button class="sheet-pay" bindtap="confirmExchange" disabled="{{exchangeSending}}">{{exchangeSending ? '交换中…' : (exchangeNote ? '交换名片并捎话' : '交换名片')}}</button>
    </view>
  </view>

  <!-- 让 TA 找我：零门槛「举手」，点选意向即送达主人（代替打字留言） -->
  <view class="mask" wx:if="{{leaveVisible}}" bindtap="closeLeave">
    <view class="sheet" catchtap="noop">
      <view class="sheet-grab"></view>
      <view class="sheet-title">让 {{realName}} 找我</view>
      <view class="sheet-sub">点一个最贴近的意向，{{realName}} 会看到并主动联系你</view>
      <view class="sheet-chips leave-chips">
        <view class="sheet-chip {{leaveNote === item ? 'on' : ''}}" wx:for="{{leavePresets}}" wx:key="*this" data-msg="{{item}}" bindtap="pickLeave">{{item}}</view>
      </view>
      <button class="sheet-pay" bindtap="sendLeave" disabled="{{leaveSending || !leaveNote}}">{{leaveSending ? '发送中…' : (leaveNote ? '发送给 ' + realName : '先选一个意向')}}</button>
    </view>
  </view>

  <!-- 行动完成反馈（全屏彩带 + 大字弹簧），2.4s 自动收起 -->
  <view wx:if="{{celebrate}}" class="celebrate">
    <view class="confetti">
      <view class="cf cf-1"></view><view class="cf cf-2"></view><view class="cf cf-3"></view>
      <view class="cf cf-4"></view><view class="cf cf-5"></view><view class="cf cf-6"></view>
      <view class="cf cf-7"></view><view class="cf cf-8"></view><view class="cf cf-9"></view>
      <view class="cf cf-10"></view><view class="cf cf-11"></view><view class="cf cf-12"></view>
    </view>
    <view class="celeb-card">
      <view class="celeb-spark">🎉</view>
      <view class="celeb-up">{{celebrate.up}}</view>
      <view class="celeb-name">{{celebrate.name}}</view>
      <view class="celeb-sub">{{celebrate.sub}}</view>
    </view>
  </view>

  </block>
</view>
