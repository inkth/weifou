.editor-page { min-height: 100vh; padding: 24rpx 24rpx calc(env(safe-area-inset-bottom) + 150rpx); background: #edf0ec; }
.loading-card { height: 540rpx; border-radius: 38rpx; }

.preview-wrap { position: relative; }
.preview-label { margin: 0 8rpx 15rpx; color: #69756f; font-size: 20rpx; font-weight: 700; }
.preview-live { display: inline-block; width: 9rpx; height: 9rpx; margin-right: 7rpx; border-radius: 50%; background: #77a68b; box-shadow: 0 0 0 6rpx rgba(119,166,139,.12); }
.mini-card { position: relative; height: 530rpx; overflow: hidden; border-radius: 40rpx; color: #fff; background: #17231f; box-shadow: 0 24rpx 65rpx rgba(32,47,40,.23); isolation: isolate; }
.card-sky { position: absolute; inset: 0; background: radial-gradient(circle at 76% 18%, rgba(244,224,178,.25), transparent 28%), linear-gradient(150deg, var(--card-b, #9cab9f), var(--card-a, #52665e) 55%, #17231f); }
.card-orbit { position: absolute; z-index: 1; top: -105rpx; right: -80rpx; width: 370rpx; height: 370rpx; border: 1rpx solid rgba(255,239,201,.20); border-radius: 50%; box-shadow: 0 0 0 35rpx rgba(255,239,201,.035); animation: orbit 6s ease-in-out infinite; }
.card-character { position: absolute; z-index: 2; top: -78rpx; right: -15rpx; width: 450rpx; height: 600rpx; animation: breathe 5.5s ease-in-out infinite; }
.card-fade { position: absolute; z-index: 3; inset: 0; background: linear-gradient(90deg, rgba(15,25,21,.92) 0%, rgba(15,25,21,.55) 46%, transparent 73%), linear-gradient(0deg, rgba(14,24,20,.88), transparent 50%); }
.card-status { position: absolute; z-index: 4; top: 25rpx; left: 28rpx; color: #d9c18d; font-size: 16rpx; letter-spacing: 3rpx; font-weight: 800; }
.card-copy { position: absolute; z-index: 5; left: 29rpx; right: 29rpx; bottom: 28rpx; width: 64%; }
.card-name { display: inline-block; font-family: "Songti SC", serif; font-size: 49rpx; line-height: 1.15; font-weight: 800; }
.tap-edit { color: #d9c18d; font-family: sans-serif; font-size: 19rpx; }
.card-role { margin-top: 5rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: rgba(255,255,255,.62); font-size: 19rpx; }
.card-intro { margin-top: 19rpx; color: rgba(255,255,255,.91); font-size: 23rpx; line-height: 1.45; font-weight: 600; }
.card-tags { display: flex; flex-wrap: wrap; gap: 7rpx; margin-top: 15rpx; }
.card-tag { padding: 4rpx 11rpx; border-radius: 999rpx; color: rgba(255,255,255,.75); background: rgba(255,255,255,.09); border: 1rpx solid rgba(255,255,255,.13); font-size: 16rpx; }
.card-tag-add { color: #d9c18d; }

.dialog-panel { margin-top: 24rpx; padding: 23rpx 22rpx 27rpx; border-radius: 33rpx; background: rgba(255,255,255,.84); border: 1rpx solid rgba(39,54,47,.08); box-shadow: 0 10rpx 35rpx rgba(38,52,46,.06); }
.topic-tabs { width: 100%; white-space: nowrap; }
.topic-row { display: inline-flex; gap: 10rpx; padding-bottom: 5rpx; }
.topic { padding: 10rpx 21rpx; border-radius: 999rpx; color: #718079; background: #eef0ec; font-size: 21rpx; font-weight: 750; }
.topic.active { color: #f8f2e3; background: #2b3b34; }
.ai-row { display: flex; align-items: flex-start; gap: 12rpx; margin-top: 22rpx; }
.ai-avatar { width: 50rpx; height: 50rpx; flex: 0 0 auto; display: flex; align-items: center; justify-content: center; border-radius: 17rpx; color: #8b754d; background: #eee6d4; font-size: 21rpx; }
.ai-bubble { max-width: 565rpx; padding: 17rpx 20rpx; border-radius: 8rpx 21rpx 21rpx 21rpx; color: #35423c; background: #f1f2ee; font-size: 23rpx; line-height: 1.5; }
.answer-area { margin-top: 19rpx; }
.choice-grid { display: flex; flex-wrap: wrap; gap: 10rpx; }
.choice { padding: 11rpx 18rpx; border-radius: 15rpx; color: #59665f; background: #fff; border: 1rpx solid #dfe3dd; font-size: 21rpx; font-weight: 650; }
.choice.selected { color: #f7f1e3; background: #35483f; border-color: #35483f; }
.input-row { display: flex; gap: 11rpx; margin-top: 12rpx; }
.answer-input, .answer-textarea { color: #29362f; background: #fff; border: 1rpx solid #dfe3dd; border-radius: 16rpx; font-size: 23rpx; }
.answer-input { flex: 1; min-width: 0; height: 70rpx; padding: 0 18rpx; }
.answer-textarea { width: 100%; min-height: 125rpx; margin-top: 13rpx; padding: 17rpx 19rpx; line-height: 1.5; }
.sentence-choice { margin-bottom: 10rpx; padding: 15rpx 18rpx; border-radius: 16rpx; color: #4d5a54; background: #fff; border: 1rpx solid #e0e3de; font-size: 22rpx; line-height: 1.45; }
.sentence-choice:active { color: #f8f2e3; background: #35483f; }
.custom-row { display: flex; gap: 10rpx; margin-top: 13rpx; }
.custom-input { flex: 1; }
.add-tag { width: 100rpx; display: flex; align-items: center; justify-content: center; border-radius: 16rpx; color: #f8f2e3; background: #35483f; font-size: 22rpx; font-weight: 750; }
.portrait-scroll { width: 100%; white-space: nowrap; }
.portrait-row { display: inline-flex; gap: 13rpx; padding: 3rpx 3rpx 10rpx; }
.portrait-item { width: 128rpx; padding: 7rpx 7rpx 11rpx; border-radius: 20rpx; background: #fff; border: 2rpx solid transparent; }
.portrait-item.selected { border-color: #957f54; box-shadow: 0 0 0 4rpx rgba(149,127,84,.10); }
.portrait-thumb { width: 110rpx; height: 128rpx; display: flex; align-items: center; justify-content: center; overflow: hidden; border-radius: 14rpx; color: rgba(255,255,255,.8); font-size: 29rpx; }
.portrait-thumb image { width: 100%; height: 100%; }
.portrait-label { margin-top: 7rpx; overflow: hidden; text-overflow: ellipsis; text-align: center; color: #59655f; font-size: 18rpx; font-weight: 700; }
.tone-list { display: grid; grid-template-columns: 1fr 1fr; gap: 11rpx; }
.tone-item { display: flex; align-items: center; justify-content: space-between; padding: 17rpx; border-radius: 17rpx; background: #fff; border: 1rpx solid #dfe3dd; }
.tone-item.selected { border-color: #657b70; background: #eef3ef; }
.tone-name { color: #35423c; font-size: 22rpx; font-weight: 800; }
.tone-desc { margin-top: 3rpx; color: #89918d; font-size: 17rpx; }
.tone-check { color: #667d71; font-size: 24rpx; font-weight: 900; }

.save-bar { position: fixed; z-index: 20; left: 0; right: 0; bottom: 0; display: flex; align-items: center; gap: 20rpx; padding: 16rpx 24rpx calc(env(safe-area-inset-bottom) + 16rpx); background: rgba(247,248,245,.96); border-top: 1rpx solid rgba(36,51,44,.08); }
.save-note { flex: 1; color: #7b8580; font-size: 19rpx; }
.save-btn { width: 245rpx; height: 78rpx; display: flex; align-items: center; justify-content: center; padding: 0; border-radius: 22rpx; color: #f9f3e5; background: #273830; font-size: 25rpx; font-weight: 800; box-shadow: 0 12rpx 28rpx rgba(39,56,48,.18); }

@keyframes breathe { 0%,100% { transform: translateY(0) scale(1.01); } 50% { transform: translateY(-9rpx) scale(1.035); } }
@keyframes orbit { 0%,100% { opacity: .45; transform: scale(.94); } 50% { opacity: .9; transform: scale(1.05); } }
@media (prefers-reduced-motion: reduce) { .card-character, .card-orbit { animation: none; } }
