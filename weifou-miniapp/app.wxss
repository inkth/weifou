/* 设计令牌（双端真源见 docs/design-tokens.md）。墨黑仍为主色，暖橙只做强调。 */
page {
  --ink: #1f2330;        /* 主色 / 文字 */
  --bg: #f5f6fa;         /* 页面底色 */
  --border: #e5e7ec;     /* 描边 */
  --sub: #8a8f9c;        /* 次要文字 */
  --accent: #fb923c;     /* 暖强调色：仅 CTA 高亮 / 活跃态 / 强调 */
  --accent-strong: #ef7d1f; /* 强调色按下态 */
  --accent-soft: #fff3e9;   /* 浅暖底：高亮区背景 / 标签 */
  --accent-ink: #9a4d12;    /* accent-soft 上的文字 */
  --success: #10b981;
  --warn: #f59e0b;
  --danger: #e0404b;
  --shadow-soft: 0 6rpx 26rpx rgba(249, 140, 60, 0.10); /* 柔和暖阴影 */
}

page {
  background: var(--bg);
  color: var(--ink);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: 28rpx;
  line-height: 1.55;
}

view, text, button {
  box-sizing: border-box;
}

button {
  background: transparent;
  padding: 0;
  line-height: normal;
}
button::after { border: none; }

.btn-primary {
  background: #1f2330;
  color: #fff;
  border-radius: 100rpx;
  padding: 24rpx 0;
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
}
.btn-primary[disabled] { opacity: 0.4; }

.btn-ghost {
  background: #fff;
  color: #1f2330;
  border: 2rpx solid #e5e7ec;
  border-radius: 100rpx;
  padding: 24rpx 0;
  text-align: center;
  font-size: 30rpx;
}

/* 暖色强调主按钮：仅用在关键转化点（预约 / 立即开聊 等），不替代墨黑 .btn-primary */
.btn-accent {
  background: var(--accent);
  color: #fff;
  border-radius: 100rpx;
  padding: 24rpx 0;
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
}
.btn-accent[disabled] { opacity: 0.4; }

/* 浅暖底高亮块（推荐位 / 强调标签） */
.accent-soft {
  background: var(--accent-soft);
  color: var(--accent-ink);
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: var(--shadow-soft);
}

.tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  margin: 0 12rpx 12rpx 0;
  background: #f0f1f5;
  border-radius: 100rpx;
  font-size: 24rpx;
  color: #4a5070;
}

.muted { color: #8a8f9c; }
.title { font-size: 36rpx; font-weight: 600; color: #1f2330; }
.subtitle { font-size: 28rpx; color: #4a5070; }
