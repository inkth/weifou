@import "./styles/icons.wxss";

/* ============================================================================
   微否设计系统 · 双端真源见 docs/design-tokens.md
   原则：清新浅色 + 薄荷青。整套中性阶带一丝青温（绿相灰），墨青 #16241E 为主
   文字与主按钮；碧绿 #18B690 只做点睛强调，绝不铺陈。
   卡片语言统一为：白卡 + 1rpx 青边 + 极淡绿调阴影（克制、干净、可信）。
   本文件是小程序端令牌真源；改色先改 docs，再同步 app_theme.dart。
   ========================================================================== */
page {
  /* —— 中性色阶（青温灰：同一绿相递进，从墨青到雾青）—— */
  --ink: #16241e;        /* 主文字 / 墨青主按钮 / 用户气泡 */
  --ink-2: #4a5a53;      /* 次级文字：副标题、正文辅助 */
  --sub: #8a9a93;        /* 三级文字：说明、占位、非活跃 */
  --faint: #aab4af;      /* 四级文字：时间戳、极弱信息 */
  --line: #f0f2f0;       /* 发丝分隔线 / 内部描边 */
  --border: #ecefec;     /* 卡片 / 输入框边框 */
  --fill: #eef2ef;       /* 中性填充：标签底、头像回退底 */
  --fill-pressed: #f4f7f5; /* 单元格按下底 */

  /* —— 表面与底色 —— */
  --bg: #fbfcfb;         /* 页面底色（近白、带一丝青） */
  --surface: #ffffff;    /* 卡片 / 浮层表面 */
  --surface-sunken: #f3f6f4; /* 内嵌凹陷区 / 输入底 */

  /* —— 强调色（碧绿点睛，绝不替换主色）—— */
  --accent: #18b690;     /* CTA 高亮 / 活跃态 / 强调图标 */
  --accent-strong: #0e9c7a; /* accent 按下态 / 渐变深端 */
  --accent-deep: #0f766e;   /* soft 底上的图标 / 强化小字 */
  --accent-soft: #e8f5ef;   /* 浅绿底：推荐位 / 标签背景 */
  --accent-ink: #0c5a48;    /* accent-soft 上文字 */

  /* —— 功能色（success 用草绿，与碧绿 accent 拉开避免撞色）—— */
  --success: #16a34a;
  --warn: #f59e0b;
  --danger: #e0404b;

  /* —— 间距阶（4 基数）—— */
  --sp-1: 8rpx; --sp-2: 16rpx; --sp-3: 24rpx; --sp-4: 32rpx;
  --sp-5: 40rpx; --sp-6: 56rpx; --sp-7: 72rpx;

  /* —— 圆角阶 —— */
  --r-sm: 12rpx; --r-md: 16rpx; --r-lg: 20rpx; --r-xl: 24rpx;
  --r-2xl: 32rpx; --r-3xl: 36rpx; --r-full: 999rpx;

  /* —— 高度 / 阴影（极淡、分层、带青温；成交克制区不滥用）—— */
  --shadow-hair: 0 1rpx 2rpx rgba(20, 40, 30, 0.04);
  --shadow-card: 0 2rpx 10rpx rgba(20, 40, 30, 0.04), 0 1rpx 2rpx rgba(20, 40, 30, 0.03);
  --shadow-lift: 0 4rpx 16rpx rgba(20, 40, 30, 0.05), 0 1rpx 3rpx rgba(20, 40, 30, 0.04); /* hero 级大卡 */
  --shadow-soft: 0 6rpx 26rpx rgba(24, 182, 144, 0.10); /* 绿柔：推荐位 */
  --shadow-pop: 0 12rpx 40rpx rgba(20, 40, 30, 0.12);   /* 浮层 / 弹层 */
  --shadow-accent: 0 10rpx 24rpx rgba(24, 182, 144, 0.28); /* accent CTA 光晕 */

  /* —— 动效 —— */
  --ease: cubic-bezier(0.4, 0, 0.2, 1);
  --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
  --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);

  /* —— 沉浸件（角色层复用：立绘卡 / 玻璃浮层；底盘区不引入）——
     源自「分身首页沉浸版」北极星样板，沉淀为真源，供 discover / profile / chat 复用 */
  --glass-light: rgba(252, 253, 252, 0.78); /* 浅色毛玻璃：悬浮底栏 / 浅底浮层 */
  --glass-dark: rgba(18, 22, 28, 0.42);      /* 深色毛玻璃：立绘上的信息面板 */
  --glass-hair: rgba(255, 255, 255, 0.16);   /* 玻璃描边 */
  --blur-glass: blur(28rpx) saturate(180%);  /* 统一毛玻璃模糊 */
  --shadow-lihe: 0 6rpx 22rpx rgba(20, 40, 30, 0.07), 0 1rpx 3rpx rgba(20, 40, 30, 0.04); /* 立绘卡浮起 */
}

page {
  background: var(--bg);
  color: var(--ink);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: 28rpx;
  line-height: 1.55;
  -webkit-font-smoothing: antialiased;
}

view, text, button { box-sizing: border-box; }

button {
  background: transparent;
  padding: 0;
  line-height: normal;
}
button::after { border: none; }

/* —— 文字阶（语义化辅助类，在重写页面统一用）—— */
.t-hero { font-size: 52rpx; font-weight: 600; color: var(--ink); letter-spacing: -1rpx; line-height: 1.2; }
.t-display { font-size: 46rpx; font-weight: 600; color: var(--ink); letter-spacing: -1rpx; line-height: 1.2; }
.t-section { font-size: 32rpx; font-weight: 600; color: var(--ink); letter-spacing: -0.3rpx; }
.t-body { font-size: 28rpx; color: var(--ink); }
.t-sub { font-size: 26rpx; color: var(--ink-2); }
.t-caption { font-size: 24rpx; color: var(--sub); }
.t-micro { font-size: 22rpx; color: var(--faint); }

.title { font-size: 36rpx; font-weight: 600; color: var(--ink); letter-spacing: -0.3rpx; }
.subtitle { font-size: 28rpx; color: var(--ink-2); }
.muted { color: var(--sub); }

/* 区段标（列表小节眉标：细字 + 大字距，安静地分区） */
.eyebrow { font-size: 24rpx; letter-spacing: 3rpx; color: var(--faint); }

/* —— 按钮三类 —— */
.btn-primary {
  background: var(--ink);
  color: #fff;
  border-radius: var(--r-full);
  padding: 24rpx 0;
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
  letter-spacing: 0.5rpx;
  transition: transform 0.16s var(--ease), opacity 0.16s var(--ease);
}
.btn-primary:active { transform: scale(0.975); opacity: 0.92; }
.btn-primary[disabled] { opacity: 0.4; }

.btn-ghost {
  background: var(--surface);
  color: var(--ink);
  border: 1rpx solid var(--border);
  border-radius: var(--r-full);
  padding: 24rpx 0;
  text-align: center;
  font-size: 30rpx;
  transition: transform 0.16s var(--ease), background 0.16s var(--ease);
}
.btn-ghost:active { transform: scale(0.975); background: var(--fill); }

/* 碧绿强调主按钮：仅关键转化点（问分身 / 立即开聊），不替代墨青 .btn-primary */
.btn-accent {
  background: var(--accent);
  color: #fff;
  border-radius: var(--r-full);
  padding: 24rpx 0;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
  box-shadow: var(--shadow-accent);
  transition: transform 0.16s var(--ease), box-shadow 0.16s var(--ease);
}
.btn-accent:active { transform: scale(0.975); box-shadow: 0 4rpx 12rpx rgba(24, 182, 144, 0.26); }
.btn-accent[disabled] { opacity: 0.4; box-shadow: none; }

/* 浅绿底高亮块（推荐位 / 强调标签） */
.accent-soft { background: var(--accent-soft); color: var(--accent-ink); }

/* —— 卡片 / 标签（统一卡片语言：白卡 + 青边 + 极淡阴影）—— */
.card {
  background: var(--surface);
  border: 1rpx solid var(--border);
  border-radius: var(--r-2xl);
  padding: 32rpx;
  box-shadow: var(--shadow-card);
}

.tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  margin: 0 12rpx 12rpx 0;
  background: var(--fill);
  border-radius: var(--r-full);
  font-size: 24rpx;
  color: var(--ink-2);
}

/* —— 空态三层（图标圆底 + 标题 + 说明，可选 CTA）—— */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 140rpx 48rpx 60rpx;
}
.empty-ic {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: var(--accent-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
}
.empty-ic .ic { font-size: 56rpx; color: var(--accent); }
.empty-title { font-size: 32rpx; font-weight: 600; color: var(--ink); }
.empty-sub { margin-top: 12rpx; font-size: 26rpx; color: var(--sub); line-height: 1.6; max-width: 480rpx; }
.empty-cta {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 36rpx;
  padding: 20rpx 48rpx;
  background: var(--ink);
  color: #fff;
  border-radius: var(--r-full);
  font-size: 28rpx;
  font-weight: 500;
  transition: transform 0.16s var(--ease), opacity 0.16s var(--ease);
}
.empty-cta:active { transform: scale(0.97); opacity: 0.92; }

/* —— 骨架屏（加载占位：雾青底 + 流光扫过）—— */
.skel {
  position: relative;
  overflow: hidden;
  background: var(--fill);
  border-radius: var(--r-md);
}
.skel::after {
  content: '';
  position: absolute;
  inset: 0;
  transform: translateX(-100%);
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.65), transparent);
  animation: skelShine 1.4s infinite;
}
@keyframes skelShine { 100% { transform: translateX(100%); } }

/* —— 通用按压反馈 —— */
.tap { transition: transform 0.16s var(--ease), opacity 0.16s var(--ease); }
.tap:active { transform: scale(0.98); opacity: 0.9; }
.card-press { transform: scale(0.985); }
.hairline { border-bottom: 1rpx solid var(--line); }
