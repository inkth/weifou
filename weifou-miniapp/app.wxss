@import "./styles/icons.wxss";

/* ============================================================================
   微否设计系统 · 人物编辑感 + 雾蓝紫 AI 气场
   双端真源见 docs/design-tokens.md。
   中性色负责人物、信息与信任；雾蓝紫只表达分身气场、AI 状态和关键行动。
   卡片使用细边与柔和空间阴影，按压使用轻缩放，不使用糖果式 3D 底唇。
   ========================================================================== */
page {
  /* —— 中性色阶 —— */
  --ink: #17181c;
  --ink-2: #5e616d;
  --sub: #8d909b;
  --faint: #b5b7c0;
  --line: #f0f1f5;
  --border: #e7e8ee;
  --border-strong: #d9dae3;
  --fill: #f3f4f7;
  --fill-pressed: #eceef3;

  /* —— 表面与底色 —— */
  --bg: #f6f7fb;
  --surface: #ffffff;
  --surface-sunken: #f1f2f7;

  /* —— 雾蓝紫品牌与 AI 气场 —— */
  --accent: #7772c8;
  --accent-strong: #5b569f;
  --accent-deep: #4f4a8b;
  --accent-soft: #efedfa;
  --accent-ink: #47427d;
  --on-accent: #ffffff;
  --hl: #e2dff5;
  --mist-blue: #b9dded;
  --mist-lilac: #c9c3eb;

  /* —— 兼容旧类名的克制成长色 —— */
  --pop-butter: #eee7d9;  --pop-butter-ink: #725f3d;
  --pop-coral: #ead7ca;   --pop-coral-ink: #80583f;
  --pop-mint: #dcebe7;    --pop-mint-ink: #466a61;
  --pop-lilac: #e8e3f3;   --pop-lilac-ink: #65547e;
  --pop-sky: #e2eef4;     --pop-sky-ink: #506f80;
  --cand-blue: #73a8cf;   --cand-blue-strong: #5d8faf;
  --gold: #c7a45d;        --gold-strong: #a88747;
  --paper: #fbfaf7;

  /* —— 功能色 —— */
  --success: #4f9d78; --success-strong: #3f805f;
  --warn: #d39a4a;
  --danger: #d85c68; --danger-strong: #b84853;

  /* —— 描边宽度阶 —— */
  --bw: 3rpx;            /* 标准卡片/按钮/输入框描边 */
  --bw-thin: 2rpx;       /* 小件：chip / 徽章 / 头像框 */

  /* —— 间距阶（4 基数）—— */
  --sp-1: 8rpx; --sp-2: 16rpx; --sp-3: 24rpx; --sp-4: 32rpx;
  --sp-5: 40rpx; --sp-6: 56rpx; --sp-7: 72rpx;
  --page-x: 32rpx;        /* 页面统一横向安全留白 */
  --section-gap: 28rpx;   /* 页面主区块节奏 */

  /* —— 圆角阶 —— */
  --r-sm: 12rpx; --r-md: 20rpx; --r-lg: 26rpx; --r-xl: 32rpx;
  --r-2xl: 40rpx; --r-3xl: 48rpx; --r-full: 999rpx;

  /* —— 柔和空间阴影（旧 token 名保留供页面兼容）—— */
  --lip: 0rpx;
  --lip-lg: 0rpx;
  --shadow-hair: 0 2rpx 8rpx rgba(34, 32, 56, 0.04);
  --shadow-card: 0 8rpx 28rpx rgba(34, 32, 56, 0.06);
  --shadow-lift: 0 18rpx 54rpx rgba(50, 46, 91, 0.10);
  --shadow-soft: 0 12rpx 38rpx rgba(91, 86, 159, 0.11);
  --shadow-pop: 0 24rpx 72rpx rgba(28, 27, 38, 0.16);
  --shadow-accent: 0 10rpx 28rpx rgba(91, 86, 159, 0.20);

  /* —— 动效 —— */
  --ease: cubic-bezier(0.4, 0, 0.2, 1);
  --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
  --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);

  /* —— 亮场玻璃 —— */
  --glass-light: rgba(255, 255, 255, 0.94);
  --glass-dark: rgba(255, 255, 255, 0.92);
  --glass-hair: rgba(23, 24, 28, 0.09);
  --blur-glass: none;
  --shadow-lihe: 0 12rpx 34rpx rgba(91, 86, 159, 0.16);

  /* —— 遮罩底（弹层/抽屉；换肤时统一改这两个）—— */
  --scrim: rgba(0, 0, 0, 0.5);          /* 模态弹层黑底 */
  --scrim-soft: rgba(35, 34, 56, 0.30); /* 抽屉/温和遮罩 */

  /* —— 沉浸天空渐变（名片演示 / 学习舞台背景；改天空皮就改这里）—— */
  --sky-1: #e2dff5;
  --sky-2: #e2f0f6;
  --grad-sky: linear-gradient(165deg, var(--sky-1) 0%, var(--sky-2) 46%, var(--bg) 100%);
}

page {
  background: var(--bg);
  color: var(--ink);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: 28rpx;
  line-height: 1.55;
  -webkit-font-smoothing: antialiased;
  text-rendering: optimizeLegibility;
}

view, text, button, input, textarea, image { box-sizing: border-box; }

button {
  background: transparent;
  padding: 0;
  line-height: normal;
}
button::after { border: none; }
button[disabled] { opacity: 0.42; }

/* —— 文字阶：编辑式大标题 + 清晰正文 —— */
.t-hero { font-size: 56rpx; font-weight: 800; color: var(--ink); line-height: 1.25; }
.t-display { font-size: 46rpx; font-weight: 800; color: var(--ink); line-height: 1.25; }
.t-section { font-size: 32rpx; font-weight: 800; color: var(--ink); }
.t-body { font-size: 28rpx; color: var(--ink); }
.t-sub { font-size: 26rpx; color: var(--ink-2); }
.t-caption { font-size: 24rpx; color: var(--sub); }
.t-micro { font-size: 22rpx; color: var(--faint); }

.title { font-size: 36rpx; font-weight: 800; color: var(--ink); }
.subtitle { font-size: 28rpx; color: var(--ink-2); }
.muted { color: var(--sub); }

/* 马克笔高亮：包住标题关键词 <text class="hl">什么？</text> */
.hl { background: var(--hl); padding: 0 8rpx; border-radius: 8rpx; color: var(--ink); }

/* 区段眉标 + 裁切线 */
.eyebrow { font-size: 24rpx; letter-spacing: 3rpx; color: var(--sub); font-weight: 700; }
.cutline { border-top: var(--bw-thin) dashed var(--border); }

/* —— 按钮：实底与细边，按压轻缩放 —— */
.btn-primary {
  background: var(--ink);
  color: #ffffff;
  border: none;
  border-radius: var(--r-md);
  padding: 24rpx 0;
  text-align: center;
  font-size: 30rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
  box-shadow: 0 10rpx 28rpx rgba(23, 24, 28, 0.14);
  transition: transform 0.1s var(--ease), box-shadow 0.1s var(--ease);
}
.btn-primary:active { transform: scale(0.985); background: #2d2f36; box-shadow: 0 5rpx 16rpx rgba(23, 24, 28, 0.10); }
.btn-primary[disabled] { opacity: 0.4; box-shadow: none; }

.btn-ghost {
  background: var(--surface);
  color: var(--ink);
  border: var(--bw-thin) solid var(--border);
  border-radius: var(--r-md);
  padding: 24rpx 0;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: var(--shadow-hair);
  transition: transform 0.1s var(--ease), box-shadow 0.1s var(--ease);
}
.btn-ghost:active { transform: scale(0.985); background: var(--fill-pressed); }

/* AI 主 CTA（保留旧类名兼容） */
.btn-accent {
  background: var(--accent);
  color: var(--on-accent);
  border: none;
  border-radius: var(--r-md);
  padding: 24rpx 0;
  text-align: center;
  font-size: 30rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
  box-shadow: var(--shadow-accent);
  transition: transform 0.1s var(--ease), box-shadow 0.1s var(--ease);
}
.btn-accent:active { transform: scale(0.985); background: var(--accent-strong); box-shadow: 0 5rpx 16rpx rgba(91, 86, 159, 0.14); }
.btn-accent[disabled] { opacity: 0.4; box-shadow: none; }

.accent-soft { background: var(--accent-soft); color: var(--accent-ink); }

/* —— 兼容旧类名的通用按压 —— */
.press-3d { transition: transform 0.1s var(--ease), box-shadow 0.1s var(--ease); }
.press-3d:active { transform: scale(0.985); opacity: 0.9; }

/* 金冠胶囊（已掌握态） */
.pill-gold {
  display: inline-block;
  padding: 6rpx 20rpx;
  background: var(--gold);
  color: #7a5c00;
  border-radius: var(--r-full);
  font-size: 22rpx;
  font-weight: 800;
  box-shadow: var(--shadow-hair);
}

/* —— 卡片 / 标签 / 贴纸 —— */
.card {
  background: var(--surface);
  border: var(--bw-thin) solid var(--border);
  border-radius: var(--r-xl);
  padding: 32rpx;
  box-shadow: var(--shadow-card);
}

/* 页面级共性：统一标题节奏与表单聚焦态，减少各页视觉漂移。 */
.page-title { font-size: 46rpx; line-height: 1.25; font-weight: 800; color: var(--ink); letter-spacing: -1rpx; }
.section-title { font-size: 30rpx; line-height: 1.35; font-weight: 800; color: var(--ink); }
input, textarea { caret-color: var(--accent); }
.input:focus, .textarea:focus { border-color: var(--accent); background: var(--surface); }

.tag {
  display: inline-block;
  padding: 6rpx 20rpx;
  margin: 0 12rpx 12rpx 0;
  background: var(--fill);
  border: var(--bw-thin) solid var(--border);
  border-radius: var(--r-full);
  font-size: 24rpx;
  color: var(--ink-2);
  font-weight: 600;
}

/* 贴纸徽章：低饱和状态标识，一屏不超过两张 */
.sticker {
  display: inline-block;
  padding: 4rpx 18rpx;
  background: var(--pop-butter);
  border: none;
  border-radius: var(--r-full);
  font-size: 22rpx;
  font-weight: 700;
  color: var(--pop-butter-ink);
  box-shadow: var(--shadow-hair);
}
.sticker-mint { background: var(--pop-mint); color: var(--pop-mint-ink); }
.sticker-coral { background: var(--pop-coral); color: #ffffff; }

/* —— 空态三层 —— */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 140rpx 48rpx 60rpx;
}
.empty-ic {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: var(--accent-soft);
  border: var(--bw-thin) solid var(--border);
  box-shadow: var(--shadow-card);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}
.empty-ic .ic { font-size: 56rpx; color: var(--accent-deep); }
.empty-title { font-size: 32rpx; font-weight: 800; color: var(--ink); }
.empty-sub { margin-top: 12rpx; font-size: 26rpx; color: var(--sub); line-height: 1.6; max-width: 480rpx; }
.empty-cta {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 36rpx;
  padding: 20rpx 48rpx;
  background: var(--accent);
  color: var(--on-accent);
  border: none;
  border-radius: var(--r-md);
  font-size: 28rpx;
  font-weight: 800;
  box-shadow: var(--shadow-accent);
  transition: transform 0.1s var(--ease), box-shadow 0.1s var(--ease);
}
.empty-cta:active { transform: scale(0.985); background: var(--accent-strong); }

/* —— 骨架屏 —— */
.skel {
  position: relative;
  overflow: hidden;
  background: var(--fill);
  border-radius: var(--r-md);
}
.skel::after {
  content: '';
  position: absolute;
  inset: 0;
  transform: translateX(-100%);
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.65), transparent);
  animation: skelShine 1.4s infinite;
}
@keyframes skelShine { 100% { transform: translateX(100%); } }

/* —— 通用按压 —— */
.tap { transition: transform 0.1s var(--ease), box-shadow 0.1s var(--ease); }
.tap:active { transform: scale(0.985); opacity: 0.9; }
.hairline { border-bottom: 1rpx solid var(--line); }
/* hover-class 用：卡片轻缩放，保留空间层级 */
.card-press { transform: scale(0.985); opacity: 0.94; }
