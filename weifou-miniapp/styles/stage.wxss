/* 共享：角色舞台 / 氛围词汇（对话页 + 主页 hero 等"参与类"界面复用）。
   只含可复用原子：氛围层 / 温度档 tint / 开幕 / 状态耦合 / 思考指示器 / 欣喜。
   各页自带容器尺寸（如 .stage / .hero 的高宽布局），不在此文件。
   纪律：氛围只做低 alpha tint，绝不实心填充；成交/支付/资质区不引入本词汇。 */

/* 氛围层：纯 CSS、低 alpha，仅 transform/opacity 动画；pointer-events:none 让点击落到容器 */
.amb-layer { position: absolute; inset: 0; pointer-events: none; z-index: 0; opacity: 0; overflow: hidden; }
.stage-in .amb-layer { animation: ambBloom 0.9s ease forwards; }
@keyframes ambBloom { to { opacity: 1; } }

.amb-wash { position: absolute; inset: 0; opacity: 0.55; }
/* 光晕：取头像同色系（容器 style 注入 --amb-a），整体低不透明度，氛围才"是 TA 的" */
.amb-glow {
  position: absolute; inset: 0;
  background: radial-gradient(130rpx 130rpx at 50% 40%, var(--amb-a, #18b690) 0%, transparent 72%);
  opacity: 0.16;
  filter: blur(2rpx);
}
.amb-blob { position: absolute; width: 240rpx; height: 240rpx; border-radius: 50%; filter: blur(40rpx); opacity: 0.14; }
.amb-blob-1 { left: -60rpx; top: -40rpx; background: var(--amb-a, #18b690); animation: ambDrift1 11s ease-in-out infinite; }
.amb-blob-2 { right: -70rpx; bottom: -50rpx; background: var(--amb-b, #14b8a6); animation: ambDrift2 13s ease-in-out infinite; }
@keyframes ambDrift1 { 0%, 100% { transform: translate(0, 0); } 50% { transform: translate(24rpx, 18rpx); } }
@keyframes ambDrift2 { 0%, 100% { transform: translate(0, 0); } 50% { transform: translate(-20rpx, -16rpx); } }

/* 温度档：糖果亮场 tint——白底上加浓一档才可见，仍不实心填充 */
.tier-cool .amb-wash { background: linear-gradient(180deg, rgba(28, 176, 246, 0.10), rgba(255, 255, 255, 0)); }
.tier-cool .amb-blob { opacity: 0.14; }
.tier-warm .amb-wash { background: linear-gradient(180deg, rgba(24, 182, 144, 0.12), rgba(255, 255, 255, 0)); }
.tier-warm .amb-blob { opacity: 0.18; }
.tier-lively .amb-wash { background: linear-gradient(180deg, rgba(206, 130, 255, 0.10), rgba(28, 176, 246, 0.06)); }
.tier-lively .amb-blob { opacity: 0.18; animation-duration: 9s; }

/* 名牌：开幕前隐藏，容器加 .stage-in 时升入 */
.stage-meta {
  position: relative; z-index: 1;
  display: flex; flex-direction: column; align-items: center;
  opacity: 0; transform: translateY(8rpx);
}
.stage-name { font-size: 32rpx; font-weight: 600; color: var(--ink); }
.stage-more { color: var(--faint); font-weight: 400; }
.stage-status {
  font-size: 24rpx; margin-top: 2rpx; max-width: 80vw; text-align: center;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.stage-in .stage-meta { animation: metaRise 0.5s ease 0.18s forwards; }
@keyframes metaRise { to { transform: translateY(0); opacity: 1; } }

/* 状态耦合：思考/说话时光晕脉冲升温（头像更快呼吸由组件 active 处理） */
.stage-active .amb-glow { animation: glowPulse 1.6s ease-in-out infinite; }
@keyframes glowPulse { 0%, 100% { opacity: 0.16; } 50% { opacity: 0.30; } }

/* 思考指示器（3 点） */
.stage-indicator { position: relative; z-index: 1; height: 0; opacity: 0; display: flex; gap: 8rpx; transition: opacity 0.25s ease; }
.stage-indicator.on { height: auto; opacity: 1; }
.stage-indicator .dot { width: 10rpx; height: 10rpx; border-radius: 50%; background: var(--sub); animation: dotBob 1s ease-in-out infinite; }
.stage-indicator .dot:nth-child(2) { animation-delay: 0.15s; }
.stage-indicator .dot:nth-child(3) { animation-delay: 0.30s; }
@keyframes dotBob { 0%, 100% { transform: translateY(0); opacity: 0.4; } 50% { transform: translateY(-6rpx); opacity: 1; } }

/* === 立绘卡原子（discover 推荐墙 / 聚光位、profile 等角色层复用）===
   art：角色立绘容器。无真图时用温度档糖果亮渐变兜底；有真图则在其上叠 <image class="art-img"> 铺满。
   纪律：仅角色层用；底盘卡片保持中性 surface，不引入本族渐变与光晕。 */
.art { position: relative; overflow: hidden; background: linear-gradient(150deg, #e8f7f1, #d3f0e4); }
.art-warm   { background: linear-gradient(150deg, #3ecfa4, #18b690); }
.art-cool   { background: linear-gradient(150deg, #54c3f9, #1cb0f6); }
.art-lively { background: linear-gradient(150deg, #d9a5ff, #ce82ff); }
.art-img { position: absolute; inset: 0; width: 100%; height: 100%; z-index: 0; }
/* 温度光晕：低 alpha 径向、明灭呼吸 */
.art-glow { position: absolute; inset: 0; opacity: 0.5; animation: artGlow 3.6s ease-in-out infinite; }
.art-warm   .art-glow { background: radial-gradient(120rpx 150rpx at 50% 24%, rgba(120, 235, 200, 0.5), transparent 62%); }
.art-cool   .art-glow { background: radial-gradient(120rpx 150rpx at 50% 24%, rgba(120, 175, 240, 0.5), transparent 62%); }
.art-lively .art-glow { background: radial-gradient(120rpx 150rpx at 50% 24%, rgba(190, 150, 255, 0.5), transparent 62%); }
@keyframes artGlow { 0%, 100% { opacity: 0.45; } 50% { opacity: 0.9; } }
/* 立绘微动呼吸（聚光位用） */
.art-breath { animation: artBreath 7s ease-in-out infinite; }
@keyframes artBreath { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.04); } }
/* 名牌浮层：底部 scrim + 名字 */
.art-scrim { position: absolute; left: 0; right: 0; bottom: 0; height: 120rpx; background: linear-gradient(transparent, rgba(20, 60, 48, 0.45)); z-index: 1; }
.art-name { position: absolute; left: 22rpx; bottom: 18rpx; z-index: 2; }
.art-name .n { display: block; font-size: 32rpx; font-weight: 700; color: #fff; text-shadow: 0 2rpx 14rpx rgba(0, 0, 0, 0.55); }
.art-name .r { font-size: 22rpx; color: rgba(255, 255, 255, 0.86); }
/* 角色层玻璃信息面板（聚光位浮底卡） */
.glass-panel { background: var(--glass-dark); -webkit-backdrop-filter: var(--blur-glass); backdrop-filter: var(--blur-glass); border: 1rpx solid var(--glass-hair); color: var(--ink); }
