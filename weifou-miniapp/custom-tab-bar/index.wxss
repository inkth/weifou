/* 组件默认 styleIsolation:isolated，app.wxss 的 .ic 不会下传，需自行 import 图标真源。
   色值与 app.wxss 新粗野令牌对齐（组件隔离故落成字面量）。 */
@import "../styles/icons.wxss";

/* 新粗野悬浮 dock：白底胶囊 + 墨青粗描边 + 硬投影，悬浮于纸底之上。
   活跃态 = 薄荷实底胶囊（描边 + 墨字）。仅 tabBar 页渲染，沉浸页不出现。 */
.tabbar {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  bottom: calc(env(safe-area-inset-bottom) + 20rpx);
  z-index: 1000;
  display: flex;
  align-items: center;
  padding: 10rpx 12rpx;
  background: #ffffff;
  border: 3rpx solid #16241e;
  border-radius: 999rpx;
  box-shadow: 6rpx 6rpx 0 #16241e;
}
.tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
  padding: 6rpx 0;
  color: #8a9a93; /* = currentColor → 驱动图标颜色 */
  border-radius: 999rpx;
  transition: background 0.18s cubic-bezier(0.16, 1, 0.3, 1);
}
.tab-pill {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 52rpx;
  border-radius: 999rpx;
  border: 2rpx solid transparent;
  transition: background 0.18s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.18s cubic-bezier(0.16, 1, 0.3, 1), transform 0.18s cubic-bezier(0.16, 1, 0.3, 1);
}
.tab-ic {
  font-size: 40rpx;
  transition: transform 0.18s cubic-bezier(0.16, 1, 0.3, 1);
}
.tab-label {
  font-size: 22rpx;
  color: #8a9a93;
  letter-spacing: 0.5rpx;
  transition: color 0.15s ease;
}
.tab.active {
  color: #06251c;
}
.tab.active .tab-pill {
  background: #18b690;
  border-color: #16241e;
}
.tab.active .tab-ic {
  transform: scale(1.04);
}
.tab.active .tab-label {
  color: #16241e;
  font-weight: 700;
}
.tab:active .tab-pill {
  transform: scale(0.9);
}
