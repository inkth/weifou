/* 组件样式隔离，令牌均提供与 app.wxss 一致的雾蓝紫回退值。 */
@import "../styles/icons.wxss";

/* 平面底栏：不使用悬浮胶囊，视觉退到内容之后。 */
.tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx calc(env(safe-area-inset-bottom) + 10rpx);
  background: rgba(246, 247, 251, 0.96);
  border-top: 1rpx solid rgba(23, 24, 28, 0.04);
}
.tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0;
  padding: 8rpx 0 4rpx;
  color: var(--sub, #8d909b);
  transition: color 0.18s cubic-bezier(0.16, 1, 0.3, 1);
}
.tab-pill {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 50rpx;
  transition: transform 0.18s cubic-bezier(0.16, 1, 0.3, 1);
}
.tab-ic {
  font-size: 42rpx;
  transition: transform 0.18s cubic-bezier(0.16, 1, 0.3, 1);
}
.tab-label {
  font-size: 23rpx;
  color: var(--sub, #999999);
  letter-spacing: 0.5rpx;
  transition: color 0.15s ease;
}
.tab.active {
  color: var(--accent-deep, #4f4a8b);
}
.tab.active .tab-pill {
  background: transparent;
}
.tab.active .tab-ic {
  transform: scale(1.06);
}
.tab.active .tab-label {
  color: var(--accent-deep, #4f4a8b);
  font-weight: 800;
}
.tab:active .tab-pill {
  transform: scale(0.94);
}
