/* 毛玻璃悬浮底栏：半透明 + 背景模糊，页面内容从栏下透出 = Apple 式「悬浮毛玻璃」。
   仅在 tabBar 页面渲染，沉浸页不出现。 */
.tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(40rpx) saturate(180%);
  -webkit-backdrop-filter: blur(40rpx) saturate(180%);
  border-top: 1rpx solid rgba(31, 35, 48, 0.06);
  box-shadow: 0 -2rpx 24rpx rgba(31, 35, 48, 0.05);
  padding-bottom: env(safe-area-inset-bottom);
}
.tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 12rpx 0;
}
.tab-ic {
  font-size: 40rpx;
  line-height: 1.1;
  opacity: 0.42;
  transition: opacity 0.18s ease, transform 0.18s ease;
}
.tab-label {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #8a90a0;
  transition: color 0.18s ease;
}
.tab.active .tab-ic {
  opacity: 1;
  transform: scale(1.06);
}
.tab.active .tab-label {
  color: #fb923c;
  font-weight: 600;
}
.tab:active {
  opacity: 0.7;
}
