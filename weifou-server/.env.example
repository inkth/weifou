# ---------- App ----------
ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000

# ---------- 微信小程序 ----------
WX_APPID=
WX_APPSECRET=

# ---------- 微信订阅消息（异步问答通知 / 主人召回） ----------
# 模板需在公众平台「功能→订阅消息」申请；留空则全链路静默降级（不推送、不报错）。
# 申请后填模板 ID，并与小程序 utils/subscribe.js 的同名常量对齐。
WX_SUBSCRIBE_NEW_QUESTION_TMPL_ID=
WX_SUBSCRIBE_ANSWERED_TMPL_ID=
WX_SUBSCRIBE_LEAD_TMPL_ID=
WX_SUBSCRIBE_STATE=formal

# ---------- 服务号（公众号）：承接 iOS 会员开通 + 召回 ----------
# 留空则服务号承接全链路 no-op。需在公众平台「设置→服务器配置」开启消息回调（明文/兼容模式），
# 回调 URL 填 https://你的域名/api/wx/mp/callback，Token 与 WX_MP_TOKEN 一致；
# 并把服务号绑定到微信开放平台（与小程序同主体）以便按 unionid 匹配账号。
WX_MP_APPID=
WX_MP_SECRET=
WX_MP_TOKEN=
# 服务端构造 H5 链接（会员收银页 / 服务号推送）用的公网基址，如 https://api.weifou.com
H5_BASE_URL=

# ---------- JWT ----------
JWT_SECRET=please-change-me
JWT_EXPIRES_HOURS=720

# ---------- 数据库 ----------
DATABASE_URL=postgresql://weifou:weifou@localhost:5432/weifou?sslmode=disable

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379

# ---------- DeepSeek ----------
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ---------- 第三方头像 API（占位） ----------
AVATAR_API_BASE_URL=
AVATAR_API_KEY=

# ---------- 腾讯云 COS ----------
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=ap-guangzhou
COS_BUCKET=
COS_PUBLIC_HOST=

# ---------- 限流 ----------
CHAT_FREE_QUOTA_PER_DAY=10

# ---------- 微信支付 V3 ----------
WXPAY_MCHID=
WXPAY_API_V3_KEY=
WXPAY_CERT_SERIAL=
WXPAY_PRIVATE_KEY_PATH=./certs/apiclient_key.pem
WXPAY_PLATFORM_CERT_PATH=./certs/wxp_platform_cert.pem
WXPAY_NOTIFY_URL=https://your-domain.com/api/payment/notify
ORDER_TIMEOUT_MIN=15

# ---------- 微信小程序虚拟支付（虚拟商品=会员；iOS 自动走苹果 IAP，2026-04 起强制接入） ----------
# appID 复用上面的 WX_APPID（同一小程序）。offerId/appKey 来自开通虚拟支付后的米大师控制台。
# 两者都留空则 vpay 未就绪：小程序会员页隐藏套餐入口、显示「敬请期待」（clientcfg 降级，不报错）。
# 现网 AppKey 与沙箱 AppKey 不同；用现网 key 时 WXV_SANDBOX=false。
# 各会员套餐的米大师商品 ID 存 DB（membership_plans.product_id），空则回退按 goodsPrice 现价直购。
WXV_OFFER_ID=
WXV_APP_KEY=
WXV_SANDBOX=false

# ---------- 音乐生成（做音乐 Agent；默认 fal，复用 fal key） ----------
# 未配 MUSIC_API_KEY / FALAI_API_KEY 时，做音乐返回「暂未开通」。
MUSIC_PROVIDER=fal
MUSIC_API_KEY=
FALAI_API_KEY=
MUSIC_BASE_URL=https://fal.run
MUSIC_MODEL=fal-ai/ace-step
