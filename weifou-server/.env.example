# ---------- App ----------
ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000

# ---------- 微信小程序 ----------
WX_APPID=
WX_APPSECRET=

# ---------- JWT ----------
JWT_SECRET=please-change-me
JWT_EXPIRES_HOURS=720

# ---------- 数据库 ----------
DATABASE_URL=postgresql://weifou:weifou@localhost:5432/weifou?sslmode=disable

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379

# ---------- DeepSeek ----------
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ---------- 第三方头像 API（占位） ----------
AVATAR_API_BASE_URL=
AVATAR_API_KEY=

# ---------- 腾讯云 COS ----------
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=ap-guangzhou
COS_BUCKET=
COS_PUBLIC_HOST=

# ---------- 限流 ----------
CHAT_FREE_QUOTA_PER_DAY=10

# ---------- 微信支付 V3 ----------
WXPAY_MCHID=
WXPAY_API_V3_KEY=
WXPAY_CERT_SERIAL=
WXPAY_PRIVATE_KEY_PATH=./certs/apiclient_key.pem
WXPAY_PLATFORM_CERT_PATH=./certs/wxp_platform_cert.pem
WXPAY_NOTIFY_URL=https://your-domain.com/api/payment/notify
TIP_MAX_AMOUNT=50000
PLATFORM_FEE_RATE=0.1
PROFIT_SHARING_ENABLED=false
ORDER_TIMEOUT_MIN=15
CALL_EARLY_JOIN_MIN=5
CALL_GRACE_MIN=15

# ---------- 腾讯云 TRTC ----------
TRTC_SDK_APPID=
TRTC_SECRET_KEY=
TRTC_SIG_EXPIRE=86400
