# 生产 .env 模板(放服务器 /opt/weifou-server/.env,勿提交真值)。
# docker-compose.prod.yml 从这里读 DB_* / JWT_SECRET,并据此拼 DATABASE_URL/REDIS_URL。
ENV=production
PORT=8080
APP_BASE_URL=https://api.weifou.com

# 数据库(compose 用 DB_* 拼 DATABASE_URL,也建 postgres 库)
DB_NAME=weifou
DB_USER=weifou
DB_PASSWORD=__CHANGE_ME__

# JWT
JWT_SECRET=__CHANGE_ME__
JWT_EXPIRES_HOURS=720

# 微信小程序(上线前填)
WX_APPID=
WX_APPSECRET=
# 微信开放平台移动应用(App 端,上线前填)
WX_MOBILE_APPID=
WX_MOBILE_APPSECRET=

# DeepSeek(AI 问答,上线前填)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 腾讯云 COS(占位)
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=ap-guangzhou
COS_BUCKET=
COS_PUBLIC_HOST=

CHAT_FREE_QUOTA_PER_DAY=10

# 微信支付 V3(证书放 ./certs/,挂载进容器后填)
WXPAY_MCHID=
WXPAY_API_V3_KEY=
WXPAY_CERT_SERIAL=
WXPAY_PRIVATE_KEY_PATH=./certs/apiclient_key.pem
WXPAY_PLATFORM_CERT_PATH=./certs/wxp_platform_cert.pem
WXPAY_NOTIFY_URL=https://api.weifou.com/api/payment/notify
ORDER_TIMEOUT_MIN=15

# 微信小程序虚拟支付（会员）
WXV_OFFER_ID=
WXV_APP_KEY=
WXV_SANDBOX=false
